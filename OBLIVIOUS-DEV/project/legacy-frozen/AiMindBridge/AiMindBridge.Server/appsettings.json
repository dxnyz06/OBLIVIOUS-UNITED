      "MaxTokens": 512,
      "Temperature": 0.1
    },
    "Perplexity": {
      "Enabled": false,
      "ApiKeyEnv": "PERPLEXITY_API_KEY",
      "Model": "llama-3.1-sonar-small-128k-online",
      "MaxTokens": 512,
      "Temperature": 0.1
    }
  }
}
