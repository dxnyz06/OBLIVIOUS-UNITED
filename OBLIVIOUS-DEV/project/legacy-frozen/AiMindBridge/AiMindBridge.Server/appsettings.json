{
  "Bridge": {
    "PipeName": "\\\\.\\pipe\\OBLIVIOUS_AIPC",
    "PipeTimeout": 3000,
    "MaxConcurrentPipes": 4,
    "ProviderTimeoutMs": 8000,
    "ProviderRetryLimit": 2,
    "LogLevel": "Information",
    "LogFile": "AiMindBridge.log",
    "ProviderPriority": [ "openai", "anthropic", "google", "xai", "deepseek", "qwen", "perplexity" ],
    "EnableBookmap": false,
    "BookmapWsUrl": "ws://localhost:9090",
    "CacheMode": "moderate",
    "OpenAI": {
      "Enabled": true,
      "ApiKeyEnv": "OPENAI_API_KEY",
      "Model": "gpt-4o-mini",
      "MaxTokens": 512,
      "Temperature": 0.1
    },
    "Anthropic": {
      "Enabled": true,
      "ApiKeyEnv": "ANTHROPIC_API_KEY",
      "Model": "claude-3-5-haiku-20241022",
      "MaxTokens": 512,
      "Temperature": 0.1
    },
    "Google": {
      "Enabled": true,
      "ApiKeyEnv": "GOOGLE_API_KEY",
      "Model": "gemini-1.5-flash",
      "MaxTokens": 512,
      "Temperature": 0.1
    },
    "XAI": {
      "Enabled": false,
      "ApiKeyEnv": "XAI_API_KEY",
      "Model": "grok-beta",
      "MaxTokens": 512,
      "Temperature": 0.1
    },
    "DeepSeek": {
      "Enabled": false,
      "ApiKeyEnv": "DEEPSEEK_API_KEY",
      "Model": "deepseek-chat",
      "MaxTokens": 512,
      "Temperature": 0.1
    },
    "Qwen": {
      "Enabled": false,
      "ApiKeyEnv": "QWEN_API_KEY",
