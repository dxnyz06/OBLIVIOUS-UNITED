// ============================================================
// OBLIVIOUS AI EA - Expert Advisor for MetaTrader 4
// Version: 3.00  |  Refactored: 2026-03-30
// Architecture: 3-Level (Owner Strategies / Indicator Modules / Pattern Support)
//
// LEVEL 1 - OWNER STRATEGIES (6 canonical, own all trades):
//   Predicted, Grid, Breakout, FVG, SMC, ICT, Reverse (7 strategies)
//
// LEVEL 2 - INDICATOR MODULES (context only, no trade execution):
//   RSI, MACD, ADX, Bollinger, Stochastic, EMA, SMA, ATR, and 60+ more
//   All contribute to g_ind_consensus via DispatchIndicatorStrategies()
//
// LEVEL 3 - PATTERN ENGINE (always active, non-owner, context only):
//   Alpha, Crown, Engulfing, Hammer, Doji, PinBar, MorningStar, TurtleSoup,
//   Fakey, Quasimodo, 2B Reversal, Spring/Upthrust, and more
//   All contribute to g_pat_consensus / g_pat_direction_support via DispatchPatternStrategies()
//
// DISPATCH CHAIN:
//   OnTick -> Orchestrator_OnTick -> {
//     DispatchIndicatorStrategies  (Level 2: Indicator Engine context)
//     UpdateFilterEngine           (Level 2: Filter Engine context)
//     DispatchPatternStrategies    (Level 3: Pattern Engine context — non-owner)
//     DispatchAIStrategy           (Level 2: AI context support)
//     DispatchPredictedStrategy    (Level 1: Predicted strategy owner)
//     FVG_Logic                    (Level 1: FVG strategy owner)
//     Strategy_SMC_Logic (Level 1: SMC strategy owner)
//     Strategy_ICT_Logic (Level 1: ICT strategy owner)
//     ExecuteStrategies            (Level 1: Grid + Breakout + Reverse strategy owners)
//   }
//
// SECTIONS:
//   01: Header / #property / #import / kernel32
//   02: #define / constants / macros / config
//   03: Input / user parameters
//   04: Enum / struct / types
//   05: Globals / state / ownership / bridge buffers
//   06: Forward declarations
//   07: Utility / logging / math / time / string / price
//   08: Bridge kernel32 / news / AI pipe / parsing / polling
//   09: State / persistence / KPI / performance / adaptive logic
//   10: Dashboard / UI / drawing / toggles
//   11: Indicators raw / Is* / Get* / candle helpers
//   12: Indicator signal + confidence
//   13: Filters raw / helpers / filter score
//   14: Filter confidence / combined filter
//   15: Patterns raw / FVG / SMC / ICT / liquidity / structure
//   16: Pattern signal + confidence / combined pattern
//   17: Risk / exposure / lot sizing / challenge / drawdown
//   18: Execution / order / position management
//   19: TP-SL / trailing / breakeven / profit guards / overlays
//   20: Strategy helpers / orchestrator / dispatchers
//   21: Strategy_<Indicator>_Logic (indicator context producers)
//   25: Indicator enabled flags
//   26: Late global declarations
//   27: Recovered helpers (utility, session, pattern)
//   28: Indicator strategy minimal implementations
//   29: Global helpers and pattern utilities
//   30: Globals, indicator flags, candlestick helpers
// ============================================================

// SECTION 01: HEADER / #PROPERTY / #IMPORT / KERNEL32

#property copyright "OBLIVIOUS AI EA"
#property version "3.0"
#property strict

// Unified kernel32.dll Import — must be defined BEFORE all modules
#import "kernel32.dll"

//| 7. utility / logging / math / time / string / price

int CreateFileA(string, uint, uint, int, uint, uint, int);

int CreateNamedPipeA(string, uint, uint, uint, uint, uint, uint, int);

int ConnectNamedPipe(int, int);

int WriteFile(int, uchar &buffer[], int, int &bytesWritten, int);

int GetFileAttributesA(string);

int DeleteFileA(string);

int FlushFileBuffers(int);

int GetFileSize(int, int);
int ReadFile(int, uchar &buffer[], int, int &bytesRead, int);
int CloseHandle(int);
int PeekNamedPipe(int, string &buf, int, int &bytesRead, int &bytesAvail, int &bytesLeft);
int CreateFileW(string, uint, uint, int, uint, uint, int);
#import

