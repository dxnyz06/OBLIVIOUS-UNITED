                      string GetSmartLogJSON() {
                        // Questa versione genera log JSON
                        // sintetici che riflettono
                        // l'attivitÃƒÃ†ÃƒÃ‚Â  dell'EA
                        string log_entries = "";
                        // Add current EA status to log -
                        // MQL4 doesn't allow function calls
                        // in array initialization
                        string entries[4];
                        entries[0] = StringFormat(
                            "[%s] EA initialized "
                            "successfully",
                            TimeToString(TimeCurrent(), TIME_MINUTES));
                        entries[1] = StringFormat(
                            "[%s] EA active - personal use",
                            TimeToString(TimeCurrent(), TIME_MINUTES));
                        entries[2] = StringFormat(
                            "[%s] AI Bridge mode: %s",
                            TimeToString(TimeCurrent(), TIME_MINUTES),
                            (IsTPSL_AI() && g_BridgeConnected) ? "ACTIVE" : "OFFLINE");
                        entries[3] = StringFormat(
                            "[%s] Active strategies: %d",
                            TimeToString(TimeCurrent(), TIME_MINUTES),
                            CountActiveStrategies());
                        for (int i = 0; i < 4; i++) {
                          if (i > 0)
                            log_entries += ",";
                          log_entries += """ + entries[i] + """;
                        }
                        return log_entries;
                      }

                                          bool GetConfirmationFromIndicators(
                                              bool isBuy) {
                                            if (!true)
                                              return true;
                                            // All indicators must confirm
                                            // (AND logic) - MQL4 doesn't
                                            // allow function calls in array
                                            // initialization
                                            bool confirmations[9];
                                            confirmations[0] =
                                                ConfirmRSI(isBuy);
                                            confirmations[1] =
                                                ConfirmMACD(isBuy);
                                            confirmations[2] =
                                                ConfirmStochastic(isBuy);
                                            confirmations[3] =
                                                ConfirmBollinger(isBuy);
                                            confirmations[4] =
                                                ConfirmCCI(isBuy);
                                            confirmations[5] = ConfirmEMA(
                                                isBuy); // This handles MA
                                            // as well
                                            confirmations[6] =
                                                ConfirmSuperTrend(isBuy);
                                            confirmations[7] =
                                                ConfirmADX(isBuy);
                                            confirmations[8] =
                                                ConfirmMomentum(isBuy);
                                            int confirmed = 0;
                                            int total_active = 9;
                                            for (int i = 0; i < 9; i++) {
                                              if (confirmations[i])
                                                  confirmed++;
                                            }
                                            // Require at least 70% of
                                            // active indicators to confirm
                                            double confirmation_rate =
                                                (total_active > 0)
                                                    ? (confirmed * 100.0 /
                                                       total_active)
                                                    : 100.0;
                                            return (confirmation_rate >= 70.0);
                                          }

