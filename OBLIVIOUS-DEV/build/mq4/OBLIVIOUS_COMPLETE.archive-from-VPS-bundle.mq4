//| 17. risk / exposure / lot sizing / protections / challenge

double RiskEngine_ComputeLotsAdvanced(string sym, int lotMode, double riskPct, double slPips, double baseLot, int level) {
    return Lot_Compute(sym, lotMode, riskPct, slPips, baseLot, level); }

bool PersistRiskDD(double dailyDD, double totalDD, double peakEquity, string key) {
    GlobalVariableSet(key + "_DD",  dailyDD);
    GlobalVariableSet(key + "_TDD", totalDD);
    GlobalVariableSet(key + "_PEQ", peakEquity);
    return true; }

bool RestoreRiskDD(double &dailyDD, double &totalDD, double &peakEquity, string key) {
    if (GlobalVariableCheck(key + "_DD"))  dailyDD    = GlobalVariableGet(key + "_DD");
    if (GlobalVariableCheck(key + "_TDD")) totalDD    = GlobalVariableGet(key + "_TDD");
    if (GlobalVariableCheck(key + "_PEQ")) peakEquity = GlobalVariableGet(key + "_PEQ");
    return true; }


double ClampLots(double lots) {
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double lotStep = MarketInfo(Symbol(), MODE_LOTSTEP);
      lots = MathMax(minLot, MathMin(maxLot, lots));
      return NormalizeDouble(lots / lotStep, 0) * lotStep;
}

// DrawToggleSwitch_AIPilot: REMOVED â€” AiPilot removed, bridge routing via TPSLMode

double Auto_GridLotMult(){
      VolRegime r = (VolRegime)g_adapt.regime;
      if (r == VOL_LOW)
        return 1.15;
      if (r == VOL_NORMAL)
        return 1.00;
      if (r == VOL_HIGH)
        return 0.90;
      return 0.85; }

double LotsForRiskPercent(double riskPercent, double stopPoints){
      if (riskPercent <= 0 || stopPoints <= 0)
        return 0.0;
      double equity = AccountEquity();
      double riskMoney = equity * (riskPercent / 100.0);
      double vpp = ValuePerPointPerLot();
      double lots = riskMoney / (stopPoints * vpp);
      // Clamp to broker limits
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double step = MarketInfo(Symbol(), MODE_LOTSTEP);
      if (step <= 0)
        step = 0.01;
      // round down to step
      lots = MathFloor(lots / step) * step;
      if (lots < minLot)
        lots = minLot;
      if (lots > maxLot)
        lots = maxLot;
      return lots;
}

double ScaleRiskMultiplier(int levelIndex)
{
      if (levelIndex < 1)
        levelIndex = 1;
      return (double)levelIndex;
}

double LotsGrid_ByLevel(double baseLots, int level)
{
      // Grid: constant lot size per level
      return NormalizeLotToMarket(baseLots);
}

// Grid lot progression: level 0 = ManualLot, level n = ManualLot * GridLotMultiplier^n
// Example: ManualLot=0.10, GridLotMultiplier=2.0 => L0=0.10, L1=0.20, L2=0.40, L3=0.80
double LotsGrid_ByLevelScaled(double baseLots, int level)
{
      if (level <= 0) return NormalizeLotToMarket(baseLots);
      double mult = (GridLotMultiplier > 1.0 ? GridLotMultiplier : 2.0);
      return NormalizeLotToMarket(baseLots * MathPow(mult, (double)level));
}

double Active_ManualLot()  {
      return ManualLot; }

double LotsByRisk(double sl_points){
      if (sl_points <= 0)
        return 0.0;
      double riskPct = Active_RiskForTradePercent() / 100.0;
      if (riskPct <= 0)
        return 0.0;
      double equity = AccountEquity();
      double risk_money = equity * riskPct;
      double pipval = __PipValuePerLot();
      double pip_points = (Digits == 3 || Digits == 5) ? 10.0 : 1.0;
      double sl_pips = sl_points / pip_points;
      double denom = sl_pips * pipval;
      if (denom <= 0)
        return 0.0;
      return risk_money / denom;
}

// All non-Grid strategies use ManualLot — no dynamic auto-sizing
double LotsHybrid(double sl_points){
      double lots = NormalizeLotToMarket(Active_ManualLot());
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      if (lots < minLot) lots = minLot;
      return lots;
}

void RiskEngine_Init()
{
      g_risk.currentEquity = AccountEquity();
      g_risk.currentBalance = AccountBalance();
      g_risk.canTrade = true;
      g_risk.blockReason = "";
      g_risk.killSwitchActive = false;

      // Restore historic equity peak
      if (GlobalVariableCheck(GV_EQUITY_PEAK_HIST))
        g_risk.equityPeakHistoric = GlobalVariableGet(GV_EQUITY_PEAK_HIST);
      else
        g_risk.equityPeakHistoric = g_risk.currentEquity;

      // Ensure peak is at least current equity
      if (g_risk.equityPeakHistoric < g_risk.currentEquity)
        g_risk.equityPeakHistoric = g_risk.currentEquity;

      // Restore daily peak
      if (GlobalVariableCheck(GV_DAILY_PEAK_DAY)) {
        int savedDay = (int)GlobalVariableGet(GV_DAILY_PEAK_DAY);
        int today = TimeDay(TimeCurrent());
        if (savedDay == today && GlobalVariableCheck(GV_EQUITY_PEAK_DAILY))
          g_risk.equityPeakDaily = GlobalVariableGet(GV_EQUITY_PEAK_DAILY);
        else
          g_risk.equityPeakDaily = g_risk.currentEquity;
      } else
        g_risk.equityPeakDaily = g_risk.currentEquity;

      // Restore peak profit
      if (GlobalVariableCheck(GV_PEAK_PROFIT))
        g_risk.peakProfit = GlobalVariableGet(GV_PEAK_PROFIT);
      else
        g_risk.peakProfit = 0;

      // Restore kill switch
      if (GlobalVariableCheck(GV_KILL_SWITCH))
        g_risk.killSwitchActive = ((int)GlobalVariableGet(GV_KILL_SWITCH) != 0);

      // Restore trades today
      g_risk.lastResetDay = TimeDay(TimeCurrent());
      if (GlobalVariableCheck(GV_TRADES_TODAY_DAY)) {
        int savedDay = (int)GlobalVariableGet(GV_TRADES_TODAY_DAY);
        if (savedDay == g_risk.lastResetDay &&
            GlobalVariableCheck(GV_TRADES_TODAY))
          g_risk.tradesToday = (int)GlobalVariableGet(GV_TRADES_TODAY);
        else
          g_risk.tradesToday = 0;
      } else
        g_risk.tradesToday = 0;

      RiskEngine_Persist();
      PrintFormat(
          "[RiskEngine] Init | EqPeak: %.2f | DailyPeak: %.2f | Balance: %.2f",
          g_risk.equityPeakHistoric, g_risk.equityPeakDaily,
          g_risk.currentBalance);
}

void RiskEngine_Update()
{
      g_risk.currentEquity = AccountEquity();
      g_risk.currentBalance = AccountBalance();
      g_risk.canTrade = true;
      g_risk.blockReason = "";

      // Daily reset check
      int today = TimeDay(TimeCurrent());
      if (today != g_risk.lastResetDay) {
        g_risk.equityPeakDaily = g_risk.currentEquity;
        g_risk.peakProfit = 0;
        g_risk.tradesToday = 0;
        g_risk.lastResetDay = today;
        GlobalVariableSet(GV_DAILY_PEAK_DAY, (double)today);
        GlobalVariableSet(GV_TRADES_TODAY, 0);
        GlobalVariableSet(GV_TRADES_TODAY_DAY, (double)today);
      }

      // Update equity peaks
      if (g_risk.currentEquity > g_risk.equityPeakHistoric) {
        g_risk.equityPeakHistoric = g_risk.currentEquity;
        GlobalVariableSet(GV_EQUITY_PEAK_HIST, g_risk.equityPeakHistoric);
      }
      if (g_risk.currentEquity > g_risk.equityPeakDaily) {
        g_risk.equityPeakDaily = g_risk.currentEquity;
        GlobalVariableSet(GV_EQUITY_PEAK_DAILY, g_risk.equityPeakDaily);
      }

      // Calculate drawdowns
      if (g_risk.equityPeakDaily > 0)
        g_risk.dailyDDPercent =
            (g_risk.equityPeakDaily - g_risk.currentEquity) /
            g_risk.equityPeakDaily * 100.0;
      else
        g_risk.dailyDDPercent = 0;

      if (g_risk.equityPeakHistoric > 0)
        g_risk.totalDDPercent =
            (g_risk.equityPeakHistoric - g_risk.currentEquity) /
            g_risk.equityPeakHistoric * 100.0;
      else
        g_risk.totalDDPercent = 0;

      // Update peak profit tracking
      double unrealizedPnL = g_risk.currentEquity - g_risk.currentBalance;
      if (unrealizedPnL > g_risk.peakProfit) {
        g_risk.peakProfit = unrealizedPnL;
        GlobalVariableSet(GV_PEAK_PROFIT, g_risk.peakProfit);
      }

      // Update market data (only on new bar to save CPU)
      if (IsNewBar()) {
        g_risk.currentATR = iATR(Symbol(), 0, 14, 0);
        g_risk.medianATR = iATR(Symbol(), 0, 50, 0);
        g_risk.currentADX = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0);
      }

      // Spread (always current)
      double spreadPoints = MarketInfo(Symbol(), MODE_SPREAD);
      int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
      if (digits == 3 || digits == 5)
        g_risk.currentSpreadPips = spreadPoints / 10.0;
      else
        g_risk.currentSpreadPips = spreadPoints;

      // Margin level
      double marginUsed = AccountMargin();
      if (marginUsed > 0)
        g_risk.currentMarginLevel = AccountEquity() / marginUsed * 100.0;
      else
        g_risk.currentMarginLevel = 99999;

      // Run all risk checks
      RiskEngine_RunChecks();
}

void RiskEngine_RunChecks()
{
      // 1. Kill switch
      if (g_risk.killSwitchActive) {
        g_risk.canTrade = false;
        g_risk.blockReason = "KILL SWITCH ACTIVE";
        return;
      }

      // 2. Total DD check
      if (MaxTotalDDPercent > 0 && g_risk.totalDDPercent >= MaxTotalDDPercent) {
        g_risk.canTrade = false;
        g_risk.blockReason =
            StringFormat("Total DD %.2f%% >= %.2f%%", g_risk.totalDDPercent,
                         MaxTotalDDPercent);
        return;
      }

      // 3. Daily DD check
      if (MaxDailyDDPercent > 0 && g_risk.dailyDDPercent >= MaxDailyDDPercent) {
        g_risk.canTrade = false;
        g_risk.blockReason =
            StringFormat("Daily DD %.2f%% >= %.2f%%", g_risk.dailyDDPercent,
                         MaxDailyDDPercent);
        return;
      }

      // EquityLockPercent removed - PeakProfitRetracePercent handles retrace protection

      // 5. Profit retrace protection
      if (PeakProfitRetracePercent > 0 && g_risk.peakProfit > 0) {
        double unrealized = g_risk.currentEquity - g_risk.currentBalance;
        double retracePct =
            (g_risk.peakProfit - unrealized) / g_risk.peakProfit * 100.0;
        if (retracePct >= PeakProfitRetracePercent) {
          g_risk.canTrade = false;
          g_risk.blockReason =
              StringFormat("Profit retrace %.2f%% >= %.2f%%", retracePct,
                           PeakProfitRetracePercent);
          return;
        }
      }

      // 6. Spread filter
      if (MaxSpreadPoints > 0 && g_risk.currentSpreadPips > MaxSpreadPoints) {
        g_risk.canTrade = false;
        g_risk.blockReason =
            StringFormat("Spread %.1f > max %.1f pips",
                         g_risk.currentSpreadPips, MaxSpreadPoints);
        return;
      }

      // 7. ATR volatility filter (block when ATR > 3x median)
      if (g_risk.medianATR > 0 && g_risk.currentATR > g_risk.medianATR * 3.0) {
        g_risk.canTrade = false;
        g_risk.blockReason =
            StringFormat("ATR volatility spike: %.5f > 3x median %.5f",
                         g_risk.currentATR, g_risk.medianATR);
        return;
      }

      // 8. Market closed check
      if (!RiskEngine_IsMarketOpen(Symbol())) {
        g_risk.canTrade = false;
        g_risk.blockReason = "Market closed";
        return;
      }

      // 9. Margin level check (block below 200%)
      if (g_risk.currentMarginLevel < 200.0 && AccountMargin() > 0) {
        g_risk.canTrade = false;
        g_risk.blockReason = StringFormat("Margin level %.1f%% < 200%%",
                                          g_risk.currentMarginLevel);
        return;
      }

      // 10. Balance sanity
      if (g_risk.currentBalance <= 0) {
        g_risk.canTrade = false;
        g_risk.blockReason = "Balance is zero or negative";
        return;
      }
}

void RiskEngine_ActivateKillSwitch(string reason)
{
      g_risk.killSwitchActive = true;
      g_risk.canTrade = false;
      g_risk.blockReason = "KILL SWITCH: " + reason;
      GlobalVariableSet(GV_KILL_SWITCH, 1.0);
      PrintFormat("[RiskEngine] KILL SWITCH ACTIVATED: %s", reason);
      Alert("OBLIVIOUS EA KILL SWITCH: " + reason);
}

void RiskEngine_DeactivateKillSwitch()
{
      g_risk.killSwitchActive = false;
      GlobalVariableSet(GV_KILL_SWITCH, 0.0);
      Print("[RiskEngine] Kill switch deactivated");
}

void RiskEngine_RecordNewTrade()
{
      g_risk.tradesToday++;
      GlobalVariableSet(GV_TRADES_TODAY, (double)g_risk.tradesToday);
}

double RiskEngine_ComputeLots(string symbol, double riskPercent, double slPips)
{
      if (riskPercent <= 0 || slPips <= 0)
        return MarketInfo(symbol, MODE_MINLOT);

      double riskAmount = g_risk.currentBalance * riskPercent / 100.0;
      
      // Apply Gold-specific risk adjustment
      if (IsGoldSymbol()) {
         double goldAdjustment = GetGoldRiskAdjustment();
         riskAmount *= goldAdjustment;
         SmartLog("INFO", "GOLD", "Risk adjusted by " + DoubleToString(goldAdjustment, 2) + " for Gold");
      }
      
      double tickValue = MarketInfo(symbol, MODE_TICKVALUE);
      double tickSize = MarketInfo(symbol, MODE_TICKSIZE);
      double point = MarketInfo(symbol, MODE_POINT);

      if (tickValue <= 0 || tickSize <= 0 || point <= 0)
        return MarketInfo(symbol, MODE_MINLOT);

      double pipValue = PipValue(symbol);
      double slPrice = slPips * pipValue;
      double pipCost = tickValue * (pipValue / tickSize);

      if (pipCost <= 0)
        return MarketInfo(symbol, MODE_MINLOT);

      double lots = riskAmount / (slPips * pipCost);

      return NormalizeLots(symbol, lots);
}

