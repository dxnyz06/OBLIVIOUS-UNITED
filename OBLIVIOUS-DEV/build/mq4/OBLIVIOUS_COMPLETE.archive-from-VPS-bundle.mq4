// ParentSetup: tracks the parent context for burst + addon trades
struct ParentSetup {
   int    setup_id;            // unique setup identifier
   string owner_strategy;      // "FVG", "SMC", "ICT", etc.
   int    direction;           // 1=buy, -1=sell
   double htf_bias;            // HTF price bias level
   double invalidation_level;  // price that invalidates setup
   double total_risk_budget;   // risk % allocated to this setup
   int    setup_score;         // 0-100 ICT/SMC quality score
   double primary_poi;         // primary POI price level
   int    management_profile;  // 0=conservative, 1=standard, 2=aggressive
   int    burst_count;         // number of burst entries placed
   int    addon_count;         // number of adaptive add-ons placed
   bool   is_valid;            // setup still active/valid
};

// ChildTradeContext: identifies child trade within a parent setup
struct ChildTradeContext {
   int    parent_setup_id;     // links to ParentSetup.setup_id
   string child_type;          // "BURST_ENTRY" or "ADAPTIVE_ADDON"
   string entry_reason;        // e.g. "FVG_PROXIMAL", "OB_MITIGATION"
   string poi_tag;             // e.g. "FVG_H1_12345", "OB_M15_67890"
   double risk_slice;          // fraction of total_risk_budget
   int    ladder_index;        // 0=burst, 1..N=addon levels
   double entry_price;         // pending LIMIT price
};

