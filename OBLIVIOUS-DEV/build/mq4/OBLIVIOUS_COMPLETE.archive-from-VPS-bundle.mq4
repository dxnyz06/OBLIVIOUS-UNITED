bool IsCMF() {
      int period = 21;
      double sumMFV = 0, sumVol = 0;
      for (int i = 0; i < period; i++) {
        double h = iHigh(NULL, 0, i), l = iLow(NULL, 0, i),
               c = iClose(NULL, 0, i), v = (double)iVolume(NULL, 0, i);
        double range = h - l;
        if (range < Point)
          continue;
        double mfm = ((c - l) - (h - c)) / range;
        sumMFV += mfm * v;
        sumVol += v;
      }
      return (sumVol > 0 && sumMFV / sumVol > 0);
}

