void FVG_Registry_MarkFilled(){
      // optional pass: dim or remove objects once filled
      int total = ObjectsTotal();
      for (int k = 0; k < total; k++) {
        string id = ObjectName(0, k);
        if (StringFind(id, "Trig_fvg_", 0) == 0) {
          double p0 = ObjectGetDouble(0, id, OBJPROP_PRICE, 0);
          double p1 = ObjectGetDouble(0, id, OBJPROP_PRICE, 1);
          double top = MathMax(p0, p1), bot = MathMin(p0, p1);
          if (FVG_IsFilled(top, bot)) {
            // Dim by switching style to DOT and lowering width
            ObjectSetInteger(0, id, OBJPROP_STYLE, STYLE_DOT);
            SL("fvg", "fill", "gap filled");
            ObjectSetInteger(0, id, OBJPROP_WIDTH, 1);
          }
        }
      }
}

double DynamicFVGMinPoints() {
      double atr = iATR(Symbol(), 0, 14, 1);
      if (atr <= 0) atr = 10 * Point;
      int pip2pt = (Digits == 3 || Digits == 5) ? 10 : 1;
      return MathMax(atr * 0.3, 3.0 * Point * pip2pt);
}

bool FVG_FindRecent(int dir, double minPts, double &top, double &bot, int &idx){
      if (minPts <= 0)
        minPts = DynamicFVGMinPoints();
      // dir: +1 bullish, -1 bearish
      int N = (int)MathMin(200, Bars - 3);
      for (int i = 2; i <= N; i++) {
        if (dir > 0) {
          // bullish FVG
          if (Bridge_IsConnected()) {
            string aiPayload;
            if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
              if (StringFind(aiPayload, "fvg=0") >= 0) {
                Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
                return false;
              }
            }
          }
          if (Low[i] - High[i + 2] >= minPts) {
            top = Low[i];
            bot = High[i + 2];
            idx = i;
            if (!FVG_IsFilled(top, bot))
              return true;
          }
        } else if (dir < 0) {
          // bearish FVG
          if (Bridge_IsConnected()) {
            string aiPayload;
            if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
              if (StringFind(aiPayload, "fvg=0") >= 0) {
                Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
                return false;
              }
            }
          }
          if (Low[i + 2] - High[i] >= minPts) {
            top = Low[i + 2];
            bot = High[i];
            idx = i;
            if (!FVG_IsFilled(top, bot))
              return true;
          }
        }
      }
      return false;
}

bool FVG_InstitutionalImbalance()
  {
      // Controllo auto-adaptive dello squilibrio (VI/Imbalance) senza soglie
      // fisse: usiamo statistiche robuste (median + MAD) sui range recenti.
      int p = Auto_ATR_Period();
      int n = (int)MathMax(3, p);
      if (Bars < n + 5)
        return (false);

      double atr_now = iATR(Symbol(), PERIOD_CURRENT, p, 0);
      if (atr_now <= 0.0)
        atr_now = iATR(Symbol(), PERIOD_CURRENT, p, 1);

      double atrs[];
      ArrayResize(atrs, n);
      for (int i = 1; i <= n; i++)
        atrs[i - 1] = iATR(Symbol(), PERIOD_CURRENT, p, i);
      double atr_med = __Median(atrs, n);
      if (atr_med <= 0.0)
        atr_med = atr_now;
      if (atr_med <= 0.0)
        return (false);

      // Definizione gap per FVG a 3 candele (su barre chiuse): c2=3, c1=2, c0=1
      double atr = iATR(NULL, 0, 14, 0);
      double spread = (Ask - Bid) / _Point;
      double maxSpread = iStdDevOnArray(Close, 0, 20, 0, MODE_SMA, 0);
      if (spread > maxSpread * 2.0) {
        Bridge_SendLog(2, "FVG", "Spread too high, skipping");
        return false;
      }
      if (Bridge_IsConnected()) {
        string aiPayload;
        if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
          if (StringFind(aiPayload, "fvg=0") >= 0) {
            Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
            return false;
          }
        }
      }
      int c0 = 1, c2 = 3;
      double bull_gap = Low[c0] - High[c2];
      double bear_gap = Low[c2] - High[c0];
      double gap_size = MathMax(bull_gap, bear_gap);
      if (gap_size <= 0.0)
        return (false);

      // Serie storica di gap normalizzati (stessa definizione, finestre
      // precedenti)
      double ratios[];
      ArrayResize(ratios, n);
      for (int k = 1; k <= n; k++) {
        int s0 = c0 + k;
        int s2 = c2 + k;
        if (s2 >= Bars) {
          ratios[k - 1] = 0.0;
          continue;
        }
        double bg = Low[s0] - High[s2];
        double sg = Low[s2] - High[s0];
        double gs = MathMax(bg, sg);
        ratios[k - 1] = gs / atr_med;
      }

      double r_med = __Median(ratios, n);

      double devs[];
      ArrayResize(devs, n);
      for (int j = 0; j < n; j++)
        devs[j] = MathAbs(ratios[j] - r_med);
      double r_mad = __Median(devs, n);

      double ratio_now = gap_size / atr_med;
      double score = (r_mad > 0.0 ? (ratio_now - r_med) / r_mad : ratio_now);

      // Regime-aware (volatilitÃƒÃ†ÃƒÃ‚Â  + modalitÃƒÃ†ÃƒÃ‚Â ): richiede che il gap sia un
      // outlier positivo.
      double need = Auto_VolFactor() * ModeScale();
      return (score > need);
  }

bool Structure_FibonacciConfirmation(double entry_price, double high_price, double low_price) {
      // Controlla se entry ÃƒÃ†ÃƒÃ‚Â¨ vicino a livelli fibonacci chiave
      double range = high_price - low_price;
      double fib_618 = high_price - (range * 0.618);
      double fib_382 = high_price - (range * 0.382);
      double fib_786 = high_price - (range * 0.786);
      double tolerance = range * 0.02; // 2% tolerance
      return (MathAbs(entry_price - fib_618) < tolerance ||
              MathAbs(entry_price - fib_382) < tolerance ||
              MathAbs(entry_price - fib_786) < tolerance);
}

bool IsReversalEngulfing() {
      if (!GlobalStrategyGuards())
        return (false);
      // Candela 1 inghiotte completamente candela 2
return ((Open[1] < Close[1] && Open[2] > Close[2] && Open[1] < Close[2] && Close[1] > Open[2])
     || (Open[1] > Close[1] && Open[2] < Close[2] && Open[1] > Close[2] && Close[1] < Open[2]));
}

bool SMC_AA_OK(bool isBuy){
      bool bos = AA_BOS(isBuy);
      int n = AA_AutoN();
      double prevH = iHigh(
          Symbol(), Period(),
          iHighest(Symbol(), Period(), MODE_HIGH, MathMax(5, (int)(n / 3)), 2));
      double prevL = iLow(
          Symbol(), Period(),
          iLowest(Symbol(), Period(), MODE_LOW, MathMax(5, (int)(n / 3)), 2));
      double c1 = iClose(Symbol(), Period(), 1);
      bool sweep = isBuy ? (iHigh(Symbol(), Period(), 1) > prevH && c1 < prevH)
                         : (iLow(Symbol(), Period(), 1) < prevL && c1 > prevL);
      return bos && sweep && AA_SessionOK();
}

void FVG_AddGapICT(const ADV_FVG_ZONE &z, bool hasOB)
{
      FVG_AddGap(z.bot, z.top, z.dir, z.barNewer);
      // Tag the latest gap with ICT info
      if (g_fvgCount > 0) {
        g_fvgGaps[g_fvgCount - 1].hasOB = hasOB;
        g_fvgGaps[g_fvgCount - 1].ictScore = (hasOB ? 80.0 : 60.0);
      }
}

void FVG_ScanNewGaps(string symbol)
{
      double atr = iATR(symbol, 0, 14, 0);

      for (int shift = 1; shift < 5; shift++) {
        // Bullish FVG: bar[shift+1].high < bar[shift-1].low
        double highBefore = iHigh(symbol, 0, shift + 1);
        double lowAfter = iLow(symbol, 0, shift - 1);

        if (lowAfter > highBefore) {
          double gapSize = lowAfter - highBefore;
          double minGap = atr * 0.2;
          if (gapSize > minGap)
            FVG_AddGap(highBefore, lowAfter, 1, shift);
        }

        // Bearish FVG: bar[shift-1].high < bar[shift+1].low
        double lowBefore = iLow(symbol, 0, shift + 1);
        double highAfter = iHigh(symbol, 0, shift - 1);

        if (lowBefore > highAfter) {
          double gapSize = lowBefore - highAfter;
          double minGap = atr * 0.2;
          if (gapSize > minGap)
            FVG_AddGap(highAfter, lowBefore, -1, shift);
        }
      }
}

void FVG_AddGap(double lower, double upper, int dir, int barIdx)
{
      // Check if already tracked
      for (int i = 0; i < g_fvgCount; i++) {
        if (g_fvgGaps[i].active &&
            MathAbs(g_fvgGaps[i].upperLimit - upper) < Point &&
            MathAbs(g_fvgGaps[i].lowerLimit - lower) < Point)
          return;
      }

      if (g_fvgCount >= FVG_MAX_GAPS) {
        for (int i = 0; i < FVG_MAX_GAPS - 1; i++)
          g_fvgGaps[i] = g_fvgGaps[i + 1];
        g_fvgCount = FVG_MAX_GAPS - 1;
      }

      g_fvgGaps[g_fvgCount].upperLimit = upper;
      g_fvgGaps[g_fvgCount].lowerLimit = lower;
      g_fvgGaps[g_fvgCount].direction = dir;
      g_fvgGaps[g_fvgCount].barIndex = barIdx;
      g_fvgGaps[g_fvgCount].filled = false;
      g_fvgGaps[g_fvgCount].active = true;
      g_fvgGaps[g_fvgCount].ictScore = 0;
      g_fvgGaps[g_fvgCount].hasOB = false;
      g_fvgCount++;
}

bool IsMarginLevelSufficient(double minMarginLevel = 100.0) {
      if (minMarginLevel <= 0) return true;
      double ml = AccountInfoDouble(ACCOUNT_MARGIN_LEVEL);
      if (ml == 0) return true;
      return (ml >= minMarginLevel);
}

bool IsMarketDormant() {
      double atr = iATR(Symbol(), 0, 14, 1);
      double atrAvg = iATR(Symbol(), 0, 14, 10);
      return (atrAvg > 0 && atr < atrAvg * 0.3);
}

bool IsMaxTotalDDExceeded(double maxTotalDD = -1.0) {
      if (maxTotalDD < 0) maxTotalDD = MaxDailyDDPercent;
      if (maxTotalDD <= 0) return false;
      double eq = AccountEquity();
      if (g_startEquity <= 0) return false;
      double dd = (g_startEquity - eq) / g_startEquity * 100.0;
      return (dd >= maxTotalDD);
}
