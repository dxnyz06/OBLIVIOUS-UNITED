void AA_MeanStd(double &mean,double &stdv,bool useBody=true,int n=-1){
      if (n < 0)
        n = AA_AutoN();
      double s = 0, s2 = 0;
      int c = 0;
      for (int i = 1; i <= n; i++) {
        double v;
        if (useBody) {
          double o = iOpen(Symbol(), Period(), i),
                 c0 = iClose(Symbol(), Period(), i);
          v = MathAbs(c0 - o);
        } else {
          double h = iHigh(Symbol(), Period(), i),
                 l = iLow(Symbol(), Period(), i);
          v = h - l;
        }
        s += v;
        s2 += v * v;
        c++;
      }
      mean = (c > 0 ? s / c : 0);
      double var = (c > 1 ? s2 / c - mean * mean : 0);
      stdv = (var > 0 ? MathSqrt(var) : 0);
}

bool AA_ImpulseOK(int sh=1){
      int n = AA_AutoN();
      double mB, sB, mR, sR;
      AA_MeanStd(mB, sB, true, n);
      AA_MeanStd(mR, sR, false, n);
      double o = iOpen(Symbol(), Period(), sh),
             c = iClose(Symbol(), Period(), sh);
      double h = iHigh(Symbol(), Period(), sh),
             l = iLow(Symbol(), Period(), sh);
      double body = MathAbs(c - o), range = h - l;
      double atr0 = iATR(Symbol(), Period(), MathMax(5, (int)MathSqrt(n)), sh);
      double sum = 0, sum2 = 0;
      for (int i = 1; i <= n; i++) {
        double a = iATR(Symbol(), Period(), MathMax(5, (int)MathSqrt(n)), i);
        sum += a;
        sum2 += a * a;
      }
      double mA = sum / n, sA = MathSqrt(MathMax(0, sum2 / n - mA * mA));
      return (body >= mB + sB) || (range >= mR + sR) || (atr0 >= mA + sA);
}

int AA_MinTouches(int tf)
{
      double atr = AA_ATR(tf, 1);
      double hi = iHigh(Symbol(), tf, 1);
      double lo = iLow(Symbol(), tf, 1);
      // Use recent range vs ATR to infer regime (range-heavy => require more
      // touches)
      int bars = (int)MathMax(10, Auto_ATR_Period());
      double rH = hi, rL = lo;
      for (int i = 2; i < bars; i++) {
        double h = iHigh(Symbol(), tf, i), l = iLow(Symbol(), tf, i);
        if (h > rH)
          rH = h;
        if (l < rL)
          rL = l;
      }
      double range = rH - rL;
      if (atr <= 0.0)
        atr = 10 * ADV_Pip();
      double ratio = range / atr;
      if (ratio < 4.0)
        return 3; // tighter/rangier => stronger pool definition
      return 2;
}

double AA_ExtremeInLookback(int tf, int dir, int lookback)
{
      double x = (dir > 0 ? iHigh(Symbol(), tf, 1) : iLow(Symbol(), tf, 1));
      for (int s = 2; s <= lookback; s++) {
        double h = iHigh(Symbol(), tf, s), l = iLow(Symbol(), tf, s);
        if (dir > 0) {
          if (h > x)
            x = h;
        } else {
          if (l < x)
            x = l;
        }
      }
      return x;
}

bool AA_FindNextEQPool(int tf, int dir, int lookback, double minLevel, double &poolLevel, int &touches)
{
      poolLevel = 0.0;
      touches = 0;
      double tol = AA_Tol(tf);
      int minT = AA_MinTouches(tf);

      // collect candidates
      double cands[];
      ArrayResize(cands, 0);

      for (int s = 2; s <= lookback; s++) {
        double v = 0.0;
        if (dir > 0)
          v = iFractals(Symbol(), tf, MODE_UPPER, s);
        else
          v = iFractals(Symbol(), tf, MODE_LOWER, s);
        if (v <= 0.0)
          continue;

        if (dir > 0) {
          if (v <= minLevel + tol)
            continue;
        } else {
          if (v >= minLevel - tol)
            continue;
        }
        int n = ArraySize(cands);
        ArrayResize(cands, n + 1);
        cands[n] = v;
      }
      if (ArraySize(cands) == 0)
        return false;

      // build clusters
      AA_EQ_CLUSTER clusters[];
      ArrayResize(clusters, 0);

      for (int i = 0; i < ArraySize(cands); i++) {
        double v = cands[i];
        bool placed = false;
        for (int j = 0; j < ArraySize(clusters); j++) {
          if (MathAbs(v - clusters[j].lvl) <= tol) {
            // incremental mean
            clusters[j].lvl =
                (clusters[j].lvl * clusters[j].n + v) / (clusters[j].n + 1);
            clusters[j].n++; placed = true;
            break;
          }
        }
        if (!placed) {
          int k = ArraySize(clusters);
          ArrayResize(clusters, k + 1);
          clusters[k].lvl = v;
          clusters[k].n = 1;
        }
      }

      // pick nearest valid cluster in the direction with enough touches
      double best = 0.0;
      int bestN = 0;
      for (int j = 0; j < ArraySize(clusters); j++) {
        if (clusters[j].n < minT)
          continue;

        double lvl = clusters[j].lvl;
        if (dir > 0) {
          if (best == 0.0 || lvl < best) {
            best = lvl;
            bestN = clusters[j].n;
          }
        } else {
          if (best == 0.0 || lvl > best) {
            best = lvl;
            bestN = clusters[j].n;
          }
        }
      }
      if (best == 0.0)
        return false;

      poolLevel = best;
      touches = bestN;
      return true;
}

void AA_EnsureTicketTargets(string ns, int ticket, int tf, int dir, double entry, double sl)
{
      string k1 = AA_GVKey(ns, ticket, "T1");
      if (AA_GVHas(k1))
        return;

      double t1, t2, t3, tmax;
      AA_ComputeTargets(tf, dir, entry, sl, t1, t2, t3, tmax);

      AA_GVSet(k1, t1);
      AA_GVSet(AA_GVKey(ns, ticket, "T2"), t2);
      AA_GVSet(AA_GVKey(ns, ticket, "T3"), t3);
      AA_GVSet(AA_GVKey(ns, ticket, "TM"), tmax);
      AA_GVSet(AA_GVKey(ns, ticket, "BE"), 0.0);    // BE not moved
      AA_GVSet(AA_GVKey(ns, ticket, "STAGE"), 0.0); // 0..4
}

int AA_FVG_Signal()
{
      int tfPOI = (Period() <= PERIOD_M5 ? PERIOD_M15 : Period());
      int tfLTF = Period();

      // Spread filter
      double atr = iATR(Symbol(), 0, 14, 0);
      if (atr <= 0)
        return 0;
      double spreadPx = AA_SpreadPrice();
      if (spreadPx > atr * 0.5)
        return 0;

      // Directional bias from EMA20 slope
      double ema0 = iMA(Symbol(), tfLTF, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
      double ema1 = iMA(Symbol(), tfLTF, 20, 0, MODE_EMA, PRICE_CLOSE, 1);
      int emaSlope = (ema0 > ema1 ? +1 : (ema0 < ema1 ? -1 : 0));
      if (emaSlope == 0)
        return 0;

      // Find displacement-qualified FVG
      ADV_FVG_ZONE z;
      ADV_OB_ZONE ob;
      if (!ADV_FindFVG_Pro(tfPOI, emaSlope, ADV_FVG_LOOKBACK, false, z, ob))
        return 0;

      // Require price interaction with the zone
      if (!ADV_PriceInZone(tfLTF, z))
        return 0;

      // Identify most recent touch of the zone
      int touchLB = (int)MathMax(20, Auto_ATR_Period() * 6);
      int touchShift = ADV_FirstZoneTouchShift(tfLTF, z, touchLB);
      if (touchShift < 0)
        return 0;

      // Liquidity sweep filter: require EQ pool raid before zone touch
      double pool = 0.0;
      int touches = 0;
      int sweepShift = -1;
      int poolLB = (int)MathMax(30, Auto_ATR_Period() * 10);
      if (ADV_FindEQPool(tfLTF, z.dir, poolLB, pool, touches)) {
        if (!ADV_HasLiquiditySweep(tfLTF, z.dir, pool, poolLB, sweepShift))
          return 0;
        if (sweepShift <= touchShift)
          return 0; // sweep must precede touch
      }

      // Mitigation + rejection
      int rejShift = -1;
      if (!ADV_FVG_MitigatedAndRejected(z, tfLTF, ADV_FVG_TOUCH_BARS, rejShift))
        return 0;
      if (sweepShift > 0 && sweepShift <= rejShift)
        return 0;

      // Avoid late chase: reject extreme outlier candles
      double atrLTF = ADV_ATR(tfLTF, MathMax(10, Auto_ATR_Period()), 1);
      if (atrLTF <= 0.0)
        atrLTF = 10 * ADV_Pip();
      double range = iHigh(Symbol(), tfLTF, 1) - iLow(Symbol(), tfLTF, 1);
      if (range > 2.5 * atrLTF)
        return 0;

      return z.dir;
}

void AA_FVG_PlaceEB(int dir, ADV_FVG_ZONE &z, double sl, double lotsBase)
{
      int magic = AA_MagicFVG();
      if (AA_HasOpenOrPendingByMagic(magic))
        return;

      bool isLong = (dir > 0);
      double zHi = z.top;
      double zLo = z.bot;

      // Entry reference for targets
      double entryRef = z.mid;

      // Compute TMax (used as TP for all non-runner legs)
      double t1, t2, t3, tmax;
      AA_ComputeTargets(Period(), dir, entryRef, sl, t1, t2, t3, tmax);

      // Place LIMIT mini-grid inside the zone using EB engine (runner + others
      // to TMax)
      EB_PlaceEdgeBiasedLimits(Symbol(), magic, isLong, zHi, zLo,
                               AA_ClampPrice(sl), AA_ClampPrice(tmax),
                               lotsBase);
}

int AA_SMC_Signal()
{
      // Session filter: London + NY
      if (!SMC_TimeFilter(true, true, false))
        return 0;

      int tfBias = (Period() <= PERIOD_M15 ? PERIOD_H1 : PERIOD_H4);
      int bias = SMC_BiasHTF(tfBias);
      if (bias == 0)
        return 0;

      int tfPOI = PERIOD_M15;
      int tfLTF = (Period() <= PERIOD_M5 ? PERIOD_M1 : PERIOD_M5);

      // Spread check
      double spreadPx = AA_SpreadPrice();
      double atrCheck = iATR(Symbol(), 0, 14, 0);
      if (atrCheck > 0 && spreadPx > atrCheck * 0.5)
        return 0;

      // Find ICT-grade POI
      ADV_FVG_ZONE poi;
      ADV_OB_ZONE ob;
      if (!ADV_FindFVG_ICT(tfPOI, bias, ADV_FVG_LOOKBACK, poi, ob))
        return 0;

      // Premium/discount filter
      double hi, lo;
      ADV_DealingRange(tfPOI, 240, hi, lo);
      double mid = (hi + lo) * 0.5;
      if (bias > 0 && poi.mid > mid)
        return 0; // bullish POI must be in discount
      if (bias < 0 && poi.mid < mid)
        return 0; // bearish POI must be in premium

      // Liquidity sweep prerequisite
      int touchLB = (int)MathMax(30, Auto_ATR_Period() * 8);
      int touchShift = ADV_FirstZoneTouchShift(tfLTF, poi, touchLB);
      if (touchShift < 0)
        return 0;

      double pool = 0.0;
      int touches = 0;
      int poolLB = (int)MathMax(40, Auto_ATR_Period() * 12);
      int sweepShift = -1;
      if (!ADV_FindEQPool(tfLTF, bias, poolLB, pool, touches))
        return 0;
      if (!ADV_HasLiquiditySweep(tfLTF, bias, pool, poolLB, sweepShift))
        return 0;
      if (sweepShift <= touchShift)
        return 0;

      // Mitigation + rejection
      int rejShift = -1;
      if (!SMC_FVGRespected(poi, tfLTF, rejShift))
        return 0;
      if (sweepShift > 0 && sweepShift <= rejShift)
        return 0;

      // MSS confirmation
      if (!SMC_MSS(tfLTF, bias))
        return 0;

      return bias;
}

