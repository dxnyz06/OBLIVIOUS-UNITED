bool AA_BOS(bool up){
      int n = AA_AutoN();
      double recentMax = iHigh(Symbol(), Period(),
                               iHighest(Symbol(), Period(), MODE_HIGH, n, 2));
      double recentMin =
          iLow(Symbol(), Period(), iLowest(Symbol(), Period(), MODE_LOW, n, 2));
      double c2 = iClose(Symbol(), Period(), 2);
      return up ? (c2 > recentMax) : (c2 < recentMin);
}

void AA_ComputeTargets(int tf, int dir, double entry, double sl, double &t1, double &t2, double &t3, double &tmax)
{
      double atr = AA_ATR(tf, 1);
      if (atr <= 0.0)
        atr = 10 * ADV_Pip();

      int lookback = (int)MathMax(50, Auto_ATR_Period() * Auto_ADX_Period());
      lookback = MathMin(lookback, iBars(Symbol(), tf) - 10);
      if (lookback < 20)
        lookback = 20;

      double tol = AA_Tol(tf);
      double minLvl = entry;
      int touches = 0;

      t1 = 0;
      t2 = 0;
      t3 = 0;
      tmax = 0;

      if (AA_FindNextEQPool(tf, dir, lookback, minLvl, t1, touches))
        minLvl = t1 + (dir > 0 ? tol : -tol);
      if (AA_FindNextEQPool(tf, dir, lookback, minLvl, t2, touches))
        minLvl = t2 + (dir > 0 ? tol : -tol);
      if (AA_FindNextEQPool(tf, dir, lookback, minLvl, t3, touches))
        minLvl = t3 + (dir > 0 ? tol : -tol);

      tmax = AA_ExtremeInLookback(tf, dir, lookback);

      // If pools are missing, build adaptive targets from risk and volatility
      double risk = MathAbs(entry - sl);
      if (risk <= 0.0)
        risk = MathMax(tol, atr * 0.25);

      // rr1 in [1,2] adaptive
      double rr1 = 1.0 + MathMin(1.0, atr / (risk + atr));
      double rr2 = rr1 + MathMin(1.0, 0.5 * atr / (risk + atr));
      double rr3 = rr2 + MathMin(1.0, 0.5 * atr / (risk + atr));

      if (t1 == 0.0)
        t1 = entry + dir * (risk * rr1);
      if (t2 == 0.0)
        t2 = entry + dir * (risk * rr2);
      if (t3 == 0.0)
        t3 = entry + dir * (risk * rr3);

      if (tmax == 0.0)
        tmax = entry + dir * (risk * (rr3 + rr1));
}

