double Confirmations_Score(string sym = "", int dir = 0) { double score = 50.0; score += IndicatorAlignmentBonus(dir); if (dir != 0 && PatternSupportsTrade(dir, 20.0)) score += 10.0; if (IsSessionValid()) score += 5.0; if (!CheckHighImpactNews()) score += 5.0; double atrP = iATR(Symbol(), Period(), 14, 1) / iATR(Symbol(), Period(), 14, 5); if (atrP > 0.8 && atrP < 1.5) score += 5.0; return MathMin(95.0, score); }
int FindLastPivotHigh(int strength, int span, int maxlook) {
  for (int i = strength; i < maxlook; i++)
    if (PivotHigh(span, span, i)) return i;
  return -1;
}
int FindLastPivotLow(int strength, int span, int maxlook) {
  for (int i = strength; i < maxlook; i++)
    if (PivotLow(span, span, i)) return i;
  return -1;
}
