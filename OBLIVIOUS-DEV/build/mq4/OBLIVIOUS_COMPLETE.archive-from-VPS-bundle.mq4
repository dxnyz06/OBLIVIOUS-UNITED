                                          void Strategy_Grid_RestoreState(
                                              string symbol) {
                                            int idx = Grid_GetState(symbol);
                                            if (idx < 0)
                                              return;

                                            if (GlobalVariableCheck(
                                                    GV_GRID_ACTIVE + symbol)) {
                                              g_grid[idx].active =
                                                  ((int)GlobalVariableGet(
                                                       GV_GRID_ACTIVE +
                                                       symbol) != 0);
                                              g_grid[idx].gridCount =
                                                  (int)GlobalVariableGet(
                                                      GV_GRID_COUNT + symbol);
                                              g_grid[idx].direction =
                                                  (int)GlobalVariableGet(
                                                      GV_GRID_DIR + symbol);

                                              if (g_grid[idx].active)
                                                PrintFormat(
                                                    "[Grid] Restored state "
                                                    "for %s: %d levels",
                                                    symbol,
                                                    g_grid[idx].gridCount);
                                            }
                                          }

                                          void Mart_SaveState(int idx) {
                                            string sym = g_mart[idx].symbol;
                                            GlobalVariableSet(
                                                GV_MART_STEP + sym,
                                                (double)g_mart[idx]
                                                    .currentStep);
                                            GlobalVariableSet(
                                                GV_MART_DIR + sym,
                                                (double)g_mart[idx].direction);
                                            GlobalVariableSet(
                                                GV_MART_BASE_LOT + sym,
                                                g_mart[idx].baseLot);
                                            GlobalVariableSet(
                                                GV_MART_ACTIVE + sym,
                                                g_mart[idx].active ? 1.0 : 0.0);
                                          }

                                          void Strategy_Martingale_RestoreState(
                                              string symbol) {
                                            int idx = Mart_GetState(symbol);
                                            if (idx < 0)
                                              return;

                                            if (GlobalVariableCheck(
                                                    GV_MART_ACTIVE + symbol)) {
                                              g_mart[idx].active =
                                                  ((int)GlobalVariableGet(
                                                       GV_MART_ACTIVE +
                                                       symbol) != 0);
                                              g_mart[idx].currentStep =
                                                  (int)GlobalVariableGet(
                                                      GV_MART_STEP + symbol);
                                              g_mart[idx].direction =
                                                  (int)GlobalVariableGet(
                                                      GV_MART_DIR + symbol);
                                              g_mart[idx].baseLot =
                                                  GlobalVariableGet(
                                                      GV_MART_BASE_LOT +
                                                      symbol);

                                              if (g_mart[idx].active)
                                                PrintFormat(
                                                    "[Martingale] Restored "
                                                    "state for %s: Step %d "
                                                    "Dir %d",
                                                    symbol,
                                                    g_mart[idx].currentStep,
                                                    g_mart[idx].direction);
                                            }
                                          }

                                          void __AP_ClearPeakPips(int ticket) {
                                            string key = StringConcatenate(
                                                "PEAKPIPS_", ticket);
                                            if (GlobalVariableCheck(key))
                                              GlobalVariableDel(key);
                                          }

                                          bool __AP_UpdatePeakPips() {
                                            int tk = OrderTicket();
                                            string key = StringConcatenate(
                                                "PEAKPIPS_", tk);
                                            double cur =
                                                __AP_OrderFavorablePips();
                                            double peak = 0;
                                            if (GlobalVariableCheck(key))
                                              peak = GlobalVariableGet(key);
                                            if (cur > peak) {
                                              GlobalVariableSet(key, cur);
                                              return true;
                                            }
                                            return false;
                                          }

                                          int Grid_GetState(string symbol) {
                                            for (int i = 0; i < g_gridCount;
                                                 i++)
                                              if (g_grid[i].symbol == symbol)
                                                return i;

                                            if (g_gridCount >= GRID_MAX_SYMBOLS)
                                              return -1;

                                            int idx = g_gridCount;
                                            g_grid[idx].symbol = symbol;
                                            g_grid[idx].gridCount = 0;
                                            g_grid[idx].direction = -1;
                                            g_grid[idx].basePrice = 0;
                                            g_grid[idx].gridSpacing = 0;
                                            g_grid[idx].active = false;
                                            g_grid[idx].paused = false;
                                            g_gridCount++;
                                            return idx;
                                          }

                                          void Grid_ResetState(int idx) {
                                            g_grid[idx].active = false;
                                            g_grid[idx].gridCount = 0;
                                            g_grid[idx].basePrice = 0;
                                            Grid_SaveState(idx);
                                          }

                                          void Grid_SaveState(int idx) {
                                            string sym = g_grid[idx].symbol;
                                            GlobalVariableSet(
                                                GV_GRID_ACTIVE + sym,
                                                g_grid[idx].active ? 1.0 : 0.0);
                                            GlobalVariableSet(
                                                GV_GRID_COUNT + sym,
                                                (double)g_grid[idx].gridCount);
                                            GlobalVariableSet(
                                                GV_GRID_DIR + sym,
                                                (double)g_grid[idx].direction);
                                          }

