          "\"balance\":%.2f,\"equity\":%.2f,\"daily_profit\":%.2f,"
          "\"open_positions\":%d,\"tpsl_ai_active\":%s,"
          "\"strategies_active\":%d,\"timestamp\":\"%s\"}",
          AccountVerificationID, Symbol(),
          AccountBalance(), AccountEquity(), g_dailyProfit, OrdersTotal(),
          (IsTPSL_AI() ? "true" : "false"), CountActiveStrategies(),
          TimeToString(TimeCurrent(), TIME_SECONDS));
