bool ConfirmKeltner(bool isBuy)
{

      int mp = Auto_MA_Period(), ap = Auto_ATR_Period();
      double mid = iMA(Symbol(), 0, mp, 0, MODE_EMA, PRICE_CLOSE, 1);
      double atr = iATR(Symbol(), 0, ap, 1);
      double mult = Auto_GridATRMult();
      double up = mid + mult * atr, lo = mid - mult * atr;
      double c1 = iClose(Symbol(), 0, 1);
      return isBuy ? (c1 > up) : (c1 < lo);
}

bool ConfirmKeltnerChannel(bool isBuy)
{

      int p_ma = Auto_MA_Period(), p_atr = Auto_ATR_Period();
      double mult = Auto_KC_Mult();
      double ema0 = iMA(Symbol(), 0, p_ma, 0, MODE_EMA, PRICE_CLOSE, 0);
      double ema1 = iMA(Symbol(), 0, p_ma, 0, MODE_EMA, PRICE_CLOSE, 1);
      double atr0 = iATR(Symbol(), 0, p_atr, 0);
      double up0 = ema0 + mult * atr0, dn0 = ema0 - mult * atr0;
      double atr1 = iATR(Symbol(), 0, p_atr, 1);
      double up1 = ema1 + mult * atr1;
      double c0 = iClose(Symbol(), 0, 0);
      bool up_slope = (up0 > up1) && (ema0 > ema1);
      bool dn_slope = (dn0 < ema1 - mult * atr1) && (ema0 < ema1);
      if (isBuy)
        return (c0 > ema0 && up_slope);
      else
        return (c0 < ema0 && dn_slope);
}

bool ConfirmMTKeltnerChannel(bool isBuy)
{

      int mp = Auto_MA_Period(), ap = Auto_ATR_Period();
      double mid = iMA(Symbol(), 0, mp, 0, MODE_EMA, PRICE_CLOSE, 1);
      double atr = iATR(Symbol(), 0, ap, 1);
      double mult = Auto_GridATRMult();
      double up = mid + mult * atr, lo = mid - mult * atr;
      double c = iClose(Symbol(), 0, 1);
      return isBuy ? (c > up) : (c < lo);
}

