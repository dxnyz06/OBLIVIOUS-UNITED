int NextScaleLevel(int magic, bool isBuy)
{
      int openCnt = CountOpenBySide(magic, isBuy);
      int nextLevel = openCnt + 1;
      int N = (int)MathMax(1, (int)MathFloor(Active_MaxRiskForSymbol()));
      if (nextLevel > N)
        nextLevel = N;
      return nextLevel;
}

int MaxLevelsForSymbol()
{
      int N = (int)MathFloor(Active_MaxRiskForSymbol());
      if (N < 1)
        N = 1;
      return N;
}

double LevelMultiplier(int levelIndex)
{
      if (levelIndex < 1)
        levelIndex = 1;
      return (double)levelIndex;
}

double TotalMultiplierSum(int N)
{
      return (N <= 0 ? 0.0 : (double)N * ((double)N + 1.0) / 2.0);
}

string CommentWithLevelDefault(string baseComment, int magic, int cmd)
{
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      int level = NextScaleLevel(magic, isBuy);
      int suffix = (int)MathMax(0, level - 1);
      if (StringFind(baseComment, "~") >= 0 ||
          StringFind(baseComment, " - ") >= 0 ||
          StringFind(baseComment, " x ") >= 0)
        return baseComment;
      return baseComment + " ~ " + IntegerToString(suffix);
}

string CommentWithLevelBlue(string baseComment, int magic, int cmd)
{
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      int level = NextScaleLevel(magic, isBuy);
      int suffix = (int)MathMax(0, level - 1);
      if (StringFind(baseComment, "~") >= 0 ||
          StringFind(baseComment, " - ") >= 0 ||
          StringFind(baseComment, " x ") >= 0)
        return baseComment;
      return baseComment + " x " + IntegerToString(suffix);
}

int MagicBase(int observedMagic)
{
      if (ObliviousAiMagic == 0)
        return observedMagic;
      return (observedMagic ^ ObliviousAiMagic);
}

int MagicCompose(int strategyMagic)
{
      if (ObliviousAiMagic == 0)
        return strategyMagic;
      return (strategyMagic ^ ObliviousAiMagic);
}

bool BypassCooldownForStrategy(int magic)
{
      return (MagicBase(magic) == GridMagic);
   return 0;
}

int DirFromCmd(int cmd)
{
      if (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP)
        return +1;
      if (cmd == OP_SELL || cmd == OP_SELLLIMIT || cmd == OP_SELLSTOP)
        return -1;
      return 0;
}

bool BlueMart_AA_AllowNextLayer(int steps){
      int n = AA_AutoN();
      double eq = AccountEquity(), bal = AccountBalance();
      double dd = (bal > 0 ? (bal - eq) / bal : 0);
      double mR, sR;
      AA_MeanStd(mR, sR, false, n);
      double atr = iATR(Symbol(), Period(), MathMax(5, (int)MathSqrt(n)), 1);
      bool vol_ok = atr <= (mR + sR);
      bool dd_ok = dd < 0.1;
      bool steps_ok = steps < MathMax(2, (int)(MathSqrt(n) / 4));
      return vol_ok && dd_ok && steps_ok;
}

bool ATRRegimeOK() {
      double atr = EATR(Symbol(), 0, 14);
      double atr_long_term = EATR(Symbol(), 0, 50);
      return (atr > 0.8 * atr_long_term);
}

double VolumeMA(int period = 20)
{
      double sum = 0;
      for (int i = 1; i <= period; i++)
        sum += (double)iVolume(Symbol(), Period(), i);
      return sum / period;
}

enum POIType { POI_NONE=0, POI_OB=1, POI_FVG=2, POI_EQ=3, POI_SWEEP=4, POI_ALL=99 };
struct POI {
   POIType type;
   double  hi;
   double  lo;
   double  zHigh;
   double  zLow;
   double  mid;
   int     tf;
   int     bar;
   bool    valid;
   bool    active;
   bool    isBull;
   string  symbol;
};
POI  g_POIs[100];
int  g_POIsCount = 0;

enum VolRegime { VOL_LOW=0, VOL_NORMAL=1, VOL_HIGH=2, VOL_EXTREME=3 };

struct AdaptState {
   int    regime;
   double vol_factor;
   bool   isTrend;
   int    rsi_period;
   int    ema_fast;
   int    ema_slow;
   int    cci_period;
   int    bb_period;
   double bb_dev;
   int    mom_period;
