        return;
      string tag = TagFromOrder(ticket);
      SL_AddMessage(StringFormat(
          "%s [ORDER] Modify ticket=%d SL: %.5f->%.5f TP: %.5f->%.5f", tag,
          ticket, oldSL, OrderStopLoss(), oldTP, OrderTakeProfit()));
}

bool IsLeverageSufficient(double minLeverage);

double BreakEvenPips() {
      double atr = iATR(Symbol(), Period(), 14, 0);
      double pip = ADV_Pip();
      if (pip <= 0)
        pip = Point * 10;
      double pips = atr / pip;
      if (Mode == Conservative)
        pips *= 1.3;
      else if (Mode == Aggressive)
        pips *= 0.7;
      return MathMax(5.0, NormalizeDouble(pips, 1));
}

double TrailingStopPips() {
      double atr = iATR(Symbol(), Period(), 14, 0);
      double pip = ADV_Pip();
      if (pip <= 0)
        pip = Point * 10;
      double pips = atr * 1.5 / pip;
      if (Mode == Conservative)
        pips *= 1.3;
      else if (Mode == Aggressive)
        pips *= 0.7;
      return MathMax(8.0, NormalizeDouble(pips, 1));
}

void ApplyTrailingStop(int ticket = -1) {
      if (!EnableTrailingStop)
        return;
      for (int i = 0; i < OrdersTotal(); i++) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          if (ticket >= 0 && OrderTicket() != ticket) continue;
          if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
          if (OrderType() == OP_BUY) {
            double newSL = Bid - (50 * Point);
            if (OrderStopLoss() < newSL) {
              LogGate("BLOCK NEWS",
                      StringFormat("Symbol=%s Time=%s (file=file path)",
                                   Symbol(),
                                   TimeToStr(TimeCurrent(), TIME_SECONDS)));
              {
                int __ticket = OrderTicket();
                double __newSL = 0,
                       __newTP = Auto_TP_Points_Strategy(
                           "__new"); /* prefetch desired sl/tp from args not
                                        trivial; logging current after select */
                SmartLogWrap("MODIFY",
                             StringFormat("PreModify | ticket=%d symbol=%s",
                                          __ticket, OrderSymbol()));
              }
              bool _wRes = OrderModify(OrderTicket(), OrderOpenPrice(), newSL,
                          OrderTakeProfit(), 0, clrBlue);
              {
                int __ok = (GetLastError() == 0);
                double __exe = OrderOpenPrice(), __sl = OrderStopLoss(),
                       __tp = OrderTakeProfit();
                SmartLogWrap(
                    "MODIFY",
                    StringFormat(
                        "%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d",
                        __ok ? "PostModify OK" : "PostModify FAIL",
                        OrderTicket(), __exe, __sl, __tp, GetLastError()));
              }
            }
          } else if (OrderType() == OP_SELL) {
            double newSL = Ask + (50 * Point);
            if (OrderStopLoss() > newSL || OrderStopLoss() == 0) {
              LogGate("BLOCK NEWS",
                      StringFormat("Symbol=%s Time=%s (file=file path)",
                                   Symbol(),
                                   TimeToStr(TimeCurrent(), TIME_SECONDS)));
              {
                int __ticket = OrderTicket();
                double __newSL = 0,
                       __newTP = Auto_TP_Points_Strategy(
                           "__new"); /* prefetch desired sl/tp from args not
                                        trivial; logging current after select */
                SmartLogWrap("MODIFY",
                             StringFormat("PreModify | ticket=%d symbol=%s",
                                          __ticket, OrderSymbol()));
              }
              bool _wRes = OrderModify(OrderTicket(), OrderOpenPrice(), newSL,
                          OrderTakeProfit(), 0, clrRed);
              {
                int __ok = (GetLastError() == 0);
                double __exe = OrderOpenPrice(), __sl = OrderStopLoss(),
                       __tp = OrderTakeProfit();
                SmartLogWrap(
                    "MODIFY",
                    StringFormat(
                        "%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d",
                        __ok ? "PostModify OK" : "PostModify FAIL",
                        OrderTicket(), __exe, __sl, __tp, GetLastError()));
              }
            }
          }
        }
      }
}

void PositionManager_ApplyBreakeven(int idx)
{
      if (idx < 0 || idx >= g_positionCount)
        return;

      string symbol = g_positions[idx].symbol;
      int cmd = g_positions[idx].cmd;
      double openPrice = g_positions[idx].openPrice;
      double pv = PipValue(symbol);
      double beDistance = BreakEvenPips() * pv;
      double beLock =
          2.0 * MarketInfo(symbol, MODE_POINT); // 2 points profit lock

      double currentPrice = (cmd == OP_BUY) ? MarketInfo(symbol, MODE_BID)
                                            : MarketInfo(symbol, MODE_ASK);

      if (cmd == OP_BUY) {
        if (currentPrice >= openPrice + beDistance) {
          double newSL = openPrice + beLock;
          if (g_positions[idx].sl < newSL) {
            if (OrderManager_Modify(g_positions[idx].ticket, newSL,
                                    g_positions[idx].tp)) {
              g_positions[idx].beApplied = true;
              g_positions[idx].sl = newSL;
            }
          }
        }
      } else if (cmd == OP_SELL) {
        if (currentPrice <= openPrice - beDistance) {
          double newSL = openPrice - beLock;
          if (g_positions[idx].sl == 0 || g_positions[idx].sl > newSL) {
            if (OrderManager_Modify(g_positions[idx].ticket, newSL,
                                    g_positions[idx].tp)) {
              g_positions[idx].beApplied = true;
              g_positions[idx].sl = newSL;
            }
          }
        }
      }
}

void VirtualTPSL_Init()
{
      g_virtualCount = 0;
      // Virtual mode is active when TPSLMode is not Native (0)
      g_virtualMode = (TPSLMode != 0);

      if (g_virtualMode)
        Print("[VirtualTPSL] Active - TP/SL levels hidden from broker");
      else
        Print("[VirtualTPSL] Inactive - Using broker native TP/SL");
}

void VirtualTPSL_Register(int ticket, string symbol, int cmd, double tp, double sl, double trailDist = 0)
{
      if (!g_virtualMode)
        return;

      // Find existing or add new
      int idx = VirtualTPSL_Find(ticket);
      if (idx < 0) {
        if (g_virtualCount >= VTP_MAX_TRACKED)
          return;
        idx = g_virtualCount;
        g_virtualCount++;
      }

      g_virtualLevels[idx].ticket = ticket;
      g_virtualLevels[idx].symbol = symbol;
      g_virtualLevels[idx].cmd = cmd;
      g_virtualLevels[idx].virtualTP = tp;
      g_virtualLevels[idx].virtualSL = sl;
      g_virtualLevels[idx].trailDistance = trailDist;
      g_virtualLevels[idx].active = true;

      // Initialize trail high water
      double currentPrice = (cmd == OP_BUY) ? MarketInfo(symbol, MODE_BID)
                                            : MarketInfo(symbol, MODE_ASK);
      g_virtualLevels[idx].trailHighWater = currentPrice;

      PrintFormat(
          "[VirtualTPSL] Registered #%d | TP: %.5f SL: %.5f Trail: %.5f",
          ticket, tp, sl, trailDist);
}

void VirtualTPSL_Monitor()
{
      if (!g_virtualMode || g_virtualCount == 0)
        return;

      for (int i = g_virtualCount - 1; i >= 0; i--) {
        if (!g_virtualLevels[i].active)
          continue;

        int ticket = g_virtualLevels[i].ticket;

        // Verify order still exists
        if (!OrderSelect(ticket, SELECT_BY_TICKET, MODE_TRADES)) {
          g_virtualLevels[i].active = false;
          continue;
        }

        if (OrderCloseTime() != 0) {
          g_virtualLevels[i].active = false;
          continue;
        }

        string symbol = g_virtualLevels[i].symbol;
        int cmd = g_virtualLevels[i].cmd;
        double bid = MarketInfo(symbol, MODE_BID);
        double ask = MarketInfo(symbol, MODE_ASK);
        double currentPrice = (cmd == OP_BUY) ? bid : ask;

        // Check virtual TP
        if (g_virtualLevels[i].virtualTP > 0) {
          bool tpHit = false;
          if (cmd == OP_BUY && bid >= g_virtualLevels[i].virtualTP)
            tpHit = true;
          if (cmd == OP_SELL && ask <= g_virtualLevels[i].virtualTP)
            tpHit = true;

          if (tpHit) {
            PrintFormat("[VirtualTPSL] TP HIT #%d @ %.5f (target: %.5f)",
                        ticket, currentPrice, g_virtualLevels[i].virtualTP);
            OrderManager_Close(ticket);
            g_virtualLevels[i].active = false;
            continue;
          }
        }

        // Check virtual SL
        if (g_virtualLevels[i].virtualSL > 0) {
          bool slHit = false;
          if (cmd == OP_BUY && bid <= g_virtualLevels[i].virtualSL)
            slHit = true;
          if (cmd == OP_SELL && ask >= g_virtualLevels[i].virtualSL)
            slHit = true;

          if (slHit) {
            PrintFormat("[VirtualTPSL] SL HIT #%d @ %.5f (target: %.5f)",
                        ticket, currentPrice, g_virtualLevels[i].virtualSL);
            OrderManager_Close(ticket);
            g_virtualLevels[i].active = false;
            continue;
          }
        }

        // Virtual trailing
        if (g_virtualLevels[i].trailDistance > 0) {
          VirtualTPSL_UpdateTrailing(i, currentPrice);
        }
      }

      // Compact periodically
      VirtualTPSL_Compact();
}

void VirtualTPSL_UpdateTrailing(int idx, double currentPrice)
{
      int cmd = g_virtualLevels[idx].cmd;
      double trailDist = g_virtualLevels[idx].trailDistance;

      if (cmd == OP_BUY) {
        // Track highest price
        if (currentPrice > g_virtualLevels[idx].trailHighWater)
          g_virtualLevels[idx].trailHighWater = currentPrice;

        // Move virtual SL up
        double newSL = g_virtualLevels[idx].trailHighWater - trailDist;

        // Only update if better than current and in profit
        if (newSL > g_virtualLevels[idx].virtualSL) {
          // Verify we're in profit
          if (!OrderSelect(g_virtualLevels[idx].ticket, SELECT_BY_TICKET,
                           MODE_TRADES))
            return;
          if (newSL > OrderOpenPrice()) {
            g_virtualLevels[idx].virtualSL = newSL;
          }
        }
      } else if (cmd == OP_SELL) {
        // Track lowest price
        if (g_virtualLevels[idx].trailHighWater == 0 ||
            currentPrice < g_virtualLevels[idx].trailHighWater)
          g_virtualLevels[idx].trailHighWater = currentPrice;

        double newSL = g_virtualLevels[idx].trailHighWater + trailDist;

        if (g_virtualLevels[idx].virtualSL == 0 ||
            newSL < g_virtualLevels[idx].virtualSL) {
          if (!OrderSelect(g_virtualLevels[idx].ticket, SELECT_BY_TICKET,
                           MODE_TRADES))
            return;
          if (newSL < OrderOpenPrice()) {
            g_virtualLevels[idx].virtualSL = newSL;
          }
        }
      }
}

bool VirtualTPSL_IsActive()
{
      return g_virtualMode;
}

double VirtualTPSL_GetTP(int ticket)
{
      int idx = VirtualTPSL_Find(ticket);
      if (idx < 0)
        return 0;
      return g_virtualLevels[idx].virtualTP;
}

double VirtualTPSL_GetSL(int ticket)
{
      int idx = VirtualTPSL_Find(ticket);
      if (idx < 0)
        return 0;
      return g_virtualLevels[idx].virtualSL;
}

int VirtualTPSL_Find(int ticket)
{
      for (int i = 0; i < g_virtualCount; i++) {
        if (g_virtualLevels[i].ticket == ticket && g_virtualLevels[i].active)
          return i;
      }
      return -1;
}

void VirtualTPSL_Remove(int ticket)
{
      int idx = VirtualTPSL_Find(ticket);
      if (idx >= 0)
        g_virtualLevels[idx].active = false;
}

void VirtualTPSL_Compact()
{
      int writeIdx = 0;
      for (int readIdx = 0; readIdx < g_virtualCount; readIdx++) {
        if (g_virtualLevels[readIdx].active) {
          if (writeIdx != readIdx)
            g_virtualLevels[writeIdx] = g_virtualLevels[readIdx];
          writeIdx++;
        }
      }
      g_virtualCount = writeIdx;
}

void VirtualTPSL_Deinit()
{
      g_virtualCount = 0;
}

void ManageTrailingStop(){
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS)) continue;
        if (OrderSymbol() != Symbol()) continue;
        if (OrderType() > OP_SELL) continue;
        if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
        ApplyTrailingStop();
      }
}

void ManageBreakEven(){
      double bePoints = Auto_SL_Pips() * 0.5;
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS) || OrderSymbol() != Symbol()) continue;
        if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
        if (OrderType() != OP_BUY && OrderType() != OP_SELL)
          continue;
        double entry = OrderOpenPrice();
        bool isBuy = (OrderType() == OP_BUY);
        double profit_pips =
            isBuy ? (Bid - entry) / Point : (entry - Ask) / Point;
        if (profit_pips >= bePoints && OrderStopLoss() != entry) {
          bool _wRes = OrderModify(OrderTicket(), entry, NormalizeDouble(entry, Digits),
                      OrderTakeProfit(), 0, clrNONE);
        }
      }
}

void CheckBreakEven(){
      ManageBreakEven();
}

double CalculateTradeTARGETProfit() {
      double riskMultiplier =
          MathMin(MathMax(Active_RiskForTradePercent(), 1), 10) *
          0.10; // Convertiamo 1-10 in 10%-100%
      return ClusterTARGETMoney * riskMultiplier;
}

void AIB_TP_CoPilot_Timer_Logic(){
      AIBNF_OnHeartbeat();
      int processed = 0;
      int total = OrdersTotal();
      for (int i = 0; i < total && processed < AIBC_MaxPerPulse; i++) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
        if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
        int type = OrderType();
        if (type != OP_BUY && type != OP_SELL)
          continue;
        long magic = OrderMagicNumber();
        if (!AIBC_IsMagicWatched(magic))
          continue;
        string sym = OrderSymbol();
        bool isBuy = (type == OP_BUY);
        double entry = OrderOpenPrice(), tpcur = OrderTakeProfit();
        long ticket = OrderTicket();
        datetime opent = OrderOpenTime();
        double atrPips = AIBC_ATR(sym, AIBC_ATR_TF, AIBC_ATR_Period);
        double pt = MarketInfo(sym, MODE_POINT);
        int dg = (int)MarketInfo(sym, MODE_DIGITS);
        double sessVol = iATR(sym, PERIOD_M5, Auto_ATR_Period(), 0) / pt /
                         ((dg == 5 || dg == 3) ? 10.0 : 1.0);
        int ageMin = (int)((TimeCurrent() - opent) / 60);
        string req = StringFormat(
            "GET_TP_ONE|mode=%d|sym=%s|isBuy=%d|entry=%G|ageMin=%d|atr=%G|"
            "sessVol=%G|magic=%I64d|style=%s|tfMin=%d|sname=%s",
            AIBC_Mode, sym, (int)isBuy, entry, ageMin, atrPips, sessVol, magic,
            AIBC_ClassifyStyle(magic, sym), AIBC_TF_Minutes(AIBC_ATR_TF),
            AIBC_InferStrategyName(magic, sym));
        int h = AIBC_OpenPipe();
        if (h <= 0) {
          AIBC_StatusLine = "KO: pipe";
          continue;
        }
        bool w = AIBC_WriteLine(h, req);
        string l1 = AIBC_ReadLine(h);
        string l2 = AIBC_ReadLine(h);
        CloseHandle(h);
        int tp1, tp2, tp3;
        if (!AIBC_ParseTPs(l2, tp1, tp2, tp3)) {
          AIBC_StatusLine = "KO: parse";
          continue;
        }
        // Parse confirmed level (lvl=3/2/1) from line1 if provided
        int lvl = 0;
        int p = StringFind(l1, "lvl=");
        if (p >= 0) {
          lvl = (int)StringToInteger(StringSubstr(l1, p + 4));
        }
        int aiChosen =
            (lvl == 3
                 ? tp3
                 : (lvl == 2
                        ? tp2
                        : (lvl == 1 ? 0
                                    : (AIBC_Mode == 0
                                           ? tp1
                                           : (AIBC_Mode == 1 ? tp2 : tp3)))));
        // Runner rule: level 1 has no TP (lvl 1 runner)
        if (lvl == 1 || aiChosen <= 0) {
          if (tpcur > 0) {
            bool ok = AIB_SafeOrderModifyTP(ticket, 0);
            AIBC_StatusLine = ok ? "OK: runner L1" : "KO: runner L1";
          } else {
            AIBC_StatusLine = "OK: runner L1";
          }
          processed++; continue;
        }
        // --- Always-attach logic ---
        int __idx = AIBC_FindIdx(ticket);
        if (tpcur > 0 && AIBC_AlwaysAttach && AIBC_Attached[__idx] == 0) {
          AIBC_Attached[__idx] = 1;
          AIBC_NativeBase[__idx] = 0;
        }
        int nativePips = 0;
        if (tpcur > 0) {
          double diff = tpcur - entry;
          if (!isBuy)
            diff = entry - tpcur;
          nativePips = AIBNF_PriceToPips(sym, diff);
        }
        string styleUsed = AIBC_ClassifyStyle(magic, sym);
        int finalPips =
            AIBC_CombinePips(nativePips, aiChosen, styleUsed,
                             (AIBC_AlwaysAttach && AIBC_Attached[__idx] == 1
                                  ? MathMax(1, AIBC_Mode)
                                  : AIBC_Mode),
                             AIBC_TF_Minutes(AIBC_ATR_TF));
        int chosen = finalPips;
        double priceDelta = AIBNF_PipsToPrice(sym, chosen);
        double newTP = isBuy ? (entry + priceDelta) : (entry - priceDelta);
        if (MathAbs(newTP - tpcur) > (pt * 4)) {
          bool ok = AIB_SafeOrderModifyTP(ticket, newTP);
          AIBC_StatusLine = ok ? "OK" : "KO: modify";
        } else
          AIBC_StatusLine = "OK: unchanged";
        processed++;
      }
      AIBC_LastPulse = TimeCurrent();
      AIBC_DrawDashboard();
}

double Mart_CalcBreakevenTP(string symbol, int dir, int magic)
{
      double avgPrice = OrderManager_AvgEntryPrice(magic, dir, symbol);
      if (avgPrice <= 0)
        return 0;

      double profitTarget = iATR(symbol, 0, 14, 0) * 0.5; // Half ATR profit
      if (profitTarget <= 0)
        profitTarget = PipValue(symbol) * 10;

      if (dir == OP_BUY)
        return NormalizeDouble(avgPrice + profitTarget, Digits);
      else
        return NormalizeDouble(avgPrice - profitTarget, Digits);
}

void ApplyATRTrailingStop() {
      if (!IsTPSL_AI()) {
        return;
      }
      double atr = EATR(Symbol(), 0, 14);
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
          if (OrderType() == OP_BUY) {
            double new_stop = Bid - 2 * atr;
            {
            }
            if (new_stop > OrderStopLoss() && new_stop < Bid) {
              int __ticket = OrderTicket();
              double __newSL = 0,
                     __newTP = Auto_TP_Points_Strategy(
                         "__new"); /* prefetch desired sl/tp from args not
                                      trivial; logging current after select */
              SmartLogWrap("MODIFY",
                           StringFormat("PreModify | ticket=%d symbol=%s",
                                        __ticket, OrderSymbol()));
            }
            bool _wRes = OrderModify(OrderTicket(), OrderOpenPrice(), new_stop,
                        OrderTakeProfit(), 0, clrNONE);
            {
              int __ok = (GetLastError() == 0);
              double __exe = OrderOpenPrice(), __sl = OrderStopLoss(),
                     __tp = OrderTakeProfit();
              SmartLogWrap(
                  "MODIFY",
                  StringFormat("%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d",
                               __ok ? "PostModify OK" : "PostModify FAIL",
                               OrderTicket(), __exe, __sl, __tp,
                               GetLastError()));
            }
          } else if (OrderType() == OP_SELL) {
            {
            }
            double new_stop = Ask + 2 * atr;
            if (new_stop < OrderStopLoss() && new_stop > Ask) {
              int __ticket = OrderTicket();
              double __newSL = 0,
                     __newTP = Auto_TP_Points_Strategy(
                         "__new"); /* prefetch desired sl/tp from args not
                                      trivial; logging current after select */
              SmartLogWrap("MODIFY",
                           StringFormat("PreModify | ticket=%d symbol=%s",
                                        __ticket, OrderSymbol()));
            }
            bool _wRes = OrderModify(OrderTicket(), OrderOpenPrice(), new_stop,
                        OrderTakeProfit(), 0, clrNONE);
            {
              int __ok = (GetLastError() == 0);
              double __exe = OrderOpenPrice(), __sl = OrderStopLoss(),
                     __tp = OrderTakeProfit();
              SmartLogWrap(
                  "MODIFY",
                  StringFormat("%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d",
                               __ok ? "PostModify OK" : "PostModify FAIL",
                               OrderTicket(), __exe, __sl, __tp,
                               GetLastError()));
            }
          }
        }
      }
}

void PreprocessSLTPForStrategy(string strategy, int dir, double entry, double &sl, double &tp, double &lot)
{
      if (IsTPSL_AI()) {
        // In automatico non tocchiamo i valori calcolati dalla strategia
        return;
      }
      // Manuale: se esistono input per la strategia, li usiamo in pips
      double slP = 0, tpP = 0, lotIn = lot;
      if (strategy == "FVG") {
        slP = FVGSL;
        tpP = FVGTP;
        lotIn = (FVGLot > 0 ? FVGLot : lot);
      } else if (strategy == "Breakout") {
        slP = BreakoutSL;
        tpP = BreakoutTP;
        lotIn = (BreakoutLot > 0 ? BreakoutLot : lot);
      } else if (strategy == "Reverse") {
        slP = ReverseSL;
        tpP = ReverseTP;
        lotIn = (ReverseLot > 0 ? ReverseLot : lot);
      } else if (strategy == "SMC") {
        slP = SMCSL;
        tpP = SMCTP;
        lotIn = (SMCLot > 0 ? SMCLot : lot);
      } else if (strategy == "ICT") {
        slP = ICTSL;
        tpP = ICTTP;
        lotIn = (ICTLot > 0 ? ICTLot : lot);

      } else if (strategy == "Grid") {
        slP = GridSL;
        tpP = GridTP;
        lotIn = (GridLot > 0 ? GridLot : lot);
      } else if (strategy == "Predicted") {
        slP = PredictedSL;
        tpP = PredictedTP;
        lotIn = (PredictedLot > 0 ? PredictedLot : lot);
      }
      if (slP > 0 && tpP > 0) {
        sl = (dir > 0) ? (entry - slP * Point) : (entry + slP * Point);
        tp = (dir > 0) ? (entry + tpP * Point) : (entry - tpP * Point);
        lot = lotIn;
      }
}

double __StrategyTP(string strat, int direction){
      double pt = MarketInfo(Symbol(), MODE_POINT);
      int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
      double tpPts = Auto_TP_Points_Strategy(strat);
      if (direction > 0)
        return NormalizeDouble(Ask + tpPts * pt, digits);
      if (direction < 0)
        return NormalizeDouble(Bid - tpPts * pt, digits);
      if (Close[0] > Open[0])
        return NormalizeDouble(Ask + tpPts * pt, digits);
      return NormalizeDouble(Bid - tpPts * pt, digits);
}

double __StrategySL(string strat, int direction){
      double pt = MarketInfo(Symbol(), MODE_POINT);
      int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
      double slPts = Auto_SL_Points_Strategy(strat);
      if (direction > 0)
        return NormalizeDouble(Ask - slPts * pt, digits);
      if (direction < 0)
        return NormalizeDouble(Bid + slPts * pt, digits);
      if (Close[0] > Open[0])
        return NormalizeDouble(Ask - slPts * pt, digits);
      return NormalizeDouble(Bid + slPts * pt, digits);
}

