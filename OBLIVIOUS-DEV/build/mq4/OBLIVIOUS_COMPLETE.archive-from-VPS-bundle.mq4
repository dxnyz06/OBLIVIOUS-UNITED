   // Strategy_HaramiPattern_Logic: real pattern detection

//| 23. Strategy_<Pattern>_Logic

void Strategy_PatternAlpha_Logic() {
   // LEVEL 3 CONTEXT: Alpha Pattern detector  always active, no AllowStrategyToTrade gate.
   // Contributes engulfing+MACD pattern signal to g_pat_consensus.
   double atr = iATR(Symbol(), PERIOD_CURRENT, Auto_ATR_Period(), 1);
   double _vol_f, _adx_f, _tf_f, _sess_f;
   GetMarketRegime(_vol_f, _adx_f, _tf_f, _sess_f);
   if (_vol_f < 0.5 && _adx_f < Auto_ADX_Threshold()) return; // choppy  no signal

   double c0 = Close[0], o0 = Open[0], c1 = Close[1], o1 = Open[1];
   bool bullEngulf = (c1 < o1) && (c0 > o0) && (c0 > o1) && (o0 < c1);
   bool bearEngulf = (c1 > o1) && (c0 < o0) && (c0 < o1) && (o0 > c1);
   if (!bullEngulf && !bearEngulf) return;

   double macd = iMACD(Symbol(), PERIOD_CURRENT, 12, 26, 9, PRICE_CLOSE, MODE_MAIN, 1);
   double sig  = iMACD(Symbol(), PERIOD_CURRENT, 12, 26, 9, PRICE_CLOSE, MODE_SIGNAL, 1);
   double conf = 55.0; int dir = 0;
   if (bullEngulf && macd > sig) { dir =  1; conf += 15.0 + (MathAbs(c0 - o0) / atr) * 10.0; }
   if (bearEngulf && macd < sig) { dir = -1; conf += 15.0 + (MathAbs(c0 - o0) / atr) * 10.0; }
   if (dir == 0) return;
   conf = MathMin(conf, 95.0);
   if (conf < PatternsConfidence) return;

   // Context contribution (NOT trade execution)
   if (dir == 1) g_pat_bull_count++; else g_pat_bear_count++;
   g_pat_confidence = MathMax(g_pat_confidence, conf);
}

                      bool Strategy_PatternCrown_Logic() {
                      if (!GlobalStrategyGuards())
                        return (false);

                      double __c_neck__;
                      int __c_iL__, __c_iH__, __c_iR__;
                      bool __c_inv__ = false;
                      if (!Crown_SymmetryDetector(__c_neck__, __c_iL__,
                                                  __c_iH__, __c_iR__, __c_inv__,
                                                  5, 8, 5, 0.15, 6) ||
                          !Crown_VolumePressureZone(__c_neck__, __c_inv__))
                        return (false);
                      if (!Crown_VolumePressureZone(10, 1.8))
                        return (false);
                      if (!SmartCandleProfiling(0, 2.0, 1.5))
                        return (false);
                      if (!PatternVolumeSpike(20, 2.0, 1.2))
                        return (false);
                      double confidence = CalculatePatternConfidence();
                      if (confidence < PatternsConfidence)
                        return false;
                      if (!CheckFiltersRSI() || !CheckFiltersATR())
                        return false;
                      return true;
                      }

