void DrawShortHLine(string id, datetime t1, datetime t2, double p, color c, string labelText="", bool withLabel=true)
{
      // main dashed segment
      if (ObjectFind(0, id) < 0)
        ObjectCreate(0, id, OBJ_TREND, 0, t1, p, t2, p);
      ObjectSetInteger(0, id, OBJPROP_COLOR, c);
      ObjectSetInteger(0, id, OBJPROP_STYLE, STYLE_DASH);
      ObjectSetInteger(0, id, OBJPROP_WIDTH, 1);
      ObjectMove(0, id, 0, t1, p);
      ObjectMove(0, id, 1, t2, p);
      ObjectSetInteger(0, id, OBJPROP_RAY, false);
      ObjectSetInteger(0, id, OBJPROP_BACK, false);
      // optional label at center
      if (withLabel && labelText != "") {
        datetime tm = t1 + (t2 - t1) / 2;
        string tid = id + "_LBL";
        if (ObjectFind(0, tid) < 0)
          ObjectCreate(0, tid, OBJ_TEXT, 0, tm, p);
        ObjectSetText(tid, labelText, 7, "Arial", c);
        ObjectSetInteger(0, tid, OBJPROP_BACK, false);
      }
}

void RGB_ApplyEverywhere()
{
      RGB_ApplyToAllUI();
      ChartRedraw(0);
}

void RGB_ApplyToAllUI()
{
      color c = RGB_Current();
      color offc = clrDimGray;
      // Known toggle IDs (so OFF stays gray)
      string TOGGLES[] = {
          "FIL_TGL_ATR",          "FIL_TGL_Bollinger",   "FIL_TGL_Fractals",
          "FIL_TGL_MultiTFTrend", "FIL_TGL_PriceAction", "IND_TGL_ADX",
          "IND_TGL_CCI",          "IND_TGL_EMA",         "IND_TGL_MA",
          "IND_TGL_MACD",         "IND_TGL_Momentum",    "IND_TGL_RSI",
          "IND_TGL_Stochastic",   "IND_TGL_SuperTrend",  "TPSLMode_AI"};
      int total = ObjectsTotal(0, -1, -1);
      for (int idx = total - 1; idx >= 0; idx--) {
        string name = ObjectName(0, idx);
        int type = ObjectType(name);
        // Skip hard backgrounds if any
        if (name == "BG" || name == "BACKGROUND")
          continue;
        // 1) Labels: keep negatives red, else RGB
        if (type == OBJ_LABEL) {
          string txt = ObjectGetString(0, name, OBJPROP_TEXT);
          bool isNegative = false;
          // fast negative check: minus followed by a digit
          for (int i = 0; i < StringLen(txt) && i < 8; i++) {
            int ch = StringGetChar(txt, i);
            if (ch == '-') {
              // look ahead
              for (int j = i + 1; j < MathMin(StringLen(txt), i + 6); j++) {
                int cj = StringGetChar(txt, j);
                if (cj >= '0' && cj <= '9') {
                  isNegative = true;
                  break;
                }
              }
            }
            if (isNegative)
              break;
          }
          ObjectSetInteger(0, name, OBJPROP_COLOR, isNegative ? clrRed : c);
          continue;
        }
        // 2) Rectangle labels (bars/toggles/panels)
        if (type == OBJ_RECTANGLE_LABEL) {
          bool processed = false;
          // Is it a toggle element?
          for (int t = 0; t < ArraySize(TOGGLES) && !processed; t++) {
            string base = TOGGLES[t];
            if (name == base || name == base + "_BG" ||
                name == base + "_CIRCLE") {
              bool on = UIToggleGet(base, false);
              color tc = on ? c : offc;
              ObjectSetInteger(0, name, OBJPROP_BGCOLOR, tc);
              ObjectSetInteger(0, name, OBJPROP_COLOR, tc);
              processed = true;
            }
          }
          if (processed)
            continue;
          // Otherwise treat as generic bar/panel ÃƒÃ‚Â¢— → RGB
          ObjectSetInteger(0, name, OBJPROP_BGCOLOR, c);
          ObjectSetInteger(0, name, OBJPROP_COLOR, c);
          continue;
        }
        // 3) Fallback for other shapes/lines
        ObjectSetInteger(0, name, OBJPROP_COLOR, c);
        // Best-effort fill if supported
        ObjectSetInteger(0, name, OBJPROP_BGCOLOR, c);
      }
}

void RGB_ApplyToChart()
{
      color c = RGB_Current();
      ChartSetInteger(0, CHART_COLOR_CHART_UP, c);
      ChartSetInteger(0, CHART_COLOR_CHART_DOWN, c);
      ChartSetInteger(0, CHART_COLOR_FOREGROUND, c);
}

void RGB_AdvancePhase()
{
      static int phase = 0;
      phase = (phase + 3) % 360;
      double r, g, b;
      int h = phase / 60;
      double f = (double)phase / 60.0 - h;
      double q = 1.0 - f;
      switch (h % 6) {
      case 0:
        r = 1.0;
        g = f;
        b = 0.0;
        break;
      case 1:
        r = q;
        g = 1.0;
        b = 0.0;
        break;
      case 2:
        r = 0.0;
        g = 1.0;
        b = f;
        break;
      case 3:
        r = 0.0;
        g = q;
        b = 1.0;
        break;
      case 4:
        r = f;
        g = 0.0;
        b = 1.0;
        break;
      default:
        r = 1.0;
        g = 0.0;
        b = q;
        break;
      }
      int ri = (int)(r * 255);
      int gi = (int)(g * 255);
      int bi = (int)(b * 255);
      g_rgbColor = (color)(ri + (gi * 256) + (bi * 65536));
      int objs = ObjectsTotal(0, 0, -1);
      for (int i = 0; i < objs; i++) {
        string oname = ObjectName(0, i, 0, -1);
        if (StringFind(oname, "RGB_") >= 0)
          ObjectSetInteger(0, oname, OBJPROP_COLOR, g_rgbColor);
      }
}

void RGB_EnforceBoxesAndLabels()
{
      int total = ObjectsTotal(0, -1, -1);
      for (int k = 0; k < total; k++) {
        string id = ObjectName(0, k);
        if (StringFind(id, "Trig_", 0) != 0)
          continue;
        int type = (int)ObjectGetInteger(0, id, OBJPROP_TYPE);
        if (type == OBJ_RECTANGLE) {
          // Style solid + RGB color
          color c = RGB_Current();
          ObjectSetInteger(0, id, OBJPROP_STYLE, STYLE_SOLID);
          ObjectSetInteger(0, id, OBJPROP_COLOR, c);
          // Centered label
          string lid = id + "_lbl";
          datetime t1 = (datetime)ObjectGetInteger(0, id, OBJPROP_TIME, 0);
          datetime t2 = (datetime)ObjectGetInteger(0, id, OBJPROP_TIME, 1);
          double p0 = ObjectGetDouble(0, id, OBJPROP_PRICE, 0);
          double p1 = ObjectGetDouble(0, id, OBJPROP_PRICE, 1);
          datetime tMid = (datetime)((t1 + t2) / 2);
          double pMid = 0.5 * (p0 + p1);
          // Choose label text by id pattern if label missing
          if (ObjectFind(0, lid) < 0) {
            string text = "BOX";
            if (StringFind(id, "fvg", 0) >= 0)
              text = "FVG";
            else if (StringFind(id, "ob_", 0) >= 0)
              text = "OB";
            else if (StringFind(id, "ai_box_main", 0) >= 0)
              text = "OTE1";
            else if (StringFind(id, "ai_box_ote2", 0) >= 0)
              text = "OTE2";
            else if (StringFind(id, "crown_LS", 0) >= 0)
              text = "LS";
            else if (StringFind(id, "crown_RS", 0) >= 0)
              text = "RS";
            else if (StringFind(id, "cobra_box", 0) >= 0)
              text = "Consolidation";
            else if (StringFind(id, "emperor", 0) >= 0)
              text = "Impulse";
            else if (StringFind(id, "struct", 0) >= 0)
              text = "Structure";
            else if (StringFind(id, "royal", 0) >= 0)
              text = "Royal";
            else if (StringFind(id, "alpha", 0) >= 0)
              text = "Alpha";
            ObjectCreate(0, lid, OBJ_TEXT, 0, tMid, pMid);
            ObjectSetText(lid, text, 8, "Arial", c);
            ObjectSetInteger(0, lid, OBJPROP_COLOR, c);
            ObjectSetInteger(0, lid, OBJPROP_BACK, false);
            ObjectSetInteger(0, lid, OBJPROP_TIME, 0, tMid);
            ObjectSetDouble(0, lid, OBJPROP_PRICE, 0, pMid);
          } else {
            // keep label RGB and centered
            ObjectSetInteger(0, lid, OBJPROP_COLOR, c);
            ObjectSetInteger(0, lid, OBJPROP_BACK, false);
            ObjectSetInteger(0, lid, OBJPROP_TIME, 0, tMid);
            ObjectSetDouble(0, lid, OBJPROP_PRICE, 0, pMid);
          }
        } else if (type == OBJ_TREND || type == OBJ_HLINE) {
          // Ensure dashed + RGB for lines
          color c = RGB_Current();
          ObjectSetInteger(0, id, OBJPROP_STYLE, STYLE_DASH);
          ObjectSetInteger(0, id, OBJPROP_COLOR, c);
        }
      }
}

void RGB_InitCycle()
{
      if (__rgb_t0 == 0)
        __rgb_t0 = TimeLocal();
      EventSetTimer(UPDATE_EVERY_SECONDS);
}

void RGB_RecolorAllTriggers()
{
      color c = RGB_Current();
      int total = ObjectsTotal(0, -1, -1);
      for (int i = total - 1; i >= 0; i--) {
        string nm = ObjectName(0, i);
        if (StringFind(nm, "Trig_", 0) != 0)
          continue;
        int tp = ObjectType(nm);
        if (tp == OBJ_TREND || tp == OBJ_HLINE || tp == OBJ_VLINE) {
          ObjectSetInteger(0, nm, OBJPROP_COLOR, c);
          ObjectSetInteger(0, nm, OBJPROP_STYLE, STYLE_DASH);
          ObjectSetInteger(0, nm, OBJPROP_BACK, false);
        } else if (tp == OBJ_RECTANGLE) {
          ObjectSetInteger(0, nm, OBJPROP_COLOR, c);
          ObjectSetInteger(0, nm, OBJPROP_BACK, true);
        } else if (tp == OBJ_TEXT || tp == OBJ_LABEL) {
          string t = ObjectDescription(nm);
          ObjectSetText(nm, t, 8, "Arial", c);
        }
      }
}

void SMC_Liquidity_Clear(){
      DeleteTrigByPrefix("SMC_LIQ_");
