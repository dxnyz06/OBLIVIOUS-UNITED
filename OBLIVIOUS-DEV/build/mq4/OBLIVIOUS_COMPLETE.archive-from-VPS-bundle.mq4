double TrueRange(int shift)
{
      double h = iHigh(Symbol(), Period(), shift);
      double l = iLow(Symbol(), Period(), shift);
      double c1 = iClose(Symbol(), Period(), shift + 1);
      return MathMax(h - l, MathMax(MathAbs(h - c1), MathAbs(l - c1)));
}

double TRavg(int n, int startShift=0)
{
      if (n <= 0)
        n = 14;
      double sum = 0.0;
      for (int i = startShift; i < startShift + n; i++)
        sum += TrueRange(i);
      return sum / n;
}

double MedianRange(string sym, int tf, int n)
{
      if (n <= 0)
        n = 20;
      double buf[];
      ArrayResize(buf, n);
      for (int i = 0; i < n; i++)
        buf[i] = iHigh(sym, tf, i + 1) - iLow(sym, tf, i + 1);
      return __Median(buf, n);
}

double RangeAt(int shift)
{
      return iHigh(Symbol(), Period(), shift) - iLow(Symbol(), Period(), shift);
}

bool PivotHigh(int leftBars, int rightBars, int shift)
{
      double h = iHigh(Symbol(), Period(), shift);
      for (int i = 1; i <= leftBars; i++)
        if (iHigh(Symbol(), Period(), shift + i) >= h)
          return false;
      for (int i = 1; i <= rightBars; i++)
        if (iHigh(Symbol(), Period(), shift - i) >= h)
          return false;
      return true;
}

bool PivotLow(int leftBars, int rightBars, int shift)
{
      double l = iLow(Symbol(), Period(), shift);
      for (int i = 1; i <= leftBars; i++)
        if (iLow(Symbol(), Period(), shift + i) <= l)
          return false;
      for (int i = 1; i <= rightBars; i++)
        if (iLow(Symbol(), Period(), shift - i) <= l)
          return false;
      return true;
}

bool __looks_negative_number(const string txt)
{
      if (StringLen(txt) < 2)
        return false;
      if (StringGetCharacter(txt, 0) != '-')
        return false;
      for (int i = 1; i < StringLen(txt); i++) {
        int c = StringGetCharacter(txt, i);
        if (c != '.' && (c < '0' || c > '9'))
          return false;
      }
      return true;
}

double __map_vs_threshold(double val01, double thr01)
{
      if (thr01 <= 0.0)
        return val01;
      return clamp01((val01 - thr01) / (1.0 - thr01 + 1e-9));
}

double ADV_Pip()
{
      return Point * (Digits == 3 || Digits == 5 ? 10 : 1);
}

int CurrentSpreadPoints(string sym=NULL){
      if (sym == NULL || sym == "")
        sym = Symbol();
      double spr = MarketInfo(sym, MODE_SPREAD);
      if (spr <= 0)
        spr = (MarketInfo(sym, MODE_ASK) - MarketInfo(sym, MODE_BID)) /
              MarketInfo(sym, MODE_POINT);
      return (int)MathRound(spr);
}

double __SpreadPoints()    {
      return SpreadPoints(); }

double __atr_pts_internal(int p)
{
      double v = iATR(Symbol(), Period(), p, 0);
      return (v > 0 ? v / Point : 0);
}

double ATRPoints(int p=14){
      int tf = 0;
#ifdef __MQL4__
      tf = Period();
#endif
      // If we have Use_TF(), prefer it
      return (iATR(Symbol(), (int)((bool)0 ? 0 : ((int)((int)0))), p, 0)); 
}

double ATRv(int p=14)
{
      return iATR(Symbol(), Period(), p, 0);
}

double NormalizedATR(int period=14)
{
      double atr = iATR(Symbol(), Period(), period, 0);
      double pip = ADV_Pip();
      return (pip > 0 ? atr / pip : 0);
}

double ATRScaledPoints(int period, double mult)
{
      return __atr_pts_internal(period) * mult;
}

double ModeScale() {
      // Scale parameters by trading mode
      if (Mode == 0)
        return 0.90; // Conservative: reduce
      if (Mode == 2)
        return 1.15; // Aggressive: increase
      return 1.00;   // Moderate: baseline
}

double ScalePipsByATR(double pips)
{
      int pts = (int)MathMax(1, MathRound(pips * AA_PointsPerPip()));
      int pts_dyn = ScalePointsByATR(pts);
      return ((double)pts_dyn) / AA_PointsPerPip();
}

double ADV_ATR(int tf, int period, int shift)
{
      return iATR(Symbol(), tf, period, shift);
}

void ADV_RangeHL(int tf, int lookback, double &hi, double &lo)
{
      hi = -DBL_MAX;
      lo = DBL_MAX;
      int bars = iBars(Symbol(), tf);
      if (bars < 5) {
        hi = iHigh(Symbol(), tf, 1);
        lo = iLow(Symbol(), tf, 1);
        return;
      }
      int maxShift = (int)MathMin(lookback, bars - 2);
      for (int s = 1; s <= maxShift; s++) {
        double h = iHigh(Symbol(), tf, s);
        double l = iLow(Symbol(), tf, s);
        if (h > hi)
          hi = h;
        if (l < lo)
          lo = l;
      }
      if (hi <= -DBL_MAX)
        hi = iHigh(Symbol(), tf, 1);
      if (lo >= DBL_MAX)
        lo = iLow(Symbol(), tf, 1);
}

void ADV_DealingRange(int tf, int lookback, double &hi, double &lo)
{
      hi = -DBL_MAX;
      lo = DBL_MAX;

      int shH = -1, shL = -1;
      double fh = 0.0, fl = 0.0;
      bool okH = ADV_LastFractal(tf, +1, lookback, fh, shH);
      bool okL = ADV_LastFractal(tf, -1, lookback, fl, shL);

      if (okH && okL) {
        hi = fh;
        lo = fl;
        if (hi < lo) {
          double tmp = hi;
          hi = lo;
          lo = tmp;
        }
        return;
      }

      int bars = iBars(Symbol(), tf);
      int n = (int)MathMin(lookback, bars - 2);
      for (int i = 1; i <= n; i++) {
        double h = iHigh(Symbol(), tf, i);
        double l = iLow(Symbol(), tf, i);
        if (h > hi)
          hi = h;
        if (l < lo)
          lo = l;
      }
      if (hi <= -DBL_MAX)
        hi = iHigh(Symbol(), tf, 1);
      if (lo >= DBL_MAX)
        lo = iLow(Symbol(), tf, 1);
}

int TFMinutes(int tf)
{
      switch (tf) {
      case PERIOD_M1:
        return 1;
      case PERIOD_M5:
        return 5;
      case PERIOD_M15:
        return 15;
      case PERIOD_M30:
        return 30;
      case PERIOD_H1:
        return 60;
      case PERIOD_H4:
        return 240;
      case PERIOD_D1:
        return 1440;
      case PERIOD_W1:
        return 10080;
      case PERIOD_MN1:
        return 43200;
      default:
        return 60;
      }
}

int PeriodSeconds_Custom(int tf = 0)
{
      // Map current chart Period() to seconds (MT4-safe)
      if (tf <= 0) tf = Period();
      if (tf == PERIOD_M1)
        return 60;
      if (tf == PERIOD_M5)
        return 5 * 60;
      if (tf == PERIOD_M15)
        return 15 * 60;
      if (tf == PERIOD_M30)
        return 30 * 60;
      if (tf == PERIOD_H1)
        return 60 * 60;
      if (tf == PERIOD_H4)
        return 4 * 60 * 60;
      if (tf == PERIOD_D1)
        return 24 * 60 * 60;
      if (tf == PERIOD_W1)
        return 7 * 24 * 60 * 60;
      if (tf == PERIOD_MN1)
        return 30 * 24 * 60 * 60;
      // fallback
      return 60 * Period();
}

int NextHigherTF(int tf)
{
      if (tf <= PERIOD_M1)
        return PERIOD_M5;
      if (tf <= PERIOD_M5)
        return PERIOD_M15;
      if (tf <= PERIOD_M15)
        return PERIOD_H1;
      if (tf <= PERIOD_M30)
        return PERIOD_H1;
      if (tf <= PERIOD_H1)
        return PERIOD_H4;
      if (tf <= PERIOD_H4)
        return PERIOD_D1;
      if (tf <= PERIOD_D1)
        return PERIOD_W1;
      if (tf <= PERIOD_W1)
        return PERIOD_MN1;
      return PERIOD_MN1;
}

bool HasDataTF(string sym, int tf)
{
      return (iBars(sym, tf) > 0);
}

