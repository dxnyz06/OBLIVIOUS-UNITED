double __OrderFloatingPnLEUR(int ticket = -1) {
      if (ticket >= 0 && !OrderSelect(ticket, SELECT_BY_TICKET)) return 0;
      if (OrderType() == OP_BUY)  return (Bid - OrderOpenPrice()) * OrderLots() * MarketInfo(OrderSymbol(), MODE_TICKVALUE) / MathMax(Point, MarketInfo(OrderSymbol(), MODE_TICKSIZE));
      if (OrderType() == OP_SELL) return (OrderOpenPrice() - Ask) * OrderLots() * MarketInfo(OrderSymbol(), MODE_TICKVALUE) / MathMax(Point, MarketInfo(OrderSymbol(), MODE_TICKSIZE));
      return 0;
}
bool __IsNegativeEUR(double pnl = -1e9) {
      if (pnl == -1e9) return (__OrderFloatingPnLEUR() < 0);
      return (pnl < 0);
}
double __AdaptiveHedgeLots(int ticket, double baselinePrice = 0.0) {
      double baseLot = 0.0;
      if (ticket >= 0 && OrderSelect(ticket, SELECT_BY_TICKET)) baseLot = OrderLots();
      if (baseLot <= 0) baseLot = ManualLot;
      return NormalizeDouble(MathMax(MarketInfo(Symbol(), MODE_MINLOT), baseLot * 0.5), 2);
}
double __CombinedPnLEUR(int ticket1, int ticket2) {
      return __OrderFloatingPnLEUR(ticket1) + __OrderFloatingPnLEUR(ticket2);
}
double __EnergyNowMA3() {
      double s = 0;
      for (int i = 1; i <= 3; i++) s += iHigh(Symbol(), 0, i) - iLow(Symbol(), 0, i);
      return s / 3.0;
}

bool IsStrategyInCooldown(long magic) {
      datetime lastEntry = 0;
      for (int i = OrdersHistoryTotal() - 1; i >= 0 && i >= OrdersHistoryTotal() - 20; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
          if ((long)OrderMagicNumber() == magic && (TimeCurrent() - OrderCloseTime()) < 300) return true;
        }
      }
      return false;
}

