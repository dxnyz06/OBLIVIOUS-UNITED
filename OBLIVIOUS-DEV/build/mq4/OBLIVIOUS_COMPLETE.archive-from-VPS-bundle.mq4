}

string RR_AA_TargetLabel(bool isBuy, double entry, double sl, double &tChosen){
      int n = AA_AutoN();
      int L1 = (int)MathMax(10, (int)(n));
      double swing = isBuy
                         ? iHigh(Symbol(), Period(),
                                 iHighest(Symbol(), Period(), MODE_HIGH, L1, 2))
                         : iLow(Symbol(), Period(),
                                iLowest(Symbol(), Period(), MODE_LOW, L1, 2));
      int L2 = (int)MathMax(L1 + 10, (int)(1.5 * n));
      double donch = isBuy
                         ? iHigh(Symbol(), Period(),
                                 iHighest(Symbol(), Period(), MODE_HIGH, L2, 2))
                         : iLow(Symbol(), Period(),
                                iLowest(Symbol(), Period(), MODE_LOW, L2, 2));
      double h2 = iHigh(Symbol(), Period(), 2),
             l2 = iLow(Symbol(), Period(), 2);
      double impulse = (isBuy ? (entry + (h2 - l2)) : (entry - (h2 - l2)));
      // pick chosen as in RR_AA_CalcTargetPrice
      double t = isBuy ? MathMax(swing, MathMax(donch, impulse))
                       : MathMin(swing, MathMin(donch, impulse));
      tChosen = t;
      // label by proximity
      double ds = MathAbs(t - swing), dd = MathAbs(t - donch),
             di = MathAbs(t - impulse);
      if (ds <= dd && ds <= di)
        return "swing";
      if (dd <= ds && dd <= di)
        return "donch";
      return "imp";
}

void DashTrigger_DrawLevel(string id, double price, color c, string label)
{
      if (ObjectFind(0, id) < 0)
        ObjectCreate(0, id, OBJ_HLINE, 0, 0, price);
      ObjectSetDouble(0, id, OBJPROP_PRICE1, price);
      ObjectSetInteger(0, id, OBJPROP_COLOR, c);
      ObjectSetInteger(0, id, OBJPROP_STYLE, STYLE_DASHDOT);
      ObjectSetInteger(0, id, OBJPROP_WIDTH, 1);
      ObjectSetString(0, id, OBJPROP_TEXT, label);
}

void DashTrigger_MarkEntry(int ticket)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      int dir = (OrderType() == OP_BUY ? 1 : -1);
      string label = OrderComment() + " #" + IntegerToString(ticket);
      DashTrigger_DrawArrow(OrderSymbol(), dir, OrderOpenPrice(),
                            OrderOpenTime(), TRIGGER_ENTRY, label);

      // Draw SL/TP levels
      if (OrderStopLoss() > 0)
        DashTrigger_DrawLevel("SL_" + IntegerToString(ticket), OrderStopLoss(),
                              clrRed, "SL");
      if (OrderTakeProfit() > 0)
        DashTrigger_DrawLevel("TP_" + IntegerToString(ticket),
                              OrderTakeProfit(), clrLime, "TP");
}

void DashTrigger_MarkExit(int ticket, double closePrice)
{
      string label = "EXIT #" + IntegerToString(ticket);
      DashTrigger_DrawArrow(Symbol(), 0, closePrice, TimeCurrent(),
                            TRIGGER_EXIT, label);

      // Clean up SL/TP lines
      string slId = "SL_" + IntegerToString(ticket);
      string tpId = "TP_" + IntegerToString(ticket);
      if (ObjectFind(0, slId) >= 0)
        ObjectDelete(0, slId);
      if (ObjectFind(0, tpId) >= 0)
        ObjectDelete(0, tpId);
}

void _DashLabel(string name, int x, int y, string text, color clr, int fontSize = 0)
{
      if (fontSize == 0)
        fontSize = DASH_FONT_SZ;
      if (ObjectFind(0, name) < 0) {
        ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, name, OBJPROP_CORNER, DASH_CORNER);
        ObjectSetInteger(0, name, OBJPROP_ANCHOR, ANCHOR_LEFT_UPPER);
        ObjectSetString(0, name, OBJPROP_FONT, DASH_FONT);
        ObjectSetInteger(0, name, OBJPROP_FONTSIZE, fontSize);
        ObjectSetInteger(0, name, OBJPROP_BACK, false);
        ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
        ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
      }
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
}

void _DashBox(string name, int x, int y, int w, int h, color bgClr, color borderClr = clrNONE)
{
      if (ObjectFind(0, name) < 0) {
        ObjectCreate(0, name, OBJ_RECTANGLE_LABEL, 0, 0, 0);
        ObjectSetInteger(0, name, OBJPROP_CORNER, DASH_CORNER);
        ObjectSetInteger(0, name, OBJPROP_BORDER_TYPE, BORDER_FLAT);
        ObjectSetInteger(0, name, OBJPROP_BACK, false);
        ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
        ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
      }
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_XSIZE, w);
      ObjectSetInteger(0, name, OBJPROP_YSIZE, h);
      ObjectSetInteger(0, name, OBJPROP_BGCOLOR, bgClr);
      ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, borderClr);
}

bool RequireConfirmation()
{
      if (Mode == 0)
        return true; // Conservative: always
      if (Mode == 2)
        return false;    // Aggressive: never
      return !IsTrend(); // Moderate: in range only
}

