      double r = iRSI(Symbol(), 0, Auto_RSI_Period(), PRICE_CLOSE, 1);
      static double r_ema = EMPTY_VALUE, sig = EMPTY_VALUE;
      r_ema = (r_ema == EMPTY_VALUE ? r : 0.2 * r + 0.8 * r_ema);
      sig = (sig == EMPTY_VALUE ? r_ema : 0.2 * r_ema + 0.8 * sig);
      return isBuy ? (r_ema > sig) : (r_ema < sig);
}

bool ConfirmForce(bool isBuy)
{

      double fi = (double)iVolume(Symbol(), 0, 1) *
                  (iClose(Symbol(), 0, 1) - iClose(Symbol(), 0, 2));
      static double ema_fi = EMPTY_VALUE;
      ema_fi = (ema_fi == EMPTY_VALUE ? fi : 0.2 * fi + 0.8 * ema_fi);
      return isBuy ? (fi > ema_fi) : (fi < ema_fi);
}

bool ConfirmLaguerreRSI(bool isBuy)
{

      int ap = Auto_ATR_Period(), sp = Auto_SUPER_ATR_Period();
      double g = (double)ap / (double)(ap + sp + 1);
      static double L0 = EMPTY_VALUE, L1 = EMPTY_VALUE, L2 = EMPTY_VALUE,
                    L3 = EMPTY_VALUE;
      if (L0 == EMPTY_VALUE) {
        double c0 = iClose(Symbol(), 0, 1);
        L0 = L1 = L2 = L3 = c0;
      }
      double c = iClose(Symbol(), 0, 1);
      double L0n = (1.0 - g) * c + g * L0;
      double L1n = -g * L0n + L0 + g * L1;
      double L2n = -g * L1n + L1 + g * L2;
      double L3n = -g * L2n + L2 + g * L3;
      double CU = 0, CD = 0;
      if (L0n >= L1n)
        CU += L0n - L1n;
      else
        CD += L1n - L0n;
      if (L1n >= L2n)
        CU += L1n - L2n;
      else
        CD += L2n - L1n;
      if (L2n >= L3n)
        CU += L2n - L3n;
      else
        CD += L3n - L2n;
      L0 = L0n;
      L1 = L1n;
      L2 = L2n;
      L3 = L3n;
      double gRSI = (CU + CD > 0 ? CU / (CU + CD) : 0.5);
      static double ema_lg = EMPTY_VALUE;
      ema_lg = (ema_lg == EMPTY_VALUE ? gRSI : 0.2 * gRSI + 0.8 * ema_lg);
      return isBuy ? (gRSI > ema_lg) : (gRSI < ema_lg);
}

bool ConfirmSchaffTrendCycle(bool isBuy)
{

      int p = Auto_MA_Period();
      int fast = (int)MathMax(4, p / 4), slow = MathMax(8, p / 2);
      double macd_val =
          iMACD(Symbol(), 0, fast, slow, 9, PRICE_CLOSE, MODE_MAIN, 1);
      double maxM = -1e10, minM = 1e10;
      for (int i = 1; i <= p; i++) {
        double m = iMACD(Symbol(), 0, fast, slow, 9, PRICE_CLOSE, MODE_MAIN, i);
        if (m > maxM)
          maxM = m;
        if (m < minM)
          minM = m;
      }
      double k =
          (maxM > minM ? 100.0 * (macd_val - minM) / (maxM - minM) : 50.0);
      static double d = EMPTY_VALUE;
      d = (d == EMPTY_VALUE ? k : 0.2 * k + 0.8 * d);
      return isBuy ? (k > d) : (k < d);
}

bool ConfirmWilliams(bool isBuy)
{

      int p = Auto_MA_Period();
      double hh = -1e10, ll = 1e10;
      for (int i = 1; i <= p; i++) {
        double h = iHigh(Symbol(), 0, i), l = iLow(Symbol(), 0, i);
        if (h > hh)
          hh = h;
        if (l < ll)
          ll = l;
      }
      double c = iClose(Symbol(), 0, 1);
      double wr = (hh > ll ? -100.0 * (hh - c) / (hh - ll) : -50.0);
      static double ema_wr = EMPTY_VALUE;
      ema_wr = (ema_wr == EMPTY_VALUE ? wr : 0.2 * wr + 0.8 * ema_wr);
      return isBuy ? (wr > ema_wr) : (wr < ema_wr);
}

bool ConfirmWPR(bool isBuy)
{
      double w = iWPR(Symbol(), 0, 14, 0);
      return isBuy ? (w < -50) : (w > -50);
}

bool ConfirmEfficiencyRatio(bool isBuy)
{

      int p = Auto_ATR_Period();
      double change =
          MathAbs(iClose(Symbol(), 0, 1) - iClose(Symbol(), 0, p + 1));
      double sum = 0;
      for (int i = 1; i <= p; i++)
        sum += MathAbs(iClose(Symbol(), 0, i) - iClose(Symbol(), 0, i + 1));
      double er = (sum > 0 ? change / sum : 0);
      static double erEMA = EMPTY_VALUE;
      erEMA = (erEMA == EMPTY_VALUE ? er : 0.2 * er + 0.8 * erEMA);
      return (er >= erEMA);
}

bool ConfirmTRIX(bool isBuy)
{

      int p = Auto_MA_Period();
      double alpha = 2.0 / (p + 1.0);
      static double e1 = EMPTY_VALUE, e2 = EMPTY_VALUE, e3 = EMPTY_VALUE,
                    prev = EMPTY_VALUE;
      double c = iClose(Symbol(), 0, 1);
      e1 = (e1 == EMPTY_VALUE ? c : alpha * c + (1 - alpha) * e1);
      e2 = (e2 == EMPTY_VALUE ? e1 : alpha * e1 + (1 - alpha) * e2);
      e3 = (e3 == EMPTY_VALUE ? e2 : alpha * e2 + (1 - alpha) * e3);
      double trix = (prev == EMPTY_VALUE ? 0 : (e3 - prev));
      prev = e3;
      static double ema_trix = EMPTY_VALUE;
      ema_trix = (ema_trix == EMPTY_VALUE ? trix : 0.2 * trix + 0.8 * ema_trix);
      return isBuy ? (trix > ema_trix) : (trix < ema_trix);
}

bool ConfirmDeMarker(bool isBuy)
{

      double dm = iDeMarker(Symbol(), 0, 14, 1);
      return isBuy ? (dm > 0.5) : (dm < 0.5);
}

bool ConfirmFibo(bool isBuy)
{

      int p = Auto_FRACTALS_Period();
      int ih = iHighest(Symbol(), 0, MODE_HIGH, p, 1);
      int il = iLowest(Symbol(), 0, MODE_LOW, p, 1);
      double H = iHigh(Symbol(), 0, ih), L = iLow(Symbol(), 0, il);
      double c = iClose(Symbol(), 0, 1);
      double r618 = L + 0.618 * (H - L), r382 = L + 0.382 * (H - L);
      double atr = iATR(Symbol(), 0, Auto_ATR_Period(), 1);
      double tol = 0.25 * atr;
      return isBuy ? (c >= r382 - tol) : (c <= r618 + tol);
}

bool ConfirmFractal(bool isBuy)
{

      double up = iFractals(Symbol(), 0, MODE_UPPER, 2);
      double dn = iFractals(Symbol(), 0, MODE_LOWER, 2);
      double c = iClose(Symbol(), 0, 1);
      return isBuy ? (up != 0 && c > up) : (dn != 0 && c < dn);
}

bool ConfirmFractals(bool isBuy)
{
      int look = Auto_FractalLookback();
      int shift = 1;
      int lastUp = -1, lastDn = -1;
      for (int i = shift + 2; i < shift + 2 + look * 10; i++) {
        if (lastUp < 0 &&
            iFractals(Symbol(), PERIOD_CURRENT, MODE_UPPER, i) != 0)
          lastUp = i;
        if (lastDn < 0 &&
            iFractals(Symbol(), PERIOD_CURRENT, MODE_LOWER, i) != 0)
          lastDn = i;
        if (lastUp >= 0 && lastDn >= 0)
          break;
      }
      if (isBuy) {
        if (lastDn < 0)
          return true;
        double lvl = Low[lastDn];
        return AdaptiveBreakout(true, lvl);
      } else {
        if (lastUp < 0)
          return true;
        double lvl = High[lastUp];
        return AdaptiveBreakout(false, lvl);
      }
}

