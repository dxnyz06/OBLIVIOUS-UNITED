double Auto_TP_Max_Pips()    {
      return 200.0; }

double Auto_SL_Mult(){
      int r = g_adapt.regime;
      bool tr = IsTrend();
      double base =
          (r == VOL_LOW
               ? 1.0
               : (r == VOL_NORMAL ? 1.2 : (r == VOL_HIGH ? 1.5 : 1.8)));
      if (!tr)
        base *= 1.1;
      return base; }

double Auto_SL_Pips(){
      double pts = Auto_SL_Points_Strategy("");
      return pts / AA_PointsPerPip();
}

double Auto_SL_Points_Strategy(string strategy){
      double atrPts = __atr_pts_internal(Auto_ATR_Period());
      double pts = atrPts * Auto_SL_Mult();
      int stopLevel = (int)MarketInfo(Symbol(), MODE_STOPLEVEL);
      if (pts < stopLevel)
        pts = stopLevel;
      double minPts = AA_PointsPerPip();
      if (pts < minPts)
        pts = minPts;
      return MathRound(pts);
}

double Auto_TP_Mult(){
      int p = Auto_ATR_Period();
      double atr_now = iATR(Symbol(), Period(), p, 0);
      double arr[];
      ArrayResize(arr, p);
      ArrayInitialize(arr, 0.0);
      for (int i = 1; i <= p; i++)
        arr[i - 1] = iATR(Symbol(), Period(), p, i);
      double atr_med = __Median(arr, p);
      double vol_ratio = (atr_med > 0 ? atr_now / atr_med : 1.0);
      double base = (IsTrend() ? 2.0 : 1.5) * ModeScale();
      return base * MathMax(0.8, MathMin(1.3, vol_ratio));
}

double Auto_TP_Pips()  {
      return ATRScaledPoints(14, 2.0) / AA_PointsPerPip(); }

double Auto_TP_Points_Strategy(string strategy){
      double atrPts = __atr_pts_internal(Auto_ATR_Period());
      double pts = atrPts * Auto_TP_Mult();
      double slPts = Auto_SL_Points_Strategy(strategy);
      if (pts < slPts)
        pts = slPts * 1.2;
      return MathRound(pts);
}

double Auto_GridSLMultiplier()  {
      return 2.0; }

double Auto_GridTPMultiplier(){
      int p = Auto_ATR_Period();
      double atr_now = iATR(Symbol(), Period(), p, 0);
      double arr[];
      ArrayResize(arr, p);
      ArrayInitialize(arr, 0.0);
      for (int i = 1; i <= p; i++)
        arr[i - 1] = iATR(Symbol(), Period(), p, i);
      double atr_med = __Median(arr, p);
      double vol_ratio = (atr_med > 0 ? atr_now / atr_med : 1.0);
      return MathMax(0.5, MathMin(2.0, vol_ratio));
}

