// --- Global helper functions ---
void DeleteTrigByPrefix(string prefix) {
   int total = ObjectsTotal();
   for (int i = total - 1; i >= 0; i--) {
      string name = ObjectName(i);
      if (StringFind(name, prefix) == 0) ObjectDelete(name);
   }
}

int CombinedIndicatorSignal() { return (g_ind_consensus > 25.0) ? 1 : (g_ind_consensus < -25.0) ? -1 : 0; }
double CombinedPatternConfidence(int dir) { if (g_pat_consensus == 0.0) return 40.0; double s = (dir == 1) ? g_pat_consensus : (dir == -1) ? -g_pat_consensus : MathAbs(g_pat_consensus); return MathMax(30.0, MathMin(95.0, 50.0 + s * 0.45)); }

bool RRValidator(int dir, double entry, double sl, double tp, double minRR) {
   if (entry <= 0 || sl <= 0) return false;
   double slDist = MathAbs(entry - sl);
   if (slDist <= 0) return false;
   double tpDist = MathAbs(tp - entry);
   return (tpDist / slDist >= minRR);
}

bool ImpulseValidator(int dir, int period, double multATR) {
   double atr = iATR(Symbol(), Period(), period, 1);
   double bodySize = MathAbs(Close[1] - Open[1]);
   return (bodySize >= atr * multATR);
}

bool VWAPDeviationTrigger(double stdMult) {
   double vwap = 0.0, totalVol = 0.0;
   int lb = (int)MathMin(50, Bars - 2);
   for (int i = 1; i <= lb; i++) {
      double vol = (double)iVolume(Symbol(), Period(), i);
      double hlc3 = (High[i] + Low[i] + Close[i]) / 3.0;
      vwap += hlc3 * vol; totalVol += vol;
   }
   if (totalVol <= 0) return false;
   vwap /= totalVol;
   double dev = 0.0;
   for (int j = 1; j <= lb; j++) {
      double vol = (double)iVolume(Symbol(), Period(), j);
      double hlc3 = (High[j] + Low[j] + Close[j]) / 3.0;
      dev += vol * (hlc3 - vwap) * (hlc3 - vwap);
   }
   dev = MathSqrt(dev / totalVol);
   double price = (Bid + Ask) / 2.0;
   return (MathAbs(price - vwap) >= stdMult * dev);
}

double GetAdaptiveRR(string stratName) {
   if (stratName == "FVG")              return 2.5;
   if (stratName == "SMC") return 2.2;
   if (stratName == "ICT") return 2.0;
   if (stratName == "Breakout")         return 2.0;
   if (stratName == "Reverse")          return 2.0;
   if (stratName == "Grid")             return 1.5;
   if (stratName == "Predicted")        return 2.0;
   return 2.0;
}

void Strategy_Breakout() {
   // Legacy alias  execution routed through ExecuteStrategies dispatcher
   if (!GlobalStrategyGuards()) return;
   if (!Breakout) return;
   // Signal check and order placement handled by CheckBreakoutSignal() + ExecuteStrategy()
}

void DrawHLineNamed(string name, double price, string label) {
   if (ObjectFind(name) < 0)
      ObjectCreate(name, OBJ_HLINE, 0, 0, price);
   ObjectSet(name, OBJPROP_PRICE1, price);
   ObjectSetText(name, label);
}

void DrawRectFilledNamed(string name, datetime t1, double p1, datetime t2, double p2, string label) {
   if (ObjectFind(name) < 0)
      ObjectCreate(name, OBJ_RECTANGLE, 0, t1, p1, t2, p2);
   ObjectSet(name, OBJPROP_TIME1, (double)t1);
   ObjectSet(name, OBJPROP_PRICE1, p1);
   ObjectSet(name, OBJPROP_TIME2, (double)t2);
   ObjectSet(name, OBJPROP_PRICE2, p2);
   ObjectSetText(name, label);
}

