bool DetectFVG_v2()  {
                                        if (Bars < 4)
                                          return false;
                                        return (Low[1] > High[3] ||
                                                High[1] < Low[3]); }

bool IsFVG() {
                                        if (!GlobalStrategyGuards())
                                          return false;
                                        if (Bridge_IsConnected()) {
                                          string aiPayload;
                                          if (Bridge_GetAISignals(
                                                  Symbol(), Period(), Time[0],
                                                  aiPayload)) {
                                            if (StringFind(aiPayload, "fvg=0") >= 0 ||
                                                StringFind(aiPayload, "fvg=0") >= 0) {
                                              Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
                                              return false;
                                            }
                                          }
                                        }
                                        double spread = (Ask - Bid) / _Point;
                                        double maxSpread = iStdDevOnArray(Close, 0, 20, 0, MODE_SMA, 0);
                                        if (spread > maxSpread * 2.0) {
                                          Bridge_SendLog(2, "FVG", "Spread too high, skipping");
                                          return false;
                                        }
                                        return DetectFVG();
}

void LoadNewsFromConfig(){
                                        // Load news configuration via
                                        // kernel32.dll
                                        string fullPath =
                                            TerminalInfoString(
                                                TERMINAL_DATA_PATH) +
                                            "\\MQL4\\Files\\news_config."
                                            "csv";
                                        if (GetFileAttributesA(fullPath) == K32_INVALID_FILE_ATTR)



                                          return;
                                        int h = CreateFileA(
                                            fullPath, K32_GENERIC_READ,
                                            K32_FILE_SHARE_READ, 0,
                                            K32_OPEN_EXISTING,
                                            K32_FILE_ATTR_NORMAL, 0);
                                        if (h == K32_INVALID_HANDLE)
                                          return;
                                        uchar buf[];
                                        ArrayResize(buf, 16384);
                                        int bytesRead = 0;
                                        ReadFile(h, buf, 16383, bytesRead, 0);
                                        CloseHandle(h);
                                        if (bytesRead > 0) {
                                          buf[bytesRead] = 0;
                                          string content = CharArrayToString(
                                              buf, 0, bytesRead, CP_ACP);
                                          string lines[];
                                          int n =
                                              StringSplit(content, '\n', lines);
                                          for (int i = 0; i < n; i++) {
                                            string fields[];
                                            int fc = StringSplit(lines[i], ',',
   fields);
                                            if (fc >= 3)
                                              SmartLog("INFO", "NEWS_CFG",
                                                       fields[0] + "|" +
                                                           fields[1] + "|" +
                                                           fields[2]);
                                          }
                                        }
}









