      }
      if (symbol == "BTCUSD") {
        return 14;
      }
      if (symbol == "US100" || symbol == "NAS100") {
        return 12;
      }
      if (symbol == "US30") {
        return 12;
      }
      if (symbol == "EURUSD") {
        return 10;
      }
      if (symbol == "GBPUSD") {
        return 10;
      }
      return 10; // default
}

