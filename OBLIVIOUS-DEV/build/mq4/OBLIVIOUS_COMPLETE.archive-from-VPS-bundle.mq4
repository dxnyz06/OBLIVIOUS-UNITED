void CheckPeakProfitClosure() {
                          double currentProfit =
                              AccountEquity() - AccountBalance();
                          double TARGETProfit =
                              (PeakProfitClosurePercent / 100.0) *
                              AccountBalance();
                          if (currentProfit >= TARGETProfit) {
                            for (int i = OrdersTotal() - 1; i >= 0; i--) {
                              if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
                                {
                                  int __ticket = OrderTicket();
                                  double __lots = OrderLots();
                                  SmartLogWrap(
                                      "CLOSE",
                                      StringFormat("PreClose | ticket=%d "
                                                   "lots=%.2f symbol=%s",
                                                   __ticket, __lots,
                                                   OrderSymbol()));
                                }
                                bool _wRes = OrderClose(OrderTicket(), OrderLots(),
                                           OrderClosePrice(),
                                           GetAdaptiveSlippagePoints(),
                                           clrNONE);
                                {
                                  int __err = GetLastError();
                                  bool __isok = (__err == 0);
                                  SmartLogWrap(
                                      "CLOSE",
                                      StringFormat("%s | ticket=%d price=%.5f "
                                                   "lots=%.2f err=%d",
                                                   __isok ? "PostClose OK"
                                                          : "PostClose FAIL",
                                                   OrderTicket(),
                                                   OrderClosePrice(),
                                                   OrderLots(), __err));
                                }
                              }
                            }
                          }
}

