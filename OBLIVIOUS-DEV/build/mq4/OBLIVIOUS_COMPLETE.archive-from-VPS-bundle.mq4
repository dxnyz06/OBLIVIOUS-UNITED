// Magic numbers: PredictedMagic, BreakoutMagic, FVGMagic, GridMagic, SMCMagic, ICTMagic, ReverseMagic






// --- Core EA tracking globals ---
int    MagicNumberBase  = 100000;
int    Magic            = 0;           // 0 = filter by all non-zero
string currentStrategy  = "";          // current active strategy name
int    AIBC_Magics[];                  // dynamic array of AI-BC magic numbers
datetime gLastTrigBarTime = 0;
datetime g_lastBarTime = 0;

string g_ai_rawMsg = "";         // kernel32 bridge global
bool g_bridge_connected = false; // kernel32 bridge global
