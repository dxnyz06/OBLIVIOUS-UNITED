string GenerateErrorDescription(int errorCode)
{
      switch (errorCode) {
      case 0:
        return "No error";
      case 1:
        return "No error but result unknown";
      case 2:
        return "Common error";
      case 3:
        return "Invalid trade parameters";
      case 4:
        return "Trade server busy";
      case 5:
        return "Old version of client terminal";
      case 6:
        return "No connection to trade server";
      case 7:
        return "Not enough rights";
      case 8:
        return "Too frequent requests";
      case 9:
        return "Malfunctional trade operation";
      case 64:
        return "Account disabled";
      case 65:
        return "Invalid account";
      case 128:
        return "Trade timeout";
      case 129:
        return "Invalid price";
      case 130:
        return "Invalid stops";
      case 131:
        return "Invalid trade volume";
      case 132:
        return "Market is closed";
      case 133:
        return "Trade is disabled";
      case 134:
        return "Not enough money";
      case 135:
        return "Price changed";
      case 136:
        return "Off quotes";
      case 137:
        return "Broker is busy";
      case 138:
        return "Requote";
      case 139:
        return "Order is locked";
      case 140:
        return "Buy orders only allowed";
      case 141:
        return "Too many requests";
      case 145:
        return "Modification denied (too close)";
      case 146:
        return "Trade context is busy";
      case 147:
        return "Expirations are denied by broker";
      case 148:
        return "Too many open/pending orders";
      case 4109:
        return "Trade is not allowed";
      default:
        return "Error " + IntegerToString(errorCode);
      }
}

bool HandleError(int error_code, string function_name, int severity = 2)
{
      string desc = GenerateErrorDescription(error_code);
      string msg =
          StringFormat("[%s] err=%d: %s", function_name, error_code, desc);
      LogError(msg);
      // Auto-recover on transient errors
      if (error_code == ERR_REQUOTE || error_code == ERR_PRICE_CHANGED ||
          error_code == ERR_TRADE_CONTEXT_BUSY ||
          error_code == ERR_SERVER_BUSY) {
        SAFE_SLEEP(1000);
        RefreshRates();
        return true;
      }
      return false;
}

bool AttemptRecovery(int error_code, string function_name, int retry_count)
{
      bool ok = false;
      switch (error_code) {
      case ERR_TRADE_CONTEXT_BUSY:
        SAFE_SLEEP(1000);
        RefreshRates();
        ok = true;
        break;
      case ERR_REQUOTE:
      case ERR_PRICE_CHANGED:
        RefreshRates();
        ok = true;
        break;
      case ERR_TRADE_TIMEOUT:
        if (retry_count < 3) {
          SAFE_SLEEP(2000);
          ok = true;
        }
        break;
      case ERR_SERVER_BUSY:
        SAFE_SLEEP(5000);
        ok = true;
        break;
      default:
        ok = false;
      }
      if (ok)
        PrintFormat("[Recovery] OK for %s (err=%d attempt=%d)", function_name,
                    error_code, retry_count);
      else
        PrintFormat("[Recovery] FAIL for %s (err=%d attempt=%d)", function_name,
                    error_code, retry_count);
      return ok;
}

string GetSystemHealth()
{
      return StringFormat("Errors=%d AvgTick=%.1fms MaxTick=%.1fms Ticks=%d",
                          g_health.totalErrors, g_health.avgTickTimeMs,
                          g_health.maxTickTimeMs, g_health.tickCount);
}

