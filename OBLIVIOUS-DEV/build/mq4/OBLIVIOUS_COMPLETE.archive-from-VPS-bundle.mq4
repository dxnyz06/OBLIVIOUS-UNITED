      return iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0); }

double RiskEngine_GetMarginLevel()     {
      double m = AccountMargin();
      return (m > 0 ? AccountEquity() / m * 100.0 : 0); }

string RiskEngine_GetBlockReason()     {
      return ""; }

bool   RiskEngine_IsBlocked() {
      if (g_sf_currentSpread > MaxSpreadPoints && MaxSpreadPoints > 0) return true;
      double equity = AccountEquity();
      double balance = AccountBalance();
      if (balance > 0) {
         double totalDD = (balance - equity) / balance * 100.0;
         if (MaxTotalDDPercent > 0 && totalDD >= MaxTotalDDPercent) return true;
      }
      return false;
   }

bool   RiskEngine_IsKillSwitch()       {
      return false; }

int    RiskEngine_GetTradesToday()     {
      int cnt = 0;
      for (int i = OrdersHistoryTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_HISTORY) &&
            OrderCloseTime() >= iTime(Symbol(), PERIOD_D1, 0))
          cnt++;
      }
      return cnt; }

void RiskEngine_Persist()
{
      GlobalVariableSet(GV_EQUITY_PEAK_HIST, g_risk.equityPeakHistoric);
      GlobalVariableSet(GV_EQUITY_PEAK_DAILY, g_risk.equityPeakDaily);
      GlobalVariableSet(GV_PEAK_PROFIT, g_risk.peakProfit);
      GlobalVariableSet(GV_DAILY_PEAK_DAY, (double)g_risk.lastResetDay);
      GlobalVariableSet(GV_TRADES_TODAY, (double)g_risk.tradesToday);
      GlobalVariableSet(GV_TRADES_TODAY_DAY, (double)g_risk.lastResetDay);
}

void RiskEngine_Deinit()
{
      RiskEngine_Persist();
}

bool RiskEngine_ChallengeMode_DDExceeded(double maxDDPct)
{
      return __AP_ChallengeMaxDDReached(maxDDPct);
}

bool RiskEngine_DailyDD_Exceeded(double maxDDPct)
{
      return __AP_DailyDDExceeded(maxDDPct);
}

bool RiskEngine_ExposureOK(string sym, double maxLots)
{
      return __AP_ExposureOK(sym, maxLots);
}

bool RiskEngine_CorrelationOK(string sym, int maxCorrelated)
{
      // Count open positions on correlated pairs
      string base = StringSubstr(sym, 0, 3);
      string quote = StringSubstr(sym, 3, 3);
      int correlated = 0;

      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        string osym = OrderSymbol();
        if (osym == sym)
          continue;
        if (StringFind(osym, base) >= 0 || StringFind(osym, quote) >= 0)
          correlated++;
      }
      return (correlated < maxCorrelated);
}

double RiskEngine_SessionRiskMultiplier()
{
      int hour = TimeHour(TimeGMT());
      // London session (7-16 GMT): full risk
      if (hour >= 7 && hour < 16)
        return 1.0;
      // NY session (12-21 GMT): full risk (overlap boost)
      if (hour >= 12 && hour < 21)
        return 1.0;
      // Asian session (23-7 GMT): reduced risk
      if (hour >= 23 || hour < 7)
        return 0.70;
      // Transition: moderate
      return 0.85;
}

double RiskEngine_CompositeRiskScore()
{
      double score = 0;

      // DD component (0-40)
      score += MathMin(40.0, g_risk.dailyDDPercent * 8.0);

      // Spread component (0-20)
      double spreadRatio =
          g_risk.currentSpreadPips / MathMax(1.0, g_risk.currentATR * 10);
      score += MathMin(20.0, spreadRatio * 100.0);

      // Margin component (0-20)
      if (g_risk.currentMarginLevel < 500)
        score += MathMin(20.0, (500.0 - g_risk.currentMarginLevel) / 15.0);

      // Session component (0-10)
      double sessMult = RiskEngine_SessionRiskMultiplier();
      score += (1.0 - sessMult) * 10.0;

      // Trades today component (0-10)
      score += MathMin(10.0, g_risk.tradesToday * 1.0);

      return MathMin(100.0, score);
}

double __AP_ComputeLots(double stopPips){
      // Use Manual Lot size
      double manualLot = Active_ManualLot();
      // Try to detect common flags
      // Heuristic: use risk model
      double balance = AccountBalance();
      double risk = __AP_RiskPerTrade();
      double tickValue = MarketInfo(Symbol(), MODE_TICKVALUE);
      if (stopPips <= 0)
        stopPips = 50; // fallback
      double lot =
          (balance * risk) / MathMax(1e-6, (stopPips * Point * tickValue));
      // clamp to broker limits
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double lotStep = MarketInfo(Symbol(), MODE_LOTSTEP);
      lot =
          MathMax(minLot, MathMin(maxLot, MathFloor(lot / lotStep) * lotStep));
      return lot;
}

double GetCalculatedLotSize()   {
      return Lot_Compute(); }

bool WillExceedRiskCapForCmd(int cmd, int magic){
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      // number of already open levels for this side
      int openCnt = CountOpenBySide(magic, isBuy);
      int N = (int)MathMax(1, (int)MathFloor(Active_MaxRiskForSymbol()));
      // next level would be openCnt+1; if that exceeds N, then we'd exceed risk
      // budget
      return (openCnt + 1 > N);
}

void ExposureManager_Init()
{
      g_exposureCount = 0;
      g_totalAccountLots = 0;
      g_totalUnrealizedPnL = 0;
      Print("[ExposureManager] Initialized");
}

void ExposureManager_Update()
{
      // Reset all
      for (int i = 0; i < g_exposureCount; i++) {
        g_exposure[i].buyLots = 0;
        g_exposure[i].sellLots = 0;
        g_exposure[i].netLots = 0;
        g_exposure[i].totalLots = 0;
        g_exposure[i].unrealizedPnL = 0;
        g_exposure[i].buyCount = 0;
        g_exposure[i].sellCount = 0;
      }
      g_totalAccountLots = 0;
      g_totalUnrealizedPnL = 0;

      // Scan all open orders
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;

        string sym = OrderSymbol();
        int idx = ExposureManager_FindOrAdd(sym);
        if (idx < 0)
          continue;

        double lots = OrderLots();
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();

        if (OrderType() == OP_BUY) {
          g_exposure[idx].buyLots += lots;
          g_exposure[idx].buyCount++;
        } else if (OrderType() == OP_SELL) {
          g_exposure[idx].sellLots += lots;
          g_exposure[idx].sellCount++;
        }

        g_exposure[idx].unrealizedPnL += pnl;
        g_totalUnrealizedPnL += pnl;
      }

      // Compute net and total
      for (int i = 0; i < g_exposureCount; i++) {
        g_exposure[i].netLots = g_exposure[i].buyLots - g_exposure[i].sellLots;
        g_exposure[i].totalLots =
            g_exposure[i].buyLots + g_exposure[i].sellLots;
        g_totalAccountLots += g_exposure[i].totalLots;
      }
}

bool ExposureManager_CanAddExposure(string symbol, double lots, int direction)
{
      int idx = ExposureManager_FindOrAdd(symbol);
      if (idx < 0)
        return false;

      // Per-symbol lot limit
      double currentTotal = g_exposure[idx].totalLots;
      if (MaxRiskForSymbol > 0 && (currentTotal + lots) > MaxRiskForSymbol) {
        PrintFormat(
            "[ExposureManager] Blocked: %s total %.2f + %.2f > max %.2f",
            symbol, currentTotal, lots, MaxRiskForSymbol);
        return false;
      }

      // Check opposing exposure if conflict blocking is needed
      if (direction == OP_BUY && g_exposure[idx].sellLots > 0) {
        // Allow hedging only if explicitly enabled
        // By default, block opposing positions on same symbol
      }
      if (direction == OP_SELL && g_exposure[idx].buyLots > 0) {
        // Same check
      }

      return true;
}

double ExposureManager_GetSymbolLots(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].totalLots;
}

double ExposureManager_GetBuyLots(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].buyLots;
}

double ExposureManager_GetSellLots(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].sellLots;
}

double ExposureManager_GetUnrealizedPnL(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].unrealizedPnL;
}

double ExposureManager_GetTotalLots()
{
      return g_totalAccountLots;
}

double ExposureManager_GetTotalPnL()
{
      return g_totalUnrealizedPnL;
}

int ExposureManager_Find(string symbol)
{
      for (int i = 0; i < g_exposureCount; i++) {
        if (g_exposure[i].symbol == symbol)
          return i;
      }
      return -1;
}

int ExposureManager_FindOrAdd(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx >= 0)
        return idx;

      if (g_exposureCount >= EXP_MAX_SYMBOLS)
        return -1;

      g_exposure[g_exposureCount].symbol = symbol;
      g_exposure[g_exposureCount].buyLots = 0;
      g_exposure[g_exposureCount].sellLots = 0;
      g_exposure[g_exposureCount].netLots = 0;
      g_exposure[g_exposureCount].totalLots = 0;
      g_exposure[g_exposureCount].unrealizedPnL = 0;
      g_exposure[g_exposureCount].buyCount = 0;
      g_exposure[g_exposureCount].sellCount = 0;
      g_exposureCount++;

      return g_exposureCount - 1;
}

double Lot_MinLot()       {
      return MarketInfo(Symbol(), MODE_MINLOT); }

double Lot_MaxLot()       {
      return MarketInfo(Symbol(), MODE_MAXLOT); }

double Lot_LotStep()      {
      return MarketInfo(Symbol(), MODE_LOTSTEP); }

double Lot_TickValue()    {
      return MarketInfo(Symbol(), MODE_TICKVALUE); }

double Lot_TickSize()     {
      return MarketInfo(Symbol(), MODE_TICKSIZE); }

double Lot_Normalize(double lots)
{
      double step = Lot_LotStep();
      if (step <= 0)
        step = 0.01;
      lots = MathFloor(lots / step) * step;
      lots = MathMax(lots, Lot_MinLot());
      lots = MathMin(lots, Lot_MaxLot());
      return NormalizeDouble(lots, 2);
}

double Lot_Fixed(double fixedLot)
{
      return Lot_Normalize(fixedLot);
}

double Lot_RiskBased(string sym, double riskPercent, double slPips)
{
      if (slPips <= 0)
        return Lot_MinLot();
      double equity = AccountEquity();
      double riskMoney = equity * riskPercent / 100.0;
      double tickVal = MarketInfo(sym, MODE_TICKVALUE);
      double tickSz = MarketInfo(sym, MODE_TICKSIZE);
      double pt = MarketInfo(sym, MODE_POINT);
      int dg = (int)MarketInfo(sym, MODE_DIGITS);
      double pipFactor = (dg == 5 || dg == 3) ? 10.0 : 1.0;
      double slPoints = slPips * pipFactor;
      double pipValue =
          (tickSz > 0 ? tickVal / tickSz * pt * pipFactor : tickVal);
      if (pipValue <= 0)
        pipValue = tickVal;
      double lots = riskMoney / (slPips * pipValue);
      return Lot_Normalize(lots);
}

double Lot_EquityProportional(double equityPerLot)
{
      if (equityPerLot <= 0)
        equityPerLot = 10000;
      double lots = AccountEquity() / equityPerLot;
      return Lot_Normalize(lots);
}

double Lot_Martingale(double baseLot, double multiplier, int maxLevel)
{
      // Count consecutive losses
      int losses = 0;
      for (int i = OrdersHistoryTotal() - 1; i >= 0 && losses < maxLevel; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();
        if (pnl < 0)
          losses++;
        else
          break;
      }
      double lots = baseLot * MathPow(multiplier, MathMin(losses, maxLevel));
      return Lot_Normalize(lots);
}

double Lot_AntiMartingale(double baseLot, double multiplier, int maxLevel)
{
      int wins = 0;
      for (int i = OrdersHistoryTotal() - 1; i >= 0 && wins < maxLevel; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();
        if (pnl > 0)
          wins++;
        else
          break;
      }
      double lots = baseLot * MathPow(multiplier, MathMin(wins, maxLevel));
      return Lot_Normalize(lots);
}

double Lot_Kelly(double baseLot, int lookback)
{
      int wins = 0, total = 0;
      double avgWin = 0, avgLoss = 0;

      for (int i = OrdersHistoryTotal() - 1; i >= 0 && total < lookback; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();
        total++;
        if (pnl > 0) {
          wins++;
          avgWin += pnl;
        } else
          avgLoss += MathAbs(pnl);
      }

      if (total < 10 || wins == 0 || (total - wins) == 0)
        return Lot_Normalize(baseLot);

      double winRate = (double)wins / total;
      avgWin /= wins;
      avgLoss /= (total - wins);

      if (avgLoss <= 0)
        return Lot_Normalize(baseLot);
      double kellyFraction = winRate - (1.0 - winRate) / (avgWin / avgLoss);
      kellyFraction =
          MathMax(0.01, MathMin(0.25, kellyFraction)); // Clamp to 1-25%

      double lots =
          baseLot * (kellyFraction / 0.02); // Normalize around 2% base
      return Lot_Normalize(lots);
}

double Lot_Adaptive(string sym, double riskPercent, int atrPeriod)
{
      double atr = iATR(sym, 0, atrPeriod, 0);
      double pt = MarketInfo(sym, MODE_POINT);
      int dg = (int)MarketInfo(sym, MODE_DIGITS);
      double pipFactor = (dg == 5 || dg == 3) ? 10.0 : 1.0;
      double slPips = atr / (pt * pipFactor) * 1.5; // 1.5x ATR as SL
      return Lot_RiskBased(sym, riskPercent, slPips);
}

double Lot_Grid(double baseLot, int level, double scaleFactor)
{
      double lots = baseLot + (level - 1) * scaleFactor * baseLot;
      return Lot_Normalize(lots);
}

double Lot_Compute(string sym = "", int mode = 0, double riskPercent = 1.0, double slPips = 20.0,
                   double baseLot = 0.01, int level = 1) {
    if (sym == "") sym = Symbol();
    if (mode == 1) return Lot_RiskBased(sym, riskPercent, slPips);
    if (mode == 2) return Lot_Grid(baseLot, level, 0.5);
    return DynamicLotSize(); }

double CalculateLotSize() {
      return 0.01; }

double CalculateDynamicLot(double risk_percent, double atr_value) {
      double equity = AccountBalance();
      double risk_amount = equity * (risk_percent / 100.0);
      if (atr_value <= 0)
        atr_value = 0.0001;
      double lot = risk_amount / (atr_value * 10);
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      if (lot < minLot)
        lot = minLot;
      if (lot > maxLot)
        lot = maxLot;
      return NormalizeDouble(lot, 2);
}

double CalculateStrategyLotSize(string strategy){
      return DynamicLotSize(strategy);
}

double CalculateTradeLotSize(double sl_points){
      return LotsHybrid(sl_points);
}

// GetLot: all strategies use ManualLot regardless of bridge mode
double GetLot(string strategy) {
      return NormalizeLotToMarket(Active_ManualLot());
}

// ============================================================
// R5 — Risk_Preflight: the SINGLE point of truth for any lot that
// is about to leave the EA towards OrderSend.  Every placement
// path (Strategy_ComputeLots, Cmd_HandleExecute, Grid level,
// add-on / scale-in) MUST route through here.  ManualLot can no
// longer bypass MaxRiskTradePercent.
// ============================================================
double Risk_GridBasketRiskPct(string sym) {
   double eq = AccountEquity();
   if (eq <= 0.0) return 0.0;
   double totalPct = 0.0;
   int total = OrdersTotal();
   for (int i = 0; i < total; i++) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if (OrderSymbol() != sym) continue;
      if (MagicBase(OrderMagicNumber()) != GridMagic) continue;
      double slp = OrderStopLoss();
      if (slp <= 0.0) continue;
      double entry  = OrderOpenPrice();
      double slDist = MathAbs(entry - slp);
      double tv     = MarketInfo(sym, MODE_TICKVALUE);
      double ts     = MarketInfo(sym, MODE_TICKSIZE);
      if (tv <= 0.0 || ts <= 0.0) continue;
      double riskMoney = (slDist / ts) * tv * OrderLots();
      totalPct += (riskMoney / eq) * 100.0;
   }
   return totalPct;
}

double Risk_Preflight(string sym, string owner, double desiredLots,
                      double slPips, int direction, string &outReason) {
   if (desiredLots <= 0.0) { outReason = "zero_desired"; return 0.0; }
   if (!EA_IsTradeAllowed()) { outReason = "ea_blocked"; return 0.0; }
   if (!SpreadOk())          { outReason = "spread_wide"; return 0.0; }

   double clamped = desiredLots;
   if (slPips > 0.0 && (direction == 1 || direction == -1)) {
      int    digits = (int)MarketInfo(sym, MODE_DIGITS);
      double pipPts = (digits == 3 || digits == 5) ? 10.0 : 1.0;
      double sl_pts = slPips * pipPts;
      clamped = Risk_ApplyClampToLots(sym, clamped, sl_pts, direction);
      if (clamped < 0.0) { outReason = "below_min_after_risk_clamp"; return 0.0; }
   }

   clamped = NormalizeLots(sym, clamped);
   if (clamped <= 0.0) { outReason = "broker_normalize_zero"; return 0.0; }

   if (owner == "Grid") {
      // Cap aggregate Grid basket at 4x single-trade budget.
      double basketPct = Risk_GridBasketRiskPct(sym);
      if (basketPct >= MaxRiskTradePercent * 4.0) {
         outReason = "grid_basket_full";
         return 0.0;
      }
   }

   outReason = "ok";
   return clamped;
}

double Strategy_ComputeLots(string symbol, double riskPercent, double slPips)
{
   // R5: ManualLot must NEVER bypass MaxRiskTradePercent.  Whichever
   // raw size we start from (ManualLot or risk-percent based), we
   // route it through Risk_Preflight before returning.
   double desired = (ManualLot > 0)
                       ? ManualLot
                       : RiskEngine_ComputeLots(symbol, riskPercent, slPips);
   string reason;
   // NOTE: variable name `final` is a reserved token for the MQL4 parser,
   // so we use `finalLots` here. Behaviour is identical.
   double finalLots = Risk_Preflight(symbol, "Strategy", desired, slPips, 1, reason);
   if (finalLots <= 0.0) {
      PrintFormat("[Risk] Strategy_ComputeLots blocked sym=%s desired=%.2f reason=%s",
                  symbol, desired, reason);
   }
   return finalLots;
}

void LogManualLotStatus()
{
      Print("[Risk] ManualLot: ", DoubleToStr(Active_ManualLot(), 2), " | Bridge: ", (IsTPSL_AI() ? "AI" : "Native"));
}

double __PipValuePerLot(){
      double tickval = MarketInfo(Symbol(), MODE_TICKVALUE);
      double ticksize = MarketInfo(Symbol(), MODE_TICKSIZE);
      if (ticksize <= 0)
        return 0.0;
      // pips vs points handling simplified: assume 1 pip = 10 points when
      // 5-digit
      double point = MarketInfo(Symbol(), MODE_POINT);
      double pip_points = (Digits == 3 || Digits == 5) ? 10.0 : 1.0;
      double pip = point * pip_points;
      return (pip > 0 ? tickval * (pip / MarketInfo(Symbol(), MODE_TICKSIZE))
                      : 0.0);
}

double __PointValuePerLot() {
      double tv = MarketInfo(Symbol(), MODE_TICKVALUE);
      double ts = MarketInfo(Symbol(), MODE_TICKSIZE);
      return (ts > 0 ? tv / ts : 0);
}

double NormalizeLotToMarket(double lots)
{
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double step = MarketInfo(Symbol(), MODE_LOTSTEP);
      if (step <= 0)
        step = 0.01;
      lots = MathFloor(lots / step) * step;
      if (lots < minLot)
        lots = minLot;
      if (lots > maxLot)
        lots = maxLot;
      return NormalizeDouble(lots, 2);
}

double ADV_NormalizeLots(double lots)
{
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double step = MarketInfo(Symbol(), MODE_LOTSTEP);
      if (step <= 0.0)
        step = 0.01;

      lots = MathMax(minLot, MathMin(maxLot, lots));
      lots = MathFloor(lots / step) * step;
      return NormalizeDouble(lots, 2);
}

double __RoundLot(double lots)
{
      return NormalizeLotToMarket(lots);
}

double NormalizeLots(string symbol, double lots)
{
      double minLot = MarketInfo(symbol, MODE_MINLOT);
      double maxLot = MarketInfo(symbol, MODE_MAXLOT);
      double lotStep = MarketInfo(symbol, MODE_LOTSTEP);

      if (lotStep <= 0)
        lotStep = 0.01;
      if (minLot <= 0)
        minLot = 0.01;
      if (maxLot <= 0)
        maxLot = 100.0;

      lots = MathMax(minLot, MathMin(maxLot, lots));
      lots = MathFloor(lots / lotStep) * lotStep;

      return NormalizeDouble(lots, 2);
}

double LevelRiskPercent(int levelIndex)
{
      int N = (int)MathMax(1, (int)MathFloor(Active_MaxRiskForSymbol()));
      double baseRiskBudget = Active_MaxRiskForSymbol();
      double baseUnit =
          (TotalMultiplierSum(N) > 0 ? baseRiskBudget / TotalMultiplierSum(N)
                                     : baseRiskBudget);
      return baseUnit * MathMax(1, levelIndex);
}

double CurrentLevelRiskPercent(int magic, bool isBuy)
{
      int lvl = NextScaleLevel(magic, isBuy);
      return LevelRiskPercent(lvl);
}

bool CheckRiskLimits() {
                          // limiti di drawdown giornaliero e totale per account
                          // di tipo prop firm.
                          if (!ChallengePassage)
                            return true; // Se non attivo, nessun limite
                          double dailyDD = GetDailyDDLimit();
                          if (dailyDD <= 0)
                            return true; // Nessun limite per LIVE_ACCOUNT
                          double pnlToday = 0;
                          datetime todayStart = iTime(Symbol(), PERIOD_D1, 0);
                          for (int i = OrdersHistoryTotal() - 1; i >= 0; i--) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
                              if (OrderCloseTime() >= todayStart) {
                                pnlToday += OrderProfit() + OrderSwap() +
                                            OrderCommission();
                              }
                            }
                          }
                          double floatingPnl = 0;
                          for (int i = OrdersTotal() - 1; i >= 0; i--) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
                              floatingPnl += OrderProfit() + OrderSwap() +
                                             OrderCommission();
                            }
                          }
                          if ((pnlToday + floatingPnl) <= -dailyDD) {
                            Print("BLOCCO ORDINI: Limite DD giornaliero "
                                  "superato (",
                                  dailyDD, ")");
                            return false;
                          }
                          return true;
}


bool CheckMultiSymbolRisk() {
                          // CHALLENGE PASSAGE
                          // per rispettare i limiti di
                          // drawdown giornaliero e totale per
                          // account di tipo prop firm.
                          if (!ChallengePassage)
                            return true;
                          double totalRisk = 0;
                          for (int i = 0; i < OrdersTotal(); i++) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
totalRisk += MathAbs(OrderProfit());
                            }
                          }
                          return totalRisk <= GetDailyDDLimit();
}

double CalculateClusterLot(double TARGETProfit) {
                          double pipValue =
                              MarketInfo(Symbol(), MODE_TICKVALUE);
                          double lot =
                              TARGETProfit / (pipValue * 50); // stima di 50
                          // pips come base
                          return NormalizeDouble(lot, 2);
}

                      double Active_MaxRiskForSymbol() {
                        return (ChallengePassage ? MaxRiskForSymbol
                                                 : MaxRiskForSymbol);
                      }

                      double Active_RiskForTradePercent() {
                        return (ChallengePassage ? RiskPercent
                                                 : RiskPercent);
                      }

                      double GetCurrentStrategyLot();

                      double __AP_TotalExposure(string sym) {
                        double totalLots = 0;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderSymbol() != sym)
                            continue;
                          totalLots += OrderLots();
                        }
                        return totalLots;
                      }

                      bool __AP_ExposureOK(string sym, double maxLots) {
                        return (__AP_TotalExposure(sym) < maxLots);
                      }

                      double CalculateLots(double riskPercent) {
                        double risk = riskPercent / 100.0;
                        double sl_pips = 30; // fallback, oppure derivato
                        // da ATR/SL
                        double tick_value =
                            MarketInfo(Symbol(), MODE_TICKVALUE);
                        double contract_size =
                            MarketInfo(Symbol(), MODE_LOTSIZE);
                        double stoploss_value =
                            sl_pips * Point *
                            (Digits == 3 || Digits == 5 ? 10 : 1);
                        if (stoploss_value <= 0 || tick_value <= 0)
                          return 0;
                        double lots = AccountFreeMargin() * risk /
                                      (stoploss_value * tick_value);
                        return ClampLots(lots);
                      }

                      double CalculateLotFromConfidence(double confidence) {
                        double base = DynamicLotSize();
                        return base * MathMax(0.5, confidence / 100.0);
                      }

bool AutoPilotManager(string strategy) {
                                        if (!IsTPSL_AI()) {
                                          return true;
                                        }
                                        bool newsHigh = HighImpactNewsActive();
                                        if (newsHigh && !Predicted &&
                                            strategy != "Predicted") {
                                          LogGate("BLOCK NEWS",
                                                  StringFormat(
                                                      "Symbol=%s Time=%s "
                                                      "(file=file pATH)",
                                                      Symbol(),
                                                      TimeToStr(TimeCurrent(),
   TIME_SECONDS)));
                                          return false; // Disattiva tutte
                                          // tranne AI
                                          // Predicted
                                          if (Bridge_IsConnected()) {
                                            string aiPayload;
                                            if (Bridge_GetAISignals(
                                                    Symbol(), Period(), Time[0],
                                                    aiPayload)) {
                                              if (StringFind(
                                                      aiPayload,
                                                      "ai predicted=0") >= 0) {
                                                Bridge_SendLog(
                                                    1, "Predicted",
                                                    "AI suggests NO TRADE");
                                                return false;
                                              }
                                            }
                                          }
                                        }
                                        return true;
}


                                          double Grid_CalcLevelLot(int idx) {
                                            if (idx < 0 || idx >= g_martCount) return Active_ManualLot();
                                            double baseLot = g_mart[idx].baseLot;
                                            int lvl = g_mart[idx].level;
                                            double mult = (GridLotMultiplier > 1.0 ? GridLotMultiplier : 2.0);
                                            double lot = baseLot * MathPow(mult, (double)MathMax(0, lvl));
                                            double maxLot = MarketInfo(g_mart[idx].symbol, MODE_MAXLOT);
                                            if (maxLot > 0) lot = MathMin(lot, maxLot);
                                            return NormalizeLots(g_mart[idx].symbol, lot);
                                          }


                                          double AdjustLotReverseMartingale(
                                              double baseLot, int winsInRow) {
                                            // Reverse martingale: aumenta
                                            // il lotto solo dopo trade
                                            // vincenti
                                            double factor =
                                                1.0 + (0.5 * winsInRow);
                                            return MathMin(
                                                baseLot * factor,
                                                10.0); // Limitiamo lotto
                                            // massimo
                                          }

// Grid lot controller: handled by LotsGrid_ByLevel()

                                          double GridLotMultiplier_Auto() {
                                            return Auto_GridLotMult();
                                          }


   double CapLotNormalize(double lot) { return NormalizeLotToMarket(lot); }
   /* Wrapper: tutti gli ordini passano da qui */
   /* ===== End helpers + wrapper ===== */
   // === Dashboard prev
   // === BEGIN: Auto-Adaptive RR Guard (no inputs) ===

double AdjustLotForChallenge(double userLot, double stopLossPips) {
   // ModalitÃƒÃ†ÃƒÃ‚Â  per rispettare i limiti di drawdown giornaliero e totale per account di tipo prop firm.
   if (!ChallengePassage)
   return userLot; // Nessun controllo se disattivato
   double dailyDD =
   GetDailyDDLimit();
   double pnlToday =
   0;
   datetime todayStart = iTime(
   Symbol(),
   PERIOD_D1,
   0);
   for (
   int i =
   OrdersHistoryTotal() -
   1;
   i >=
   0;
   i--) {
   if (OrderSelect(
   i,
   SELECT_BY_POS,
   MODE_HISTORY)) {
   if (OrderCloseTime() >=
   todayStart) {
   pnlToday +=
   OrderProfit() +
   OrderSwap() +
   OrderCommission();
   }
   }
   }
   double floatingPnl =
   0;
   for (
   int i =
   OrdersTotal() -
   1;
   i >=
   0;
   i--) {
   if (OrderSelect(
   i,
   SELECT_BY_POS,
   MODE_TRADES)) {
   floatingPnl +=
   OrderProfit() +
   OrderSwap() +
   OrderCommission();
   }
   }
   double riskAvailable =
   dailyDD +
   (pnlToday +
   floatingPnl);
   if (riskAvailable <=
   0)
   return 0;
double maxLot = riskAvailable / (ScalePipsByATR(stopLossPips) * Point * MarketInfo(Symbol(), MODE_TICKVALUE));
return MathMin(userLot, maxLot);
}
// --- Stato ChallengePassage ---

   double DynamicLotSize(double sl_price = 0.0, string strat = "") {
   // Lotto dinamico in base al rischio
   double riskPercent =
   1.0; // rischio di default 1%
   double balance =
   AccountBalance();
   double atr = EATR(
   Symbol(),
   Period(),
   14);
   double tickValue =
   MarketInfo(
   Symbol(),
   MODE_TICKVALUE);
   return MathMax(
   0.01,
   (balance *
   riskPercent /
   100) /
   (atr *
   tickValue));
   }

// AI Bridge Functions
string ProcessAITradingRequest(string symbol, string strategyName, int direction, double entryPrice) {
   if (!IsTPSL_AI()) {
      return ""; // Native mode
   }
   
   if (IsBridgeHealthy() == 0) {
      Print("[AI Bridge] Bridge is not healthy");
      return "";
   }
   
   // Build request JSON
   string requestJson = BuildAIRequestJson(symbol, strategyName, direction, entryPrice);
   
   // Process request via DLL
   string response[4096];
//    int result = ProcessAIRequest(requestJson, response, 4096, 30000); // 30 second timeout
   
   string result = "";

   if (result == 0) {
      string error[256];
      GetLastError();
      Print("[AI Bridge] Request failed: ", error[0]);
      return "";
   }
   
   return response[0];
}

string BuildAIRequestJson(string symbol, string strategyName, int direction, double entryPrice) {
   string json = "{";
   json += "\"symbol\":\"" + symbol + "\",";
   json += "\"timeframe\":\"" + PeriodToString(Period()) + "\",";
   json += "\"direction\":" + IntegerToString(direction) + ",";
   json += "\"entry_price\":" + DoubleToString(entryPrice, 5) + ",";
   json += "\"strategy_name\":\"" + strategyName + "\",";
   json += "\"tpsl_mode\":\"AI\",";
   json += "\"setup_score\":" + DoubleToString(GetCurrentSetupScore(), 1) + ",";
   
   // Add volatility context
   double atr = iATR(symbol, Period(), Auto_ATR_Period(), 1);
   json += "\"volatility_context\":{";
   json += "\"atr_value\":" + DoubleToString(atr, 5) + ",";
   json += "\"atr_percentile\":" + DoubleToString(GetATRPercentile(), 1) + ",";
   json += "\"volatility_regime\":\"" + GetVolatilityRegime() + "\"";
   json += "},";
   
   // Add session context
// [AUTO-FIX]    json += "\"session_context\":{";,";
   
   // Add filter supports
   json += "\"filter_supports\":{";
   json += "\"quality_score\":80.0,";
   json += "\"penalty_score\":5.0,";
   json += "\"context_score\":85.0";
   json += "},";
   
   // Add pattern supports
   json += "\"pattern_supports\":{";
   json += "\"direction_support\":" + IntegerToString(g_pat_direction_support) + ",";
   json += "\"confidence_support\":" + DoubleToString(g_pat_confidence_support, 1) + ",";
   json += "\"trigger_quality\":" + DoubleToString(g_pat_trigger_quality, 1);
   json += "}";
   
   json += "}";
   return json;
}

double GetCurrentSetupScore() {
   return 75.0; // Default setup score
}

double GetATRPercentile() {
   return 50.0; // Default ATR percentile
}

string GetVolatilityRegime() {
   double atr = iATR(Symbol(), Period(), Auto_ATR_Period(), 1);
   double atrMA = iMA(Symbol(), Period(), Auto_ATR_Period() * 3, 0, MODE_SMA, PRICE_CLOSE, 1);
   
   if (atr > atrMA * 1.5) return "High";
   if (atr < atrMA * 0.7) return "Low";
   return "Normal";
}


double GetSessionQuality() {
   return 80.0; // Default session quality
}

double GetRelativeVolume() {
   return 1.0; // Default relative volume
}

string PeriodToString(int period) {
   switch(period) {
      case PERIOD_M1: return "M1";
      case PERIOD_M5: return "M5";
      case PERIOD_M15: return "M15";
      case PERIOD_M30: return "M30";
      case PERIOD_H1: return "H1";
      case PERIOD_H4: return "H4";
      case PERIOD_D1: return "D1";
      case PERIOD_W1: return "W1";
      case PERIOD_MN1: return "MN1";
      default: return "UNKNOWN";
   }
}

   double __AP_RiskPerTrade() {
   // Base risk: 0.6% per trade; reduce in high vol or after loss streaks.
   double risk =
   0.006;
   // simple volatility proxy
   double v =
   _MedianTrueRangeN(
   14);
   double vL =
   _MedianTrueRangeN(
   64);
   if (vL >
   0 &&
   v / vL >=
   1.2)
   risk *=
   0.8; // high vol -> reduce
   return risk;
   }

//| 18. execution / order / position / open / modify / close

// [INCOMPLETE_SIGNATURE] int OrderManager_Send(string symbol, int cmd, double lots, double sl, double tp,

// [INCOMPLETE_SIGNATURE] int OrderManager_SendPending(string symbol, int cmd, double lots, double price,

void SmartLog_CloseSnapshot(int ticket)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      double pnl = OrderProfit() + OrderSwap() + OrderCommission();
      string tag = TagFromStrategy(OrderComment());
      SmartLogWrap("CLOSE",
                   StringFormat("%s | Ticket:%d | PnL:%.2f | Lots:%.2f", tag,
                                ticket, pnl, OrderLots()));
}

void SmartLog_UpdateAllPositions()
{
  for (int _i = OrdersTotal() - 1; _i >= 0; _i--)
    if (OrderSelect(_i, SELECT_BY_POS) && OrderSymbol() == Symbol())
      SmartLog_UpdatePosition(OrderTicket());
}
void SmartLog_UpdatePosition(int ticket)
{
      if (!g_smartlog_active)
        return;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      if (OrderSymbol() != Symbol())
        return;

      double pnl = OrderProfit() + OrderSwap() + OrderCommission();
      double entry = OrderOpenPrice();
      double cur = (OrderType() == OP_BUY ? Bid : Ask);
      double dist = cur - entry;
      if (OrderType() == OP_SELL)
        dist = entry - cur;

      double pip = MarketInfo(Symbol(), MODE_POINT);
      if (pip <= 0)
        pip = 0.00001;
      double pips = dist / pip;

      string tag = TagFromStrategy(OrderComment());
      SmartLog_AddLine("POS_UPD",
                       StringFormat("%s | Tk:%d | Pips:%.1f | PnL:%.2f", tag,
                                    ticket, pips, pnl));
}

bool AA_CloseOrderFull(int ticket)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      if (OrderType() != OP_BUY && OrderType() != OP_SELL)
        return false;
      RefreshRates();
      double lots = OrderLots();
      double price = (OrderType() == OP_BUY ? Bid : Ask);
      bool ok = OrderClose(ticket, lots, price, Slippage, clrNONE);
      if (!ok) {
        ResetLastError();
        RefreshRates();
        price = (OrderType() == OP_BUY ? Bid : Ask);
        ok = OrderClose(ticket, lots, price, Slippage, clrNONE);
        if (!ok)
          ResetLastError();
      }
      return ok;
}

bool AA_HasOpenOrPendingByMagic(int magic)
{
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != magic)
          continue;
        int t = OrderType();
        if (t == OP_BUY || t == OP_SELL || t == OP_BUYLIMIT ||
            t == OP_SELLLIMIT || t == OP_BUYSTOP || t == OP_SELLSTOP)
          return true;
      }
      return false;
}

bool AA_OrderModify(int ticket, double price, double sl, double tp)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      RefreshRates();
      datetime exp = OrderExpiration();
      bool ok = OrderModify(ticket, price, sl, tp, exp, clrNONE);
      if (!ok) {
        int err = GetLastError();
        ResetLastError();
        // retry once after refresh
        RefreshRates();
        ok = OrderModify(ticket, price, sl, tp, exp, clrNONE);
        if (!ok) {
          ResetLastError();
        }
      }
      return ok;
}

void AA_ManageOpenTrades()
{
      int magicF = AA_MagicFVG();
      int magicS = AA_MagicSMC();

      // Manage all open orders for these magics
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;

        int magic = OrderMagicNumber();
        int type = OrderType();

        // cleanup GV if a pending is still pending (no management)
        if (type == OP_BUYLIMIT || type == OP_SELLLIMIT || type == OP_BUYSTOP ||
            type == OP_SELLSTOP)
          continue;

        int ticket = OrderTicket();
        if (magic == magicF)
          AA_ManageTicket("AA_FVG", ticket, Period(), magicF);
        else if (magic == magicS)
          AA_ManageTicket("AA_SMC", ticket,
                          (Period() <= PERIOD_M5 ? PERIOD_M1 : PERIOD_M5),
                          magicS);
      }

      // Cleanup GV for closed tickets (best-effort)
      // (Avoid unbounded GV growth)
      // Note: MT4 has no direct "closed orders iteration" without history scan;
      // keep minimal.
}

void AA_FVG_Execute(int dir)
{
      ADV_FVG_ZONE z;
      ADV_OB_ZONE ob;
      int tfPOI = (Period() <= PERIOD_M5 ? PERIOD_M15 : Period());
      int lookback = (int)MathMax(50, Auto_ATR_Period() * Auto_ADX_Period());
      if (!ADV_FindFVG_Pro(tfPOI, dir, lookback, false, z, ob))
        return;

      int tfLTF = Period();
      double atr = AA_ATR(tfLTF, 1);
      if (atr <= 0.0)
        atr = 10 * ADV_Pip();
      double buffer = MathMax(AA_Tol(tfLTF), atr * 0.25);

      double sl = (dir > 0 ? (z.bot - buffer) : (z.top + buffer));

      // lots from existing sizing function if present, else fallback to fixed
      // input lot
      double lots = GetCurrentStrategyLot();
      if (lots <= 0.0)
        lots = Lots;

      // EB engine via limit ladder inside the zone
      AA_FVG_PlaceEB(dir, z, sl, lots);
}

void AA_SMC_Execute(int dir)
{
      int tfPOI = PERIOD_M15;
      int tfLTF = (Period() <= PERIOD_M5 ? PERIOD_M1 : PERIOD_M5);

      ADV_FVG_ZONE poi;
      ADV_OB_ZONE ob;
      int lookback = (int)MathMax(80, Auto_ATR_Period() * Auto_ADX_Period());
      if (!ADV_FindFVG_ICT(tfPOI, dir, lookback, poi, ob))
        return;

      double atr = AA_ATR(tfLTF, 1);
      if (atr <= 0.0)
        atr = 10 * ADV_Pip();
      double buffer = MathMax(AA_Tol(tfLTF), atr * 0.25);
      double sl = (dir > 0 ? (poi.bot - buffer) : (poi.top + buffer));

      double lots = GetCurrentStrategyLot();
      if (lots <= 0.0)
        lots = Lots;

      int magic = AA_MagicSMC();
      if (AA_HasOpenOrPendingByMagic(magic))
        return;

      // Entry reference for targets (ICT OTE preference)
      double entryRef = poi.mid;

      double t1, t2, t3, tmax;
      AA_ComputeTargets(tfLTF, dir, entryRef, sl, t1, t2, t3, tmax);

      // Place LIMIT mini-grid inside POI zone (runner + others to TMax)
      EB_PlaceEdgeBiasedLimits(Symbol(), magic, (dir > 0), poi.top, poi.bot,
                               AA_ClampPrice(sl), AA_ClampPrice(tmax), lots);
}

double Score_OpeningMarubozu()  {
      double r = High[1] - Low[1];
      if (r <= 0)
        return 0;
      bool bull = Close[1] > Open[1];
      double tail = bull ? (Open[1] - Low[1]) : (High[1] - Open[1]);
      return ((tail < r * 0.02) ? 0.6 : 0); }

bool SMC_OrderBlockValidation(double ob_level, bool is_bullish)
  {
      // Validazione autoadaptive dell'Order Block:
      // - Displacement (body vs ATR) + Participation (volume vs median)
      // - Senza moltiplicatori fissi: confronto con mediane robuste di finestra
      // recente
      int p = Auto_ATR_Period();
      int q = Auto_ADX_Period();
      int n = p + q;
      n = MathMax(3, n);
      if (Bars < n + 10)
        return (false);

      int sh = 1; // ultima barra chiusa
      double atr = iATR(Symbol(), PERIOD_CURRENT, p, sh);
      if (atr <= 0.0)
        atr = iATR(Symbol(), PERIOD_CURRENT, p, 0);
      if (atr <= 0.0)
        return (false);

      // Baseline volume/body
      double vols[];
      ArrayResize(vols, n);
      double bods[];
      ArrayResize(bods, n);
      for (int i = 0; i < n; i++) {
        int s = sh + i;
        vols[i] = iVolume(Symbol(), PERIOD_CURRENT, s);
        bods[i] = MathAbs(Close[s] - Open[s]);
      }
      double vmed = __Median(vols, n);
      double bmed = __Median(bods, n);
      if (vmed <= 0.0)
        vmed = vols[0];
      if (bmed <= 0.0)
        bmed = bods[0];

      // Score di riferimento (mediana dei prodotti normalizzati)
      double scores[];
      ArrayResize(scores, n);
      for (int j = 0; j < n; j++) {
        double vr = (vmed > 0.0 ? vols[j] / vmed : 1.0);
        double br = (atr > 0.0 ? bods[j] / atr : 1.0);
        scores[j] = vr * br;
      }
      double s_med = __Median(scores, n);

      // Score corrente (displacement candle)
      double v0 = iVolume(Symbol(), PERIOD_CURRENT, sh);
      double b0 = MathAbs(Close[sh] - Open[sh]);
      double vr0 = (vmed > 0.0 ? v0 / vmed : 1.0);
      double br0 = (atr > 0.0 ? b0 / atr : 1.0);
      double s0 = vr0 * br0;

      // Direzione coerente (ordine block bullish -> displacement bullish,
      // viceversa)
      bool dirOK = is_bullish ? (Close[sh] > Open[sh]) : (Close[sh] < Open[sh]);
      if (!dirOK)
        return (false);

      // Outlier positivo rispetto alla baseline, scalato da regime/Mode (no
      // numeri fissi)
      double need = Auto_VolFactor() * ModeScale();
      return (s0 > (s_med * need));
  }

void SMC_ScanOrderBlocks(string symbol)
{
      double atr = iATR(symbol, 0, 14, 0);
      if (atr <= 0)
        return;

      for (int i = 3; i < 15; i++) {
        double body_i = iClose(symbol, 0, i) - iOpen(symbol, 0, i);
        double body_next = iClose(symbol, 0, i - 1) - iOpen(symbol, 0, i - 1);

        // Impulse: next candle body > 1.5 ATR
        if (MathAbs(body_next) < atr * 1.5)
          continue;

        // Bullish OB: bearish candle followed by strong bullish impulse
        if (body_i < 0 && body_next > 0) {
          // Cross-reference with ICT OB engine for quality
          ADV_OB_ZONE advOB;
          double ictBonus = 0;
          if (ADV_FindOrderBlock(Period(), i - 1, +1, advOB))
            ictBonus = 20.0;

          SMC_AddOrderBlock(iHigh(symbol, 0, i), iLow(symbol, 0, i), 1, i,
                            ictBonus);
        }

        // Bearish OB: bullish candle followed by strong bearish impulse
        if (body_i > 0 && body_next < 0) {
          ADV_OB_ZONE advOB;
          double ictBonus = 0;
          if (ADV_FindOrderBlock(Period(), i - 1, -1, advOB))
            ictBonus = 20.0;

          SMC_AddOrderBlock(iHigh(symbol, 0, i), iLow(symbol, 0, i), -1, i,
                            ictBonus);
        }
      }
}

void SMC_AddOrderBlock(double high, double low, int dir, int barIdx, double ictScore=0)
{
      // Check for duplicates
      for (int i = 0; i < g_ictObCount; i++) {
        if (g_orderBlocks[i].active &&
            MathAbs(g_orderBlocks[i].high - high) < Point * 10 &&
            MathAbs(g_orderBlocks[i].low - low) < Point * 10)
          return;
      }

      if (g_ictObCount >= SMC_MAX_OB) {
        for (int i = 0; i < SMC_MAX_OB - 1; i++)
          g_orderBlocks[i] = g_orderBlocks[i + 1];
        g_ictObCount = SMC_MAX_OB - 1;
      }

      g_orderBlocks[g_ictObCount].high = high;
      g_orderBlocks[g_ictObCount].low = low;
      g_orderBlocks[g_ictObCount].direction = dir;
      g_orderBlocks[g_ictObCount].age = 0;
      g_orderBlocks[g_ictObCount].active = true;
      g_orderBlocks[g_ictObCount].mitigated = false;
      g_orderBlocks[g_ictObCount].ictScore = ictScore;
      g_ictObCount++;
}

int SMC_OrderBlockEntry(string symbol)
{
      double close = iClose(symbol, 0, 0);

      for (int i = 0; i < g_ictObCount; i++) {
        if (!g_orderBlocks[i].active || g_orderBlocks[i].mitigated)
          continue;
        g_orderBlocks[i].age++;

        // Expire old OBs (adaptive: ICT-confirmed last longer)
        int maxAge = (g_orderBlocks[i].ictScore > 0 ? 60 : 40);
        if (g_orderBlocks[i].age > maxAge) {
          g_orderBlocks[i].active = false;
          continue;
        }

        // Bullish OB: price returns to zone and bounces
        if (g_orderBlocks[i].direction > 0) {
          if (close >= g_orderBlocks[i].low && close <= g_orderBlocks[i].high) {
            if (iClose(symbol, 0, 0) > iOpen(symbol, 0, 0)) {
              // ICT killzone bonus
              bool kzActive = ICT_InAnyKillzone();
              if (kzActive || g_orderBlocks[i].ictScore > 0) {
                g_orderBlocks[i].mitigated = true;
                return 1;
              }
            }
          }
        }

        // Bearish OB: price returns to zone and rejects
        if (g_orderBlocks[i].direction < 0) {
          if (close >= g_orderBlocks[i].low && close <= g_orderBlocks[i].high) {
            if (iClose(symbol, 0, 0) < iOpen(symbol, 0, 0)) {
              bool kzActive = ICT_InAnyKillzone();
              if (kzActive || g_orderBlocks[i].ictScore > 0) {
                g_orderBlocks[i].mitigated = true;
                return -1;
              }
            }
          }
        }
      }

      return 0;
}

double ComputeLotsFromOrderParams(int cmd, int magic, double sl_points){
      // detect next level by side + comment suffix
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      int level = 0;
      for (int i = 0; i < OrdersTotal(); i++) {
        if (!OrderSelect(i, SELECT_BY_POS))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != magic)
          continue;
        int t = OrderType();
        bool dir = (t == OP_BUY || t == OP_BUYLIMIT || t == OP_BUYSTOP);
        if (dir != isBuy)
          continue;
        int parsed = ParseLevelFromComment(OrderComment(), magic);
        if (parsed <= 0)
          parsed = 1; // fallback seed if not present
        if (parsed > level)
          level = parsed;
      }
      level = level + 1; // next
                         // next
      // base from hybrid (Manual lot + risk cap if SL known)
      double base_manual = Active_ManualLot();
      double risk_lots = LotsByRisk(sl_points);
      double base = (risk_lots > 0 ? MathMin(base_manual, risk_lots) : base_manual);
      if (risk_lots > 0 && risk_lots < base_manual) {
        SmartLog("INFO", "RISK",
                 "Risk cap applied (req=" + DoubleToString(base_manual, 2) +
                     ", risk=" + DoubleToString(risk_lots, 2) + ")");
      }
      // per-strategy branch
      double lots = base;
      if (MagicBase(magic) == GridMagic) {
        int maxL = AllowedLevels_Grid();
        if (level > maxL) {
          SmartLog("INFO", "GRID",
                   "Cycle cap reached: level=" + IntegerToString(level) +
                       " > max=" + IntegerToString(maxL));
          return 0.0;
        }
        lots = LotsGrid_ByLevel(base, level);
        // generic linear 1x,2x,3x
        int maxL_gen = (int)MathFloor(Active_MaxRiskForSymbol());
        if (level > maxL_gen) {
          SmartLog("INFO", "RISK",
                   "Active_MaxRiskForSymbol() reached: level=" +
                       IntegerToString(level) +
                       " > max=" + IntegerToString(maxL_gen));
          return 0.0;
        }
        lots = base * level;
      }
      // Apply market lot cap ONLY to seed
      if (level == 1) {
        double cap_market = MarketInfo(Symbol(), MODE_MAXLOT);
        if (lots > cap_market) {
          double reqLots = lots;
          lots = cap_market;
          SmartLog(
              "INFO", "CAP",
              "Seed clamped by market cap (req=" + DoubleToString(reqLots, 2) +
                  ", applied=" + DoubleToString(lots, 2) + ")");
        }
      }
      // broker constraints + rounding after cap
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double step = MarketInfo(Symbol(), MODE_LOTSTEP);
      if (step <= 0)
        step = 0.01;
      lots = MathFloor(lots / step) * step;
      if (lots < minLot)
        lots = minLot;
      if (lots > maxLot)
        lots = maxLot;
      return lots;
}

bool RiskEngine_CanOpenTrade(string symbol, int cmd, double lots)
{
      if (!g_risk.canTrade)
        return false;

      // Additional per-trade checks

      // Margin check for this specific trade
      double freeMargin = AccountFreeMarginCheck(symbol, cmd, lots);
      if (freeMargin <= 0) {
        g_risk.blockReason = StringFormat(
            "Insufficient margin for %.2f lots on %s", lots, symbol);
        return false;
      }

      // Lot size broker limits
      double maxLot = MarketInfo(symbol, MODE_MAXLOT);
      if (maxLot > 0 && lots > maxLot) {
        g_risk.blockReason =
            StringFormat("Lots %.2f > broker max %.2f", lots, maxLot);
        return false;
      }

      double minLot = MarketInfo(symbol, MODE_MINLOT);
      if (minLot > 0 && lots < minLot) {
        g_risk.blockReason =
            StringFormat("Lots %.2f < broker min %.2f", lots, minLot);
        return false;
      }

      return true;
}

bool RiskEngine_IsMarketOpen(string symbol)
{
      double tradeAllowed = MarketInfo(symbol, MODE_TRADEALLOWED);
      return (tradeAllowed > 0);
}

int ExposureManager_GetOrderCount(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].buyCount + g_exposure[idx].sellCount;
}

bool StateManager_ShouldCloseAll()
{
      return (g_systemState == STATE_EMERGENCY_CLOSE);
}

bool Orders_Select(int index, int selectType=SELECT_BY_POS, int pool=MODE_TRADES) {
      return OrderSelect(index, selectType, pool) &&
             OrderSymbol() == Symbol() &&
             OrderMagicNumber() == ObliviousAiMagic;
}

int Orders_Count() {
      int count = 0;
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (Orders_Select(i))
          count++;
      }
      return count;
}

bool Orders_HasPosition() {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (Orders_Select(i) && OrderType() <= OP_SELL)
          return true;
      }
      return false;
}

bool Orders_SendSafe(int type, double lots, double price, double sl, double tp, string comment="") {
      RefreshRates();
      double ask = MarketInfo(Symbol(), MODE_ASK);
      double bid = MarketInfo(Symbol(), MODE_BID);
      sl = NormalizePrice(sl);
      tp = NormalizePrice(tp);
      price = NormalizePrice(price);
      int retries = 0;
      int ticket = -1;
      while (retries < 3) {
        ticket = SafeOrderSend(Symbol(), type, ClampLots(lots), price, 3, sl, tp,
                           comment, ObliviousAiMagic, 0, clrNONE);
        if (ticket >= 0)
          return true;
        int err = GetLastError();
        if (err == 130 || err == 131 || err == 133 || err == 136 ||
            err == 146) {
          retries++; Sleep(500);
          RefreshRates();
          continue;
        } else {
          LogError("Ordine fallito: err=" + IntegerToString(err));
          break;
        }
      }
      return false;
}

bool Orders_ModifySafe(int ticket, double price, double sl, double tp) {
      RefreshRates();
      price = NormalizeDouble(price, Digits);
      sl = NormalizeDouble(sl, Digits);
      tp = NormalizeDouble(tp, Digits);
      int retries = 0;
      while (retries < 3) {
        if (!OrderSelect(ticket, SELECT_BY_TICKET) || OrderSymbol() != Symbol()) {
          retries++;
          RefreshRates();
          continue;
        }
        if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) break;
        if (OrderModify(ticket, price, sl, tp, 0, clrNONE))
          return true;
        int err = GetLastError();
        if (err == 130 || err == 131 || err == 133 || err == 136 ||
            err == 146) {
          retries++;
          Sleep(500);
          RefreshRates();
          continue;
        } else {
          Print("Order modify failed: err=", err);
          break;
        }
      }
      return false;
}

bool Orders_CloseSafe(int ticket) {
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      double closePrice = OrderType() == OP_BUY ? Bid : Ask;
      closePrice = NormalizeDouble(closePrice, Digits);
      int retries = 0;
      while (retries < 3) {
        if (OrderClose(ticket, OrderLots(), closePrice, 3, clrNONE))
          return true;
        int err = GetLastError();
        if (err == 130 || err == 131 || err == 133 || err == 136 ||
            err == 146) {
          retries++;
          Sleep(500);
          RefreshRates();
        } else {
          Print("Order close failed: err=", err);
          break;
        }
      }
      return false;
}

void CloseAllTrades(int typeToClose = -1) {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          if (OrderSymbol() == Symbol() &&
              (typeToClose == -1 || OrderType() == typeToClose)) {
            double closePrice = (OrderType() == OP_BUY)
                                    ? MarketInfo(Symbol(), MODE_BID)
                                    : MarketInfo(Symbol(), MODE_ASK);
            RefreshRates();
            {
    // Global safety: only allowed from risk engine, kill-switch, or emergency
              int __ticket = OrderTicket();
              double __lots = OrderLots();
              SmartLogWrap(
                  "CLOSE",
                  StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s",
                               __ticket, __lots, OrderSymbol()));
            }
            if (!OrderClose(OrderTicket(), OrderLots(), closePrice,
                            GetAdaptiveSlippagePoints(), clrRed)) {
              {
                int __err = GetLastError();
                bool __isok = (__err == 0);
                SmartLogWrap(
                    "CLOSE",
                    StringFormat("%s | ticket=%d price=%.5f lots=%.2f err=%d",
                                 __isok ? "PostClose OK" : "PostClose FAIL",
                                 OrderTicket(), OrderClosePrice(), OrderLots(),
                                 __err));
              }
              PrintFormat("? Errore chiusura ordine %d: %d", OrderTicket(),
                          GetLastError());
            } else {
              PrintFormat("? Ordine chiuso: %d", OrderTicket());
            }
          }
        }
      }
}

void CloseAllOpenOrders() {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (Orders_Select(i)) {
          if (OrderType() <= OP_SELL) {
            Orders_CloseSafe(OrderTicket());
          } else {
            bool _wRes = OrderDelete(OrderTicket());
          }
        }
      }
}

