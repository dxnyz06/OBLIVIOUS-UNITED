double Auto_GridATRMult(){
      VolRegime r = (VolRegime)g_adapt.regime;
      double vf = g_adapt.vol_factor;
      if (vf < 0.8)
        vf = 0.8;
      if (vf > 1.2)
        vf = 1.2;
      double base = 1.0;
      if (r == VOL_LOW)
        base = 1.25;
      else if (r == VOL_NORMAL)
        base = 1.00;
      else if (r == VOL_HIGH)
        base = 0.85;
      else
        base = 0.75;
      return base * vf; }

bool AdaptiveBreakout(bool isBuy, double level){
      double atr = _AA_ATR(Period());
      double need = Auto_PA_ThresholdATR() * atr;
      if (isBuy)
        return (Close[1] - level) >= need;
      else
        return (level - Close[1]) >= need;
}

void AdaptiveFiboBand(double &loOut, double &hiOut){
      double loB = 0, hiB = 0, tol = 0;
      bool ok = OTEBandFromHistory(true, Period(), 15, loB, hiB, tol);
      if (ok) {
        loOut = loB;
        hiOut = hiB;
        return;
      }
      int N = (int)MathMin(200, EB_BarsForWindowTF() * 3);
      double fr[];
      ArrayResize(fr, N);
      int k = 0;
      for (int i = 1; i <= N; i++) {
        double H = iHigh(Symbol(), Period(), i),
               L = iLow(Symbol(), Period(), i),
               C = iClose(Symbol(), Period(), i);
        double leg = H - L;
        if (leg <= Point * 5)
          continue;
        double fu = (H - C) / leg;
        double fd = (C - L) / leg;
        double f = (fu > fd ? fu : fd);
        fr[k++] = MathMin(1.0, MathMax(0.0, f));
      }
      if (k <= 0) {
        double H0 = iHigh(Symbol(), Period(), 1),
               L0 = iLow(Symbol(), Period(), 1),
               C0 = iClose(Symbol(), Period(), 1);
        double leg0 = H0 - L0;
        double f0 =
            (leg0 > Point * 5 ? MathMax((H0 - C0) / leg0, (C0 - L0) / leg0)
                              : 0.5);
        loOut = MathMax(0.0, f0 - 0.0);
        hiOut = MathMin(1.0, f0 + 0.0);
        return;
      }
      double sub[];
      ArrayResize(sub, k);
      for (int j = 0; j < k; j++)
        sub[j] = fr[j];
      double med = EB_Median(sub, k);
      double mad = EB_MAD(sub, k);
      loOut = MathMax(0.0, med - mad);
      hiOut = MathMin(1.0, med + mad);
}

void AutoConfigureForAsset(){
      // Asset-specific parameter tuning
      string sym = Symbol();
      if (StringFind(sym, "JPY") >= 0)
        SmartLog("INFO", "ASSET", "JPY pair — adjusting for 3-digit pricing");
      else if (StringFind(sym, "XAU") >= 0 || StringFind(sym, "GOLD") >= 0)
        SmartLog("INFO", "ASSET",
                 "Gold — wider SL/TP, higher volatility tolerance");
      else if (StringFind(sym, "BTC") >= 0)
        SmartLog("INFO", "ASSET",
                 "Crypto — extended hours, wider parameters");
}

double ConfirmationThreshold()
{
      double base = 0.50;
      if (Mode == 0)
        base = 0.65;
      else if (Mode == 2)
        base = 0.45;
      if (IsTrend())
        base -= 0.05;
      if (base < 0.30)
        base = 0.30;
      if (base > 0.80)
        base = 0.80;
      return base;
}

bool ConfirmEMA(bool isBuy)
{

      double fast =
          iMA(Symbol(), 0, Auto_EMA_Fast(), 0, MODE_EMA, PRICE_CLOSE, 1);
      double slow =
          iMA(Symbol(), 0, Auto_EMA_Slow(), 0, MODE_EMA, PRICE_CLOSE, 1);
      return isBuy ? (fast > slow) : (fast < slow);
}

bool ConfirmMA(bool isBuy)
{

      double fast = iMA(Symbol(), 0, 20, 0, MODE_SMA, PRICE_CLOSE, 1);
      double slow = iMA(Symbol(), 0, 50, 0, MODE_SMA, PRICE_CLOSE, 1);
      return isBuy ? (fast > slow) : (fast < slow);
}

bool ConfirmHullMovingAverage(bool isBuy){

      int p = Auto_MA_Period();
      int n = (int)MathMax(6, p), n2 = MathMax(2, n / 2), sqrtN = (int)MathSqrt(n);
      double lw_n  = iMA(Symbol(), 0, n,  0, MODE_LWMA, PRICE_CLOSE, 1);
      double lw_n2 = iMA(Symbol(), 0, n2, 0, MODE_LWMA, PRICE_CLOSE, 1);
      double tmp = 2.0 * lw_n2 - lw_n;
      static double hma = EMPTY_VALUE;
      double alpha = 2.0 / (sqrtN + 1.0);
      hma = (hma == EMPTY_VALUE ? tmp : alpha * tmp + (1 - alpha) * hma);
      static double ema = EMPTY_VALUE;
      ema = (ema == EMPTY_VALUE ? hma : 0.2 * hma + 0.8 * ema);
      return isBuy ? (hma > ema) : (hma < ema); }

bool ConfirmHMA(bool isBuy)   {
      double hma = iMA(Symbol(), 0, 14, 0, MODE_LWMA, PRICE_CLOSE, 0);
      return (isBuy ? (Bid > hma) : (Bid < hma)); }

bool ConfirmIchimoku(bool isBuy)
{

      int p = Auto_MA_Period();
      int tenkan = (int)MathMax(3, p / 4), kijun = MathMax(6, p / 2),
          senkouB = MathMax(12, p);
      double ten =
          iIchimoku(Symbol(), 0, tenkan, kijun, senkouB, MODE_TENKANSEN, 1);
      double kij =
          iIchimoku(Symbol(), 0, tenkan, kijun, senkouB, MODE_KIJUNSEN, 1);
      double sa =
          iIchimoku(Symbol(), 0, tenkan, kijun, senkouB, MODE_SENKOUSPANA, 1);
      double sb =
          iIchimoku(Symbol(), 0, tenkan, kijun, senkouB, MODE_SENKOUSPANB, 1);
      double c = iClose(Symbol(), 0, 1);
      double top = MathMax(sa, sb), bot = MathMin(sa, sb);
      return isBuy ? (ten > kij && c > top) : (ten < kij && c < bot);
}

bool ConfirmKAMA(bool isBuy)
{

      int p = Auto_MA_Period();
      int fast = (int)MathMax(2, p / 4), slow = MathMax(4, p);
      double change =
          MathAbs(iClose(Symbol(), 0, 1) - iClose(Symbol(), 0, p + 1));
      double vol = 0;
      for (int i = 1; i <= p; i++)
        vol += MathAbs(iClose(Symbol(), 0, i) - iClose(Symbol(), 0, i + 1));
      double ER = (vol > 0 ? change / vol : 0);
      double scFast = 2.0 / (fast + 1.0), scSlow = 2.0 / (slow + 1.0);
      double sc = MathPow(ER * scFast + (1.0 - ER) * scSlow, 2);
      static double kama = EMPTY_VALUE;
      double c = iClose(Symbol(), 0, 1);
      kama = (kama == EMPTY_VALUE ? c : kama + sc * (c - kama));
      static double ema_kama = EMPTY_VALUE;
      ema_kama = (ema_kama == EMPTY_VALUE ? kama : 0.2 * kama + 0.8 * ema_kama);
      return isBuy ? (kama > ema_kama) : (kama < ema_kama);
}

bool ConfirmLinReg(bool isBuy)
{

      int p = Auto_MA_Period();
      double sx = 0, sy = 0, sxx = 0, sxy = 0;
      for (int i = 1; i <= p; i++) {
        double x = (double)i, y = iClose(Symbol(), 0, i);
        sx += x;
        sy += y;
        sxx += x * x;
        sxy += x * y;
      }
      double den = p * sxx - sx * sx;
      if (den == 0)
        return true;
      double slope = (p * sxy - sx * sy) / den;
      static double ema_lr = EMPTY_VALUE;
      ema_lr = (ema_lr == EMPTY_VALUE ? slope : 0.2 * slope + 0.8 * ema_lr);
      return isBuy ? (slope > ema_lr) : (slope < ema_lr);
}

bool ConfirmSAR(bool isBuy)
{

      double step = Auto_SAR_Step();
      double mx = Auto_SAR_Max();
      double sar0 = iSAR(Symbol(), PERIOD_CURRENT, step, mx, 0);
      double sar1 = iSAR(Symbol(), PERIOD_CURRENT, step, mx, 1);
      double c0 = iClose(Symbol(), 0, 0), c1 = iClose(Symbol(), 0, 1);
      bool sar_up = (sar0 > sar1);
      bool sar_down = (sar0 < sar1);
      if (isBuy) {
        if (c0 > sar0 && c1 <= sar1 && !sar_down)
          return true;
        if (c0 > sar0 && sar_up)
          return true;
        return false;
      } else {
        if (c0 < sar0 && c1 >= sar1 && !sar_up)
          return true;
        if (c0 < sar0 && sar_down)
          return true;
        return false;
      }
}

bool ConfirmParabolicSAR(bool isBuy)
{

      double step = Auto_SAR_Step();
      double sar = iSAR(Symbol(), 0, step, 0.2, 1);
      double c = iClose(Symbol(), 0, 1);
      return isBuy ? (c > sar) : (c < sar);
}

bool ConfirmTEMA(bool isBuy)
{

      int p = Auto_MA_Period();
      double alpha = 2.0 / (p + 1.0);
      static double e1 = EMPTY_VALUE, e2 = EMPTY_VALUE, e3 = EMPTY_VALUE;
      double c = iClose(Symbol(), 0, 1);
      e1 = (e1 == EMPTY_VALUE ? c : alpha * c + (1 - alpha) * e1);
      e2 = (e2 == EMPTY_VALUE ? e1 : alpha * e1 + (1 - alpha) * e2);
      e3 = (e3 == EMPTY_VALUE ? e2 : alpha * e2 + (1 - alpha) * e3);
      double tema = 3.0 * e1 - 3.0 * e2 + e3;
      static double ema_t = EMPTY_VALUE;
      ema_t = (ema_t == EMPTY_VALUE ? tema : 0.2 * tema + 0.8 * ema_t);
      return isBuy ? (tema > ema_t) : (tema < ema_t);
}

bool ConfirmReflex(bool isBuy)
{

      double c = iClose(Symbol(), 0, 1);
      double ma =
          iMA(Symbol(), 0, Auto_MA_Period(), 0, MODE_EMA, PRICE_CLOSE, 1);
      double slope = c - ma;
      static double sEMA = EMPTY_VALUE;
      sEMA = (sEMA == EMPTY_VALUE ? slope : 0.2 * slope + 0.8 * sEMA);
      return isBuy ? (slope > sEMA) : (slope < sEMA);
}

bool ConfirmGannHiLo(bool isBuy)
{

      int p = Auto_MA_Period();
      int n = (int)MathMax(2, p / 4);
      double c = iClose(Symbol(), 0, 1);
      double hi = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, n, 2));
      double lo = iLow(Symbol(), 0, iLowest(Symbol(), 0, MODE_LOW, n, 2));
      return isBuy ? (c > lo) : (c < hi);
}

bool ConfirmHeikenAshi(bool isBuy)
{

      double haC = (iOpen(Symbol(), 0, 1) + iHigh(Symbol(), 0, 1) +
                    iLow(Symbol(), 0, 1) + iClose(Symbol(), 0, 1)) /
                   4.0;
      double prevC = (iOpen(Symbol(), 0, 2) + iHigh(Symbol(), 0, 2) +
                      iLow(Symbol(), 0, 2) + iClose(Symbol(), 0, 2)) /
                     4.0;
      double haO = (prevC + haC) / 2.0;
      return isBuy ? (haC > haO) : (haC < haO);
}

bool ConfirmElder(bool isBuy)
{

      int p = Auto_MA_Period();
      double ma = iMA(Symbol(), 0, p, 0, MODE_EMA, PRICE_CLOSE, 1);
      double bulls = iHigh(Symbol(), 0, 1) - ma;
      double bears = iLow(Symbol(), 0, 1) - ma;
      return isBuy ? (bulls > 0) : (bears < 0);
}

bool ConfirmElderRay(bool isBuy)
{

