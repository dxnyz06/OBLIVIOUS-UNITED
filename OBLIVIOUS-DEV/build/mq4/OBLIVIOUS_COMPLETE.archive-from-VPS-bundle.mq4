   double __CombinedBreakEvenPrice(
   int tk1,
   int tk2) {
   double V =
   __PointValuePerLot();
   if (V <=
   0)
   return 0;
   double
   sum_q =
   0,
   sum_qe =
   0,
   C = 0;
   int arr[2];
   arr[0] = tk1;
   arr[1] = tk2;
   for (int i = 0; i < 2; i++) {
   int tk = arr[i];
   if (tk <= 0 || !OrderSelect(tk, SELECT_BY_TICKET)) continue;
   double q = (OrderType() == OP_BUY ? +OrderLots() : -OrderLots());
   double e = OrderOpenPrice();
   sum_q += q;
   sum_qe += q * e;
   C += OrderCommission() + OrderSwap();
   }
   return (sum_q != 0.0) ? (sum_qe / sum_q) : 0.0;
}
   bool AIB_SafeOrderModifyTP(
   int ticket,
   double
   tp) {
   if (ticket <=
   0 ||
   !OrderSelect(
   ticket,
   SELECT_BY_TICKET))
   return false;
   RefreshRates();
   double sl =
   OrderStopLoss();
   double price =
   (OrderType() == OP_BUY



   ? Bid
   : Ask);
   datetime exp =
   OrderExpiration();
   return OrderModify(
   ticket,
   price,
   sl,
   tp,
   exp,
   clrNONE);
   }

bool AI_RequestSLTP(int cmd, double entry, double &sl, double &tp) {
  // Request AI-refined SL/TP values; returns true if modified
   return false; // AI SL/TP bridge not connected: returns false to use native SL/TP
}
color OrderArrowColor() { return clrNONE; }

   bool AI_SyncSLTP_OpenOrders() {
   bool updated =
   false;
   for (
   int i =
   OrdersTotal() -
   1;
   i >=
   0;
   i--) {
   if (!OrderSelect(
   i,
   SELECT_BY_POS,
   MODE_TRADES))
   continue;
   if (OrderSymbol() !=
   Symbol())
   continue;
   if (StringFind(
   OrderComment(),
   AI_TPSL_TAG) <
   0)
   continue;
   int cmd =
   OrderType();
   double entry =
   OrderOpenPrice();
   double sl =
   OrderStopLoss();
   double tp =
   OrderTakeProfit();
   double
   newSL =
   sl,
   newTP =
   tp;
   if (AI_RequestSLTP(
   cmd,
   entry,
   newSL,
   newTP)) {
   if (!IsTPSL_AI())
   newSL =
   sl;
   if (!IsTPSL_AI())
   newTP =
   tp;
   if (newSL !=
   sl ||
   newTP !=
   tp) {
   int digits =
   (int)MarketInfo(
   Symbol(),
   MODE_DIGITS);
   newSL =
   (newSL > 0
   ? NormalizeDouble(
   newSL,
   digits)
   : 0);
   newTP =
   (newTP > 0
   ? NormalizeDouble(
   newTP,
   digits)
   : 0);
   if (OrderModify(
   OrderTicket(),
   OrderOpenPrice(),
   newSL,
   newTP,
   OrderExpiration(),
   OrderArrowColor())) {
   updated =
   true;
   Print(StringFormat(
   "?? AI updated SL/TP | ticket=%d sl=%.5f tp=%.5f",
   OrderTicket(),
   newSL,
   newTP));
   }
   }
   }
   }
   return (
   updated);
   }

