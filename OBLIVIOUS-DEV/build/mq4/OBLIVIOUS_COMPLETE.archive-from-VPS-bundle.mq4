color TypeColor(string tp) {
  if (tp == "BUY"  || tp == "buy")  return clrLime;
  if (tp == "SELL" || tp == "sell") return clrRed;
  return clrWhite;
}
void UIToggle_Toggle(int idx) {
  if (idx < 0 || idx >= g_uitoggle_count) return;
  g_uitoggles[idx].state = !g_uitoggles[idx].state;
  ObjectSetInteger(0, g_uitoggles[idx].objBg, OBJPROP_BGCOLOR,
                   g_uitoggles[idx].state ? clrGreen : clrFireBrick);
}
