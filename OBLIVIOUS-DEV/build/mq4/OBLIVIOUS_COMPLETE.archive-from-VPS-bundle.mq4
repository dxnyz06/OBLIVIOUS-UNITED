   MarketSession
   _SessionNow() {
   int h = TimeHour(
   TimeCurrent());
   // Rough session map (broker time): adjust if needed
   if (h >=
   0 &&
   h < 7)
   return SESSION_ASIA;
   if (h >=
   7 &&
   h < 13)
   return SESSION_LONDON;
   if (h >=
   13 &&
   h < 22)
   return SESSION_NEWYORK;
   return SESSION_OTHER;
   }

