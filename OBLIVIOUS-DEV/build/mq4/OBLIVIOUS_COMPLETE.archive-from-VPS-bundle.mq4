   bool BridgeConnect() {
   // Attempt to open named pipe
   // Pipe name must match the Python bridge server
   string pipeName =
   "\\\\\\\\.\\\\pipe\\\\ObliviousAIBridge";
   g_hPipeIn = (int)CreateFileA(
   pipeName,
   GENERIC_READ |
   GENERIC_WRITE,
   0,
   0,
   OPEN_EXISTING,
   0,
   0);
   if (g_hPipeIn == K32_HANDLE_INVALID) {



   g_bridge_connected =
   false;
   g_ai_connected =
   false;
   return false;
   }
   g_bridge_connected =
   true;
   g_ai_connected =
   true;
   return true;
   }

   // Bridge_PollAIData: polls kernel32 named pipe for fresh AI generic signals.
   // Called from OnTimer every N seconds. Updates g_ai_* globals.

   void Bridge_PollAIData() {
   if (!g_ai_connected) {
   if (!BridgeConnect())
   return;
   }
   // Pipe read handled by kernel32 ReadFile -- bridge .exe writes:
   // "AI,direction,confidence,timestamp\n" per line
   long delta =
   (long)(TimeCurrent() -
   g_ai_timestamp);
   if (delta >
   300) {
   g_ai_direction =
   0;
   g_ai_connected =
   false;
   }
   }

   // Bridge_PollNewsData: polls kernel32 bridge pipe for high-impact news.
   // Updates g_aip_* for Predicted pipeline. No file I/O.

   void Bridge_PollNewsData() {
   if (!g_ai_connected) {
   if (!BridgeConnect())
   return;
   }
   // Pipe read handled by kernel32 ReadFile -- bridge .exe writes:
   // "NEWS,direction,impact,confidence,timestamp\n" per line
   long delta =
   (long)(TimeCurrent() -
   g_aip_timestamp);
   if (delta >
   180) {
   g_aip_direction =
   0;
   }
   }

   void BridgeDisconnect() {
   if (g_hPipeIn !=
   K32_HANDLE_INVALID) {
   CloseHandle(
   g_hPipeIn);
   g_hPipeIn =
   K32_HANDLE_INVALID;
   }
   g_bridge_connected =
   false;
   g_ai_connected =
   false;
   }

