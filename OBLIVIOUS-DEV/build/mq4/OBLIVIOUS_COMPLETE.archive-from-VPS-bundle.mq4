                                          int GetEMADirection() {
                                            double ema20 =
                                                iMA(Symbol(), Period(), 20, 0,
                                                    MODE_EMA, PRICE_CLOSE, 1);
                                            double ema50 =
                                                iMA(Symbol(), Period(), 50, 0,
                                                    MODE_EMA, PRICE_CLOSE, 1);
                                            if (ema20 > ema50)
                                              return 1;
                                            if (ema20 < ema50)
                                              return -1;
                                            return 0;
                                          }

                                          int GetRSISignal() {
                                            double rsi =
                                                iRSI(Symbol(), Period(), 14,
                                                     PRICE_CLOSE, 1);
                                            if (rsi > 70)
                                              return -1;
                                            if (rsi < 30)
                                              return 1;
                                            return 0;
                                          }

                                          int Mart_GetState(string symbol) {
                                            for (int i = 0; i < g_martCount;
                                                 i++)
                                              if (g_mart[i].symbol == symbol)
                                                return i;

                                            if (g_martCount >= MART_MAX_SYMBOLS)
                                              return -1;

                                            int idx = g_martCount;
                                            g_mart[idx].symbol = symbol;
                                            g_mart[idx].currentStep = 0;
                                            g_mart[idx].direction = -1;
                                            g_mart[idx].baseLot =
                                                ManualLot > 0
                                                    ? ManualLot
                                                    : MarketInfo(symbol,
   MODE_MINLOT);
                                            g_mart[idx].lastEntryPrice = 0;
                                            g_mart[idx].active = false;
                                            g_mart[idx].paused = false;
                                            g_mart[idx].pauseReason = "";
                                            g_martCount++;
                                            return idx;
                                          }

                                          int AIBC_GetATRPeriod() { return 14; }

                                          int AIBC_GetMaxPerPulse() {
                                            return 5;
                                          }

                                          bool GetSMA_Signal(int cmd = -1) {
                                            double s20 =
                                                iMA(Symbol(), 0, 20, 0,
                                                    MODE_SMA, PRICE_CLOSE, 0);
                                            double s50 =
                                                iMA(Symbol(), 0, 50, 0,
                                                    MODE_SMA, PRICE_CLOSE, 0);
                                            if (cmd == OP_BUY)
                                              return (s20 > s50);
                                            if (cmd == OP_SELL)
                                              return (s20 < s50);
                                            return (s20 != s50);
                                          }

                                          double CalculateBreakoutConfidence() {
                                            double confidence = 0;
                                            // Breakout quality evaluation
                                            if (SmartTrailBreakoutPattern(
                                                    10, 2.0))
                                              confidence += 30;
                                            if (Breakout_VolatilityExpansion())
                                              confidence += 25;
                                            if (PatternVolumeSpike(20, 2.0,
   1.2))
                                              confidence += 20;
                                            if (ThreeSoldiersCrows(true))
                                              confidence += 25;
                                            return MathMin(100.0, confidence);
                                          }

                                          double CalculateCrownSymmetryScore(
                                              int left_index, int high_index,
                                              int right_index) {
                                            // Calculate symmetry quality of
                                            // crown pattern
                                            if (Bridge_IsConnected()) {
                                              string aiPayload;
                                              if (Bridge_GetAISignals(
                                                      Symbol(), Period(),
                                                      Time[0], aiPayload)) {
                                                if (StringFind(aiPayload,
   "crown "
   "pattern=0") >=
                                                    0) {
                                                  Bridge_SendLog(
                                                      1, "Pattern",
                                                      "AI suggests NO "
                                                      "TRADE");
                                                  return 0.0;
                                                }
                                              }
                                            }
                                            double left_distance =
                                                high_index - left_index;
                                            double right_distance =
                                                right_index - high_index;
                                            if (left_distance == 0 ||
                                                right_distance == 0)
                                              return 0;
                                            double ratio =
                                                MathMin(left_distance,
                                                        right_distance) /
                                                MathMax(left_distance,
                                                        right_distance);
                                            return ratio; // 0-1 score, 1 =
                                            // perfect
                                            // symmetry
                                          }

                                          int GetMartingaleDirection() {
                                            double ema20 =
                                                iMA(Symbol(), Period(), 20, 0,
                                                    MODE_EMA, PRICE_CLOSE, 1);
                                            double mom =
                                                iMomentum(Symbol(), Period(),
                                                          14, PRICE_CLOSE, 1);
                                            if (Close[1] > ema20 && mom > 100.0)
                                              return 1;
                                            if (Close[1] < ema20 && mom < 100.0)
                                              return -1;
                                            return 0;
                                          }

                                          int GetSmartBreakoutDirection() {
                                            double highest = High[iHighest(
                                                Symbol(), Period(), MODE_HIGH,
                                                20, 1)];
                                            double lowest =
                                                Low[iLowest(Symbol(), Period(),
   MODE_LOW, 20, 1)];
                                            if (Close[1] > highest)
                                              return 1;
                                            if (Close[1] < lowest)
                                              return -1;
                                            return 0;
                                          }

                                          double CalculateCrownConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            double rsi =
                                                iRSI(Symbol(), Period(), 14,
                                                     PRICE_CLOSE, 1);
                                            return MathMin(
                                                100.0,
                                                base + ((rsi < 30 || rsi > 70)
   ? 10.0
   : 0.0));
                                          }

                                          double CalculateCobraConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            double atr =
                                                iATR(Symbol(), Period(), 14, 1);
                                            double atr5 =
                                                iATR(Symbol(), Period(), 14, 5);
                                            return MathMin(
                                                100.0,
                                                base + ((atr > atr5 * 1.3)
   ? 10.0
   : 0.0));
                                          }

                                          double CalculateChallengeConfidence() {
                                            return MathMax(
                                                0,
                                                CalculatePatternConfidence() *
                                                    0.90);
                                          }

                                          double CalculateFVGConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            double gapSize =
                                                MathAbs(Low[1] - High[3]);
                                            double atr =
                                                iATR(Symbol(), Period(), 14, 1);
                                            return MathMin(
                                                100.0,
                                                base + ((atr > 0 &&
                                                         gapSize > atr * 0.3)
   ? 10.0
   : 0.0));
                                          }

                                          double CalculateSMCConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            double adx =
                                                iADX(Symbol(), Period(), 14,
                                                     PRICE_CLOSE, MODE_MAIN, 1);
                                            return MathMin(100.0,
                                                           base + ((adx > 25)
   ? 10.0
   : 0.0));
                                          }

                                          double CalculateMartingaleConfidence() {
                                            return MathMax(
                                                0,
                                                CalculatePatternConfidence() *
                                                    0.85);
                                          }

                                          double CalculateRoyalConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            double rsi =
                                                iRSI(Symbol(), Period(), 14,
                                                     PRICE_CLOSE, 1);
                                            return MathMin(
                                                100.0,
                                                base + ((rsi < 25 || rsi > 75)
   ? 15.0
   : 0.0));
                                          }

                                          double CalculateSmartBreakoutConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            double atr =
                                                iATR(Symbol(), Period(), 14, 1);
                                            double atr10 = iATR(
                                                Symbol(), Period(), 14, 10);
                                            return MathMin(
                                                100.0,
                                                base + ((atr > atr10 * 1.2)
   ? 10.0
   : 0.0));
                                          }

                                          double CalculateStructureConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            bool aligned =
                                                (High[1] > High[2] &&
                                                 High[2] > High[3]) ||
                                                (Low[1] < Low[2] &&
                                                 Low[2] < Low[3]);
                                            return MathMin(
                                                100.0,
                                                base + (aligned ? 10.0 : 0.0));
                                          }

                                          double CalculateTradeEntryConfidence() {
                                            double base =
                                                CalculatePatternConfidence();
                                            double adx =
                                                iADX(Symbol(), Period(), 14,
                                                     PRICE_CLOSE, MODE_MAIN, 1);
                                            return MathMax(
                                                0,
                                                MathMin(100.0,
                                                        base + ((adx > 25)
   ? 5.0
   : -5.0)));
                                          }

