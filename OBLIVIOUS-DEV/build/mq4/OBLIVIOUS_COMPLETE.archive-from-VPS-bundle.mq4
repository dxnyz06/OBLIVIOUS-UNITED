bool FVG_AA_Detect(bool isBuy, int sh, double &gL, double &gH, double &ce){
      double h2 = iHigh(Symbol(), Period(), sh + 2),
             l2 = iLow(Symbol(), Period(), sh + 2);
      double h0 = iHigh(Symbol(), Period(), sh),
             l0 = iLow(Symbol(), Period(), sh);
      if (isBuy) {
        if (l0 > h2) {
          gL = h2;
          gH = l0;
          ce = (gL + gH) / 2.0;
          return true;
        }
      } else {
        if (h0 < l2) {
          gL = h0;
          gH = l2;
          ce = (gL + gH) / 2.0;
          return true;
        }
      }
      return false;
}

bool FVG_AA_DisplacementOK(int sh)  {
