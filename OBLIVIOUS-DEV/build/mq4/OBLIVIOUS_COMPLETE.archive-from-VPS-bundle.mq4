bool SLTP_AA_ManageTicket(int ticket, string strat){
      bool a = SL_AA_ApplyToTicket(ticket, strat);
      bool b = TP_AA_ApplyToTicket(ticket, strat);
      return a && b;
}

bool SL_AA_ApplyToTicket(int ticket, string strat){
      string __tag = TagFromStrategy(strat);

      if (ticket <= 0)
        return false;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber()))
        return false;
      if (OrderSymbol() != Symbol())
        return false;
      int type = OrderType();
      if (type != OP_BUY && type != OP_SELL)
        return false;
      double entry = OrderOpenPrice();
      double sl = OrderStopLoss();
      bool isBuy = (type == OP_BUY);
      // compute adaptive swing and sigma buffer
      int n = AA_AutoN();
      int L = (int)MathMax(8, (int)(n)); // window tied to ÃƒÃ‚Â¢ÃƒÃ¢Â ÃƒÃ‚Â¡Bars
      double mR, sR;
      AA_MeanStd(mR, sR, false, n);
      double swing = isBuy
                         ? iLow(Symbol(), Period(),
                                iLowest(Symbol(), Period(), MODE_LOW, L, 2))
                         : iHigh(Symbol(), Period(),
                                 iHighest(Symbol(), Period(), MODE_HIGH, L, 2));
      double buf = sR; // one std of range as buffer (fully adaptive)
      double newSL = isBuy ? (swing - buf) : (swing + buf);
      // If no SL, set it; if trailing is favorable, tighten behind new swing
      bool improve =
          (sl <= 0) || (isBuy ? (newSL > sl + Point) : (newSL < sl - Point));
      if (improve) {
        bool ok = OrderModify(ticket, entry, newSL, OrderTakeProfit(),
                              OrderExpiration(), clrNONE);
        if (ok)
          AddToSmartLog(StringFormat(
              "%s [SL] ticket=%d swing=%.5f buf=%.5f -> SL=%.5f",
              (isBuy ? "BUY" : "SELL"), ticket, swing, buf, newSL));
        return ok;
      }
      return true;
}

bool TP_AA_ApplyToTicket(int ticket, string strat){
      string __tag = TagFromStrategy(strat);

      if (ticket <= 0)
        return false;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber()))
        return false;
      if (OrderSymbol() != Symbol())
        return false;
      int type = OrderType();
      if (type != OP_BUY && type != OP_SELL)
        return false;
      bool isBuy = (type == OP_BUY);
      int magic = OrderMagicNumber();
      int lvl = AA_LevelFromComment(OrderComment(), magic);
      if (lvl <= 0)
        lvl = 1;
      // Respect runner rule: lvl 1 runner => no TP forced
      if (lvl == 1)
        return true;
      // Skip TP auto for grid/martingala (gestite dal loro motore)
      if (StringFind(strat, "Grid", 0) >= 0) {
        return true; // Grid manages own TP
      }
      double entry = OrderOpenPrice();
      double sl = OrderStopLoss();
      double tp = OrderTakeProfit();
      if (sl <= 0)
        return false; // TP from RR needs a valid SL
      // compute RR-based TP as in RR_AA_ApplyToTicket
      double distSL = MathAbs(entry - sl);
      if (distSL < Point * 5)
        return false;
      double tprice = RR_AA_CalcTargetPrice(isBuy, entry, sl);
      double distTP = MathAbs(tprice - entry);
      if (distTP <= Point * 5)
        return false;
      double rr_raw = distTP / distSL;
      double rr_base = (rr_raw < 2.0 ? 2.0 : rr_raw);
      double rr = RR_AA_Round(rr_base);
      double newTP = isBuy ? (entry + rr * distSL) : (entry - rr * distSL);
      bool needUpdate =
          (tp <= 0) || (isBuy ? (newTP > tp + Point) : (newTP < tp - Point));
      if (needUpdate) {
        bool ok = OrderModify(ticket, entry, sl, newTP, OrderExpiration(), clrNONE);
        AddToSmartLog(
            StringFormat("%s [TP] ticket=%d rr_raw=%.2f -> rr=%.2f TP=%.5f",
                         (isBuy ? "BUY" : "SELL"), ticket, rr_raw, rr, newTP));
        return ok;
      }
      return true;
}

void ComputeAdaptiveSLTP(int &slPoints, int &tpPoints, double rr=2.0, int atrPeriod=14)
{
      double atr = iATR(Symbol(), 0, atrPeriod, 1);
      if (atr <= 0)
        return;
      int atrPts = (int)MathRound(atr / Point);
      int minSL =
          MathMax((int)MathRound(1.2 * atrPts), 8); // ~1.2*ATR or min 8 points
      int minTP = (int)MathMax((int)MathRound(rr * minSL), 12); // RR default 2.0
      if (slPoints <= 0 || slPoints < minSL)
        slPoints = minSL;
      if (tpPoints <= 0 || tpPoints < minTP)
        tpPoints = minTP;
}

bool IsLaguerreRSI() {
      double gamma = 0.7, c = iClose(NULL, 0, 0), c1 = iClose(NULL, 0, 1);
      static double L0 = 0, L1 = 0, L2 = 0, L3 = 0;
      double pL0 = L0, pL1 = L1, pL2 = L2;
      L0 = (1.0 - gamma) * c + gamma * pL0;
      L1 = -gamma * L0 + pL0 + gamma * pL1;
      L2 = -gamma * L1 + pL1 + gamma * pL2;
      L3 = -gamma * L2 + pL2 + gamma * L3;
      double cu = 0, cd = 0;
      if (L0 >= L1) {
        cu += (L0 - L1);
      } else {
        cd += (L1 - L0);
      }
      if (L1 >= L2) {
        cu += (L1 - L2);
      } else {
        cd += (L2 - L1);
      }
      if (L2 >= L3) {
        cu += (L2 - L3);
      } else {
        cd += (L3 - L2);
      }
      double lrsi = (cu + cd > 0) ? cu / (cu + cd) : 0;
      return (lrsi < 0.2);
}

bool IsLinReg() {
      int n = 14;
      if (Bars < n)
        return false;
      double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
      for (int i = 0; i < n; i++) {
        double x = i, y = iClose(NULL, 0, i);
        sumX += x;
        sumY += y;
        sumXY += x * y;
        sumX2 += x * x;
      }
      double denom = n * sumX2 - sumX * sumX;
      if (MathAbs(denom) < 1e-10)
        return false;
      double slope = (n * sumXY - sumX * sumY) / denom;
      double intercept = (sumY - slope * sumX) / n;
      double linRegValue = intercept; // value at shift=0
      return (linRegValue < iClose(NULL, 0, 0));
}

bool IsLowest()            {
      return false; }

bool IsLowestIndex()       {
      return false; }

bool IsLowestInRange()     {
      return false; }

bool IsPatternAlpha() {
      if (iBars(Symbol(), 0) < 10) return false;
      double atr = iATR(Symbol(), 0, 14, 1);
      if (atr <= 0) return false;
      double c1 = iClose(Symbol(), 0, 1), c2 = iClose(Symbol(), 0, 2), c3 = iClose(Symbol(), 0, 3);
      double h1 = iHigh(Symbol(), 0, 1), h2 = iHigh(Symbol(), 0, 2);
      double l1 = iLow(Symbol(), 0, 1),  l2 = iLow(Symbol(), 0, 2);
      bool bullAlpha = (c2 < iOpen(Symbol(), 0, 2)) && (c1 > iOpen(Symbol(), 0, 1)) && (c1 > c2) && ((c1 - l1) > atr * 0.5);
      bool bearAlpha = (c2 > iOpen(Symbol(), 0, 2)) && (c1 < iOpen(Symbol(), 0, 1)) && (c1 < c2) && ((h1 - c1) > atr * 0.5);
      return (bullAlpha || bearAlpha);
}

bool IsPatternCrown() {
      if (iBars(Symbol(), 0) < 5) return false;
      double left = iHigh(Symbol(), 0, 3);
      double head = iHigh(Symbol(), 0, 2);
      double right = iHigh(Symbol(), 0, 1);
      if (head > left && head > right && MathAbs(left - right) < (head * 0.015))
        return true;
      double lLeft = iLow(Symbol(), 0, 3);
      double lHead = iLow(Symbol(), 0, 2);
      double lRight = iLow(Symbol(), 0, 1);
      return (lHead < lLeft && lHead < lRight && MathAbs(lLeft - lRight) < (MathAbs(lHead) * 0.015));
}

bool IsFVGPattern() {
      if (iBars(Symbol(), 0) < 4) return false;
      double h1 = iHigh(Symbol(), 0, 3), l3 = iLow(Symbol(), 0, 1);
      double l1 = iLow(Symbol(), 0, 3),  h3 = iHigh(Symbol(), 0, 1);
      return (l3 > h1) || (h3 < l1);
}

bool IsPatternCrownAdvanced() {
      if (!IsPatternCrown()) return false;
      double atr = iATR(Symbol(), 0, 14, 1);
      double head = iHigh(Symbol(), 0, 2);
      double lHead = iLow(Symbol(), 0, 2);
      double bodyHead = MathAbs(iClose(Symbol(), 0, 2) - iOpen(Symbol(), 0, 2));
      return (bodyHead > atr * 0.3) || (head > lHead + atr * 0.5);
}

double GetPatternAlphaConfidence() {
      if (!IsPatternAlpha()) return 0;
      double atr = iATR(Symbol(), 0, 14, 1);
      if (atr <= 0) return 50.0;
      double body = MathAbs(iClose(Symbol(), 0, 1) - iOpen(Symbol(), 0, 1));
      double conf = MathMin(95.0, 50.0 + (body / atr) * 40.0);
      return conf;
}

int GetPatternAlphaSignal() {
      double c1 = iClose(Symbol(), 0, 1);
      double o1 = iOpen(Symbol(), 0, 1);
      return (c1 > o1) ? +1 : -1;
}

double GetPatternCrownConfidence() {
      if (!IsPatternCrown()) return 0;
      double left = iHigh(Symbol(), 0, 3);
      double head = iHigh(Symbol(), 0, 2);
      double right = iHigh(Symbol(), 0, 1);
      double symm = 1.0 - MathAbs(left - right) / (head > 0 ? head : 1.0) * 10.0;
      return MathMin(90.0, MathMax(40.0, symm * 80.0));
}

int GetPatternCrownSignal() {
      double h2 = iHigh(Symbol(), 0, 2);
      double l2 = iLow(Symbol(), 0, 2);
      double mid = (h2 + l2) / 2.0;
      return (iClose(Symbol(), 0, 1) < mid) ? -1 : +1;
}

double GetFVGConfidence() {
      if (!IsFVGPattern()) return 0;
      double atr = iATR(Symbol(), 0, 14, 1);
      if (atr <= 0) return 50.0;
      double gap = MathAbs(iLow(Symbol(), 0, 1) - iHigh(Symbol(), 0, 3));
      return MathMin(90.0, 50.0 + (gap / atr) * 30.0);
}

bool HTFConfirmDefault() {
      int htfTF = PERIOD_H4;
      double htfClose = iClose(Symbol(), htfTF, 1);
      double htfOpen  = iOpen(Symbol(),  htfTF, 1);
      double lClose   = iClose(Symbol(), PERIOD_CURRENT, 1);
      double lOpen    = iOpen(Symbol(),  PERIOD_CURRENT, 1);
      bool htfBull = (htfClose > htfOpen);
      bool htfBear = (htfClose < htfOpen);
      bool ltfBull = (lClose > lOpen);
      bool ltfBear = (lClose < lOpen);
      return (htfBull && ltfBull) || (htfBear && ltfBear);
}

int GetFVGPatternSignal() {
      double h1 = iHigh(Symbol(), 0, 3);
      double l3 = iLow(Symbol(), 0, 1);
      if (l3 > h1) return +1;
      return -1;
}

bool BoxRangeDetector(int lookback = 20, double thresholdFactor = 1.2) {
      if (iBars(Symbol(), 0) < lookback + 2) return false;
      double atr = iATR(Symbol(), 0, 14, 1);
      if (atr <= 0) return false;
      int hiIdx = iHighest(Symbol(), 0, MODE_HIGH, lookback, 1);
      int loIdx = iLowest(Symbol(), 0, MODE_LOW,  lookback, 1);
      double rangeHigh = iHigh(Symbol(), 0, hiIdx);
      double rangeLow  = iLow(Symbol(), 0, loIdx);
      double rangeSize = rangeHigh - rangeLow;
      return (rangeSize <= atr * thresholdFactor * lookback * 0.1);
}

// CupAndHANDLEPattern: REMOVED  was a recursive alias of CupAndHandlePattern (MQL4 case-insensitive)

bool CupAndHandlePattern(int period=60, double minCupDepth=0.003, double maxHandleRatio=0.38) {
      if (iBars(Symbol(), 0) < period + 5) return false;
      int cupStart = period;
      double cupHigh = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, cupStart / 2, cupStart));
      double cupLow  = iLow(Symbol(),  0, iLowest(Symbol(),  0, MODE_LOW,  cupStart / 2, cupStart / 2 + 1));
      double cupDepth = (cupHigh - cupLow) / (cupHigh > 0 ? cupHigh : 1.0);
      if (cupDepth < minCupDepth) return false;
      double handleHigh = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, cupStart / 4, 1));
      double handleDepth = (cupHigh - handleHigh) / (cupHigh - cupLow + 0.000001);
      return (handleDepth <= maxHandleRatio);
}

bool ComputeModeDrivenBiasOverlay() {
      double htfClose = iClose(Symbol(), PERIOD_H1, 1);
      double htfOpen  = iOpen(Symbol(),  PERIOD_H1, 1);
      double htfClose4 = iClose(Symbol(), PERIOD_H4, 1);
      double htfOpen4  = iOpen(Symbol(),  PERIOD_H4, 1);
      bool h1Bull = (htfClose > htfOpen);
      bool h4Bull = (htfClose4 > htfOpen4);
      return (h1Bull == h4Bull);
}

int GetPatternSignal() {
      int signal = 0;
      double confidence = 0.0;
      if (IsPatternAlpha()) {
        if (!SmartCandleProfiling(0, 2.0, 1.5))
          return 0;
        if (!BoxRangeDetector(20, 1.2))
          return 0;
        if (!CupAndHandlePattern(60, 0.003, 0.38))
          return 0;
        confidence = GetPatternAlphaConfidence();
        if (confidence >= PatternsConfidence)
          signal = GetPatternAlphaSignal(); // 1 = Buy, -1 = Sell
      } else if (IsPatternCrown()) {
        double __c_neck__;
        int __c_iL__, __c_iH__, __c_iR__;
        bool __c_inv__ = false;
        if (!Crown_SymmetryDetector(__c_neck__, __c_iL__, __c_iH__, __c_iR__,
                                    __c_inv__, 5, 8, 5, 0.15, 6) ||
            !Crown_VolumePressureZone(__c_neck__, __c_inv__))
          return 0;
        if (!Crown_VolumePressureZone(10, 1.8))
          return 0;
        if (!SmartCandleProfiling(0, 2.0, 1.5))
          return 0;
        if (!PatternVolumeSpike(20, 2.0, 1.2))
          return 0;
        confidence = GetPatternCrownConfidence();
        if (confidence >= PatternsConfidence)
          signal = GetPatternCrownSignal();
      } else if (IsFVGPattern()) {
        confidence = GetFVGConfidence();
        if (confidence >= PatternsConfidence) {
          bool htfOK = HTFConfirmDefault();
          if (!htfOK)
            return 0;
        }
        if (!SpreadOk())
          return 0;
        signal = GetFVGPatternSignal();
      }
      if (signal == 0)
        signal = CheckProPatterns();
      return signal;
}

int Check_PeakProfitLock(string sym, int tf, double &confidence)
{
      // If equity has retraced significantly from peak, block new trades
      double balance = AccountBalance();
      double equity = AccountEquity();
      if (balance <= 0) {
        confidence = 0;
        return 0;
      }
      double ddPct = (balance - equity) / balance * 100.0;
      confidence = MathMin(100, MathMax(0, 100 - ddPct * 10));
      // If DD > PeakProfitRetracePercent, block
      if (ddPct > PeakProfitRetracePercent)
        return -1; // block
      return +1;   // allow
}

int Check_PivotPoints(string sym, int tf, double &confidence)
{
      // Daily pivot points
      if (iBars(sym, PERIOD_D1) < 2) {
        confidence = 0;
        return 0;
      }
      double prevH = iHigh(sym, PERIOD_D1, 1);
      double prevL = iLow(sym, PERIOD_D1, 1);
      double prevC = iClose(sym, PERIOD_D1, 1);
      double PP = (prevH + prevL + prevC) / 3.0;
      double R1 = 2.0 * PP - prevL;
      double S1 = 2.0 * PP - prevH;
      double R2 = PP + (prevH - prevL);
      double S2 = PP - (prevH - prevL);
      double price = iClose(sym, tf, 0);
      double atr = iATR(sym, tf, 14, 0);
      // How close to nearest level
      double distPP = MathAbs(price - PP);
      double distR1 = MathAbs(price - R1);
      double distS1 = MathAbs(price - S1);
      double minDist = MathMin(distPP, MathMin(distR1, distS1));
      confidence =
          MathMin(100, (atr > 0 ? (1.0 - minDist / (atr + 0.00001)) * 60 : 30));
      if (price > R1)
        return +1; // above R1 = bullish
      if (price < S1)
        return -1; // below S1 = bearish
      if (price > PP)
        return +1;
      return -1;
}

bool ADV_HasLiquiditySweep(int tf, int dir, double poolLevel, int maxLookback, int &sweepShift)
{
      sweepShift = -1;
      if (poolLevel <= 0.0)
        return false;

      int bars = iBars(Symbol(), tf);
      if (bars < 10)
        return false;

      int maxShift = (int)MathMin(maxLookback, bars - 3);
      for (int s = 1; s <= maxShift; s++) {
        double tol = ADV_Tol_ICT(tf, s);
        double h = iHigh(Symbol(), tf, s);
        double l = iLow(Symbol(), tf, s);
        double c = iClose(Symbol(), tf, s);

        if (dir > 0) {
          // Bullish: price raids below pool then reclaims above
          bool raided = (l < (poolLevel - tol));
          bool reclaimed = (c > (poolLevel + 0.2 * tol));
          if (raided && reclaimed) {
            sweepShift = s;
            return true;
          }
        } else {
          // Bearish: price raids above pool then reclaims below
          bool raided = (h > (poolLevel + tol));
          bool reclaimed = (c < (poolLevel - 0.2 * tol));
          if (raided && reclaimed) {
            sweepShift = s;
            return true;
          }
        }
      }
      return false;
}

int GetPatternBias(int shift=0)
{
      int bull = 0, bear = 0;

      if (CheckHammer(shift))
        bull++;
      if (CheckBullishEngulfing(shift))
        bull++;
      if (CheckHaramiBullish(shift))
        bull++;
      if (CheckMorningStar(shift))
        bull++;
      if (CheckThreeWhiteSoldiers(shift))
        bull++;
      if (CheckThreeInsideUp(shift))
        bull++;
      if (CheckThreeOutsideUp(shift))
        bull++;
      if (CheckPiercingLine(shift))
        bull++;
      if (CheckRisingWindow(shift))
        bull++;
      if (CheckTweezerBottom(shift))
        bull++;

      if (CheckShootingStar(shift))
        bear++;
      if (CheckBearishEngulfing(shift))
        bear++;
      if (CheckHaramiBearish(shift))
        bear++;
      if (CheckEveningStar(shift))
        bear++;
      if (CheckThreeBlackCrows(shift))
        bear++;
      if (CheckThreeInsideDown(shift))
        bear++;
      if (CheckThreeOutsideDown(shift))
        bear++;
      if (CheckDarkCloudCover(shift))
        bear++;
      if (CheckFallingWindow(shift))
        bear++;
      if (CheckTweezerTop(shift))
        bear++;

      if (bull > bear)
        return +1;
      if (bear > bull)
        return -1;
      return 0;
}

