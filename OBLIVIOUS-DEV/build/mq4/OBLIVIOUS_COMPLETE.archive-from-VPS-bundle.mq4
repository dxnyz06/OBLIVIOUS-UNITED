void DrawStrategyWithBar(string strategyName, bool enabled, int y) {
   string barName  = "BAR_" + strategyName;
   double confidence = GetStrategyConfidence(strategyName);
   string label = strategyName + (enabled ? " ON" : " OFF");
   DrawProgressBar(
   barName,
   20,
   y,
   150,
   10,
   (int)confidence);
   DrawLabel(
   barName +
   "_LABEL",
   180,
   y - 2,
   label,
   enabled
   ? clrLime
   : clrRed);

}

