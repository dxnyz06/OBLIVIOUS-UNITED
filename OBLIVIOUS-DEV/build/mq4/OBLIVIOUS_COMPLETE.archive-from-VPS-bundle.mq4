bool CheckSuperTrendSignal(bool isBullish) {
      double atr = iATR(Symbol(), Period(), Auto_ATR_Period(), 1) * 3.0;
      double midNow  = (High[1] + Low[1]) * 0.5;
      double midPrev = (High[2] + Low[2]) * 0.5;
      double atrPrev = iATR(Symbol(), Period(), Auto_ATR_Period(), 2) * 3.0;
      double superTrendValue         = isBullish ? (midNow  - atr)     : (midNow  + atr);
      double previousSuperTrendValue = isBullish ? (midPrev - atrPrev) : (midPrev + atrPrev);
      if (isBullish)
        return Close[0] > superTrendValue && Close[1] <= previousSuperTrendValue;
      else
        return Close[0] < superTrendValue && Close[1] >= previousSuperTrendValue;
}

