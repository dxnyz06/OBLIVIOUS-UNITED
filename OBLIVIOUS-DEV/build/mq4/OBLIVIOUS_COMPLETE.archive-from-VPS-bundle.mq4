          "=== ERROR REPORT ===\nSystem Health: %.1f%%\nErrors: %d\n",
          system_health_score, g_health.totalErrors);
}

void UpdateSystemHealth(int severity)
{
      // severity: 0=info, 1=warning, 2=error, 3=critical
      switch (severity) {
      case 0:
        system_health_score = MathMax(95.0, system_health_score - 0.1);
        break;
      case 1:
        system_health_score = MathMax(85.0, system_health_score - 0.5);
        break;
      case 2:
        system_health_score = MathMax(70.0, system_health_score - 2.0);
        break;
      case 3:
        system_health_score = MathMax(50.0, system_health_score - 10.0);
        break;
      }
}

int FindMetricIndex(string name)
{
      for (int i = 0; i < g_perfMetricCount; i++)
        if (g_perfMetrics[i].name == name)
          return i;
      return -1;
}

int FindOrCreateMetricIndex(string strategy_name) {
      int existing_index = FindMetricIndex(strategy_name);
      if (existing_index >= 0)
        return existing_index;
      for (int i = 0; i < MAX_PERF_METRICS; i++) {
        if (g_perfMetrics[i].name == "") {
          g_perfMetrics[i].name = strategy_name;
          g_perfMetrics[i].startUs = 0;
          g_perfMetrics[i].totalMs = 0.0;
          g_perfMetrics[i].count = 0;
          g_perfMetrics[i].maxMs = 0.0;
          return i;
        }
      }
      return -1;
}

void StartMeasurement(string name)
{
      int idx = FindOrCreateMetricIndex(name);
      if (idx < 0)
        return;
      g_perfMetrics[idx].startUs = GetMicrosecondCount();
}

void EndMeasurement(string strategy_name, bool success = true)
{
      int idx = KPI_FindIndex(strategy_name);
      if (idx < 0 || KPI_active[idx] != strategy_name)
        return;
      double elapsed = (double)(GetTickCount() - KPI_start_ticks[idx]);
      KPI_metrics[idx].execution_time_ms = elapsed;
      KPI_metrics[idx].end_time = TimeCurrent();
      KPI_metrics[idx].total_executions++;
      int n = KPI_metrics[idx].total_executions;
      if (n == 1) {
        KPI_metrics[idx].min_execution_time = elapsed;
        KPI_metrics[idx].max_execution_time = elapsed;
        KPI_metrics[idx].avg_execution_time = elapsed;
      } else {
        KPI_metrics[idx].min_execution_time =
            MathMin(KPI_metrics[idx].min_execution_time, elapsed);
        KPI_metrics[idx].max_execution_time =
            MathMax(KPI_metrics[idx].max_execution_time, elapsed);
        KPI_metrics[idx].avg_execution_time =
            ((KPI_metrics[idx].avg_execution_time * (n - 1)) + elapsed) / n;
      }
      if (success)
        KPI_metrics[idx].orders_processed++;
      KPI_metrics[idx].success_rate =
          (KPI_metrics[idx].orders_processed * 100.0) / n;
      KPI_total_cpu += elapsed;
      KPI_active[idx] = "";
      if (elapsed > 100.0)
        PrintFormat("[KPI] WARNING: %s took %.1f ms", strategy_name, elapsed);
}

double GetAverageExecutionTime(string name)
{
      int idx = FindMetricIndex(name);
      if (idx < 0 || g_perfMetrics[idx].count == 0)
        return 0;
      return g_perfMetrics[idx].totalMs / g_perfMetrics[idx].count;
}

string GeneratePerformanceReport() {
      string report = "=== PERFORMANCE REPORT ===\n";
      report += StringFormat("Report Period: up to %s\n\n", TimeToString(TimeCurrent()));
      report += "Name                 | Count | AvgMs | MaxMs |\n";
      report += "-------------------- | ----- | ----- | ----- |\n";
      for (int i = 0; i < g_perfMetricCount && i < MAX_PERF_METRICS; i++) {
        if (g_perfMetrics[i].name != "" && g_perfMetrics[i].count > 0) {
          double avg = (g_perfMetrics[i].count > 0) ? g_perfMetrics[i].totalMs / g_perfMetrics[i].count : 0;
          report += StringFormat("%-20s | %5d | %5.2f | %5.2f |\n",
              g_perfMetrics[i].name, g_perfMetrics[i].count, avg, g_perfMetrics[i].maxMs);
        }
      }
      report += "\nPerformance Recommendations:\n";
      report += GetPerformanceRecommendations();
      return report;
}

double Mid(double a, double b)   {
      return (a + b) * 0.5; }

double Percentile(double &arr[], int n, double p)  // p in [0,1]
{
      if (n <= 0)
        return 0.0;
      ArraySort(arr, n, 0, MODE_ASCEND);
      double idx = p * (n - 1);
      int lo = (int)MathFloor(idx);
      int hi = (int)MathCeil(idx);
      if (lo < 0)
        lo = 0;
      if (hi >= n)
        hi = n - 1;
      if (lo == hi)
        return arr[lo];
      double frac = idx - lo;
      return arr[lo] + frac * (arr[hi] - arr[lo]);
}

double PercentileRange(int lookback, double q)
{
      int n = (int)MathMin(lookback, Bars - 1);
      if (n <= 1)
        return RangeAt(1);
      double arr[512];
      int cnt = 0;
      int cap = (int)MathMin(n, 512);
      for (int i = 1; i <= cap; i++)
        arr[cnt++] = RangeAt(i);
      // sort
      for (int i = 0; i < cnt; i++)
        for (int j = i + 1; j < cnt; j++)
          if (arr[j] < arr[i]) {
            double t = arr[i];
            arr[i] = arr[j];
            arr[j] = t;
          }
      if (cnt == 0)
        return RangeAt(1);
      int idx = (int)MathFloor(q * (cnt - 1));
      if (idx < 0)
        idx = 0;
      if (idx >= cnt)
        idx = cnt - 1;
      return arr[idx];
}

