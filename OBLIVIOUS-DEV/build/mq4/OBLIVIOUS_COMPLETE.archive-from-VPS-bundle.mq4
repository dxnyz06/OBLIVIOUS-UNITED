// Parent setup registry — tracks active setups for burst/addon management
ParentSetup g_active_setups[20];
int         g_active_setup_count = 0;
int         g_next_setup_id      = 1000;  // auto-increments

// SECTION 06: FORWARD DECLARATIONS
// --- Strategy enable aliases (canonical 6 owner strategies) ---
