bool HasOpenOrdersInZone(double priceHi, double priceLo){
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS) && OrderSymbol() == Symbol()) {
          double op = OrderOpenPrice();
          if (op >= priceLo && op <= priceHi)
            return true;
        }
      }
      return false;
}

int OrderManager_CloseAllByMagic(int magic, string symbol = "")
{
      int closed = 0;
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderMagicNumber() != magic)
          continue;
        if (symbol != "" && OrderSymbol() != symbol)
          continue;

        if (OrderManager_Close(OrderTicket()))
          closed++;
      }
      return closed;
}

int OrderManager_CloseAll()
{
      int closed = 0;
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;

        // Check if this is our order (has our comment prefix)
        string cmnt = OrderComment();
        if (StringFind(cmnt, OM_COMMENT_PREFIX) < 0)
          continue;

        if (OrderManager_Close(OrderTicket()))
          closed++;
      }
      if (closed > 0)
        PrintFormat("[OrderManager] EMERGENCY CLOSE: %d orders closed", closed);
      return closed;
}

void ExecuteAITrade(){
      // Full AI trade pipeline: read signal, validate, execute
      int signal = CheckPredictedSignal();
      if (signal == 0)
        return;
      if (!IsSessionValid() || !MarketFiltersActive())
        return;
      double confidence = ComputeStrategyConfidence("Predicted");
      if (confidence < 60.0)
        return;
      double lots = DynamicLotSize("AI") * MathMax(0.5, confidence / 100.0);
      double sl = DynamicStopLoss();
      double tp = DynamicTakeProfit();
      SendTradeOrder(signal > 0 ? OP_BUY : OP_SELL, lots, sl, tp);
}

void ExecuteAITradeLogic(){
      // AI trade logic with additional OTE zone validation
      int signal = CheckPredictedSignal();
      if (signal == 0)
        return;
      double hi = FindLastPivotHigh();
      double lo = FindLastPivotLow();
      double fib618 = lo + (hi - lo) * 0.618;
      // Only enter at premium/discount zones
      if (signal > 0 && Ask > fib618)
        return; // Too high for buy
      if (signal < 0 && Bid < (hi - (hi - lo) * 0.618))
        return; // Too low for sell
      ExecuteAITrade();
}

// ExecuteGridLevel: handled by Grid strategy canonical pipeline

// Grid execution: handled by Grid_Logic() canonical pipeline

void ExecuteFVGStrategy(int dir)
{
      int magic = ADV_MAGIC_FVG();
      if (ADV_HasOpenPosition(magic))
        return;

      ADV_FVG_ZONE z;
      ADV_OB_ZONE ob;
      int tfPOI = (Period() <= PERIOD_M5 ? PERIOD_M15 : Period());
      if (!ADV_FindFVG_Pro(tfPOI, dir, ADV_FVG_LOOKBACK, false, z, ob))
        return;

      // Entry at market only when price is interacting with the zone on chart
      // TF
      if (!ADV_PriceInZone(Period(), z))
        return;

      double pip = ADV_Pip();
      double atr = ADV_ATR(Period(), MathMax(10, Auto_ATR_Period()), 1);
      if (atr <= 0.0)
        atr = 10 * pip;

      double buffer = MathMax(1.5 * pip, 0.20 * atr);
      double sl = (dir > 0 ? (z.bot - buffer) : (z.top + buffer));
      sl = NormalizeDouble(sl, Digits);

      double lots = ADV_NormalizeLots(FVG_Lot);
      int cmd = (dir > 0 ? OP_BUY : OP_SELL);
      double price = (dir > 0 ? Ask : Bid);

      SafeOrderSend(Symbol(), cmd, lots, price, 5, sl, 0.0, "FVG", magic, 0,
                    clrNONE);
}

void ExecuteSMC(int dir)
{
      int magic = ADV_MAGIC_SMC();
      if (ADV_HasOpenPosition(magic))
        return;

      int tfPOI = PERIOD_M15;
      int tfLTF = (Period() <= PERIOD_M5 ? PERIOD_M1 : PERIOD_M5);

      ADV_FVG_ZONE poi;
      ADV_OB_ZONE ob;
      if (!ADV_FindFVG_ICT(tfPOI, dir, ADV_FVG_LOOKBACK, poi, ob))
        return;

      // Require price interaction with the POI zone on LTF to avoid chasing
      if (!ADV_PriceInZone(tfLTF, poi))
        return;

      double pip = ADV_Pip();
      double atr = ADV_ATR(tfLTF, MathMax(10, Auto_ATR_Period()), 1);
      if (atr <= 0.0)
        atr = 10 * pip;

      double buffer = MathMax(2.0 * pip, 0.25 * atr);
      double sl = (dir > 0 ? (poi.bot - buffer) : (poi.top + buffer));
      sl = NormalizeDouble(sl, Digits);

      double lots = ADV_NormalizeLots(SMC_Lot);
      int cmd = (dir > 0 ? OP_BUY : OP_SELL);
      double price = (dir > 0 ? Ask : Bid);

      SafeOrderSend(Symbol(), cmd, lots, price, 5, sl, 0.0, "SMC+ICT", magic, 0,
                    clrNONE);
}

// [INCOMPLETE_SIG] int OrderSend_AIP(string symbol, int cmd, double volume, double price, int slippage,
// [INCOMPLETE_SIG]                   double stoploss, double takeprofit, string comment=NULL, int magic=0,

void ExecuteBuy(double lots, double sl, double tp, string comment, int magic=0){
      if (magic == 0)
        magic = ObliviousAiMagic;
      double price = Ask;
      int __eb_ticket = SafeOrderSend(Symbol(), OP_BUY, lots, price, GetAdaptiveSlippagePoints(),
                    sl, tp, comment, magic, 0, clrLime);
      if (__eb_ticket > 0) {
         string __eb_strat = "Unknown";
         if (magic == PredictedMagic) __eb_strat = "Predicted";
         else if (magic == BreakoutMagic) __eb_strat = "Breakout";
         else if (magic == FVGMagic) __eb_strat = "FVG";
         else if (magic == GridMagic) __eb_strat = "Grid";
         else if (magic == SMCMagic) __eb_strat = "SMC";
         else if (magic == ICTMagic) __eb_strat = "ICT";
         else if (magic == ReverseMagic) __eb_strat = "Reverse";
         TPSL_RegisterTrade(__eb_ticket, magic, __eb_strat, OP_BUY, price, sl);
      }
}

bool ExecuteSell(double lot, double sl, double tp, int magic = 0, string comment = "") {
   if (magic == 0)
      magic = ObliviousAiMagic;
   double price = Bid;
   int __es_ticket = SafeOrderSend(Symbol(), OP_SELL, lot, price, GetAdaptiveSlippagePoints(),
                 sl, tp, comment, magic, 0, clrRed);
   if (__es_ticket > 0) {
      string __es_strat = "Unknown";
      if (magic == PredictedMagic) __es_strat = "Predicted";
      else if (magic == BreakoutMagic) __es_strat = "Breakout";
      else if (magic == FVGMagic) __es_strat = "FVG";
      else if (magic == GridMagic) __es_strat = "Grid";
      else if (magic == SMCMagic) __es_strat = "SMC";
      else if (magic == ICTMagic) __es_strat = "ICT";
      else if (magic == ReverseMagic) __es_strat = "Reverse";
      TPSL_RegisterTrade(__es_ticket, magic, __es_strat, OP_SELL, price, sl);
      return true;
   }
   return false;
}
                                                                                                                                                                                      // Bridge-based wrapper

                                                                                                                                                                                                        double __AP_OrderFavorablePips() {
                                                                                                                                                                                                          // positive if trade in profit (in pips), negative if in loss
                                                                                                                                                                                                          double pips =
                                                                                                                                                                                                              0;
                                                                                                                                                                                                          if (OrderType() == OP_BUY) {



                                                                                                                                                                                                            pips =
                                                                                                                                                                                                                (Bid -
                                                                                                                                                                                                                 OrderOpenPrice()) /
                                                                                                                                                                                                                Point;
                                                                                                                                                                                                          } else if (
                                                                                                                                                                                                              OrderType() == OP_SELL) {



                                                                                                                                                                                                            pips =
                                                                                                                                                                                                                (OrderOpenPrice() -
                                                                                                                                                                                                                 Ask) /
                                                                                                                                                                                                                Point;
                                                                                                                                                                                                          }
                                                                                                                                                                                                          return pips;
                                                                                                                                                                                                        }

                                                                                                                                                                                                        double _EMA_close(
                                                                                                                                                                                                            string
                                                                                                                                                                                                                sym,
                                                                                                                                                                                                            int tf,
                                                                                                                                                                                                            int len,
                                                                                                                                                                                                            int shift) {
                                                                                                                                                                                                          double k =
                                                                                                                                                                                                              2.0 /
                                                                                                                                                                                                              (len +
                                                                                                                                                                                                               1.0);
                                                                                                                                                                                                          double ema = iClose(
                                                                                                                                                                                                              sym,
                                                                                                                                                                                                              tf,
                                                                                                                                                                                                              shift +
                                                                                                                                                                                                                  len -
                                                                                                                                                                                                                  1);
                                                                                                                                                                                                          for (
                                                                                                                                                                                                              int i =
                                                                                                                                                                                                                  len -
                                                                                                                                                                                                                  2;
                                                                                                                                                                                                              i >=
                                                                                                                                                                                                              0;
                                                                                                                                                                                                              i--) {
                                                                                                                                                                                                            double price = iClose(
                                                                                                                                                                                                                sym,
                                                                                                                                                                                                                tf,
                                                                                                                                                                                                                shift +
                                                                                                                                                                                                                    i);
                                                                                                                                                                                                            ema =
                                                                                                                                                                                                                k * price +
                                                                                                                                                                                                                (1.0 -
                                                                                                                                                                                                                 k) *
                                                                                                                                                                                                                    ema;
                                                                                                                                                                                                          }
                                                                                                                                                                                                          return ema;
                                                                                                                                                                                                        }

                                                                                                                                                                                                        bool _NeckBreakClose(
                                                                                                                                                                                                            int isTop,
                                                                                                                                                                                                            int W =
                                                                                                                                                                                                                10) {
                                                                                                                                                                                                          double neck = _Neckline(
                                                                                                                                                                                                              isTop,
                                                                                                                                                                                                              W);
                                                                                                                                                                                                          if (neck <=
                                                                                                                                                                                                              0)
                                                                                                                                                                                                            return false;
                                                                                                                                                                                                          if (isTop)
                                                                                                                                                                                                            return (
                                                                                                                                                                                                                Close
                                                                                                                                                                                                                    [1] <
                                                                                                                                                                                                                neck); // bearish break for H&S top
                                                                                                                                                                                                          else
                                                                                                                                                                                                            return (
                                                                                                                                                                                                                Close
                                                                                                                                                                                                                    [1] >
                                                                                                                                                                                                                neck); // bullish break for inverse
                                                                                                                                                                                                        }

                                                                                                                                                                                                        bool __PeakRetraceCloseConfirmed(
                                                                                                                                                                                                            long
                                                                                                                                                                                                                ticket,
                                                                                                                                                                                                            double
                                                                                                                                                                                                                peakCash,
                                                                                                                                                                                                            double
                                                                                                                                                                                                                curCash,
                                                                                                                                                                                                            double
                                                                                                                                                                                                                lots) {
                                                                                                                                                                                                          if (peakCash <=
                                                                                                                                                                                                              0.0)
                                                                                                                                                                                                            return false;
                                                                                                                                                                                                          double retrPct =
                                                                                                                                                                                                              __GetAdaptiveRetracePct();
                                                                                                                                                                                                          double level =
                                                                                                                                                                                                              peakCash *
                                                                                                                                                                                                              (1.0 -
                                                                                                                                                                                                               retrPct /
                                                                                                                                                                                                                   100.0);
                                                                                                                                                                                                          double atrCash =
                                                                                                                                                                                                              __ATR_(
                                                                                                                                                                                                                  14) *
                                                                                                                                                                                                              MarketInfo(
                                                                                                                                                                                                                  Symbol(),
                                                                                                                                                                                                                  MODE_TICKVALUE) *
                                                                                                                                                                                                              lots;
                                                                                                                                                                                                          double kAtr =
                                                                                                                                                                                                              __GetAdaptiveATRk();
                                                                                                                                                                                                          int needBars =
                                                                                                                                                                                                              __GetAdaptiveConfirmBarsFull();
                                                                                                                                                                                                          bool cond =
                                                                                                                                                                                                              (curCash <=
                                                                                                                                                                                                               level) &&
                                                                                                                                                                                                              ((peakCash -
                                                                                                                                                                                                                curCash) >=
                                                                                                                                                                                                               kAtr *
                                                                                                                                                                                                                   atrCash);
                                                                                                                                                                                                          double lastBarStamp =
                                                                                                                                                                                                              GlobalVariableGet(
                                                                                                                                                                                                                  __gvNameLast(
                                                                                                                                                                                                                      ticket));
                                                                                                                                                                                                          if (lastBarStamp == 0) {



                                                                                                                                                                                                            GlobalVariableSet(
                                                                                                                                                                                                                __gvNameLast(
                                                                                                                                                                                                                    ticket),
                                                                                                                                                                                                                (double)Time
                                                                                                                                                                                                                    [0]);
                                                                                                                                                                                                          }
                                                                                                                                                                                                          if ((datetime)
                                                                                                                                                                                                                  lastBarStamp !=
                                                                                                                                                                                                              Time[0]) {
                                                                                                                                                                                                            GlobalVariableSet(
                                                                                                                                                                                                                __gvNameLast(
                                                                                                                                                                                                                    ticket),
                                                                                                                                                                                                                (double)Time
                                                                                                                                                                                                                    [0]);
                                                                                                                                                                                                            double okBars = GlobalVariableGet(
                                                                                                                                                                                                                __gvNameBars(
                                                                                                                                                                                                                    ticket));
                                                                                                                                                                                                            if (cond)
                                                                                                                                                                                                              okBars++; else okBars =
                                                                                                                                                                                                                  0;
                                                                                                                                                                                                            GlobalVariableSet(
                                                                                                                                                                                                                __gvNameBars(
                                                                                                                                                                                                                    ticket),
                                                                                                                                                                                                                okBars);
                                                                                                                                                                                                            if (okBars >=
                                                                                                                                                                                                                needBars) {
                                                                                                                                                                                                              GlobalVariableDel(
                                                                                                                                                                                                                  __gvNameBars(
                                                                                                                                                                                                                      ticket));
                                                                                                                                                                                                              GlobalVariableDel(
                                                                                                                                                                                                                  __gvNameLast(
                                                                                                                                                                                                                      ticket));
                                                                                                                                                                                                              return true;
                                                                                                                                                                                                            }
                                                                                                                                                                                                          }
                                                                                                                                                                                                          return false;
                                                                                                                                                                                                        }

                                                                                                                                                                                                        void _hdr_RefreshLicenseLabelsPosition() {
                                                                                                                                                                                                          int chartW =
                                                                                                                                                                                                              (int)ChartGetInteger(
                                                                                                                                                                                                                  0,
                                                                                                                                                                                                                  CHART_WIDTH_IN_PIXELS,
                                                                                                                                                                                                                  0);
                                                                                                                                                                                                          int x =
                                                                                                                                                                                                              chartW /
                                                                                                                                                                                                              2;
                                                                                                                                                                                                          if (ObjectFind(
                                                                                                                                                                                                                  0,
                                                                                                                                                                                                                  "LBL_HDR_NAME") >=
                                                                                                                                                                                                              0)
                                                                                                                                                                                                            ObjectSetInteger(
                                                                                                                                                                                                                0,
                                                                                                                                                                                                                "LBL_HDR_NAME",
                                                                                                                                                                                                                OBJPROP_XDISTANCE,
                                                                                                                                                                                                                x);
                                                                                                                                                                                                          if (ObjectFind(
                                                                                                                                                                                                                  0,
                                                                                                                                                                                                                  "LBL_HDR_LICENSE") >=
                                                                                                                                                                                                              0)
                                                                                                                                                                                                            ObjectSetInteger(
                                                                                                                                                                                                                0,
                                                                                                                                                                                                                "LBL_HDR_LICENSE",
                                                                                                                                                                                                                OBJPROP_XDISTANCE,
                                                                                                                                                                                                                x);

//| 19. TP/SL / trailing / breakeven / overlay / profit guards

}
void ParseNewsLine(string line, string &text, string &impact) {
      string s = StringTrim(line);
      if (StringLen(s) == 0) {
        text = "";
        impact = "";
        return;
      }
      string up = StringUpper(s);
      impact = "";
      if (StringFind(up, "HIGH") >= 0)
        impact = "HIGH";
      else if (StringFind(up, "LOW") >= 0)
        impact = "LOW";
      else if (StringFind(up, "MED") >= 0)
        impact = "MEDIUM";
      int l = StringFind(s, "["), r = StringFind(s, "]");
      if (l >= 0 && r > l)
        text = StringTrim(StringSubstr(s, r + 1));
      else {
        l = StringFind(s, "(");
        r = StringFind(s, ")");
        if (l >= 0 && r > l)
          text = StringTrim(StringSubstr(s, r + 1));
        else
          text = s;
      }
}

double GetTodayProfit();

void DrawHLine_SL(string prefix, double price)
{
      DrawHLine(prefix + "_SL", price, clrRed, STYLE_DASH, 1);
}

void ExecuteStrategies() {
   // === Canonical dispatcher for: Grid, Breakout, Reverse ===
   // (Predicted -> DispatchPredictedStrategy, FVG -> FVG_Logic, SMC -> Strategy_SMC_Logic, ICT -> Strategy_ICT_Logic)
   // === GATE 1: Daily risk limit ===
   if (DailyStopOpenGate()) return;
   // === GATE 2: Session hours + day-of-week ===
   if (!IsSessionValid()) return;
   // === GATE 3: Volatility/spread check ===
   if (!MarketFiltersActive()) return;
   // === GATE 4: High-impact news block ===
   // NewsPolicy: per-strategy gating (Predicted exempt from high-impact block)

   int regime = TrendRegime(Symbol(), Period()); // 0=ranging, 1=trending

   // Breakout (trending regime only  session momentum breakouts)
   if (regime == 1 && Breakout && NewsPolicy_CanOpen("Breakout")) {
      int sigB = CheckBreakoutSignal();
      if (sigB != 0 && !IsStrategyCoolingDown("Breakout"))
         ExecuteStrategy("Breakout", sigB, 80.0);
   }

   // Reverse (counter-trend  mean reversion)
   if (Reverse && NewsPolicy_CanOpen("Reverse")) {
      int sigR = CheckReverseSignal();
      if (sigR != 0 && !IsStrategyCoolingDown("Reverse"))
         ExecuteStrategy("Reverse", sigR, 65.0);
   }

   // Grid (ranging regime only  adaptive range reversion)
   if (regime == 0 && Grid && NewsPolicy_CanOpen("Grid")) {
      int sigG = CheckGridSignal();
      if (sigG != 0 && !IsStrategyCoolingDown("Grid"))
         ExecuteStrategy("Grid", sigG, 60.0);
   }
}

void ExecuteStrategy(string name, int direction, double confidence) {
   if (!IsSafeToTrade()) return;
   if (!MarketFiltersActive()) return;
   if (!NewsPolicy_CanOpen(name)) return;
   if (confidence < GetMinConfidence(name)) return;
   if (IsStrategyCoolingDown(name)) return;
   int magic = GetStrategyMagic(name);
   if (CountOpenOrders(magic) >= MaxOpenTradesPerStrat) return;
   double sl_pts = Auto_SL_Points_Strategy(name);
   double tp_pts = Auto_TP_Points_Strategy(name);
   double lots   = LotsHybrid(sl_pts);
   double sl     = direction > 0 ? Bid - sl_pts * Point : Ask + sl_pts * Point;
   double entry  = direction > 0 ? Ask : Bid;
   lots = Risk_ClampLotToMaxRisk(Symbol(), lots, sl, entry);
   if (lots <= 0) return;
   double tp     = direction > 0 ? Ask + tp_pts * Point : Bid - tp_pts * Point;
   if (direction > 0)
      ExecuteBuy(lots, sl, tp, name, magic);
   else
      ExecuteSell(lots, sl, tp, magic, name);
   UpdateLastTradeTime(name);
}

