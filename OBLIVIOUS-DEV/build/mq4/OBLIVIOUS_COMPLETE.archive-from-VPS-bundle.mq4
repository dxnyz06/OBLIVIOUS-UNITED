double Score_ClosingMarubozu()  {
      double r = High[1] - Low[1];
      if (r <= 0)
        return 0;
      bool bull = Close[1] > Open[1];
      double tail = bull ? (High[1] - Close[1]) : (Open[1] - Low[1]);
      return ((tail < r * 0.02) ? 0.6 : 0); }

double Score_DragonflyDoji()  {
      double r = High[1] - Low[1], b = MathAbs(Close[1] - Open[1]);
      if (r <= 0)
        return 0;
      double lw = MathMin(Open[1], Close[1]) - Low[1];
      return ((b < r * 0.05 && lw > r * 0.7) ? 0.7 : 0); }

double Score_FourPriceDoji()  {
