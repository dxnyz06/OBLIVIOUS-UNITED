bool IsFlagOrPennantPattern(){
                    if (Bars < 15)
                      return false;
                    double range1 = High[iHighest(NULL, 0, MODE_HIGH, 5, 1)] -
                                    Low[iLowest(NULL, 0, MODE_LOW, 5, 1)];
                    double range2 = High[iHighest(NULL, 0, MODE_HIGH, 5, 6)] -
                                    Low[iLowest(NULL, 0, MODE_LOW, 5, 6)];
                    return (range2 > 0 && range1 / range2 < 0.5);
}

bool IsLiquiditySweepQuick() {
                    double prevHigh = High[iHighest(NULL, 0, MODE_HIGH, 10, 1)];
                    double prevLow = Low[iLowest(NULL, 0, MODE_LOW, 10, 1)];
                    return (High[0] > prevHigh || Low[0] < prevLow);
}

bool FormsLowerHigh(){
                    int h1 = iHighest(NULL, 0, MODE_HIGH, 10, 1),
                        h2 = iHighest(NULL, 0, MODE_HIGH, 10, 11);
                    return (High[h1] < High[h2]);
}

void CheckPeakProfitAndEmergency() {
                          for (int i = OrdersTotal() - 1; i >= 0; i--) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
                              if (OrderSymbol() == Symbol()) {
                                static double peakProfit = 0;
                                double currentProfit = OrderProfit() +
                                                       OrderSwap() +
                                                       OrderCommission();
                                // Aggiorna il picco massimo
                                // raggiunto
                                if (currentProfit > peakProfit)
                                  peakProfit = currentProfit;
                                // Controllo ritracciamento
                                // dal picco (auto-adaptive
                                // con anti-spike) Sostituisce
                                // la chiusura immediata su
                                // percentuale fissa.
                                if (__PeakRetraceCloseConfirmed(
                                        OrderTicket(), peakProfit,
                                        currentProfit, OrderLots())) {
                                  Print("Peak retrace "
                                        "auto-adaptive "
                                        "confermato. Chiudo "
                                        "trade: ",
                                        OrderTicket());
                                  {
                                    int __ticket = OrderTicket();
                                    double __lots = OrderLots();
                                    SmartLogWrap("CLOSE",
                                                 StringFormat("PreClose | "
   "ticket=%d "
   "lots=%.2f "
   "symbol=%s",
   __ticket, __lots,
   OrderSymbol()));
                                  }
                                  bool _wOk = OrderClose(
                                      OrderTicket(), OrderLots(),
                                      (OrderType() == OP_BUY ? Bid : Ask),
                                      GetAdaptiveSlippagePoints(), clrGreen);
                                  {
                                    int __err = GetLastError();
                                    bool __isok = (__err == 0);
                                    SmartLogWrap(
                                        "CLOSE",
                                        StringFormat("%s | ticket=%d "
                                                     "price=%.5f "
                                                     "lots=%.2f "
                                                     "err=%d",
                                                     __isok ? "PostClose "
   "OK"
   : "PostClose "
   "FAIL",
                                                     OrderTicket(),
                                                     OrderClosePrice(),
                                                     OrderLots(), __err));
                                  }
                                }
                                // profit check - integrated
                                // into ProfitGuards module
                              }
                            }
                          }
}

bool ProfitLockTriggered() {
                          double currentProfit =
                              AccountEquity() - initialDayEquity;
                          if (currentProfit > maxDailyProfit)
                            maxDailyProfit = currentProfit;
                          if (UseClusterMoneyMode &&
                              maxDailyProfit > ClusterTARGETMoney) {
                            double lockLevel =
                                maxDailyProfit * (ProfitLockPercent / 100.0);
                            if (currentProfit <= lockLevel) {
                              Print("Profit Lock attivato: "
                                    "chiusura di tutte le "
                                    "posizioni.");
                              return true;
                            }
                          }
                          return false;
}

void RunApplyPeakProfit() {
                          if (IsTPSL_AI()) {
                            if (AI_SyncSLTP_OpenOrders())
                              return;
                          }
                          // Se il profitto corrente supera
                          // una soglia di picco, chiudiamo le
                          // operazioni per proteggere i
                          // guadagni
                          if (g_currentProfit >= peakThreshold) {
                            for (int i = OrdersTotal() - 1; i >= 0; i--) {
                              if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES) &&
                                  OrderSymbol() == Symbol()) {
                                {
                                  int __ticket = OrderTicket();
                                  double __lots = OrderLots();
                                  SmartLogWrap("CLOSE",
                                               StringFormat("PreClose | "
   "ticket=%d "
   "lots=%.2f "
   "symbol=%s",
   __ticket, __lots,
   OrderSymbol()));
                                }
                                bool _wRes = OrderClose(OrderTicket(), OrderLots(), Bid,
                                           GetAdaptiveSlippagePoints(),
                                           clrGreen);
                                {
                                  int __err = GetLastError();
                                  bool __isok = (__err == 0);
                                  SmartLogWrap(
                                      "CLOSE",
                                      StringFormat("%s | ticket=%d "
                                                   "price=%.5f "
                                                   "lots=%.2f err=%d",
                                                   __isok ? "PostClose OK"
                                                          : "PostClose "
   "FAIL",
                                                   OrderTicket(),
                                                   OrderClosePrice(),
                                                   OrderLots(), __err));
                                }
                              }
                            }
                          }
}

                      int TPSL_CurrentMode() {
                        // 1) GlobalVariables with explicit
                        // mode text
                        if (GlobalVariableCheck("TPSL_MODE")) {
                          string v = GlobalVariableGet("TPSL_MODE") > 0
                                         ? "AI"
                                         : "Native";
                          // if user writes string into GV
                          // via double mapping, still
                          // accept numeric: >0 => AI
                          return (GlobalVariableGet("TPSL_MODE") > 0) ? 1 : 0;
                        }
                        if (GlobalVariableCheck("TP_SL_MODE")) {
                          double vv = GlobalVariableGet("TP_SL_MODE");
                          return (vv > 0) ? 1 : 0;
                        }
                        // 2) Label on chart: LBL_TPSL or
                        // LBL_TPSL_MODE containing "AI" or
                        // "Native"
                        string ids[2] = {"LBL_TPSL", "LBL_TPSL_MODE"};
                        for (int i = 0; i < 2; i++) {
                          string id = ids[i];
                          if (ObjectFind(0, id) >= 0) {
                            string t = ObjectGetString(0, id, OBJPROP_TEXT);
                            string u = StringToUpper(t);
                            if (StringFind(u, "AI", 0) >= 0)
                              return 1;
                            if (StringFind(u, "NATIVE", 0) >= 0)
                              return 0;
                          }
                        }
                        // 3) Fallback: prefer AI if AI
                        // server is on
                        if (GlobalVariableCheck("AI_SERVER_ON"))
                          return (GlobalVariableGet("AI_SERVER_ON") > 0) ? 1
   : 0;
                        return 0; // default Native
                      }

                      void TPSL_LogModeIfChanged() {
                        static string lastMode = "";
                        string mode = TPSL_CurrentMode();
                        if (mode != lastMode) {
                          SmartLog("INFO", "TPSL", "Mode changed to: " + mode);
                          lastMode = mode;
                        }
                      }

