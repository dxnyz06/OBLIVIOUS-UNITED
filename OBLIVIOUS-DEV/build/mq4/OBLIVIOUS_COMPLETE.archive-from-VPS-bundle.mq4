bool IsEfficiencyRatio() {
      int n = 10;
      if (Bars < n + 1)
        return false;
      double direction = MathAbs(iClose(NULL, 0, 0) - iClose(NULL, 0, n));
      double volatility = 0;
      for (int i = 0; i < n; i++)
        volatility += MathAbs(iClose(NULL, 0, i) - iClose(NULL, 0, i + 1));
      return (volatility > 0 && direction / volatility > 0.5);
}

