void DrawRect(string name, int x, int y, int w, int h, color bgClr, int corner)
{
      if (ObjectFind(0, name) < 0) {
        ObjectCreate(0, name, OBJ_RECTANGLE_LABEL, 0, 0, 0);
        ObjectSetInteger(0, name, OBJPROP_CORNER, corner);
        ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
        ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
        ObjectSetInteger(0, name, OBJPROP_BORDER_TYPE, BORDER_FLAT);
      }
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_XSIZE, w);
      ObjectSetInteger(0, name, OBJPROP_YSIZE, h);
      ObjectSetInteger(0, name, OBJPROP_BGCOLOR, bgClr);
      ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, clrDimGray);
}

void Dashboard_OnChartEvent(int id, long lparam, double dparam, string sparam)
{
      // Handle chart click events on dashboard UI elements
      if (id != CHARTEVENT_OBJECT_CLICK)
        return;
      // Check if a top-bar strategy label was clicked
      for (int i = 0; i < 12; i++) {
        string tbName = "TB_" + IntegerToString(i);
        if (sparam == tbName) {
          // Toggle highlight on clicked strategy
          color currentClr = (color)ObjectGetInteger(0, tbName, OBJPROP_COLOR);
          color newClr = (currentClr == clrLime) ? clrGray : clrLime;
          ObjectSetInteger(0, tbName, OBJPROP_COLOR, newClr);
          SmartLog("INFO", "UI", "Toggled strategy label: " + tbName);
          ChartRedraw();
          return;
        }
      }
      // Check for DD/strategy panel clicks
      if (StringFind(sparam, "STRAT_") == 0) {
        SmartLog("INFO", "UI", "Strategy panel clicked: " + sparam);
      }
}

void DrawingHelpers_CleanupAll(string prefix)
{
      int total = ObjectsTotal(0, -1, -1);
      for (int i = total - 1; i >= 0; i--) {
        string objName = ObjectName(0, i);
        if (StringFind(objName, prefix) == 0)
          ObjectDelete(0, objName);
      }
}

