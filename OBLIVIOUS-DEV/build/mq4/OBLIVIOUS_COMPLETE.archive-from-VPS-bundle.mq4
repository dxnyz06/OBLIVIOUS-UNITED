double Score_LadderBottom(){
      double ok = 0;
      if (Close[4] < Open[4] && Close[3] < Open[3] && Close[2] < Open[2] &&
          Close[0] > Open[0] && Close[0] > Open[2])
        ok = 1;
      return znorm(ok, 0.5); }

double Score_UniqueThreeRiver(){
      double ok = 0;
      if (Close[2] < Open[2] && Low[1] < Low[2] && Close[1] > Close[2] &&
          Close[0] > Open[0] && Close[0] > Close[1])
        ok = 1;
      return znorm(ok, 0.5); }

double Score_StickSandwich(){
      double ok = 0;
      if (Close[2] < Open[2] && Close[1] > Open[1] && Close[0] < Open[0] &&
          MathAbs(Close[0] - Close[2]) <= Point * 3)
        ok = 1;
      return znorm(ok, 0.5); }

double Score_MatchingLow()  {
      if (Bars < 3)
        return 0;
      return (MathAbs(Low[1] - Low[2]) < Point * 3 ? 0.5 : 0); }

double Score_MatchingHigh()  {
      if (Bars < 3)
        return 0;
      return (MathAbs(High[1] - High[2]) < Point * 3 ? 0.5 : 0); }

double Score_Counterattack(){
      double ok = 0;
      if (((Close[1] > Open[1] && Close[0] < Open[0]) ||
           (Close[1] < Open[1] && Close[0] > Open[0])) &&
          MathAbs(Close[0] - Close[1]) <= Point * 3)
        ok = 1;
      return znorm(ok, 0.5); }

double Score_Kicking(){
      double ok = 0;
      if (Score_Marubozu() > 80 && (Close[1] > Open[1] && Close[0] < Open[0] ||
                                    Close[1] < Open[1] && Close[0] > Open[0]))
        ok = 1;
      return znorm(ok, 0.5); }

double Score_BeltHold2()  {
      double r = High[1] - Low[1], b = MathAbs(Close[1] - Open[1]);
      if (r <= 0)
        return 0;
      return ((b > r * 0.8) ? 0.5 : 0); }

double Score_AdvanceBlock()  {
