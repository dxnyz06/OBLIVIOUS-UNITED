      g_licenseValidated = true;
      g_licenseStatus = "ACTIVE";
      license_validated = true;
      license_status = "ACTIVE";
      return true;
}

string __PersistFilename(string category, string suffix="")
{
      string sym = Symbol();
      // Replace non-alphanumeric chars for safe filename
      StringReplace(sym, ".", "_");
      StringReplace(sym, "/", "_");
      string fn = PERSIST_DIR + category + "_" + sym;
      if (suffix != "")
        fn += "_" + suffix;
      fn += ".dat";
      return fn;
}

bool PersistFileExists(string category, string suffix="")
{
      string fn = __PersistFilename(category, suffix);
      string fullPath =
          TerminalInfoString(TERMINAL_COMMONDATA_PATH) + "\\Files" + fn;
      return (GetFileAttributesA(fullPath) != K32_INVALID_FILE_ATTR);
}

bool PersistDoubleArray(string category, double &values[], int count, string suffix="")
{
      string fn = __PersistFilename(category, suffix);
      string fullPath =
          TerminalInfoString(TERMINAL_COMMONDATA_PATH) + "\\Files" + fn;
      int h = CreateFileA(fullPath, K32_GENERIC_WRITE, 0, 0, K32_CREATE_ALWAYS,
                          K32_FILE_ATTR_NORMAL, 0);
      if (h == K32_INVALID_HANDLE) {
        SmartLog("WARN", "PERSIST", "Cannot write " + fn);
        return false;
      }

      // Build text content: version\ncount\nval1\nval2\n...
      string content = IntegerToString(PERSIST_VERSION) + "\n" +
                       IntegerToString(count) + "\n";
      for (int i = 0; i < count; i++)
        content += DoubleToString(values[i], 10) + "\n";

      uchar buf[];
      StringToCharArray(content, buf, 0, WHOLE_ARRAY, CP_ACP);
      int written = 0;
      WriteFile(h, buf, ArraySize(buf) - 1, written, 0);
      CloseHandle(h);
      return true;
}

bool PersistAdaptiveContext()
{
      double vals[9];
      vals[0] = g_adapt.regime;
      vals[1] = g_adapt.vol_factor;
      vals[2] = g_adapt.rsi_period;
      vals[3] = g_adapt.ema_fast;
      vals[4] = g_adapt.ema_slow;
      vals[5] = g_adapt.cci_period;
      vals[6] = g_adapt.bb_period;
      vals[7] = g_adapt.bb_dev;
      vals[8] = g_adapt.mom_period;
      return PersistDoubleArray("ADAPT", vals, 9);
}

void ClearAllPersistence()
{
      string categories[] = {"GRID", "BLUE", "RISK", "ADAPT"};
      string commonPath =
          TerminalInfoString(TERMINAL_COMMONDATA_PATH) + "\\Files";
      for (int i = 0; i < 4; i++) {
        string fn = __PersistFilename(categories[i]);
        string fullPath = commonPath + fn;
        if (GetFileAttributesA(fullPath) != K32_INVALID_FILE_ATTR)
          DeleteFileA(fullPath);
      }
      SmartLog("INFO", "PERSIST", "All persistence cleared for " + Symbol());
}

void PersistAllState()
{
      PersistAdaptiveContext();
      // Grid and Blue states are persisted by their respective modules
      SmartLog("INFO", "PERSIST", "State persisted for " + Symbol());
}

bool RestoreAllState()
{
      bool ok = RestoreAdaptiveContext();
      if (ok)
        SmartLog("INFO", "PERSIST", "State restored for " + Symbol());
      else
        SmartLog("WARN", "PERSIST",
                 "No saved state for " + Symbol() + " — using defaults");
      return ok;
}

void Toggle_SetState(string key, bool state)
{
      int idx = Toggle_FindByName(key);
      if (idx >= 0) {
        g_toggles[idx].state = state;
        Toggle_UpdateColors(idx);
      }
}

bool Toggle_GetState(string key)
{
      int idx = Toggle_FindByName(key);
      if (idx >= 0)
        return g_toggles[idx].state;
      return false;
}

bool CheckPiercingLine(int i)
{
      double mid = (Open[i + 1] + Close[i + 1]) * 0.5;
      return (Close[i + 1] < Open[i + 1] && Close[i] > Open[i] &&
              Open[i] < Close[i + 1] && Close[i] > mid &&
              Close[i] < Open[i + 1]);
}

