// Strategy_StructureElite_Logic: does not exist in this system
// Strategy_EmperorShot_Logic: does not exist in this system
void Strategy_FVG_Logic() {
   if (!GlobalStrategyGuards()) return;
   if (!FVG) return;
   if (TimeCurrent() - lastTradeTime_FVG < MinSecondsBetweenTrades) return;
   if (CountOpenOrders(FVGMagic) >= MaxOpenTradesPerStrat) return;
   if (Bridge_IsConnected()) {
      string aiPayload;
      if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
         if (StringFind(aiPayload, "fvg=0") >= 0) {
            Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
            return;
         }
      }
   }
   Strategy_FVG_Logic_v2();
}

bool Strategy_SMC_Logic() {
   if (!SMC || !AllowStrategyToTrade()) return false;
   int lb = 30;
   double swH = iHigh(Symbol(), Period(), iHighest(Symbol(), Period(), MODE_HIGH, lb, 1));
   double swL = iLow(Symbol(), Period(), iLowest(Symbol(), Period(), MODE_LOW, lb, 1));
   double close1 = iClose(Symbol(), Period(), 1);
   double close2 = iClose(Symbol(), Period(), 2);
   bool bullBOS = (close1 > swH && close2 <= swH);
   bool bearBOS = (close1 < swL && close2 >= swL);
   for (int i = 3; i < lb; i++) {
      double h_i = iHigh(Symbol(), Period(), i);
      double l_i = iLow(Symbol(), Period(), i);
      double c_i = iClose(Symbol(), Period(), i);
      double o_i = iOpen(Symbol(), Period(), i);
      if (bullBOS && c_i > o_i && l_i <= swL * 1.001) {
         double obMid = (h_i + l_i) / 2.0;
         if (Bid <= obMid) {
            ExecuteBuy(ManualLot, 0, 0, "SMC", SMCMagic);
            return true;
         }
      }
      if (bearBOS && c_i < o_i && h_i >= swH * 0.999) {
         double obMid = (h_i + l_i) / 2.0;
         if (Ask >= obMid) {
            ExecuteSell(ManualLot, 0, 0, SMCMagic, "SMC");
            return true;
         }
      }
   }
   return false;
}

bool Strategy_ICT_Logic() {
   if (!ICT || !AllowStrategyToTrade()) return false;
   int lb = 50;
   double swH = iHigh(Symbol(), Period(), iHighest(Symbol(), Period(), MODE_HIGH, lb, 1));
   double swL = iLow(Symbol(), Period(), iLowest(Symbol(), Period(), MODE_LOW, lb, 1));
   double range = swH - swL;
   if (range <= 0) return false;
   double ote618 = swH - range * 0.618;
   double ote786 = swH - range * 0.786;
   double eq = (swH + swL) / 2.0;
   double close1 = iClose(Symbol(), Period(), 1);
   bool bullLiqSweep = (iLow(Symbol(), Period(), 1) < swL && close1 > swL);
   bool bearLiqSweep = (iHigh(Symbol(), Period(), 1) > swH && close1 < swH);
   if (bullLiqSweep && Bid >= ote786 && Bid <= ote618) {
      ExecuteBuy(ManualLot, 0, 0, "ICT", ICTMagic);
      return true;
   }
   if (bearLiqSweep && Ask <= swH - range * 0.382 && Ask >= eq) {
      ExecuteSell(ManualLot, 0, 0, ICTMagic, "ICT");
      return true;
   }
   return false;
}


bool Strategy_Reverse_Logic() {
   if (!GlobalStrategyGuards()) return false;
   if (!Reverse) return false;
   if (Bridge_IsConnected()) {
      string aiPayload;
      if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
         if (StringFind(aiPayload, "reverse=0") >= 0) {
            Bridge_SendLog(1, "Reverse", "AI suggests NO TRADE");
            return false;
         }
      }
   }
   double confidence = CalculatePatternConfidence();
   if (confidence < PatternsConfidence) return false;
   if (!CheckFiltersRSI() || !CheckFiltersATR()) return false;
   return true;
}

bool Strategy_Grid_Logic() {
   if (!GlobalStrategyGuards()) return false;
   if (!Grid) return false;
   
   // FTMO-safe Grid checks
   if (Grid_IsInCooldown()) {
      SmartLog("INFO", "GRID", "Grid in cooldown period");
      return false;
   }
   
   if (g_gridState.invalidated) {
      SmartLog("INFO", "GRID", "Grid previously invalidated");
      return false;
   }
   
   // Range regime requirement
   if (!Grid_IsRangeRegime()) {
      SmartLog("INFO", "GRID", "Market not in ranging regime suitable for Grid");
      return false;
   }
   
   // Gold-specific Grid blocking
   if (ShouldBlockGoldGridNearNews()) {
      SmartLog("INFO", "GRID", "Grid blocked for Gold near high-impact news");
      return false;
   }
   
   if (Bridge_IsConnected()) {
      string aiPayload;
      if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
         if (StringFind(aiPayload, "grid=0") >= 0) {
            Bridge_SendLog(1, "Grid", "AI suggests NO TRADE");
            return false;
         }
      }
   }
   if (!VWAPDeviationTrigger(2.0)) return false;
   if (BayesianSuperTrendFilter(10, 3.0) == 0) return false;
   double confidence = CalculatePatternConfidence();
   if (confidence < PatternsConfidence) return false;
   if (!CheckFiltersRSI() || !CheckFiltersATR()) return false;
   
   // Additional Gold context check
   if (IsGoldSymbol()) {
      double goldContext = GetGoldMacroContext();
      double goldLevels = GetGoldKeyLevels();
      if (goldContext < 30.0 || goldLevels < 40.0) {
         SmartLog("INFO", "GRID", "Grid blocked for Gold - poor macro context or key levels");
         return false;
      }
   }
   
   return true;
}

void Strategy_Breakout_Logic() {
   // Breakout strategy execution  routed through ExecuteStrategies dispatcher
   // CheckBreakoutSignal() + ExecuteStrategy("Breakout", ...) handles trade placement
   if (!GlobalStrategyGuards()) return;
   if (!Breakout) return;
}

// SECTION 14: FILTER CONFIDENCE / COMBINED FILTER

//| 14. filter confidence

   double CombinedFilterConfidence(
   int dir) {
   // CANONICAL PURE-FILTER AGGREGATOR
   // Contains ONLY filter qualifiers. Zero indicators. Zero patterns. Zero AI.
   double score =
   50.0;
   if (ATRFilter)
   score +=
   (Filter_ATRFilter_Score_v2(
   dir) -
   50.0) *
   0.20;
   if (VolumeFilter)
   score +=
   (Filter_VolumeFilter_Score_v2(
   dir) -
   50.0) *
   0.20;
   if (MultiTFTrend)
   score +=
   (Filter_MultiTFTrend_Score_v2(
   dir) -
   50.0) *
   0.25;
   if (SessionFilter)
   score +=
   (Filter_Session_Score_v2(
   dir) -
   50.0) *
   0.15;
   if (SpreadFilter)
   score +=
   (Filter_Spread_Score_v2(
   dir) -
   50.0) *
   0.10;
   if (RegimeFilter)
   score +=
   (Filter_Regime_Score_v2(
   dir) -
   50.0) *
   0.10;
   return clamp100(
   score);
   }

//| 16. pattern signal / pattern confidence

                                          int CheckPatternAlphaSignal() {
                                            if (!GlobalStrategyGuards())
                                              return (0);
                                            bool buyCond = false, sellCond = false;
                                            if (buyCond) {
                                              string t = "GEN";
                                              double b1 =
                                                  MathAbs(Close[1] - Open[1]);
                                              double w1 = High[1] - Low[1];
                                              double upw =
                                                  High[1] -
                                                  MathMax(Close[1], Open[1]);
                                              double loww =
                                                  MathMin(Close[1], Open[1]) -
                                                  Low[1];
                                              if (b1 / w1 < 0.25 &&
                                                  loww / w1 > 0.5)
                                                t = "PIN";
                                              else if (Close[1] > Open[1] &&
                                                       Open[1] <= Close[2] &&
                                                       Close[1] >= Open[2])
                                                t = "ENG";
                                              else if (High[1] < High[2] &&
                                                       Low[1] > Low[2])
                                                t = "IB";
                                              int score =
                                                  (t == "GEN"
                                                       ? 1
                                                       : (t == "IB"
   ? 2
   : (t == "PIN"
   ? 3
   : 4)));
                                              int conf = 0;
                                              if (score >= 3)
                                                conf++;
                                              if ((Close[0] - Open[0]) *
                                                      (Close[1] - Open[1]) >
                                                  0)
                                                conf++;
                                              AddToSmartLog(StringFormat(
                                                  "[ALPHA][PAT] type=%s "
                                                  "score=%d",
                                                  t, score));
                                              AddToSmartLog(StringFormat(
                                                  "[ALPHA][CONFIRM] "
                                                  "confluence=%d",
                                                  conf));
                                              AddToSmartLog(
                                                  "[STRUCTURE][SWING] "
                                                  "HL?HH confirm");
                                              return 1;
                                            }
                                            if (sellCond) {
                                              string t = "GEN";
                                              double b1 =
                                                  MathAbs(Close[1] - Open[1]);
                                              double w1 = High[1] - Low[1];
                                              double upw =
                                                  High[1] -
                                                  MathMax(Close[1], Open[1]);
                                              double loww =
                                                  MathMin(Close[1], Open[1]) -
                                                  Low[1];
                                              if (b1 / w1 < 0.25 &&
                                                  loww / w1 > 0.5)
                                                t = "PIN";
                                              else if (Close[1] > Open[1] &&
                                                       Open[1] <= Close[2] &&
                                                       Close[1] >= Open[2])
                                                t = "ENG";
                                              else if (High[1] < High[2] &&
                                                       Low[1] > Low[2])
                                                t = "IB";
                                              int score =
                                                  (t == "GEN"
                                                       ? 1
                                                       : (t == "IB"
   ? 2
   : (t == "PIN"
   ? 3
   : 4)));
                                              int conf = 0;
                                              if (score >= 3)
                                                conf++;
                                              if ((Close[0] - Open[0]) *
                                                      (Close[1] - Open[1]) >
                                                  0)
                                                conf++;
                                              AddToSmartLog(StringFormat(
                                                  "[ALPHA][PAT] type=%s "
                                                  "score=%d",
                                                  t, score));
                                              AddToSmartLog(StringFormat(
                                                  "[ALPHA][CONFIRM] "
                                                  "confluence=%d",
                                                  conf));
                                              AddToSmartLog(
                                                  "[STRUCTURE][SWING] "
                                                  "LH?LL confirm");
                                              return -1;
                                            }
                                            return 0;
                                          }

                                          int CheckPatternCrownSignal() {
                                            if (!GlobalStrategyGuards())
                                              return (false);
                                            // Condizione: pattern Crown
                                            // personalizzato confermato.
                                            if (g_buyCond) {
                                              int N = 20;
                                              int hi =
                                                  iHighest(Symbol(), Period(),
                                                           MODE_HIGH, N, 1);
                                              int lo =
                                                  iLowest(Symbol(), Period(),
                                                          MODE_LOW, N, 1);
                                              double lsh =
                                                  iHigh(Symbol(), Period(),
                                                        hi + 1) -
                                                  iLow(Symbol(), Period(),
                                                       hi + 1);
                                              double rsh =
                                                  iHigh(Symbol(), Period(),
                                                        lo + 1) -
                                                  iLow(Symbol(), Period(),
                                                       lo + 1);
                                              double sym =
                                                  (lsh > 0 && rsh > 0
                                                       ? MathMin(lsh, rsh) /
   MathMax(lsh, rsh)
                                                       : 0);
                                              double apexd =
                                                  MathAbs(iClose(Symbol(),
   Period(), hi) -
                                                          iOpen(Symbol(),
   Period(), hi)) /
                                                  Point / AA_PointsPerPip();
                                              AddToSmartLog(StringFormat(
                                                  "[CROWN][APEX] sym=%.2f "
                                                  "delta=%.1fp",
                                                  sym, apexd));
                                              if (crown_enabled) {
                                                bool bull =
                                                    (Close[1] >= Open[1]);
                                                double lvl =
                                                    bull ? High[1] : Low[1];
                                                DrawHLineNamed(
                                                    StringConcatenate("HL_NL_",
   Time[1]),
                                                    lvl, "H&S");
                                              }
                                              if (crown_enabled) {
                                                bool bull =
                                                    (Close[1] >= Open[1]);
                                                double neck =
                                                    bull ? Low[1] : High[1];
                                                double head =
                                                    MathMax(High[1], High[2]);
                                                double h = MathAbs(head - neck);
                                                DrawHLineNamed(
                                                    StringConcatenate(
                                                        "HL_HS_TG_", Time[1]),
                                                    bull ? (neck + h)
                                                         : (neck - h),
                                                    "TARGET");
                                                datetime t1 = Time[4];
                                                datetime t2 =
                                                    Time[1] +
                                                    PeriodSeconds(
                                                        PERIOD_CURRENT) *
                                                        ExtendSec(30);
                                                DrawRectFilledNamed(
                                                    StringConcatenate(
                                                        "RC_HS_RT_", Time[1]),
                                                    t1,
                                                    bull ? neck
                                                         : neck + h * 0.2,
                                                    t2,
                                                    bull ? neck - h * 0.2
                                                         : neck,
                                                    "RETEST");
                                              }
                                              return 1;
                                            }
                                            if (g_sellCond) {
                                              int N = 20;
                                              int hi =
                                                  iHighest(Symbol(), Period(),
                                                           MODE_HIGH, N, 1);
                                              int lo =
                                                  iLowest(Symbol(), Period(),
                                                          MODE_LOW, N, 1);
                                              double lsh =
                                                  iHigh(Symbol(), Period(),
                                                        hi + 1) -
                                                  iLow(Symbol(), Period(),
                                                       hi + 1);
                                              double rsh =
                                                  iHigh(Symbol(), Period(),
                                                        lo + 1) -
                                                  iLow(Symbol(), Period(),
                                                       lo + 1);
                                              double sym =
                                                  (lsh > 0 && rsh > 0
                                                       ? MathMin(lsh, rsh) /
   MathMax(lsh, rsh)
                                                       : 0);
                                              double apexd =
                                                  MathAbs(iClose(Symbol(),
   Period(), hi) -
                                                          iOpen(Symbol(),
   Period(), hi)) /
                                                  Point / AA_PointsPerPip();
                                              AddToSmartLog(StringFormat(
                                                  "[CROWN][APEX] sym=%.2f "
                                                  "delta=%.1fp",
                                                  sym, apexd));
                                              return -1;
                                            }
                                            return 0;
                                          }

   int CombinedPatternSignal() {
   double
   bull =
   0,
   bear =
   0;
   double
   v;
   v = Detect_BullishEngulfing();
   if (v >
   0)
   bull +=
   v;
   v = Detect_BearishEngulfing();
   if (v >
   0)
   bear +=
   v;
   v = Detect_Hammer();
   if (v >
   0)
   bull +=
   v;
   v = Detect_ShootingStar();
   if (v >
   0)
   bear +=
   v;
   v = Detect_Doji(); // doji = no directional signal alone
   v = Detect_MorningStar();
   if (v >
   0)
   bull +=
   v;
   v = Detect_EveningStar();
   if (v >
   0)
   bear +=
   v;
   v = Detect_ThreeWhiteSoldiers();
   if (v >
   0)
   bull +=
   v;
   v = Detect_ThreeBlackCrows();
   if (v >
   0)
   bear +=
   v;
   v = Detect_PiercingLine();
   if (v >
   0)
   bull +=
   v;
   v = Detect_DarkCloudCover();
   if (v >
   0)
   bear +=
   v;
   v = Detect_Harami(
   +1);
   if (v >
   0)
   bull +=
   v;
   v = Detect_Harami(
   -1);
   if (v >
   0)
   bear +=
   v;
   if (bull >
   bear)
   return +1;
   if (bear >
   bull)
   return -1;
   return 0;
   }

