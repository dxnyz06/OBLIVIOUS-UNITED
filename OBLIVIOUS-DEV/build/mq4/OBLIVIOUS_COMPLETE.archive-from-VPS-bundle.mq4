double Score_Breakaway(){
      double ok = 0;
      if (Close[4] < Open[4] && Close[3] < Open[3] && Close[2] < Open[2] &&
          Close[1] < Open[1] && Close[0] > Open[0] && Close[0] > Open[4])
        ok = 1;
      if (Close[4] > Open[4] && Close[3] > Open[3] && Close[2] > Open[2] &&
          Close[1] > Open[1] && Close[0] < Open[0] && Close[0] < Open[4])
        ok = 1;
      return znorm(ok, 0.5); }

bool IsBullishPinBar(int shift=1){
      double lowerWick = MathMin(Open[shift], Close[shift]) - Low[shift];
      double body = MathAbs(Close[shift] - Open[shift]);
      return (lowerWick > body * 2.0 && Close[shift] > Open[shift]);
}

bool IsBearishPinBar(int shift=1){
      double upperWick = High[shift] - MathMax(Open[shift], Close[shift]);
      double body = MathAbs(Close[shift] - Open[shift]);
      return (upperWick > body * 2.0 && Close[shift] < Open[shift]);
}

bool IsBullishEngulfing(int shift=1){
      return (Close[shift+1] < Open[shift+1] && Close[shift] > Open[shift] && Close[shift] > Open[shift+1] && Open[shift] < Close[shift+1]);
}

bool IsBearishEngulfing(int shift=1){
      return (Close[shift+1] > Open[shift+1] && Close[shift] < Open[shift] && Close[shift] < Open[shift+1] && Open[shift] > Close[shift+1]); }


bool BOS_Bearish()  {
      if (Bars < 10)
        return false;
      double ll = iLow(Symbol(), 0, iLowest(Symbol(), 0, MODE_LOW, 10, 1));
      return (Close[0] < ll); }

bool BOS_Bullish()  {
      if (Bars < 10)
        return false;
      double hh = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, 10, 1));
      return (Close[0] > hh); }

bool IsPinbar(string symbol, int timeframe, int shift) {
      double open = iOpen(symbol, timeframe, shift);
      double close = iClose(symbol, timeframe, shift);
      double high = iHigh(symbol, timeframe, shift);
      double low = iLow(symbol, timeframe, shift);
      double body = MathAbs(close - open);
      double upperShadow = high - MathMax(open, close);
      double lowerShadow = MathMin(open, close) - low;
      return (upperShadow > body * 2 || lowerShadow > body * 2);
}

bool IsDoji(string symbol, int timeframe, int shift) {
      double open = iOpen(symbol, timeframe, shift);
      double close = iClose(symbol, timeframe, shift);
      double high = iHigh(symbol, timeframe, shift);
      double low = iLow(symbol, timeframe, shift);
      double body = MathAbs(close - open);
      double range = high - low;
      return (body <= range * 0.1); // Il corpo ÃƒÃ†ÃƒÃ‚Â¨ <=10% del range
}

bool CheckEngulfingGap(int i){
      if (i < 1 || !_HasBars(i, 1))
        return false;
      bool bullGap =
          (_IsBear(i + 1) && _IsBull(i) && Open[i] > Open[i + 1] &&
           Open[i] > Close[i + 1] && Open[i] > High[i + 1] - (Point * 2) &&
           Close[i] > Open[i + 1] && Open[i] < Close[i + 1]);
      bool bearGap =
          (_IsBull(i + 1) && _IsBear(i) && Open[i] < Open[i + 1] &&
           Open[i] < Close[i + 1] && Open[i] < Low[i + 1] + (Point * 2) &&
           Close[i] < Open[i + 1] && Open[i] > Close[i + 1]);
      return (bullGap || bearGap);
}

bool SMC_FindFVG(double &hi, double &lo)  {
