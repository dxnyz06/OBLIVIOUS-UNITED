bool IsTEMA() {
      double ema1 = iMA(NULL, 0, 14, 0, MODE_EMA, PRICE_CLOSE, 0);
      // Approximate TEMA using EMA of different periods
      double ema2 = iMA(NULL, 0, 14 * 2, 0, MODE_EMA, PRICE_CLOSE, 0);
      double ema3 = iMA(NULL, 0, 14 * 3, 0, MODE_EMA, PRICE_CLOSE, 0);
      double tema = 3 * ema1 - 3 * ema2 + ema3;
      return (tema < iClose(NULL, 0, 0));
}

bool IsTRIX() {
      double ema1_0 = iMA(NULL, 0, 14, 0, MODE_EMA, PRICE_CLOSE, 0);
      double ema1_1 = iMA(NULL, 0, 14, 0, MODE_EMA, PRICE_CLOSE, 1);
      // TRIX approximation: 1-period ROC of EMA
      double trix0 = (ema1_1 > 0) ? (ema1_0 - ema1_1) / ema1_1 * 10000 : 0;
      double ema1_2 = iMA(NULL, 0, 14, 0, MODE_EMA, PRICE_CLOSE, 2);
      double trix1 = (ema1_2 > 0) ? (ema1_1 - ema1_2) / ema1_2 * 10000 : 0;
      return (trix0 > trix1);
}

