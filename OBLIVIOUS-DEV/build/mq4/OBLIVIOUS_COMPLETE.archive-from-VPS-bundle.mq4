bool FVG_IsFilled(double top, double bot){
      double hi = High[0], lo = Low[0];
      return (lo <= top && hi >= bot);
}

void SMC_Overlay_Extras() {
      if (!(SMC || ICT) || !HasBars(30)) {
        SMC_Liquidity_Clear();
        return;
      }
      bool SMC_LiquiditySwept = false;
      bool SMC_MitigationTouch = false;
      color C = RGB_Current();
      int tbar = iBars(NULL, 0);
      // Use last marked EQH/EQL levels (search recent Trig_smc_eqh_/eql_
      // lines) For simplicity, check close to current bar
      int total = ObjectsTotal();
        for (int k = 0; k < total; k++) {
          string id = ObjectName(0, k);
          if (StringFind(id, "Trig_smc_eqh_", 0) == 0 ||
              StringFind(id, "Trig_smc_eql_", 0) == 0) {
            double lvl = ObjectGetDouble(0, id, OBJPROP_PRICE, 0);
            // Sweep condition: wick through + close back
            if (High[0] > lvl && Close[0] < lvl) { // sweep of EQH (bearish)
              SL("smc", "liquidity", "sweep eqh");
              DrawShortHLine("Trig_smc_sweep_hi_" + IntegerToString(tbar),
                             Time[1], BarEndTime(0), lvl, 0, "SWEEP", true);
              SMC_LiquiditySwept = true;
            }
            if (Low[0] < lvl && Close[0] > lvl) { // sweep of EQL (bullish)
              SL("smc", "liquidity", "sweep eql");
              DrawShortHLine("Trig_smc_sweep_lo_" + IntegerToString(tbar),
                             Time[1], BarEndTime(0), lvl, 0, "SWEEP", true);
              SMC_LiquiditySwept = true;
            }
          }
        }
        // Mitigation / OB touch: if OB box exists and price taps its body
        for (int k = 0; k < total; k++) {
          string id = ObjectName(0, k);
          if (StringFind(id, "Trig_smc_ob_", 0) == 0) {
            double p0 = ObjectGetDouble(0, id, OBJPROP_PRICE, 0);
            double p1 = ObjectGetDouble(0, id, OBJPROP_PRICE, 1);
            double top = MathMax(p0, p1), bot = MathMin(p0, p1);
            if (High[0] >= bot && Low[0] <= top) {
              // touch
              SL("smc", "ob", "mitigation touch");
              DrawShortHLine("Trig_smc_ob_touch_" + IntegerToString(tbar),
                             Time[0], BarEndTime(0), Close[0], 0, "OB Touch",
                             true);
              SMC_MitigationTouch = true;
            }
          }
        }
        SMC_Liquidity_Draw();
      }
      // return (lo <= top && hi >= bot); // FVG gap zone check

bool CheckDoji(int shift) {
      double body = MathAbs(Open[shift] - Close[shift]),
             range = High[shift] - Low[shift];
      return (range > 0 && body <= 0.1 * range); }

bool CheckLongLeggedDoji(int i)
{
      double r = High[i] - Low[i];
      double b = MathAbs(Open[i] - Close[i]);
      double ls = MathMin(Open[i], Close[i]) - Low[i];
      double us = High[i] - MathMax(Open[i], Close[i]);
      return (r > 0 && b <= 0.1 * r && ls > 0.3 * r && us > 0.3 * r);
}

bool CheckBullishEngulfing(int i)
{
      return (Close[i + 1] < Open[i + 1] && Close[i] > Open[i] &&
              Open[i] <= Close[i + 1] && Close[i] >= Open[i + 1]);
}

bool CheckBearishEngulfing(int i)
{
      return (Close[i + 1] > Open[i + 1] && Close[i] < Open[i] &&
              Open[i] >= Close[i + 1] && Close[i] <= Open[i + 1]);
}

bool CheckDojiStar(int i){
      if (i < 1 || !_HasBars(i, 1))
        return false;
      double r1 = _Range(i + 1);
      if (r1 <= 0)
        return false;
      bool long1 = (_Body(i + 1) / r1 >= 0.60);
      double r = _Range(i);
      if (r <= 0)
        return false;
      bool doji = (_Body(i) / r <= 0.10);
      bool sep =
          (Low[i] > High[i + 1] || High[i] < Low[i + 1]); // "gap" / separazione
      return (
          long1 && doji &&
          (sep ||
           doji)); // su FX gap raro: ammette anche solo doji post-candela lunga
}

bool CheckMatHold(int i){
      if (i < 4 || !_HasBars(i, 4))
        return false;
      // Bull: 1 long bull, 3 piccoli controtrend dentro, 5 bull che rompe
      bool bull = (_IsBull(i + 4) && _IsBear(i + 3) && _IsBear(i + 2) &&
                   _IsBear(i + 1) && _IsBull(i) && Close[i] > Close[i + 4]);
      // Bear: speculare
      bool bear = (_IsBear(i + 4) && _IsBull(i + 3) && _IsBull(i + 2) &&
                   _IsBull(i + 1) && _IsBear(i) && Close[i] < Close[i + 4]);
      return (bull || bear);
}

bool CheckEngulfing(int i)            {
      if (Bars < 3)
        return false;
      double b0 = MathAbs(Close[1] - Open[1]), b1 = MathAbs(Close[2] - Open[2]);
      return (b0 > b1 && ((Close[1] > Open[1] && Close[2] < Open[2]) ||
                          (Close[1] < Open[1] && Close[2] > Open[2]))); }

