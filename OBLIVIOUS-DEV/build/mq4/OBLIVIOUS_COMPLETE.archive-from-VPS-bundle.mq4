string SmartLog_GetLastLines(int maxLines = 5)
{
      string result = "";
      int start = g_smartlog_head - MathMin(maxLines, g_smartlog_count);
      if (start < 0)
        start += SMARTLOG_MAX_LINES;

      int n = (int)MathMin(maxLines, g_smartlog_count);
      for (int i = 0; i < n; i++) {
        int idx = (start + i) % SMARTLOG_MAX_LINES;
        result += g_smartlog_ring[idx];
        if (i < n - 1)
          result += "\n";
      }
      return result;
}

