             pdi = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_PLUSDI, 0),
             mdi = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MINUSDI, 0);
      return (main > 20 &&
              ((s > 0 && pdi > mdi) || (s < 0 && mdi > pdi) || (s == 0 && pdi != mdi))); }

