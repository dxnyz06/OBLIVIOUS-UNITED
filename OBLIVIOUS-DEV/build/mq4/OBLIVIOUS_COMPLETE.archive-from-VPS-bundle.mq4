                                          double __AIBC_ACFAbsRet(int L) {
                                            int n = __AIBC_BarsToday(),
                                                N = n - 1;
                                            if (L >= N)
                                              return 0.0;
                                            double mean = 0;
                                            for (int i = 0; i < N; i++)
                                              mean += __AIBC_AbsReturns(i);
                                            mean /= N;
                                            double num = 0, den = 0;
                                            for (int idx = 0; idx < N; idx++) {
                                              double xi =
                                                  __AIBC_AbsReturns(idx) - mean;
                                              den += xi * xi;
                                              int j = idx + L;
                                              if (j < N) {
                                                double xj =
                                                    __AIBC_AbsReturns(j) - mean;
                                                num += xi * xj;
                                              }
                                            }
                                            if (den <= 0)
                                              return 0.0;
                                            return num / den;
                                          }

                                          double __AIBC_AbsReturns(int shift) {
                                            return 0;
                                          }

                                          int __AIBC_BarSeconds() {
                                            datetime t0 = iTime(Symbol(),
   Period(), 0),
                                                     t1 = iTime(Symbol(),
   Period(), 1);
                                            int secs = (int)MathAbs(t0 - t1);
                                            return (MathMax(
                                                1,
                                                secs)); // vincolo MQL4: min
                                            // 1s per OnTimer
                                          }

                                          int __AIBC_BarsToday() {
                                            datetime day0 = __AIBC_DailyStart();
                                            int i = 0;
                                            while (true) {
                                              datetime t =
                                                  iTime(Symbol(), Period(), i);
                                              if (t < day0 || t == 0)
                                                break;
                                              i++;
                                            }
                                            return (MathMax(
                                                2,
                                                i)); // vincolo MQL4: min
                                            // 2 per periodi
                                            // indicatori
                                          }

                                          datetime __AIBC_DailyStart() {
                                            return iTime(Symbol(), PERIOD_D1,
                                                         0);
                                          }

                                          double __AIBC_MADAbsRet() {
                                            int n = __AIBC_BarsToday();
                                            double med = __AIBC_MedianAbsRet();
                                            static double d[];
                                            ArrayResize(d, n - 1);
                                            for (int k = 0; k < n - 1; k++)
                                              d[k] = MathAbs(
                                                  __AIBC_AbsReturns(k) - med);
                                            ArraySort(d, WHOLE_ARRAY, 0);
                                            int m = (int)((n - 1) / 2);
                                            if (((n - 1) % 2) == 0)
                                              return ((d[m - 1] + d[m]) / 2.0);
                                            return d[m];
                                          }

                                          double __AIBC_MedianAbsRet() {
                                            int n = __AIBC_BarsToday();
                                            static double a[];
                                            ArrayResize(a, n - 1);
                                            for (int k = 0; k < n - 1; k++)
                                              a[k] = __AIBC_AbsReturns(k);
                                            ArraySort(a, WHOLE_ARRAY, 0);
                                            int mid = (int)((n - 1) / 2);
                                            if (((n - 1) % 2) == 0)
                                              return ((a[mid - 1] + a[mid]) /
                                                      2.0);
                                            return a[mid];
                                          }

                                          bool IsInNewsCooldown() {
                                            if (!NewsFilter)
                                              return false;
                                            static datetime lastNewsTime = 0;
                                            static int lastNewsImpact = 0;
                                            int cooldown = NewsCooldownMinutes;
                                            if (lastNewsImpact >= 3)
                                              cooldown =
                                                  NewsHighImpactCooldownMinutes;
                                            if (lastNewsTime > 0 &&
                                                TimeCurrent() - lastNewsTime <
                                                    cooldown * 60)
                                              return true;
                                            return false;
                                          }

                                          int CheckPredictedSignal() {
                                            if (g_buyCond) {
                                              return 1;
                                            }
                                            if (g_sellCond) {
                                              return -1;
                                            }
                                            return 0;
                                          }


                                            bool FVG_Logic_Legacy() {
                                              // ===== Fair Value Gap (SMC
                                              // advanced) - full auto-adaptive
                                              // (3-candle), VI (Volume
                                              // Imbalance) come
                                              // filtro/raffinamento,
                                              double atr = iATR(NULL, 0, 14, 0);
                                              double spread =
                                                  (Ask - Bid) / _Point;
                                              double maxSpread = iStdDevOnArray(
                                                  Close, 0, 20, 0, MODE_SMA, 0);
                                              if (spread > maxSpread * 2.0) {
                                                Bridge_SendLog(
                                                    2, "FVG",
                                                    "Spread too high, "
                                                    "skipping");
                                                return false;
                                              }
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              // CE/MT (entry al 50%), IFVG
                                              // (Inversion FVG) tramite
                                              // tracking locale.
                                              // Stretch/mean-reversion context
                                              // (auto-adaptive) Guard bars
                                              // (auto-adaptive, evita lookahead
                                              // e array underflow)
                                              int n_base = Auto_ATR_Period() +
                                                           Auto_ADX_Period();
                                              int c0 = 1, c1 = 2, c2 = 3;

                                              n_base = MathMax(c2, n_base);
                                              if (Bars <= (n_base + c2 + 2))
                                                return (false);

                                              double vwapZ =
                                                  Auto_Generic_Dev() *
                                                  Auto_VolFactor() *
                                                  ModeScale();
                                              if (!VWAPDeviationTrigger(vwapZ))
                                                return (false);

                                              // Imbalance istituzionale
                                              // (auto-adaptive, senza soglie
                                              // fisse)
                                              if (!FVG_InstitutionalImbalance())
                                                return (false);

                                              // Definizione FVG su barre
                                              // chiuse: c2=3, c1=2, c0=1 (evita
                                              // repaint su barra 0)
                                              bool bullFVG =
                                                  (Low[c0] > High[c2]);
                                              bool bearFVG =
                                                  (High[c0] < Low[c2]);

                                              // Tracking per IFVG (inversione)
                                              // — locale alla strategia, no
                                              // LOGIC FOR FVG]
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              static bool tr_active = false;
                                              static bool tr_bull = true;
                                              static double tr_low = 0.0,
   tr_high = 0.0;
                                              static datetime tr_time = 0;
                                              static bool tr_filled = false;
                                              static bool tr_inverted = false;

                                              // ---- IFVG maintenance: se il
                                              // gap viene "riempito" e poi
                                              // rotto, registra inversione ----
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              if (tr_active && !tr_inverted) {
                                                double buf = POI_PipSize();
                                                if (buf <= 0.0)
                                                  buf = Point;

                                                // Full fill (mitigation) e
                                                // successiva rottura oltre il
                                                // bordo => inversione
                                                if (tr_bull) {
                                                  if (!tr_filled &&
                                                      Low[c0] <= tr_low + buf)
                                                    tr_filled = true;
                                                  if (tr_filled &&
                                                      Close[c0] <
                                                          tr_low - buf) {
                                                    // Bull FVG rotto al ribasso
                                                    // => IFVG bearish
                                                    // (breaker/inversion)
                                                    // FVG]
                                                    double _atr =
                                                        iATR(NULL, 0, 14, 0);
                                                    double _spread =
                                                        (Ask - Bid) / _Point;
                                                    double _maxSpread =
                                                        iStdDevOnArray(
   Close, 0, 20, 0,
   MODE_SMA, 0);
                                                    if (_spread >
                                                        _maxSpread * 2.0) {
                                                      Bridge_SendLog(
                                                          2, "FVG",
                                                          "Spread too high, "
                                                          "skipping");
                                                      return false;
                                                    }
                                                    if (Bridge_IsConnected()) {
                                                      string aiPayload;
                                                      if (Bridge_GetAISignals(
   Symbol(),
   Period(), Time[0],
   aiPayload)) {
                                                        if (StringFind(
   aiPayload,
   "fvg=0") >= 0) {
                                                          Bridge_SendLog(
   1, "FVG",
   "AI suggests NO "
   "TRADE");
                                                          return false;
                                                        }
                                                      }
                                                    }
                                                    RegisterPOI(POI_FVG, false,
   tr_low,
   tr_high);
                                                    int idx =
                                                        ArraySize(g_POIs) - 1;
                                                    if (idx >= 0 &&
                                                        g_POIs[idx].type == POI_FVG)



                                                      g_POIs[idx].mid =
                                                          (tr_low + tr_high) /
                                                          2.0; // CE/MT
                                                    tr_inverted = true;
                                                  }
                                                } else {
                                                  if (!tr_filled &&
                                                      High[c0] >= tr_high - buf)
                                                    tr_filled = true;
                                                  if (tr_filled &&
                                                      Close[c0] >
                                                          tr_high + buf) {
                                                    // Bear FVG rotto al rialzo
                                                    // => IFVG bullish
                                                    // FVG]
                                                    double _atr =
                                                        iATR(NULL, 0, 14, 0);
                                                    double _spread =
                                                        (Ask - Bid) / _Point;
                                                    double _maxSpread =
                                                        iStdDevOnArray(
   Close, 0, 20, 0,
   MODE_SMA, 0);
                                                    if (_spread >
                                                        _maxSpread * 2.0) {
                                                      Bridge_SendLog(
                                                          2, "FVG",
                                                          "Spread too high, "
                                                          "skipping");
                                                      return false;
                                                    }
                                                    if (Bridge_IsConnected()) {
                                                      string aiPayload;
                                                      if (Bridge_GetAISignals(
   Symbol(),
   Period(), Time[0],
   aiPayload)) {
                                                        if (StringFind(
   aiPayload,
   "fvg=0") >= 0) {
                                                          Bridge_SendLog(
   1, "FVG",
   "AI suggests NO "
   "TRADE");
                                                          return false;
                                                        }
                                                      }
                                                    }
                                                    RegisterPOI(POI_FVG, true,
   tr_low,
   tr_high);
                                                    int idx =
                                                        ArraySize(g_POIs) - 1;
                                                    if (idx >= 0 &&
                                                        g_POIs[idx].type == POI_FVG)



                                                      g_POIs[idx].mid =
                                                          (tr_low + tr_high) /
                                                          2.0; // CE/MT
                                                    tr_inverted = true;
                                                  }
                                                }
                                              }

                                              if (!(bullFVG || bearFVG))
                                                return (false);

                                              // Zona FVG (full gap)
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              double zLow = 0.0, zHigh = 0.0;
                                              bool isBull = bullFVG;

                                              if (bullFVG) {
                                                zLow = High[c2];
                                                zHigh = Low[c0];
                                              } else {
                                                zLow = High[c0];
                                                zHigh = Low[c2];
                                              }

                                              if (zHigh <= zLow)
                                                return (false);

                                              // CE / MT (Mean Threshold): 50%
                                              // della zona
                                              double ce = (zLow + zHigh) / 2.0;

                                              // VI (Volume Imbalance) —
                                              // filtro/raffinamento
                                              // autoadaptive usando mediane
                                              int n = Auto_ATR_Period() +
                                                      Auto_ADX_Period();
                                              n = MathMax(3, n);
                                              n = MathMin(n, Bars - (c2 + 2));
                                              double atr_vi =
                                                  iATR(Symbol(), PERIOD_CURRENT,
                                                       Auto_ATR_Period(), c0);
                                              if (atr_vi <= 0.0)
                                                atr_vi = iATR(
                                                    Symbol(), PERIOD_CURRENT,
                                                    Auto_ATR_Period(), 0);

                                              if (n >= 3 && atr_vi > 0.0) {
                                                double vols[];
                                                ArrayResize(vols, n);
                                                double bods[];
                                                ArrayResize(bods, n);
                                                double scs[];
                                                ArrayResize(scs, n);

                                                for (int i = 0; i < n; i++) {
                                                  int sh = c0 + i;
                                                  vols[i] = iVolume(
                                                      Symbol(), PERIOD_CURRENT,
                                                      sh);
                                                  bods[i] = MathAbs(Close[sh] -
   Open[sh]);
                                                }

                                                double vmed = __Median(vols, n);
                                                double bmed = __Median(bods, n);
                                                if (vmed <= 0.0)
                                                  vmed = vols[0];
                                                if (bmed <= 0.0)
                                                  bmed = bods[0];

                                                for (int j = 0; j < n; j++) {
                                                  double vr =
                                                      (vmed > 0.0
                                                           ? vols[j] / vmed
                                                           : 1.0);
                                                  double br =
                                                      (atr_vi > 0.0 ? bods[j] / atr_vi
   : 1.0);
                                                  scs[j] = vr * br;
                                                }

                                                double sc_med =
                                                    __Median(scs, n);

                                                // score del displacement candle
                                                // (c1): dovrebbe essere outlier
                                                // positivo
                                                double v1 =
                                                    iVolume(Symbol(),
   PERIOD_CURRENT, c1);
                                                double b1 = MathAbs(Close[c1] -
   Open[c1]);
                                                double vr1 =
                                                    (vmed > 0.0 ? v1 / vmed
   : 1.0);
                                                double br1 =
                                                    (atr_vi > 0.0 ? b1 / atr_vi
   : 1.0);
                                                double sc1 = vr1 * br1;

                                                bool vi_ok = (sc1 > sc_med);

                                                if (vi_ok) {
                                                  // Raffina la zona verso
                                                  // l'imbalance (corpo del
                                                  // displacement) se
                                                  // sovrapposto al gap
                                                  double bLo = MathMin(
                                                      Open[c1], Close[c1]);
                                                  double bHi = MathMax(
                                                      Open[c1], Close[c1]);

                                                  double rzLow =
                                                      MathMax(zLow, bLo);
                                                  double rzHigh =
                                                      MathMin(zHigh, bHi);

                                                  if (rzHigh > rzLow) {
                                                    zLow = rzLow;
                                                    zHigh = rzHigh;
                                                    ce = (zLow + zHigh) /
                                                         2.0; // aggiorna CE/MT
   // sul refined
                                                  }
                                                }
                                              }

                                              // Registra POI FVG (zona
                                              // raffinata o full) e forza entry
                                              // FOR FVG]
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              RegisterPOI(POI_FVG, isBull, zLow,
                                                          zHigh);
                                              int idx = ArraySize(g_POIs) - 1;
                                              if (idx >= 0 &&
                                                  g_POIs[idx].type == POI_FVG)
                                                g_POIs[idx].mid = ce;

                                              // Aggiorna tracking IFVG
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              tr_active = true;
                                              tr_bull = isBull;
                                              tr_low = zLow;
                                              tr_high = zHigh;
                                              tr_time = TimeCurrent();
                                              tr_filled = false;
                                              tr_inverted = false;

                                              return (true);
                                            }

                                          void CheckPredictedAutoMode() {
                                            if (!g_BridgeConnected) return;
                                            // tpsl AI active: computed inline via IsTPSL_AI() && ai_file_present
                                          }

                                          void CheckPredictedManualMode() {
                                            if (g_BridgeConnected) return;
                                            // Manual mode: check AI signals file via Bridge mechanism
                                          }

                                          int GetCurrentAISignal_v2(
                                              int &confidence) {
                                            // Bridge-based: read from in-memory
                                            // AI signal state
                                            confidence = g_aiSignalConf;
                                            // Stale check: discard signal older
                                            // than AISignalStaleSeconds
                                            if (TimeCurrent() - g_aiSignalTime >
                                                AISignalStaleSeconds) {
                                              g_aiSignalDir = 0;
                                              g_aiSignalConf = 0;
                                              return 0;
                                            }
                                            return g_aiSignalDir;
                                          }

                                          // delta=+42chars from
                                          // Bridge-based: check kernel32 pipe
                                          // handle validity
                                          // (g_hAIPipeIn ==
                                          // INVALID_HANDLE_VALUE) {
                                          // AI_PIPE_NAME_IN,
                                          // OPEN_EXISTING,
                                          // FILE_ATTRIBUTE_NORMAL,
                                          // INVALID_HANDLE_VALUE);

bool CheckAISignals() {
   if (!Predicted) return false;
   return (g_aip_direction != 0 && g_aip_confidence >= (double)AiMinConfidence);
}

                                          string GetAISignalsJSON() {
                                            // Bridge-based AI signals
                                            // retrieval (replaces //
                                            // Bridge_* mechanism]
                                            string ai_signals = "";
                                            string payload = "";
                                            datetime lastBarTime = iTime(
                                                Symbol(), PERIOD_CURRENT, 1);

                                            if (Bridge_GetAISignals(
                                                    Symbol(), Period(),
                                                    lastBarTime, payload)) {
                                              // Parse payload: format
                                              // "key=value;key=value|..."
                                              // or simple
                                              // "symbol|type|confidence|..."
                                              if (StringLen(payload) > 0) {
                                                string signals[];
                                                int sigCount = StringSplit(
                                                    payload, '|', signals);
                                                int parsed = 0;

                                                for (int i = 0;
                                                     i < sigCount && parsed < 3;
                                                     i++) {
                                                  if (StringLen(signals[i]) == 0)



                                                    continue;

                                                  // Parse signal:
                                                  // "SYMBOL,TYPE,CONFIDENCE"
                                                  // or key=value pairs
                                                  string parts[];
                                                  int partCount = StringSplit(
                                                      signals[i], ',', parts);

                                                  if (partCount >= 3) {
                                                    if (parsed > 0)
                                                      ai_signals += ",";
                                                    ai_signals += StringFormat(
                                                        "{\"symbol\":\"%\""
                                                        "s\",\"type\":\"%\""
                                                        "s\",\""
                                                        "confidence\":\"%\""
                                                        "s\",\"time\":\"%\""
                                                        "s\"}",
                                                        parts[0], parts[1],
                                                        parts[2],
                                                        TimeToString(
   TimeCurrent(),
   TIME_MINUTES));
                                                    parsed++;
                                                  } else {
                                                    // Try key=value format
                                                    int eqPos = StringFind(
                                                        signals[i], "=");
                                                    if (eqPos > 0) {
                                                      // Simple format: just
                                                      // add as-is
                                                      if (parsed > 0)
                                                        ai_signals += ",";
                                                      ai_signals += StringFormat(
                                                          "{\"signal\":\"%\""
                                                          "s\",\"time\":\"%\""
                                                          "s\"}",
                                                          signals[i],
                                                          TimeToString(
   TimeCurrent(),
   TIME_MINUTES));
                                                      parsed++;
                                                    }
                                                  }
                                                }
                                              }
                                            }

                                            // If no AI signals, provide
                                            // default standby data
                                            if (ai_signals == "") {
                                              ai_signals = StringFormat(
                                                  "{\"symbol\":\"%s\","
                                                  "\"type\":\"STANDBY\","
                                                  "\"confidence\":\"0\","
                                                  "\"time\":\"%s\"}",
                                                  Symbol(),
                                                  TimeToString(TimeCurrent(), TIME_MINUTES));
                                            }
                                            return ai_signals;
                                          }

                                          int GetAISignal() { return 0; }

// ============================================================
// ZeroMQ transport state (R3, R4) — owns the live g_ai_* update path.
// ============================================================
Context  g_zmq_ctx("ObliviousEA");
Socket   g_zmq_req(g_zmq_ctx, ZMQ_REQ);
Socket   g_zmq_sub(g_zmq_ctx, ZMQ_SUB);
Socket   g_zmq_push(g_zmq_ctx, ZMQ_PUSH);
bool     g_zmq_initialized   = false;
datetime g_ai_lastHeartbeat  = 0;
uint     g_zmq_lastPushMs    = 0;
string   g_ai_lastNewsCacheJson = "";
datetime g_ai_lastNewsCacheTs   = 0;
string   g_ai_lastBookmapJson   = "";
datetime g_ai_lastBookmapTs     = 0;

// ============================================================
// Order ownership registry (R7) — every order opened by a hub
// command (EXECUTE_ORDER) is recorded so subsequent CANCEL /
// INVALIDATE / REFINE_TPSL only touches what they're allowed to.
// ============================================================
struct OrderOwnership {
   int      ticket;
   int      magic;
   string   owner;        // "Predicted"/"Breakout"/...
   string   source;       // "hub_command" | "native"
   int      ocoPeerTicket; // OCO sibling for Predicted, else 0
   datetime opened_at;
   string   correlation;  // hub correlation id, optional
};
OrderOwnership g_orderOwnership[OWNERSHIP_MAX];
int            g_ownershipCount = 0;

// Forward declarations (definitions further below).
bool   ZMQ_Init();
void   ZMQ_Shutdown();
bool   ZMQ_SendRequest(string payload, string &reply);
bool   ZMQ_PushContext(string payload);
int    ZMQ_DrainSubscriber();
void   AI_HandleHeartbeat(string body);
void   AI_HandleCommand(string body);
void   AI_HandleNews(string body);
void   AI_HandleBookmap(string body);
void   Cmd_HandleExecute(string body);
void   Cmd_HandleHold(string body);
void   Cmd_HandleCancel(string body);
void   Cmd_HandleInvalidate(string body);
void   Cmd_HandleRefineTPSL(string body);
int    Ownership_Add(int ticket, int magic, string owner, string source, int ocoPeer, string correlation);
int    Ownership_FindByTicket(int ticket);
bool   Ownership_Remove(int ticket);
string Ownership_GetOwner(int ticket);
bool   Ownership_IsHubManaged(int ticket);

                                          void AIBridge_Init() {
                                            g_ai_connected = false;
                                            g_ai_enabled = true;
                                            g_ai_status = "INIT";
                                            g_ai_errorCount = 0;
                                            g_ai_successCount = 0;

                                            // Auto-disable in Strategy
                                            // Tester
                                            if (IsTesting() ||
                                                IsOptimization()) {
                                              g_ai_enabled = false;
                                              g_ai_status = "DISABLED_TESTER";
                                              Print("[AIBridge] Disabled "
                                                    "in Strategy Tester");
                                              return;
                                            }

                                            // Check if DLLs are allowed
                                            if (!IsDllsAllowed()) {
                                              g_ai_enabled = false;
                                              g_ai_status = "DISABLED_NO_DLL";
                                              Print("[AIBridge] DLL imports "
                                                    "not allowed - running "
                                                    "in local mode");
                                              return;
                                            }

                                            // Attempt initial connection
                                            AIBridge_Connect();

                                            PrintFormat(
                                                "[AIBridge] Init | "
                                                "Enabled: %s | Connected: "
                                                "%s",
                                                g_ai_enabled ? "YES" : "NO",
                                                g_ai_connected ? "YES" : "NO");
                                          }

// ============================================================
// R3: AIBridge transport — ZeroMQ implementations.
// AIBridge_Connect, AIBridge_Disconnect, AIBridge_SendRequest and
// AIBridge_Poll are thin wrappers over the ZMQ_* helpers further
// below. The legacy named-pipe code path was removed; all four
// functions now feed/read from the live g_zmq_* sockets and update
// the g_ai_* globals so AIBridge_IsConnected/GetDirection/...
// reflect transport reality (R4).
// ============================================================
bool AIBridge_Connect() {
   if (!g_ai_enabled) return false;
   bool ok = ZMQ_Init();
   if (ok) {
      g_ai_connected    = true;
      g_BridgeConnected = true;
      g_ai_status       = "ZMQ_CONNECTED";
      Print("[AIBridge] ZMQ ready (REQ:5555 / SUB:5556 / PUSH:5557)");
   } else {
      g_ai_connected    = false;
      g_BridgeConnected = false;
      g_ai_status       = "ZMQ_CONNECT_FAILED";
      g_ai_errorCount++;
   }
   return ok;
}

void AIBridge_Disconnect() {
   ZMQ_Shutdown();
   g_ai_connected    = false;
   g_BridgeConnected = false;
   g_ai_status       = "ZMQ_DISCONNECTED";
}

bool AIBridge_SendRequest(string request) {
   // Fire-and-forget context push on PUSH socket. Used by SendMarketData
   // and Bridge_SendLog. Non-blocking; if the hub is not draining we
   // bump g_ai_errorCount and degrade the bridge state for R4.
   if (!g_ai_enabled || !g_zmq_initialized) return false;
   if (!ZMQ_PushContext(request)) {
      g_ai_errorCount++;
      g_ai_status = "ZMQ_PUSH_FAILED";
      return false;
   }
   return true;
}

void AIBridge_Poll() {
   // Drain SUB socket (non-blocking) to update g_ai_* + news/bookmap
   // caches + dispatch hub commands.  Also enforces the heartbeat
   // staleness check so g_ai_connected drops when the hub goes silent.
   if (!g_ai_enabled) return;
   if (!g_zmq_initialized) {
      AIBridge_Connect();
      if (!g_zmq_initialized) return;
   }
   int n = ZMQ_DrainSubscriber();
   if (n > 0) {
      g_ai_lastResponse = TimeCurrent();
      g_ai_successCount++;
      g_ai_status = "ACTIVE";
   }
   if (g_ai_lastHeartbeat > 0 &&
       (TimeCurrent() - g_ai_lastHeartbeat) > ZMQ_HEARTBEAT_TIMEOUT_S) {
      g_ai_connected    = false;
      g_BridgeConnected = false;
      g_ai_status       = "HEARTBEAT_TIMEOUT";
   }
}


                                          void AIBridge_ParseResponse(
                                              string response) {
                                            // Expected format:
                                            // "DIR:1|CONF:0.85|TP:1.2345|SL:1.2300|TRAIL:0.0015"
                                            // or simple: "BUY|0.85" /
                                            // "SELL|0.72" / "NONE|0.0"

                                            g_ai_direction = 0;
                                            g_ai_confidence = 0;
                                            g_ai_virtualTP = 0;
                                            g_ai_virtualSL = 0;
                                            g_ai_virtualTrail = 0;
                                            g_ai_lastSignal = response;

                                            // Try structured format first
                                            if (StringFind(response, "DIR:") >=
                                                0) {
                                              AIBridge_ParseStructured(
                                                  response);
                                              return;
                                            }

                                            // Simple format
                                            if (StringFind(response, "BUY") >=
                                                0)
                                              g_ai_direction = 1;
                                            else if (StringFind(response,
   "SELL") >= 0)
                                              g_ai_direction = -1;

                                            // Extract confidence
                                            int pipePos =
                                                StringFind(response, "|");
                                            if (pipePos > 0) {
                                              string confStr = StringSubstr(
                                                  response, pipePos + 1);
                                              g_ai_confidence =
                                                  StringToDouble(confStr);
                                            }

                                            // Validate
                                            AIBridge_ValidateSignal();
                                          }

                                          void AIBridge_ParseStructured(
                                              string response) {
                                            // DIR:1|CONF:0.85|TP:1.2345|SL:1.2300|TRAIL:0.0015
                                            string parts[];
                                            int count = AIBridge_StringSplit(
                                                response, '|', parts);

                                            for (int i = 0; i < count; i++) {
                                              int colonPos =
                                                  StringFind(parts[i], ":");
                                              if (colonPos <= 0)
                                                continue;

                                              string key = StringSubstr(
                                                  parts[i], 0, colonPos);
                                              string val = StringSubstr(
                                                  parts[i], colonPos + 1);

                                              if (key == "DIR")
                                                g_ai_direction =
                                                    (int)StringToInteger(val);
                                              else if (key == "CONF")
                                                g_ai_confidence =
                                                    StringToDouble(val);
                                              else if (key == "TP")
                                                g_ai_virtualTP =
                                                    StringToDouble(val);
                                              else if (key == "SL")
                                                g_ai_virtualSL =
                                                    StringToDouble(val);
                                              else if (key == "TRAIL")
                                                g_ai_virtualTrail =
                                                    StringToDouble(val);
                                            }

                                            AIBridge_ValidateSignal();
                                          }

                                          void AIBridge_ValidateSignal() {
                                            // Clamp direction
                                            if (g_ai_direction > 1)
                                              g_ai_direction = 1;
                                            if (g_ai_direction < -1)
                                              g_ai_direction = -1;

                                            // Clamp confidence
                                            if (g_ai_confidence < 0)
                                              g_ai_confidence = 0;
                                            if (g_ai_confidence > 1.0)
                                              g_ai_confidence = 1.0;

                                            // Validate TP/SL (must be
                                            // positive and reasonable)
                                            if (g_ai_virtualTP < 0)
                                              g_ai_virtualTP = 0;
                                            if (g_ai_virtualSL < 0)
                                              g_ai_virtualSL = 0;
                                            if (g_ai_virtualTrail < 0)
                                              g_ai_virtualTrail = 0;
                                          }

// AIBridge_SendMarketData → ships a JSON context_push on the PUSH
// socket (port 5557). High-frequency, non-blocking, throttled by
// ZMQ_PUSH_THROTTLE_MS so we never block the EA tick on transport.
void AIBridge_SendMarketData(string symbol) {
   if (!g_ai_enabled || !g_zmq_initialized) return;
   string payload = StringFormat(
      "{\"op\":\"context_push\",\"sym\":\"%s\",\"tf\":%d,\"bid\":%.5f,\"ask\":%.5f,"
      "\"atr\":%.5f,\"rsi\":%.2f,\"adx\":%.2f,\"trend\":%d,\"spread\":%.1f,"
      "\"news_block\":%s,\"news_impact\":%d,\"strategies\":{\"predicted\":%s,\"breakout\":%s,"
      "\"fvg\":%s,\"grid\":%s,\"reverse\":%s,\"smc\":%s,\"ict\":%s},"
      "\"tpsl_mode\":\"%s\",\"ts\":%d}",
      symbol, Period(),
      MarketInfo(symbol, MODE_BID), MarketInfo(symbol, MODE_ASK),
      iATR(symbol, 0, 14, 0),
      iRSI(symbol, 0, 14, PRICE_CLOSE, 0),
      Ind_ADX(symbol), Ind_TrendDir(symbol),
      RiskEngine_GetSpread(),
      g_news_blockTrading ? "true" : "false", (int)g_news_currentImpact,
      Predicted ? "true" : "false", Breakout ? "true" : "false",
      FVG ? "true" : "false", Grid ? "true" : "false",
      Reverse ? "true" : "false", SMC ? "true" : "false",
      ICT ? "true" : "false",
      IsTPSL_AI() ? "AI" : "Native",
      (int)TimeCurrent());
   AIBridge_SendRequest(payload);
}

                                          int AIBridge_StringSplit(
                                              string str, ushort sep,
                                              string & result[]) {
                                            ArrayResize(result, 0);
                                            int count = 0;
                                            string current = "";

                                            for (int i = 0; i < StringLen(str);
                                                 i++) {
                                              ushort ch =
                                                  StringGetCharacter(str, i);
                                              if (ch == sep) {
                                                ArrayResize(result, count + 1);
                                                result[count] = current;
                                                count++;
                                                current = "";
                                              } else {
                                                current +=
                                                    CharToString((uchar)ch);
                                              }
                                            }

                                            if (StringLen(current) > 0) {
                                              ArrayResize(result, count + 1);
                                              result[count] = current;
                                              count++;
                                            }

                                            return count;
                                          }

                                          bool AIBridge_IsEnabled() {
                                            return Predicted;
                                          }

                                          // R4: real bridge state.  All seven
                                          // accessors expose the live g_ai_*
                                          // globals that are updated by the
                                          // ZeroMQ transport (REQ response,
                                          // SUB heartbeat, SUB command,
                                          // timeout/reconnect).  No stub
                                          // returns.
                                          bool AIBridge_IsConnected() {
                                            return g_ai_connected;
                                          }

                                          int AIBridge_GetDirection() {
                                            return g_ai_direction;
                                          }

                                          double AIBridge_GetConfidence() {
                                            return g_ai_confidence;
                                          }

                                          string AIBridge_GetStatus() {
                                            return g_ai_status;
                                          }

                                          string AIBridge_GetLastSignal() {
                                            return g_ai_lastSignal;
                                          }

                                          int AIBridge_GetErrorCount() {
                                            return g_ai_errorCount;
                                          }

                                          int AIBridge_GetSuccessCount() {
                                            return g_ai_successCount;
                                          }

// ============================================================
// R3 / R4 / R7 — ZMQ transport, hub-command dispatcher, and
// order ownership registry implementations.
// ============================================================

// --- Pipe-format helpers (key=value | separated)
string Msg_GetField(string body, string key) {
   string sep_needle = "|" + key + "=";
   int p = StringFind(body, sep_needle);
   int valStart;
   if (p < 0) {
      string head_needle = key + "=";
      if (StringFind(body, head_needle) != 0) return "";
      valStart = StringLen(head_needle);
   } else {
      valStart = p + StringLen(sep_needle);
   }
   int valEnd = StringFind(body, "|", valStart);
   if (valEnd < 0) valEnd = StringLen(body);
   return StringSubstr(body, valStart, valEnd - valStart);
}

double Msg_GetDouble(string body, string key, double dflt) {
   string v = Msg_GetField(body, key);
   if (StringLen(v) == 0) return dflt;
   return StringToDouble(v);
}

int Msg_GetInt(string body, string key, int dflt) {
   string v = Msg_GetField(body, key);
   if (StringLen(v) == 0) return dflt;
   return (int)StringToInteger(v);
}

// --- Ownership registry (R7) -----------------------------------
int Ownership_FindByTicket(int ticket) {
   for (int i = 0; i < g_ownershipCount; i++) {
      if (g_orderOwnership[i].ticket == ticket) return i;
   }
   return -1;
}

int Ownership_Add(int ticket, int magic, string owner, string source,
                  int ocoPeer, string correlation) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx >= 0) {
      g_orderOwnership[idx].magic         = magic;
      g_orderOwnership[idx].owner         = owner;
      g_orderOwnership[idx].source        = source;
      g_orderOwnership[idx].ocoPeerTicket = ocoPeer;
      g_orderOwnership[idx].correlation   = correlation;
      return idx;
   }
   if (g_ownershipCount >= OWNERSHIP_MAX) return -1;
   idx                                    = g_ownershipCount;
   g_orderOwnership[idx].ticket           = ticket;
   g_orderOwnership[idx].magic            = magic;
   g_orderOwnership[idx].owner            = owner;
   g_orderOwnership[idx].source           = source;
   g_orderOwnership[idx].ocoPeerTicket    = ocoPeer;
   g_orderOwnership[idx].correlation      = correlation;
   g_orderOwnership[idx].opened_at        = TimeCurrent();
   g_ownershipCount++;
   return idx;
}

bool Ownership_Remove(int ticket) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx < 0) return false;
   for (int i = idx; i < g_ownershipCount - 1; i++) {
      g_orderOwnership[i] = g_orderOwnership[i + 1];
   }
   g_ownershipCount--;
   return true;
}

string Ownership_GetOwner(int ticket) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx < 0) return "";
   return g_orderOwnership[idx].owner;
}

bool Ownership_IsHubManaged(int ticket) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx < 0) return false;
   return (g_orderOwnership[idx].source == "hub_command");
}

// --- ZMQ transport core ----------------------------------------
bool ZMQ_Init() {
   if (g_zmq_initialized) return true;
   g_zmq_req.setLinger(ZMQ_LINGER_MS);
   g_zmq_req.setSendTimeout(ZMQ_REQ_TIMEOUT_MS);
   g_zmq_req.setReceiveTimeout(ZMQ_REQ_TIMEOUT_MS);
   if (!g_zmq_req.connect(ZMQ_REQ_ENDPOINT)) {
      Print("[ZMQ] REQ connect failed: ", ZMQ_REQ_ENDPOINT);
      return false;
   }
   g_zmq_sub.setLinger(ZMQ_LINGER_MS);
   g_zmq_sub.setReceiveHighWaterMark(10000);
   if (!g_zmq_sub.connect(ZMQ_SUB_ENDPOINT)) {
      Print("[ZMQ] SUB connect failed: ", ZMQ_SUB_ENDPOINT);
      g_zmq_req.disconnect(ZMQ_REQ_ENDPOINT);
      return false;
   }
   g_zmq_sub.subscribe(ZMQ_TOPIC_HEARTBEAT);
   g_zmq_sub.subscribe(ZMQ_TOPIC_COMMAND);
   g_zmq_sub.subscribe(ZMQ_TOPIC_NEWS);
   g_zmq_sub.subscribe(ZMQ_TOPIC_BOOKMAP);
   g_zmq_push.setLinger(ZMQ_LINGER_MS);
   g_zmq_push.setSendHighWaterMark(10000);
   if (!g_zmq_push.connect(ZMQ_PUSH_ENDPOINT)) {
      Print("[ZMQ] PUSH connect failed: ", ZMQ_PUSH_ENDPOINT);
      g_zmq_req.disconnect(ZMQ_REQ_ENDPOINT);
      g_zmq_sub.disconnect(ZMQ_SUB_ENDPOINT);
      return false;
   }
   g_zmq_initialized  = true;
   g_ai_lastHeartbeat = 0;
   PrintFormat("[ZMQ] connected | REQ=%s SUB=%s PUSH=%s",
               ZMQ_REQ_ENDPOINT, ZMQ_SUB_ENDPOINT, ZMQ_PUSH_ENDPOINT);
   return true;
}

void ZMQ_Shutdown() {
   if (!g_zmq_initialized) return;
   g_zmq_req.disconnect(ZMQ_REQ_ENDPOINT);
   g_zmq_sub.disconnect(ZMQ_SUB_ENDPOINT);
   g_zmq_push.disconnect(ZMQ_PUSH_ENDPOINT);
   g_zmq_initialized = false;
   Print("[ZMQ] sockets disconnected");
}

bool ZMQ_SendRequest(string payload, string &reply) {
   reply = "";
   if (!g_zmq_initialized) return false;
   ZmqMsg out_msg(payload);
   if (!g_zmq_req.send(out_msg)) {
      g_ai_errorCount++;
      g_ai_status = "ZMQ_REQ_SEND_FAIL";
      return false;
   }
   ZmqMsg in_msg;
   if (!g_zmq_req.recv(in_msg)) {
      g_ai_errorCount++;
      g_ai_status = "ZMQ_REQ_TIMEOUT";
      return false;
   }
   reply             = in_msg.getData();
   g_ai_lastResponse = TimeCurrent();
   g_ai_successCount++;
   return true;
}

bool ZMQ_PushContext(string payload) {
   if (!g_zmq_initialized) return false;
   uint nowMs = GetTickCount();
   if (g_zmq_lastPushMs > 0 &&
       (nowMs - g_zmq_lastPushMs) < ZMQ_PUSH_THROTTLE_MS) {
      return true;  // coalesced — drop within window, R3
   }
   g_zmq_lastPushMs = nowMs;
   ZmqMsg msg(payload);
   return g_zmq_push.send(msg, true);  // non-blocking
}

int ZMQ_DrainSubscriber() {
   if (!g_zmq_initialized) return 0;
   int processed = 0;
   for (int i = 0; i < ZMQ_SUB_DRAIN_MAX; i++) {
      ZmqMsg topic_msg;
      if (!g_zmq_sub.recv(topic_msg, true)) break;
      string topic = topic_msg.getData();
      string body  = "";
      // mql-zmq exposes the multipart-flag as ZmqMsg.more() (per-message)
      // which mirrors libzmq's zmq_msg_more().  hasMore() doesn't exist.
      if (topic_msg.more()) {
         ZmqMsg body_msg;
         if (g_zmq_sub.recv(body_msg, true)) body = body_msg.getData();
      }
      if (StringFind(topic, ZMQ_TOPIC_HEARTBEAT) == 0)      AI_HandleHeartbeat(body);
      else if (StringFind(topic, ZMQ_TOPIC_COMMAND)   == 0) AI_HandleCommand(body);
      else if (StringFind(topic, ZMQ_TOPIC_NEWS)      == 0) AI_HandleNews(body);
      else if (StringFind(topic, ZMQ_TOPIC_BOOKMAP)   == 0) AI_HandleBookmap(body);
      processed++;
   }
   return processed;
}

// --- SUB topic handlers (R4, R6) -------------------------------
void AI_HandleHeartbeat(string body) {
   g_ai_lastHeartbeat = TimeCurrent();
   g_ai_connected     = true;
   g_BridgeConnected  = true;
   g_ai_status        = "ACTIVE";
   string dir = Msg_GetField(body, "ai_dir");
   if (StringLen(dir) > 0) {
      if (dir == "BUY")       g_ai_direction = 1;
      else if (dir == "SELL") g_ai_direction = -1;
      else                    g_ai_direction = 0;
   }
   double conf = Msg_GetDouble(body, "ai_conf", -1.0);
   if (conf >= 0.0) g_ai_confidence = conf;
   string sig = Msg_GetField(body, "ai_signal");
   if (StringLen(sig) > 0) g_ai_lastSignal = sig;
}

// R6: news state from hub becomes a HINT for the local NewsPolicy,
//     not a parallel block layer.  We update the news cache only;
//     NewsPolicy_CanOpen() remains the single gate.
void AI_HandleNews(string body) {
   g_ai_lastNewsCacheJson = body;
   g_ai_lastNewsCacheTs   = TimeCurrent();
   int    block   = Msg_GetInt(body, "block", 0);
   int    impact  = Msg_GetInt(body, "impact", 0);
   string nextEv  = Msg_GetField(body, "next_event");
   int    untilTs = Msg_GetInt(body, "until_ts", 0);
   g_news_blockTrading   = (block != 0);
   g_news_currentImpact  = impact;
   g_news_highImpactNow  = (impact >= 3);
   if (StringLen(nextEv) > 0) g_news_nextEvent = nextEv;
   if (untilTs > 0) g_news_nextEventTime = (datetime)untilTs;
   g_news_lastUpdate = TimeCurrent();
}

void AI_HandleBookmap(string body) {
   g_ai_lastBookmapJson = body;
   g_ai_lastBookmapTs   = TimeCurrent();
}

void AI_HandleCommand(string body) {
   string op = Msg_GetField(body, "op");
   if      (op == "EXECUTE_ORDER") Cmd_HandleExecute(body);
   else if (op == "HOLD")          Cmd_HandleHold(body);
   else if (op == "CANCEL")        Cmd_HandleCancel(body);
   else if (op == "INVALIDATE")    Cmd_HandleInvalidate(body);
   else if (op == "REFINE_TPSL")   Cmd_HandleRefineTPSL(body);
   else PrintFormat("[Hub Cmd] unknown op=%s body=%s", op, body);
}

// --- Hub command handlers (R7) ---------------------------------
// All handlers preserve owner strategy / magic / comment / TP ladder
// / OCO Predicted / pending cancel / invalidation state through the
// ownership registry. Lots routed via Risk_Preflight (Phase 4).
void Cmd_HandleExecute(string body) {
   string sym         = Msg_GetField(body, "sym");
   string side        = Msg_GetField(body, "side");
   string ordType     = Msg_GetField(body, "ord_type");  // MARKET|LIMIT|STOP
   string owner       = Msg_GetField(body, "owner");
   int    magic       = Msg_GetInt(body, "magic", 0);
   double slPips      = Msg_GetDouble(body, "sl_pips", 0.0);
   double riskPct     = Msg_GetDouble(body, "risk_pct", 0.0);
   double price       = Msg_GetDouble(body, "price", 0.0);
   double tp1         = Msg_GetDouble(body, "tp1", 0.0);
   double tp2         = Msg_GetDouble(body, "tp2", 0.0);
   double tp3         = Msg_GetDouble(body, "tp3", 0.0);
   double tpMax       = Msg_GetDouble(body, "tp_max", 0.0);
   double sl          = Msg_GetDouble(body, "sl", 0.0);
   string comment     = Msg_GetField(body, "comment");
   string corr        = Msg_GetField(body, "corr");
   int    ocoPeer     = Msg_GetInt(body, "oco_peer", 0);

   if (StringLen(sym) == 0) sym = Symbol();

   // R5: every hub-driven order routes through Risk_Preflight, the
   // single point that clamps to MaxRiskTradePercent + broker step
   // + Grid basket budget + EA gates.
   double desired = (ManualLot > 0)
                       ? ManualLot
                       : RiskEngine_ComputeLots(sym, riskPct, slPips);
   string risk_reason;
   int    side_dir = (side == "BUY") ? 1 : -1;
   double lots = Risk_Preflight(sym, owner, desired, slPips, side_dir, risk_reason);
   if (lots <= 0.0) {
      PrintFormat("[Hub Cmd] EXECUTE blocked sym=%s owner=%s reason=%s",
                  sym, owner, risk_reason);
      return;
   }
   int cmd;
   if (ordType == "MARKET") {
      cmd = (side == "BUY") ? OP_BUY : OP_SELL;
      double execPrice = (cmd == OP_BUY) ? MarketInfo(sym, MODE_ASK)
                                         : MarketInfo(sym, MODE_BID);
      int ticket = SafeOrderSend(sym, cmd, lots, execPrice, 10, sl,
                             (tp1 > 0 ? tp1 : tpMax), comment, magic, 0, clrNONE);
      if (ticket > 0) {
         Ownership_Add(ticket, magic, owner, "hub_command", ocoPeer, corr);
         PrintFormat("[Hub Cmd] EXECUTE %s %s lots=%.2f ticket=%d owner=%s",
                     side, sym, lots, ticket, owner);
      } else {
         PrintFormat("[Hub Cmd] EXECUTE failed err=%d owner=%s", GetLastError(), owner);
      }
      return;
   }
   if (ordType == "LIMIT" || ordType == "STOP") {
      if (ordType == "LIMIT") cmd = (side == "BUY") ? OP_BUYLIMIT : OP_SELLLIMIT;
      else                    cmd = (side == "BUY") ? OP_BUYSTOP  : OP_SELLSTOP;
      int ticket = SafeOrderSend(sym, cmd, lots, price, 10, sl,
                             (tp1 > 0 ? tp1 : tpMax), comment, magic, 0, clrNONE);
      if (ticket > 0) {
         Ownership_Add(ticket, magic, owner, "hub_command", ocoPeer, corr);
         PrintFormat("[Hub Cmd] EXECUTE %s %s pending lots=%.2f ticket=%d owner=%s",
                     ordType, sym, lots, ticket, owner);
      } else {
         PrintFormat("[Hub Cmd] EXECUTE pending failed err=%d owner=%s",
                     GetLastError(), owner);
      }
   }
}

void Cmd_HandleHold(string body) {
   string owner = Msg_GetField(body, "owner");
   string reason = Msg_GetField(body, "reason");
   PrintFormat("[Hub Cmd] HOLD owner=%s reason=%s", owner, reason);
}

void Cmd_HandleCancel(string body) {
   int ticket = Msg_GetInt(body, "ticket", 0);
   string owner = Msg_GetField(body, "owner");
   if (ticket <= 0) return;
   if (StringLen(owner) > 0 && Ownership_GetOwner(ticket) != owner) {
      PrintFormat("[Hub Cmd] CANCEL owner mismatch ticket=%d expected=%s actual=%s",
                  ticket, owner, Ownership_GetOwner(ticket));
      return;
   }
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) return;
   int otype = OrderType();
   if (otype == OP_BUYLIMIT || otype == OP_SELLLIMIT ||
       otype == OP_BUYSTOP  || otype == OP_SELLSTOP) {
      bool ok = OrderDelete(ticket);
      PrintFormat("[Hub Cmd] CANCEL pending ticket=%d ok=%s", ticket, ok ? "Y" : "N");
   } else {
      double price = (otype == OP_BUY) ? MarketInfo(OrderSymbol(), MODE_BID)
                                       : MarketInfo(OrderSymbol(), MODE_ASK);
      bool ok = OrderClose(ticket, OrderLots(), price, 10, clrNONE);
      PrintFormat("[Hub Cmd] CANCEL market ticket=%d ok=%s", ticket, ok ? "Y" : "N");
   }
   Ownership_Remove(ticket);
}

void Cmd_HandleInvalidate(string body) {
   int ticket = Msg_GetInt(body, "ticket", 0);
   string owner = Msg_GetField(body, "owner");
   string reason = Msg_GetField(body, "reason");
   PrintFormat("[Hub Cmd] INVALIDATE ticket=%d owner=%s reason=%s",
               ticket, owner, reason);
   if (ticket > 0) {
      Cmd_HandleCancel(body);
   }
}

void Cmd_HandleRefineTPSL(string body) {
   int    ticket = Msg_GetInt(body, "ticket", 0);
   string owner  = Msg_GetField(body, "owner");
   double sl     = Msg_GetDouble(body, "sl", 0.0);
   double tp1    = Msg_GetDouble(body, "tp1", 0.0);
   if (ticket <= 0) return;
   if (StringLen(owner) > 0 && Ownership_GetOwner(ticket) != owner) {
      PrintFormat("[Hub Cmd] REFINE_TPSL owner mismatch ticket=%d", ticket);
      return;
   }
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) return;
   double useSL = (sl  > 0.0) ? sl  : OrderStopLoss();
   double useTP = (tp1 > 0.0) ? tp1 : OrderTakeProfit();
   bool ok = OrderModify(ticket, OrderOpenPrice(), useSL, useTP, 0, clrNONE);
   PrintFormat("[Hub Cmd] REFINE_TPSL ticket=%d sl=%.5f tp=%.5f ok=%s",
               ticket, useSL, useTP, ok ? "Y" : "N");
}

