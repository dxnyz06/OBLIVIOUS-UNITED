double GetCombinedConfirmationScore(bool isBuy, string &reasons)
{
      reasons = "";
      int total = 0, passed = 0;

      // Trend
      if (UI_EnableEMA()) {
        total++;
        if (ConfirmEMA(isBuy)) {
          passed++;
          reasons += "EMA ";
        }
      }
      if (UI_EnableIchimoku()) {
        total++;
        if (ConfirmIchimoku(isBuy)) {
          passed++;
          reasons += "ICH ";
        }
      }
      if (UI_EnableSuperTrend()) {
        total++;
        if (ConfirmSuperTrend(isBuy)) {
          passed++;
          reasons += "ST ";
        }
      }
      if (UI_EnableSAR()) {
        total++;
        if (ConfirmSAR(isBuy)) {
          passed++;
          reasons += "SAR ";
        }
      }

      // Momentum
      if (UI_EnableRSI()) {
        total++;
        if (ConfirmRSI(isBuy)) {
          passed++;
          reasons += "RSI ";
        }
      }
      if (UI_EnableMACD()) {
        total++;
        if (ConfirmMACD(isBuy)) {
          passed++;
          reasons += "MACD ";
        }
      }
      if (UI_EnableCCI()) {
        total++;
        if (ConfirmCCI(isBuy)) {
          passed++;
          reasons += "CCI ";
        }
      }
      if (UI_EnableStochastic()) {
        total++;
        if (ConfirmStochastic(isBuy)) {
          passed++;
          reasons += "STO ";
        }
      }

      // Volatility
      if (UI_EnableADX()) {
        total++;
        if (ConfirmADX(isBuy)) {
          passed++;
          reasons += "ADX ";
        }
      }
      if (UI_EnableVortex()) {
        total++;
        if (ConfirmVortex(isBuy)) {
          passed++;
          reasons += "VRT ";
        }
      }

      // Volume
      if (UI_EnableOBV()) {
        total++;
        if (ConfirmOBV(isBuy)) {
          passed++;
          reasons += "OBV ";
        }
      }
      if (UI_EnableMFI()) {
        total++;
        if (ConfirmMFI(isBuy)) {
          passed++;
          reasons += "MFI ";
        }
      }

      // Structure
      if (UI_EnableFibo()) {
        total++;
        if (ConfirmFibo(isBuy)) {
          passed++;
          reasons += "FIB ";
        }
      }
      if (UI_EnablePivots()) {
        total++;
        if (ConfirmPivots(isBuy)) {
          passed++;
          reasons += "PIV ";
        }
      }

      if (total == 0) {
        reasons = "No confirms enabled";
        return 50.0;
      }
      return (100.0 * passed) / total;
}

double GetHullMA(int period, int shift)
{
      int n = (int)MathSqrt((double)period);
      double wma_half =
          iMA(NULL, 0, period / 2, 0, MODE_LWMA, PRICE_CLOSE, shift);
      double wma_full = iMA(NULL, 0, period, 0, MODE_LWMA, PRICE_CLOSE, shift);
      double hull_raw = 2.0 * wma_half - wma_full;
      // Simplified: final WMA on hull_raw array would require iMAOnArray
      // Using EMA smoothing as approximation
      static double hma_ema = EMPTY_VALUE;
      double alpha = 2.0 / (n + 1.0);
      hma_ema =
          (hma_ema == EMPTY_VALUE ? hull_raw
                                  : alpha * hull_raw + (1 - alpha) * hma_ema);
      return hma_ema;
}

double CalculateVIDYA(int period, int shift)
{
      // VIDYA = Variable Index Dynamic Average
      int cmo_period = (int)MathMax(5, period / 2);
      double up_sum = 0, dn_sum = 0;
      for (int i = shift + 1; i <= shift + cmo_period; i++) {
        double diff = iClose(NULL, 0, i - 1) - iClose(NULL, 0, i);
        if (diff > 0)
          up_sum += diff;
        else
          dn_sum += MathAbs(diff);
      }
      double cmo = ((up_sum + dn_sum) > 0)
                       ? MathAbs(up_sum - dn_sum) / (up_sum + dn_sum)
                       : 0;
      double alpha = 2.0 / (period + 1.0);
      double sc = alpha * cmo;
      static double vidya = EMPTY_VALUE;
      double c = iClose(NULL, 0, shift);
      vidya = (vidya == EMPTY_VALUE ? c : sc * c + (1.0 - sc) * vidya);
      return vidya;
}

bool GetCCI_Signal(int s=0)          {
      double cci = iCCI(Symbol(), 0, 14, PRICE_CLOSE, 0);
      return ((s == OP_BUY && cci < -100) || (s == OP_SELL && cci > 100)); }

bool GetDeMarker_Signal(int s=0)     {
      double dm = iDeMarker(Symbol(), 0, 14, 0);
      return ((s == OP_BUY && dm < 0.3) || (s == OP_SELL && dm > 0.7)); }

bool GetMA_Signal(int s=0)           {
      double ma20 = iMA(Symbol(), 0, 20, 0, MODE_EMA, PRICE_CLOSE, 0),
             ma50 = iMA(Symbol(), 0, 50, 0, MODE_EMA, PRICE_CLOSE, 0);
      return ((s == OP_BUY && ma20 > ma50) ||
              (s == OP_SELL && ma20 < ma50)); }

bool GetMACD_Signal(int s=0)         {
      double m   = iMACD(Symbol(), 0, 12, 26, 9, PRICE_CLOSE, MODE_MAIN, 0),
             sig = iMACD(Symbol(), 0, 12, 26, 9, PRICE_CLOSE, MODE_SIGNAL, 0);
      return ((s == OP_BUY && m > sig) || (s == OP_SELL && m < sig)); }

bool GetStochastic_Signal(int s=0)   {
      double k = iStochastic(Symbol(), 0, 14, 3, 3, MODE_SMA, 0, MODE_MAIN, 0);
      return ((s == OP_BUY && k < 20) || (s == OP_SELL && k > 80)); }

void CalculateSuperTrend() {
      double ma = iMA(Symbol(), Use_TF(), ST_ATRPeriod * 2, 0, MODE_EMA, PRICE_CLOSE, 1);
      double atr = iATR(Symbol(), Use_TF(), ST_ATRPeriod, 1);
      g_superTrendValue = ma + SuperTrendMultiplier * atr;
      g_prevSuperTrendValue =
          ma + SuperTrendMultiplier * iATR(Symbol(), Use_TF(), ST_ATRPeriod, 2);
}

