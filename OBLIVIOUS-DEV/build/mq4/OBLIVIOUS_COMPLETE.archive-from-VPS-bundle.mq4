// OWNERSHIP MODEL: TradeOwnership + OwnerRegistry
struct TradeOwnership {
    int    ticket;
    string owner_strategy;
    string owner_family;
    int    owner_magic;
    string entry_reason;
    double entry_confidence;
    string management_profile;
    string owner_comment;
    bool   active;
};
#define OWNER_MAX 200
TradeOwnership g_ownerRegistry[OWNER_MAX];
int            g_ownerCount = 0;

void OwnerRegistry_Register(int ticket, string strategy, string family,
                             int magic, string reason, double confidence,
                             string profile, string comment = "") {
   for (int _oi = 0; _oi < g_ownerCount; _oi++) {
      if (g_ownerRegistry[_oi].ticket == ticket && g_ownerRegistry[_oi].active) {
            g_ownerRegistry[_oi].owner_strategy   = strategy;
            g_ownerRegistry[_oi].management_profile = profile;
            return;
      }
   }
   if (g_ownerCount >= OWNER_MAX) return;
    int _idx = g_ownerCount++;
    g_ownerRegistry[_idx].ticket             = ticket;
    g_ownerRegistry[_idx].owner_strategy     = strategy;
    g_ownerRegistry[_idx].owner_family       = family;
    g_ownerRegistry[_idx].owner_magic        = magic;
    g_ownerRegistry[_idx].entry_reason       = reason;
    g_ownerRegistry[_idx].entry_confidence   = confidence;
    g_ownerRegistry[_idx].management_profile = profile;
    g_ownerRegistry[_idx].owner_comment      = comment;
    g_ownerRegistry[_idx].active             = true;
}

int OwnerRegistry_Find(int ticket) {
   for (int _oi = 0; _oi < g_ownerCount; _oi++)
      if (g_ownerRegistry[_oi].active && g_ownerRegistry[_oi].ticket == ticket)
         return _oi;
   return -1;
}


string OwnerRegistry_GetStrategy(int ticket) {
    int _idx = OwnerRegistry_Find(ticket);
    return (_idx >= 0) ? g_ownerRegistry[_idx].owner_strategy : "";
}

string OwnerRegistry_GetProfile(int ticket) {
    int _idx = OwnerRegistry_Find(ticket);
    return (_idx >= 0) ? g_ownerRegistry[_idx].management_profile : "NATIVE";
}

int OwnerRegistry_GetMagic(int ticket) {
    int _idx = OwnerRegistry_Find(ticket);
    return (_idx >= 0) ? g_ownerRegistry[_idx].owner_magic : -1;
} // closes OwnerRegistry_GetMagic

void OwnerRegistry_Cleanup() {
  for (int _oi = 0; _oi < g_ownerCount; _oi++) {
    if (!g_ownerRegistry[_oi].active) continue;
    int _t = g_ownerRegistry[_oi].ticket;
    bool _inTrades = OrderSelect(_t, SELECT_BY_TICKET, MODE_TRADES);
    bool _inHist   = !_inTrades && OrderSelect(_t, SELECT_BY_TICKET, MODE_HISTORY);
    if (!_inTrades && !_inHist) { g_ownerRegistry[_oi].active = false; continue; }
    if (OrderCloseTime() != 0)  { g_ownerRegistry[_oi].active = false; }
  }
}



      // Adaptive tolerance for clustering levels / sweeps: based on ATR +
      // spread.


                                              // default: treat as positive; if
                                              // you have a predicate, plug it
                                              // here
//| 5. globali / cache / stato / bridge buffers
      // === Automatic HTF confirmation (no parameters required) ===
      // Chooses HTF automatically from current Period(), estimates trend
      // strength (MA/ATR + ADX), and applies STRICT if strong trend, SOFT
      // otherwise. If anything is ambiguous, it returns true.
        // 1) Derive signal direction from current timeframe using existing
        // logic
        // 2) Pick an appropriate Higher Timeframe automatically
        // 3) Measure trend direction and strength on HTF
        // direction via existing SuperTrend-like logic
        // strength mix: band distance (|price-MA|/ATR) + ADX
        // 4) Decision: STRICT if strong trend; else SOFT
      // Likelihoods
      // Encode likelihood: P(data|up) and P(data|down)
      // Posterior via Bayes
      // Return signed confidence

bool HasBars(int n)  { return Bars >= n; }
color BlendToBG(color c, color bg, double alpha) {
    int rv=(int)((c)&0xFF);      int gv=(int)(((c)>>8)&0xFF);  int bv=(int)(((c)>>16)&0xFF);
    int r2=(int)((bg)&0xFF);     int g2=(int)(((bg)>>8)&0xFF); int b2=(int)(((bg)>>16)&0xFF);
    int rb=(int)(rv*alpha+r2*(1.0-alpha)); int gb2=(int)(gv*alpha+g2*(1.0-alpha)); int bb=(int)(bv*alpha+b2*(1.0-alpha));
    return (color)(rb|(gb2<<8)|(bb<<16)); }
bool OTEBandFromHistory(bool isBull, int tf, int lb, double &lo, double &hi, double &tol) {
    hi = iHigh(NULL,tf,iHighest(NULL,tf,MODE_HIGH,lb,1));
    lo = iLow(NULL,tf,iLowest(NULL,tf,MODE_LOW,lb,1));
    tol = (hi-lo)*0.1; return (hi>lo && hi-lo>Point*5); }
bool LH_SweepValid(string sym, int tf, int shift) {
    double atr=iATR(sym,tf,14,shift+1);
    return (High[shift]-Low[shift] > atr*0.5); }
void SL(string cat, string name, string msg) { SmartLog("INFO", cat+"."+name, msg); }

void LogMsg(string level, string message) { Print("[" + level + "] " + message); }

color RGB_Current()  { return clrLime; }
color AccentColor()  { return clrGold; }

void LogError(string message) {
      LogMsg("ERROR", message);
}

void LogDebug(string message)    {
      SmartLog("DBG", "SYS", message); }

// ============================================================
bool IsDigit(int ch) { return (ch >= '0' && ch <= '9'); }

double EATR(string sym = NULL, int tf = 0, int period = 14) {
   if (sym == NULL || sym == "") sym = Symbol();
   return iATR(sym, tf > 0 ? tf : Period(), period, 0); }

double __TrendADX() {
   return iADX(Symbol(), Period(), Auto_ADX_Period(), PRICE_CLOSE, MODE_MAIN, 1); }

double __ATR_(int period = 14) {
   return iATR(Symbol(), Period(), period, 1); }

double EB_Median(double &arr[], int n) {
   if (n <= 0) return 0.0;
   double tmp[]; ArrayResize(tmp, n);
   for (int i = 0; i < n; i++) tmp[i] = arr[i];
   ArraySort(tmp);
   return (n % 2 == 0 ? (tmp[n/2-1]+tmp[n/2])*0.5 : tmp[n/2]); }

double EB_MAD(double &arr[], int n) {
   double med = EB_Median(arr, n);
   double diffs[]; ArrayResize(diffs, n);
   for (int i = 0; i < n; i++) diffs[i] = MathAbs(arr[i] - med);
   return EB_Median(diffs, n); }

double _MedianTrueRangeN(int n) {
   if (n <= 0 || Bars < n + 2) return iATR(Symbol(), Period(), 14, 1);
   double trs[]; ArrayResize(trs, n);
   for (int i = 0; i < n; i++) {
      double h = iHigh(Symbol(), Period(), i+1), l = iLow(Symbol(), Period(), i+1),
             pc = iClose(Symbol(), Period(), i+2);
      trs[i] = MathMax(h-l, MathMax(MathAbs(h-pc), MathAbs(l-pc))); }
   return EB_Median(trs, n); }

double _TrendScore(int lb = 30) {
   if (lb <= 0 || Bars < lb+2) return 0.0;
   int ups = 0, dns = 0;
   for (int i = 1; i <= lb; i++) {
      double c = iClose(Symbol(), Period(), i), p = iClose(Symbol(), Period(), i+1);
      if (c > p) ups++; else if (c < p) dns++; }
   return MathAbs(ups - dns) / (double)lb; }

double GetCachedADX() {
   return iADX(Symbol(), Period(), Auto_ADX_Period(), PRICE_CLOSE, MODE_MAIN, 1); }

int GetADXDirection() {
   double plus  = iADX(Symbol(), Period(), Auto_ADX_Period(), PRICE_CLOSE, MODE_PLUSDI,  1);
   double minus = iADX(Symbol(), Period(), Auto_ADX_Period(), PRICE_CLOSE, MODE_MINUSDI, 1);
   double adx   = iADX(Symbol(), Period(), Auto_ADX_Period(), PRICE_CLOSE, MODE_MAIN,    1);
   if (adx < Auto_ADX_Threshold()) return 0;
   return (plus > minus ? 1 : -1); }

double GetMinConfidence(string stratType = "") {
   if (stratType == "Strict") return 0.70;
   if (stratType == "Loose")  return 0.40;
   return 0.55; }

bool UI_UsePriceActionFilter() { return PriceAction; }

bool RR_AA_StrategyAllows(string strat) {
   if (StringFind(strat, "Grid",      0) >= 0) return false;
   if (StringFind(strat, "Martingale",0) >= 0) return false;
   if (StringFind(strat, "Hedge",     0) >= 0) return false;
   return true; }

bool RR_AA_ApplyToTicket(int ticket, string strat) {
   if (ticket <= 0 || !RR_AA_StrategyAllows(strat)) return false;
   if (!OrderSelect(ticket, SELECT_BY_TICKET))       return false;
   if (OrderCloseTime() != 0)                         return false;
   return true; }

bool ADV_PriceInZone(int tf, ADV_FVG_ZONE &z) {
   if (!z.valid) return false;
   double bid = Bid, ask = Ask;
   double price = (z.dir > 0 ? ask : bid);
   return (price >= z.bot && price <= z.top); }

bool ADV_FVG_MitigatedAndRejected(ADV_FVG_ZONE &z, int tf, int lb, int &rejShift) {
   rejShift = -1;
   if (!z.valid) return false;
   double atr = iATR(Symbol(), tf > 0 ? tf : Period(), 14, 1);
   double tol  = atr * 0.1;
   for (int i = 1; i <= lb && i < Bars-1; i++) {
      double l = iLow(Symbol(), tf, i), h = iHigh(Symbol(), tf, i);
      if (h >= z.bot - tol && l <= z.top + tol) {
         double c = iClose(Symbol(), tf, i);
         if ((z.dir > 0 && c > iOpen(Symbol(), tf, i)) ||
             (z.dir < 0 && c < iOpen(Symbol(), tf, i))) {
            rejShift = i; return true; } } }
   return false; }

bool EB_PlaceEdgeBiasedLimits(string sym, int magic, bool isLong,
                               double zHi, double zLo, double sl, double tp,
                               double lots_total) {
   if (lots_total <= 0 || zHi <= zLo) return false;
   int cmd = isLong ? OP_BUYLIMIT : OP_SELLLIMIT;
   double mid = (zHi + zLo) * 0.5;
   double price = isLong ? mid : mid;
   price = NormalizeDouble(price, (int)MarketInfo(sym, MODE_DIGITS));
   int tk = SafeOrderSend(sym, cmd, lots_total, price, 3, sl, tp, "EB_Limit_" + IntegerToString(magic), magic, 0, clrBlue);
   return (tk > 0); }

bool SMC_TimeFilter(bool london = true, bool ny = true, bool asia = false) {
   int h = TimeHour(TimeCurrent());
   bool inLondon = (h >= 7  && h < 16);
   bool inNY     = (h >= 13 && h < 22);
   bool inAsia   = (h >= 0  && h < 8);
   if (london && inLondon) return true;
   if (ny     && inNY)     return true;
   if (asia   && inAsia)   return true;
   return false; }

bool SMC_FVGRespected(ADV_FVG_ZONE &poi, int tf, int &rejShift) {
   return ADV_FVG_MitigatedAndRejected(poi, tf, 20, rejShift); }

bool IsTriangleAscendingPattern() {
   int lb = (int)MathMin(50, Bars-2);
   double hiMax = -1e10, loMin = 1e10;
   for (int i = 1; i <= lb; i++) { hiMax = MathMax(hiMax, High[i]); loMin = MathMin(loMin, Low[i]); }
   double recentHi = (High[1]+High[2]+High[3])/3.0;
   double recentLo = (Low[1]+Low[2]+Low[3])/3.0;
   double midHi = (High[lb/3]+High[lb/3+1]+High[lb/3+2])/3.0;
   double midLo = (Low[lb/3]+Low[lb/3+1]+Low[lb/3+2])/3.0;
   return (MathAbs(recentHi - midHi) < Point*20 && recentLo > midLo); }

bool IsTriangleDescendingPattern() {
   int lb = (int)MathMin(50, Bars-2);
   double recentHi = (High[1]+High[2]+High[3])/3.0;
   double recentLo = (Low[1]+Low[2]+Low[3])/3.0;
   double midHi = (High[lb/3]+High[lb/3+1]+High[lb/3+2])/3.0;
   double midLo = (Low[lb/3]+Low[lb/3+1]+Low[lb/3+2])/3.0;
   return (recentHi < midHi && MathAbs(recentLo - midLo) < Point*20); }

bool IsTriangleSymmetricalPattern() {
   int lb = (int)MathMin(50, Bars-2);
   double recentHi = (High[1]+High[2]+High[3])/3.0;
   double recentLo = (Low[1]+Low[2]+Low[3])/3.0;
   double midHi = (High[lb/3]+High[lb/3+1]+High[lb/3+2])/3.0;
   double midLo = (Low[lb/3]+Low[lb/3+1]+Low[lb/3+2])/3.0;
   return (recentHi < midHi && recentLo > midLo); }

void GetAdaptiveParameters(
      int &macd_fast, int &macd_slow, int &macd_signal,
      int &stoch_k,   int &stoch_d,   int &stoch_slow,
      int &bb_period, double &bb_dev,
      int &cci_period, int &ma_period,
      int &st_period, double &st_mult,
      int &rsi_period, int &adx_period, int &atr_period,
      int &fractals_period, int &momentum_period) {
   macd_fast        = Auto_MACD_Fast();
   macd_slow        = Auto_MACD_Slow();
   macd_signal      = Auto_MACD_Signal();
   stoch_k          = Auto_STO_K();
   stoch_d          = Auto_STO_D();
   stoch_slow       = Auto_STO_Slow();
   bb_period        = (int)Auto_BB_Period();
   bb_dev           = Auto_BB_Dev();
   cci_period       = Auto_CCI_Period();
   ma_period        = Auto_MA_Period();
   st_period        = Auto_ATR_Period();
   st_mult          = Auto_GridATRMult();
   rsi_period       = Auto_RSI_Period();
   adx_period       = Auto_ADX_Period();
   atr_period       = Auto_ATR_Period();
   fractals_period  = Auto_FRACTALS_Period();
   momentum_period  = Auto_MOM_Period(); }
// --- Ownership and pattern analysis helpers ---
bool OwnerRegistry_IsOwner(int ticket, int magic) {
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) return false;
   return (OrderMagicNumber() == magic); }

bool Crown_SymmetryDetector(double &neck, int &iL, int &iH, int &iR, bool &inv,
                             int lookL, int lookH, int lookR, double tolPct, int minBars) {
   neck = 0; iL = 0; iH = 0; iR = 0; inv = false;
   if (Bars < lookH + lookR + 5) return false;
   int hIdx = iHighest(Symbol(), Period(), MODE_HIGH, lookH, 1);
   int lIdx = iLowest(Symbol(), Period(),  MODE_LOW,  lookL, 1);
   neck = (High[hIdx] + Low[lIdx]) * 0.5;
   iL = lIdx; iH = hIdx; iR = 1;
   return true; }

bool Crown_VolumePressureZone(double p1, double p2 = 0.0) {
   double vol0 = iVolume(Symbol(), Period(), 1);
   double volMA = iMA(Symbol(), Period(), 20, 0, MODE_SMA, PRICE_CLOSE, 1);
   return (vol0 > volMA * 1.2); }

bool SmartCandleProfiling(int shift, double bodyMin, double wickMax) {
   double rng = _Range(shift);
   if (rng <= 0) return false;
   return (_Body(shift) / rng >= bodyMin); }

bool PatternVolumeSpike(int period, double multNormal, double multSpike) {
   double vol0 = iVolume(Symbol(), Period(), 1);
   double volMA = iMA(Symbol(), Period(), period, 0, MODE_SMA, PRICE_CLOSE, 1);
   return (vol0 > volMA * multNormal); }

double CalculatePatternConfidence() {
   double adx  = GetCachedADX();
   double base = 60.0 + MathMin(20.0, adx / 2.0);
   return MathMin(95.0, base); }

double _LowerWick(int i) { return MathMin(Open[i], Close[i]) - Low[i]; }
double _UpperWick(int i) { return High[i] - MathMax(Open[i], Close[i]); }
// ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ Candlestick pattern micro-helpers ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã‚ÃƒÂ¢Ã¢Ã‚Â¬
bool   _HasBars(int i, int extra = 0) { return (Bars > i + extra + 2); }
double _Range(int i)  { return (High[i] - Low[i]); }
double _Body(int i)   { return MathAbs(Close[i] - Open[i]); }
bool   _IsBull(int i) { return (Close[i] > Open[i]); }
bool   _IsBear(int i) { return (Close[i] < Open[i]); }
bool   _Near(double a, double b, double tol) { return (MathAbs(a - b) <= tol); }

