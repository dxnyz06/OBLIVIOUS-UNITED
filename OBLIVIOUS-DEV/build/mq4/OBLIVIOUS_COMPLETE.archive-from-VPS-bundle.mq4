void DisplayDashboard() {
      string status = "";
      status += ";Strategie: ";
      if (UI_EnableMomentum()) {
        status += "Momentum ";
      }
      // L'RSI (Relative Strength Index) valuta condizioni di ipercomprato e
      // ipervenduto.
      if (UI_EnableRSI()) {
        status += "RSI ";
      }
      if (EnableSMC) {
        status += "SMC ";
      }
      if (UI_EnablePredicted()) {
        status += "AI_PREDICTED ";
      }
      status += " ATR: " + DoubleToStr(Auto_ATR_Period(), 0) +
                " | SLx: " + DoubleToStr(GridSLMultiplier, 1) +
                " | TPx: " + DoubleToStr(GridTPMultiplier, 1);
      if (HighImpactNewsActive()) {
        LogGate("BLOCK NEWS",
                StringFormat("Symbol=%s Time=%s (file=file pATH)", Symbol(),
                             TimeToStr(TimeCurrent(), TIME_SECONDS)));
        status += " NOTIZIE AD ALTO IMPATTO!";
      }
      Comment(status);
}

void DisplayDrawdownLimits(){
      double maxDD = Active_MaxTotalDDPercent();
      double maxDaily = Active_MaxDailyDDPercent();
      double currentDD = GetTotalDrawdownPerc();
      DrawLabel("DD_LIMITS", 10, 350,
                StringFormat("DD: %.1f%% / Max: %.1f%% | Daily Max: %.1f%%",
                             currentDD, maxDD, maxDaily),
                currentDD > maxDD * 0.8 ? clrRed : clrLime);
}

void DrawConfidenceBar(string name, double conf, int x, int y, int width) {
      int bar_width = (int)(width * conf / 100.0);
      color bar_color = GetConfidenceColor(conf);
      ObjectCreate(0, name, OBJ_RECTANGLE_LABEL, 0, 0, 0);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_BGCOLOR, bar_color);
      ObjectSetInteger(0, name, OBJPROP_XSIZE, bar_width);
      ObjectSetInteger(0, name, OBJPROP_YSIZE, 10);
}

void CreateDashboardButton(string name, string text, int x, int y)
{
      if (ObjectFind(0, name) < 0)
        ObjectCreate(0, name, OBJ_BUTTON, 0, 0, 0);
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_XSIZE, 110);
      ObjectSetInteger(0, name, OBJPROP_YSIZE, 22);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, name, OBJPROP_BGCOLOR, C'30,50,100');
      ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, clrSilver);
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 8);
      ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
}

void CreateDashboardLabel(string name, string text, int y, color clr, int fontSize)
{
      if (ObjectFind(0, name) < 0)
        ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, fontSize);
      ObjectSetString(0, name, OBJPROP_FONT, "Arial");
      ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
}

void CreateDashboardConfidenceBar(string name, int y)
{
      string bgName = name + "_BG";
      string fgName = name + "_FG";
      if (ObjectFind(0, bgName) < 0)
        ObjectCreate(0, bgName, OBJ_RECTANGLE_LABEL, 0, 0, 0);
      ObjectSetInteger(0, bgName, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, bgName, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, bgName, OBJPROP_XSIZE, 120);
      ObjectSetInteger(0, bgName, OBJPROP_YSIZE, 10);
      ObjectSetInteger(0, bgName, OBJPROP_BGCOLOR, C'40,40,40');
      ObjectSetInteger(0, bgName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, bgName, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, bgName, OBJPROP_HIDDEN, true);
      if (ObjectFind(0, fgName) < 0)
        ObjectCreate(0, fgName, OBJ_RECTANGLE_LABEL, 0, 0, 0);
      ObjectSetInteger(0, fgName, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, fgName, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, fgName, OBJPROP_XSIZE, 0);
      ObjectSetInteger(0, fgName, OBJPROP_YSIZE, 10);
      ObjectSetInteger(0, fgName, OBJPROP_BGCOLOR, clrDodgerBlue);
      ObjectSetInteger(0, fgName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, fgName, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, fgName, OBJPROP_HIDDEN, true);
}

void DrawNewsPreview(string prefix, int x, int y, string filename, int rows) {
      string lines[];
      int n = ReadTopN(filename, lines, rows);
      for (int i = 0; i < rows; i++) {
        string nm = prefix + "_ROW_" + IntegerToString(i);
        string tag = prefix + "_TAG_" + IntegerToString(i);
        if (i >= n || StringLen(StringTrim(lines[i])) == 0) {
          if (ObjectFind(0, nm) >= 0)
            ObjectDelete(0, nm);
          if (ObjectFind(0, tag) >= 0)
            ObjectDelete(0, tag);
          continue;
        }
        string txt, imp;
        ParseNewsLine(lines[i], txt, imp);
        if (StringLen(txt) == 0) {
          if (ObjectFind(0, nm) >= 0)
            ObjectDelete(0, nm);
        } else {
          if (ObjectFind(0, nm) < 0)
            ObjectCreate(0, nm, OBJ_LABEL, 0, 0, 0);
          ObjectSetInteger(0, nm, OBJPROP_XDISTANCE, x);
          ObjectSetInteger(0, nm, OBJPROP_YDISTANCE, y + 16 * i);
          ObjectSetInteger(0, nm, OBJPROP_FONTSIZE, 9);
          ObjectSetInteger(0, nm, OBJPROP_COLOR, clrWhite);
          ObjectSetString(0, nm, OBJPROP_TEXT, txt);
        }
        if (StringLen(imp) == 0) {
          if (ObjectFind(0, tag) >= 0)
            ObjectDelete(0, tag);
        } else {
          if (ObjectFind(0, tag) < 0)
            ObjectCreate(0, tag, OBJ_LABEL, 0, 0, 0);
          ObjectSetInteger(0, tag, OBJPROP_XDISTANCE, x + 420);
          ObjectSetInteger(0, tag, OBJPROP_YDISTANCE, y + 16 * i);
          ObjectSetInteger(0, tag, OBJPROP_FONTSIZE, 9);
          ObjectSetInteger(0, tag, OBJPROP_COLOR, ImpactColor(imp));
          ObjectSetString(0, tag, OBJPROP_TEXT, StringUpper(imp));
        }
      }
}

void DrawPnLPanel() {
      for (int k = 0; k < 120; k++) {
        string lbl = "PNL_ITEM_" + IntegerToString(k);
        if (ObjectFind(0, lbl) != -1)
          ObjectDelete(0, lbl);
      }
      int y = 0;
      for (int i = 0; i < pnl_count; i++) {
        string lbl = "PNL_ITEM_" + IntegerToString(i);
        if (ObjectFind(0, lbl) == -1)
          ObjectCreate(0, lbl, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, lbl, OBJPROP_CORNER, PNL_CORNER);
        ObjectSetInteger(0, lbl, OBJPROP_XDISTANCE, PNL_OFFSET_X);
        ObjectSetInteger(0, lbl, OBJPROP_YDISTANCE, PNL_OFFSET_Y + y);
        ObjectSetInteger(0, lbl, OBJPROP_FONTSIZE, PNL_FONTSIZE);
        ObjectSetString(0, lbl, OBJPROP_FONT, PNL_FONT);
        color pnl_col = (pnl_list[i].pnl >= 0 ? clrLime : clrRed);
        string text =
            pnl_list[i].name + "" + DoubleToString(pnl_list[i].pnl, 2);
        ObjectSetString(0, lbl, OBJPROP_TEXT, text);
        ObjectSetInteger(0, lbl, OBJPROP_COLOR, pnl_col);
        y += PNL_FONTSIZE + 4;
      }
}

void DrawSectionTitle(string name, string text, int x, int y) {
      if (ObjectFind(0, name) < 0)
        ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 12);
      ObjectSetInteger(0, name, OBJPROP_BOLD, true);
}

void DrawStrategyRow(string key, string label, bool enabled, double confPct, int y) {
   string objLbl = "SROW_" + key;
   string text   = label + (enabled ? " ON" : " OFF") + " " + DoubleToString(confPct, 0) + "%";
   color  clr    = enabled ? clrLime : clrGray;
   DrawLabel(objLbl, 10, y, text, clr);
}
void DrawTradeLabels(string strategy, datetime openTime, double openPrice, datetime closeTime, double closePrice, double profit) {
      string openLabel =
          "TRADE_" + strategy + "_OPEN_" + TimeToString(openTime, TIME_SECONDS);
      string closeLabel = "TRADE_" + strategy + "_CLOSE_" +
                          TimeToString(closeTime, TIME_SECONDS);
      ObjectCreate(openLabel, OBJ_TEXT, 0, openTime, openPrice);
      ObjectSetText(openLabel, strategy, 9, "Verdana", clrGreen);
      string resultText =
          profit >= 0 ? "+" + DoubleToString(profit, 2) + "ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã…Â¡ÃƒÃ‚Â¬"
                      : "-" + DoubleToString(MathAbs(profit), 2) + "ÃƒÃ‚Â¢ÃƒÂ¢Ã¢Â¬Ã…Â¡ÃƒÃ‚Â¬";
      color resultColor = profit >= 0 ? clrLime : clrRed;
      ObjectCreate(closeLabel, OBJ_TEXT, 0, closeTime, closePrice);
      ObjectSetText(closeLabel, resultText, 9, "Verdana", resultColor);
}

void DrawTradeResultLabel(int ticket, string strategyName, double profit, datetime closeTime) {
      string objName = "Result_" + IntegerToString(ticket);
      string resultText = strategyName + ": " + (profit >= 0 ? "+" : "") +
                          DoubleToString(profit, 2) + " USD";
      color resultColor = profit >= 0 ? clrLime : clrRed;
      ObjectCreate(0, objName, OBJ_TEXT, 0, closeTime,
                   Close[0]);
      ObjectSetString(0, objName, OBJPROP_TEXT, resultText);
      ObjectSetInteger(0, objName, OBJPROP_COLOR, resultColor);
      ObjectSetInteger(0, objName, OBJPROP_CORNER, CORNER_LEFT_LOWER);
}

void RecolorTriggerObjects(){
      string sym = Symbol();
      color base = AccentColor();
      color bg = ColorBG();
      color box = BlendToBG(base, bg, 0.60);
      int total = ObjectsTotal(0, -1, -1);
      for (int i = total - 1; i >= 0; --i) {
        string nm = ObjectName(0, i);
        if (StringFind(nm, "TRIG_", 0) != 0)
          continue;
        int type = (int)ObjectGetInteger(0, nm, OBJPROP_TYPE);
        if (type == OBJ_RECTANGLE) {
          ObjectSetInteger(0, nm, OBJPROP_COLOR, box);
          ObjectSetInteger(0, nm, OBJPROP_BACK, true);
        } else if (type == OBJ_TREND) {
          ObjectSetInteger(0, nm, OBJPROP_COLOR, base);
          ObjectSetInteger(0, nm, OBJPROP_STYLE, STYLE_DASH);
        } else if (type == OBJ_TEXT) {
          // Update text color to accent as well
          // No direct OBJPROP_COLOR for text in old builds; use ObjectSetText
          int fsz = 8;
          string fnt = "Arial";
          ObjectSetText(nm, ObjectDescription(nm), fsz, fnt, base);
        }
      }
      ChartRedraw();
}

bool UI_UseMultiTFTrend()   {
      return true; }

void DashboardPanel_Init()
{
      // Clean old objects
      DashboardPanel_Cleanup();

      if (!DynamicPanel && !SmartPanel && !TriggerPanel)
        return;

      Print("[Dashboard] Panels initialized");
}

void DashboardPanel_Update()
{
      if (!DynamicPanel && !SmartPanel && !TriggerPanel)
        return;

      // Throttle: every 500ms
      int now =  (int)(GetTickCount());
      if (now - g_lastPanelUpdate < 500)
        return;
      g_lastPanelUpdate = now;

      int y = PANEL_Y_OFFSET;

      if (DynamicPanel)
        y = DashboardPanel_DrawDynamic(PANEL_X_OFFSET, y);

      if (SmartPanel)
        y = DashboardPanel_DrawSmart(PANEL_X_OFFSET, y + 10);

      if (TriggerPanel)
        y = DashboardPanel_DrawTrigger(PANEL_X_OFFSET, y + 10);

      ChartRedraw();
}

int DashboardPanel_DrawDynamic(int x, int y)
{
      int startY = y;

      // Background
      Panel_DrawBox("dyn_bg", x, y, PANEL_WIDTH, PANEL_LINE_H * 14,
                    PANEL_BG_COLOR);

      // Header
      Panel_DrawBox("dyn_hdr", x, y, PANEL_WIDTH, PANEL_LINE_H + 4,
                    PANEL_HEADER_BG);
      Panel_DrawLabel("dyn_title", x + 8, y + 3,
                      "OBLIVIOUS AI EA v" + EAVersion, PANEL_WHITE, 10);
      y += PANEL_LINE_H + 6;

      // Account info
      Panel_DrawLabel("dyn_bal", x + 8, y,
                      StringFormat("Balance: $%.2f", AccountBalance()),
                      PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
      y += PANEL_LINE_H;
      Panel_DrawLabel("dyn_eq", x + 8, y,
                      StringFormat("Equity:  $%.2f", AccountEquity()),
                      PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
      y += PANEL_LINE_H;
      Panel_DrawLabel("dyn_free", x + 8, y,
                      StringFormat("Free:    $%.2f", AccountFreeMargin()),
                      PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      // Risk info
      double dailyDD = RiskEngine_GetDailyDD();
      color ddColor = (dailyDD < 2) ? PANEL_GREEN
                                    : (dailyDD < 4 ? PANEL_YELLOW : PANEL_RED);
      Panel_DrawLabel("dyn_ddd", x + 8, y,
                      StringFormat("Daily DD: %.2f%%", dailyDD), ddColor,
                      PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      double totalDD = RiskEngine_GetTotalDD();
      ddColor = (totalDD < 5) ? PANEL_GREEN
                              : (totalDD < 10 ? PANEL_YELLOW : PANEL_RED);
      Panel_DrawLabel("dyn_tdd", x + 8, y,
                      StringFormat("Total DD: %.2f%%", totalDD), ddColor,
                      PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      Panel_DrawLabel("dyn_spread", x + 8, y,
                      StringFormat("Spread: %.1f pips", RiskEngine_GetSpread()),
                      PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      Panel_DrawLabel(
          "dyn_margin", x + 8, y,
          StringFormat("Margin: %.1f%%", RiskEngine_GetMarginLevel()),
          PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      // State
      string stateName = StateManager_GetStateName();
      color stateColor = PANEL_GREEN;
      if (StringFind(stateName, "LOCKED") >= 0 ||
          StringFind(stateName, "EMERGENCY") >= 0)
        stateColor = PANEL_RED;
      else if (StringFind(stateName, "PAUSED") >= 0)
        stateColor = PANEL_YELLOW;
      Panel_DrawLabel("dyn_state", x + 8, y, "State: " + stateName, stateColor,
                      PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      // Block reason
      if (RiskEngine_IsBlocked())
        Panel_DrawLabel("dyn_block", x + 8, y,
                        "BLOCK: " + RiskEngine_GetBlockReason(), PANEL_RED,
                        PANEL_FONT_SIZE);
      else
        Panel_DrawLabel("dyn_block", x + 8, y, "Trading: ALLOWED", PANEL_GREEN,
                        PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      // AI Bridge
      string aiStatus = AIBridge_GetStatus();
      color aiColor = (StringFind(aiStatus, "ACTIVE") >= 0 ||
                       StringFind(aiStatus, "CONNECTED") >= 0)
                          ? PANEL_GREEN
                          : PANEL_GRAY;
      Panel_DrawLabel("dyn_ai", x + 8, y, "AI: " + aiStatus, aiColor,
                      PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      // Position count
      Panel_DrawLabel("dyn_pos", x + 8, y,
                      StringFormat("Positions: %d | Today: %d",
                                   PositionManager_GetCount(),
                                   RiskEngine_GetTradesToday()),
                      PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      // Trend direction
      int tdir = Ind_TrendDir(Symbol());
      string trendStr = (tdir > 0)   ? "BULLISH"
                        : (tdir < 0) ? "BEARISH"
                                     : "NEUTRAL";
      color trendColor = (tdir > 0)   ? PANEL_GREEN
                         : (tdir < 0) ? PANEL_RED
                                      : PANEL_YELLOW;
      Panel_DrawLabel("dyn_trend", x + 8, y, "Trend: " + trendStr, trendColor,
                      PANEL_FONT_SIZE);
      y += PANEL_LINE_H;

      return y;
}

int DashboardPanel_DrawSmart(int x, int y)
{
      int rows = 0;
      for (int i = 0; i < STRAT_COUNT; i++)
        if (StrategyEnabled(i))
          rows++;

      if (rows == 0)
        return y;

      Panel_DrawBox("smt_bg", x, y, PANEL_WIDTH, PANEL_LINE_H * (rows + 2),
                    PANEL_BG_COLOR);
      Panel_DrawBox("smt_hdr", x, y, PANEL_WIDTH, PANEL_LINE_H + 4,
                    PANEL_HEADER_BG);
      Panel_DrawLabel("smt_title", x + 8, y + 3, "STRATEGY STATUS", PANEL_WHITE,
                      10);
      y += PANEL_LINE_H + 6;

      for (int i = 0; i < STRAT_COUNT; i++) {
        if (!StrategyEnabled(i))
          continue;

        int magic = StrategyMagic(i);
        int count = OrderManager_CountByMagic(magic, Symbol());
        double profit = OrderManager_ProfitByMagic(magic, Symbol());

        color profitColor = (profit >= 0) ? PANEL_GREEN : PANEL_RED;
        string label =
            StringFormat("%s: %d pos $%.2f", StrategyName(i), count, profit);
        Panel_DrawLabel("smt_s" + IntegerToString(i), x + 8, y, label,
                        (count > 0) ? profitColor : PANEL_GRAY,
                        PANEL_FONT_SIZE);
        y += PANEL_LINE_H;
      }

      return y;
}

int DashboardPanel_DrawTrigger(int x, int y)
{
      Panel_DrawBox("trg_bg", x, y, PANEL_WIDTH, PANEL_LINE_H * 8,
                    PANEL_BG_COLOR);
      Panel_DrawBox("trg_hdr", x, y, PANEL_WIDTH, PANEL_LINE_H + 4,
                    PANEL_HEADER_BG);
      Panel_DrawLabel("trg_title", x + 8, y + 3, "SIGNAL INFO", PANEL_WHITE,
                      10);
      y += PANEL_LINE_H + 6;

      int idx = IndicatorManager_FindSymbol(Symbol());
      if (idx >= 0) {
        Panel_DrawLabel("trg_rsi", x + 8, y,
                        StringFormat("RSI: %.1f", g_indCache[idx].rsi14),
                        PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
        y += PANEL_LINE_H;
        Panel_DrawLabel("trg_adx", x + 8, y,
                        StringFormat("ADX: %.1f (+DI: %.1f -DI: %.1f)",
                                     g_indCache[idx].adx14,
                                     g_indCache[idx].adxPlus,
                                     g_indCache[idx].adxMinus),
                        PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
        y += PANEL_LINE_H;
        Panel_DrawLabel("trg_macd", x + 8, y,
                        StringFormat("MACD: %.5f", g_indCache[idx].macdHist),
                        PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
        y += PANEL_LINE_H;
        Panel_DrawLabel("trg_atr", x + 8, y,
                        StringFormat("ATR: %.5f (ratio: %.2f)",
                                     g_indCache[idx].atr14,
                                     g_indCache[idx].atrRatio),
                        PANEL_TEXT_COLOR, PANEL_FONT_SIZE);
        y += PANEL_LINE_H;

        int score = Confirmations_Score(
            Symbol(), Ind_TrendDir(Symbol()) > 0 ? OP_BUY : OP_SELL);
        color scoreColor = (score > 70)
                               ? PANEL_GREEN
                               : (score > 40 ? PANEL_YELLOW : PANEL_RED);
        Panel_DrawLabel("trg_conf", x + 8, y,
                        StringFormat("Confidence: %d%%", score), scoreColor,
                        PANEL_FONT_SIZE);
        y += PANEL_LINE_H;
      }

      // News status
      if (NewsFilter) {
        string newsStr = NewsBridge_ShouldBlock() ? "BLOCKED" : "CLEAR";
        color newsColor = NewsBridge_ShouldBlock() ? PANEL_RED : PANEL_GREEN;
        Panel_DrawLabel("trg_news", x + 8, y, "News: " + newsStr, newsColor,
                        PANEL_FONT_SIZE);
        y += PANEL_LINE_H;
      }

      return y;
}

void Panel_DrawBox(string name, int x, int y, int w, int h, color clr)
{
      string objName = g_panelPrefix + name;
      if (ObjectFind(objName) < 0)
        ObjectCreate(objName, OBJ_RECTANGLE_LABEL, 0, 0, 0);
      ObjectSet(objName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSet(objName, OBJPROP_XDISTANCE, x);
      ObjectSet(objName, OBJPROP_YDISTANCE, y);
      ObjectSet(objName, OBJPROP_XSIZE, w);
      ObjectSet(objName, OBJPROP_YSIZE, h);
      ObjectSet(objName, OBJPROP_BGCOLOR, clr);
      ObjectSet(objName, OBJPROP_BORDER_COLOR, PANEL_BORDER);
      ObjectSet(objName, OBJPROP_BORDER_TYPE, BORDER_FLAT);
      ObjectSet(objName, OBJPROP_BACK, false);
      ObjectSet(objName, OBJPROP_SELECTABLE, false);
}

void Panel_DrawLabel(string name, int x, int y, string text, color clr, int fontSize)
{
      string objName = g_panelPrefix + name;
      if (ObjectFind(objName) < 0)
        ObjectCreate(objName, OBJ_LABEL, 0, 0, 0);
      ObjectSet(objName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSet(objName, OBJPROP_XDISTANCE, x);
      ObjectSet(objName, OBJPROP_YDISTANCE, y);
      ObjectSetText(objName, text, fontSize, "Consolas", clr);
      ObjectSet(objName, OBJPROP_BACK, false);
      ObjectSet(objName, OBJPROP_SELECTABLE, false);
}

void DashboardPanel_Cleanup()
{
      int total = ObjectsTotal();
      for (int i = total - 1; i >= 0; i--) {
        string name = ObjectName(i);
        if (StringFind(name, g_panelPrefix) == 0)
          ObjectDelete(name);
      }
}

void DashboardPanel_Deinit()
{
      DashboardPanel_Cleanup();
}

void UI_DashboardCreate()
{
      int y = DASH_Y;
      color rainbow = RainbowNow();

      //--- Total height calculation ---
      // Title(1) + Account(4) + pad + Profits(1) + pad + Status(3) + pad
      // + StratHeader(1) + Strats(10) + pad + FilterHeader(1) + Filters(3 rows)
      // + pad + IndHeader(1) + Indicators(8 rows) + pad + NewsHeader(1) +
      // News(3)
      int totalH = DASH_LINE_H * (1 + 4 + 1 + 3 + 1 + STRAT_COUNT + 1 + 3 + 1 +
                                  8 + 1 + 3) +
                   DASH_SECTION_PAD * 7 + 20;

      // Background Panel
      _DashBox(DP + "BG", DASH_X, DASH_Y, DASH_W, totalH, DASH_BG_COLOR,
               DASH_BORDER_CLR);

      // TITLE
      _DashLabel(DP + "TITLE", DASH_X + 8, y + 2, "OBLIVIOUS UNITED EA",
                 rainbow, DASH_TITLE_SZ);
      y += DASH_LINE_H + 4;

      // ACCOUNT SECTION
      _DashBox(DP + "ACC_BG", DASH_X + 2, y, DASH_W - 4, DASH_LINE_H * 4 + 4,
               DASH_HEADER_BG);

      _DashLabel(DP + "ACC_NAME", DASH_X + DASH_INDENT, y + 2,
                 "Name: " + AccountName(), DASH_TEXT_WHITE);
      y += DASH_LINE_H;
      _DashLabel(DP + "ACC_BROKER", DASH_X + DASH_INDENT, y,
                 "Broker: " + AccountCompany(), DASH_TEXT_LABEL);
      y += DASH_LINE_H;
      _DashLabel(DP + "ACC_BAL", DASH_X + DASH_INDENT, y,
                 "Balance: " + DoubleToString(AccountBalance(), 2),
                 DASH_TEXT_WHITE);
      _DashLabel(DP + "ACC_EQ", DASH_X + DASH_COL2, y,
                 "Equity: " + DoubleToString(AccountEquity(), 2),
                 DASH_TEXT_WHITE);
      y += DASH_LINE_H;
      _DashLabel(DP + "ACC_SPREAD", DASH_X + DASH_INDENT, y,
                 "Spread: " + DoubleToString(
                                  MarketInfo(Symbol(), MODE_SPREAD) * Point, 1),
                 DASH_TEXT_LABEL);
      _DashLabel(DP + "ACC_LEV", DASH_X + DASH_COL2, y,
                 "Leverage: 1:" + IntegerToString(AccountLeverage()),
                 DASH_TEXT_LABEL);
      y += DASH_LINE_H + DASH_SECTION_PAD;

      // PROFITS SECTION (Daily / Weekly / Monthly)
      double profitD = _CalcHistoryProfit(_StartOfDay());
      double profitW = _CalcHistoryProfit(_StartOfWeek());
      double profitM = _CalcHistoryProfit(_StartOfMonth());

      _DashLabel(DP + "PNL_D", DASH_X + DASH_INDENT, y,
                 "Daily: " + DoubleToString(profitD, 2),
                 RainbowOrRed(profitD >= 0));
      _DashLabel(DP + "PNL_W", DASH_X + 110, y,
                 "Week: " + DoubleToString(profitW, 2),
                 RainbowOrRed(profitW >= 0));
      _DashLabel(DP + "PNL_M", DASH_X + 210, y,
                 "Month: " + DoubleToString(profitM, 2),
                 RainbowOrRed(profitM >= 0));
      y += DASH_LINE_H + DASH_SECTION_PAD;

      // STATUS SECTION (Session, Market, Mode, TP/SL, AI Server)
      string session = _DetectSession();
      bool aiOnline = _IsAIServerOnline();

      _DashLabel(DP + "STS_SESSION", DASH_X + DASH_INDENT, y,
                 "Session: " + session, DASH_TEXT_WHITE);
      _DashLabel(DP + "STS_MARKET", DASH_X + DASH_COL2, y, "Market: ---",
                 DASH_TEXT_LABEL);
      y += DASH_LINE_H;
      _DashLabel(DP + "STS_MODE", DASH_X + DASH_INDENT, y, "Mode: Moderate",
                 DASH_TEXT_LABEL);
      _DashLabel(DP + "STS_TPSL", DASH_X + DASH_COL2, y, "TP/SL: Native",
                 DASH_TEXT_LABEL);
      y += DASH_LINE_H;
      _DashLabel(DP + "STS_AI", DASH_X + DASH_INDENT, y,
                 "AI Server: " + (aiOnline ? "Online" : "Offline"),
                 RainbowOrRed(aiOnline));
      y += DASH_LINE_H + DASH_SECTION_PAD;

      // STRATEGIES SECTION (10 rows, NO Pattern)
      _DashLabel(DP + "SEC_STRAT", DASH_X + 8, y, "--- STRATEGIES ---", rainbow,
                 DASH_TITLE_SZ);
      y += DASH_LINE_H + 2;

      for (int s = 0; s < STRAT_COUNT; s++) {
        string sk = g_strat_keys[s];
        string sl = g_strat_labels[s];
        bool active = _GetStrategyBool(sk);
        double conf = 0; // Will be updated in UpdateAll

        // Strategy label
        _DashLabel(DP + "STR_L_" + sk, DASH_X + DASH_INDENT, y, sl,
                   active ? DASH_TEXT_WHITE : DASH_TEXT_DIM);

        // Progress bar background
        _DashBox(DP + "STR_BBG_" + sk, DASH_X + 140, y + 3, DASH_BAR_W,
                 DASH_BAR_H, C'40,40,50');
        // Progress bar fill
        int barW = (int)(DASH_BAR_W * conf / 100.0);
        _DashBox(DP + "STR_BAR_" + sk, DASH_X + 140, y + 3, MathMax(1, barW),
                 DASH_BAR_H, active ? rainbow : clrFireBrick);

        // Percentage text
        _DashLabel(DP + "STR_P_" + sk, DASH_X + 225, y,
                   IntegerToString((int)conf) + "%", DASH_TEXT_LABEL);

        // Toggle for strategy
        int tglIdx = Toggle_Register("S_" + sk, "", active);
        Toggle_CreateObjects(tglIdx, DASH_X + DASH_W - 50, y);

        y += DASH_LINE_H;
      }
      y += DASH_SECTION_PAD;

      // FILTERS SECTION (15 toggles, A?Z, 2 columns)
      _DashLabel(DP + "SEC_FIL", DASH_X + 8, y, "--- FILTERS ---", rainbow,
                 DASH_TITLE_SZ);
      y += DASH_LINE_H + 2;

      for (int f = 0; f < FILTER_COUNT; f++) {
        bool fState = _GetFilterBool(g_filter_keys[f]);
        int col = (f % 2 == 0) ? 0 : 1;
        int row = f / 2;
        int tx = (col == 0) ? DASH_TGL_COL1_X : DASH_TGL_COL2_X;
        int ty = y + row * DASH_TGL_ROW_H;

        int tglIdx = Toggle_Register("F_" + g_filter_keys[f],
                                     g_filter_labels[f], fState);
        Toggle_CreateObjects(tglIdx, tx, ty);
      }
      int filterRows = (int)((FILTER_COUNT + 1) / 2);
      y += filterRows * DASH_TGL_ROW_H + DASH_SECTION_PAD;

      // INDICATORS SECTION (36 toggles, A?Z, 2 columns)
      _DashLabel(DP + "SEC_IND", DASH_X + 8, y, "--- INDICATORS ---", rainbow,
                 DASH_TITLE_SZ);
      y += DASH_LINE_H + 2;

      for (int ind = 0; ind < IND_COUNT; ind++) {
        bool iState = _GetIndicatorBool(g_ind_keys[ind]);
        int col = (ind % 2 == 0) ? 0 : 1;
        int row = ind / 2;
        int tx = (col == 0) ? DASH_TGL_COL1_X : DASH_TGL_COL2_X;
        int ty = y + row * DASH_TGL_ROW_H;

        int tglIdx =
            Toggle_Register("I_" + g_ind_keys[ind], g_ind_labels[ind], iState);
        Toggle_CreateObjects(tglIdx, tx, ty);
      }
      int indRows = (int)((IND_COUNT + 1) / 2);
      y += indRows * DASH_TGL_ROW_H + DASH_SECTION_PAD;

      // NEWS SECTION (3 fixed labels)
      _DashLabel(DP + "SEC_NEWS", DASH_X + 8, y, "--- NEWS ---", rainbow,
                 DASH_TITLE_SZ);
      y += DASH_LINE_H + 2;

      g_news_obj[0] = DP + "NEWS_0";
      g_news_obj[1] = DP + "NEWS_1";
      g_news_obj[2] = DP + "NEWS_2";
      g_news_lines[0] = "Waiting for news...";
      g_news_lines[1] = "";
      g_news_lines[2] = "";

      for (int n = 0; n < 3; n++) {
        _DashLabel(g_news_obj[n], DASH_X + DASH_INDENT, y, g_news_lines[n],
                   DASH_TEXT_LABEL);
        y += DASH_LINE_H;
      }

      // Update actual BG height
      int actualH = y - DASH_Y + 8;
      ObjectSetInteger(0, DP + "BG", OBJPROP_YSIZE, actualH);

      ChartRedraw(0);
}

void UI_DashboardUpdateAll()
{
      color rainbow = RainbowNow();

      //--- Title ---
      ObjectSetInteger(0, DP + "TITLE", OBJPROP_COLOR, rainbow);

      //--- Account ---
      ObjectSetString(0, DP + "ACC_NAME", OBJPROP_TEXT,
                      "Name: " + AccountName());
      ObjectSetString(0, DP + "ACC_BROKER", OBJPROP_TEXT,
                      "Broker: " + AccountCompany());
      ObjectSetString(0, DP + "ACC_BAL", OBJPROP_TEXT,
                      "Balance: " + DoubleToString(AccountBalance(), 2));
      ObjectSetString(0, DP + "ACC_EQ", OBJPROP_TEXT,
                      "Equity: " + DoubleToString(AccountEquity(), 2));
      ObjectSetString(
          0, DP + "ACC_SPREAD", OBJPROP_TEXT,
          "Spread: " +
              DoubleToString(MarketInfo(Symbol(), MODE_SPREAD) * Point, 1));
      ObjectSetString(0, DP + "ACC_LEV", OBJPROP_TEXT,
                      "Leverage: 1:" + IntegerToString(AccountLeverage()));

      //--- Profits ---
      double profitD = _CalcHistoryProfit(_StartOfDay());
      double profitW = _CalcHistoryProfit(_StartOfWeek());
      double profitM = _CalcHistoryProfit(_StartOfMonth());

      ObjectSetString(0, DP + "PNL_D", OBJPROP_TEXT,
                      "Daily: " + DoubleToString(profitD, 2));
      ObjectSetInteger(0, DP + "PNL_D", OBJPROP_COLOR,
                       RainbowOrRed(profitD >= 0));
      ObjectSetString(0, DP + "PNL_W", OBJPROP_TEXT,
                      "Week: " + DoubleToString(profitW, 2));
      ObjectSetInteger(0, DP + "PNL_W", OBJPROP_COLOR,
                       RainbowOrRed(profitW >= 0));
      ObjectSetString(0, DP + "PNL_M", OBJPROP_TEXT,
                      "Month: " + DoubleToString(profitM, 2));
      ObjectSetInteger(0, DP + "PNL_M", OBJPROP_COLOR,
                       RainbowOrRed(profitM >= 0));

      //--- Status ---
      ObjectSetString(0, DP + "STS_SESSION", OBJPROP_TEXT,
                      "Session: " + _DetectSession());

      bool aiOnline = _IsAIServerOnline();
      ObjectSetString(0, DP + "STS_AI", OBJPROP_TEXT,
                      "AI Server: " + (aiOnline ? "Online" : "Offline"));
      ObjectSetInteger(0, DP + "STS_AI", OBJPROP_COLOR, RainbowOrRed(aiOnline));

      //--- Strategies ---
      ObjectSetInteger(0, DP + "SEC_STRAT", OBJPROP_COLOR, rainbow);

      for (int s = 0; s < STRAT_COUNT; s++) {
        string sk = g_strat_keys[s];
        bool active = _GetStrategyBool(sk);
        double conf = 0;

        // Try to get confidence (forward-declared function)
        // Fallback: if not available, use 0
        // conf = GetStrategyConfidence(g_strat_labels[s]); // uncomment when
        // available

        // Update label color
        // ObjectSetInteger(0, DP + "STR_L_" + sk, OBJPROP_COLOR,
        //                  active ? DASH_TEXT_WHITE : DASH_TEXT_DIM);

        // Update progress bar width
        int barW = (int)(DASH_BAR_W * conf / 100.0);
        ObjectSetInteger(0, DP + "STR_BAR_" + sk, OBJPROP_XSIZE,
                         MathMax(1, barW));
        ObjectSetInteger(0, DP + "STR_BAR_" + sk, OBJPROP_BGCOLOR,
                         active ? rainbow : clrFireBrick);

        // Update percentage
        ObjectSetString(0, DP + "STR_P_" + sk, OBJPROP_TEXT,
                        IntegerToString((int)conf) + "%");

        // Update toggle state
        Toggle_SetState("S_" + sk, active);
      }

      //--- Filters ---
      ObjectSetInteger(0, DP + "SEC_FIL", OBJPROP_COLOR, rainbow);
      for (int f = 0; f < FILTER_COUNT; f++) {
        bool fState = _GetFilterBool(g_filter_keys[f]);
        Toggle_SetState("F_" + g_filter_keys[f], fState);
      }

      //--- Indicators ---
      ObjectSetInteger(0, DP + "SEC_IND", OBJPROP_COLOR, rainbow);
      for (int ind = 0; ind < IND_COUNT; ind++) {
        bool iState = _GetIndicatorBool(g_ind_keys[ind]);
        Toggle_SetState("I_" + g_ind_keys[ind], iState);
      }

      //--- All toggle colors (rainbow refresh) ---
      Toggle_UpdateAllColors();

      //--- News ---
      ObjectSetInteger(0, DP + "SEC_NEWS", OBJPROP_COLOR, rainbow);
      for (int n = 0; n < 3; n++)
        ObjectSetString(0, g_news_obj[n], OBJPROP_TEXT, g_news_lines[n]);

      ChartRedraw(0);
}

void UI_NewsPush(string newsText)
{
      if (newsText == "" || newsText == g_news_lines[0])
        return; // skip empty/duplicate

      // Shift down
      g_news_lines[2] = g_news_lines[1];
      g_news_lines[1] = g_news_lines[0];
      g_news_lines[0] = newsText;

      // Update fixed objects
      for (int n = 0; n < 3; n++)
        ObjectSetString(0, g_news_obj[n], OBJPROP_TEXT, g_news_lines[n]);
}

void UI_DashboardOnClick(int id, long lparam, double dparam, string sparam)
{
      if (id != CHARTEVENT_OBJECT_CLICK)
        return;
      if (Toggle_OnClick(sparam)) {
        ChartRedraw(0);
      }
}

void UI_DashboardDestroy()
{
      // Remove all objects with our prefix
      int total = ObjectsTotal(0, -1, -1);
      for (int i = total - 1; i >= 0; i--) {
        string name = ObjectName(0, i);
        if (StringFind(name, DP) == 0)
          ObjectDelete(0, name);
      }

      // Remove all toggles
      Toggle_DestroyAll();

      ChartRedraw(0);
}

bool UIToggleGet(string key, bool fallback)
{
      string gv = "UI_TOGGLE_" + key;
      if (GlobalVariableCheck(gv))
        return (GlobalVariableGet(gv) > 0.5);
      return fallback;
}

void UIToggleSet(string key, bool value)
{
      string gv = "UI_TOGGLE_" + key;
      GlobalVariableSet(gv, value ? 1.0 : 0.0);
}

