void ShowIndicatorState(string name, bool state, int y) {
  string label = name + ": " + (state ? "ON" : "OFF");
  string objName = "IND_" + name;
  if (ObjectFind(0, objName) < 0) ObjectCreate(0, objName, OBJ_LABEL, 0, 0, 0);
  ObjectSetString(0, objName, OBJPROP_TEXT, label);
  ObjectSetInteger(0, objName, OBJPROP_YDISTANCE, y);
  ObjectSetInteger(0, objName, OBJPROP_COLOR, state ? clrLime : clrRed);
}
void ShowFileState(string name, bool state, int y) {
  string label = name + ": " + (state ? "OK" : "MISSING");
  string objName = "FILE_" + name;
  if (ObjectFind(0, objName) < 0) ObjectCreate(0, objName, OBJ_LABEL, 0, 0, 0);
  ObjectSetString(0, objName, OBJPROP_TEXT, label);
  ObjectSetInteger(0, objName, OBJPROP_YDISTANCE, y);
  ObjectSetInteger(0, objName, OBJPROP_COLOR, state ? clrLime : clrOrange);
