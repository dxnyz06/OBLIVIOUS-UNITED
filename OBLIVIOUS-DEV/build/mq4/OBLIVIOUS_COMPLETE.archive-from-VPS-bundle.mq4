                                        double AIBNF_PipsToPrice(string sym,
   int pips) {
                                          return pips * ADV_Pip();
                                        }

                                        int AIBNF_PriceToPips(
                                            string sym, double priceDelta) {
                                          double pt =
                                              MarketInfo(sym, MODE_POINT);
                                          int dg =
                                              (int)MarketInfo(sym, MODE_DIGITS);
                                          double k =
                                              (dg == 5 || dg == 3) ? 10.0 : 1.0;
                                          int p = (int)MathRound(
                                              (priceDelta / pt) / k);
                                          if (p < 0)
                                            p = -p;
                                          return p;
                                        }

                                        double AIBC_ATR(string sym, int tf,
                                                        int period) {
                                          int bars = iBars(sym, tf);
                                          if (bars < period + 2)
                                            return 0.0;
                                          double sum = 0.0;
                                          for (int i = 1; i < period + 1; i++) {
                                            double hi = iHigh(sym, tf, i);
                                            double lo = iLow(sym, tf, i);
                                            double cl = iClose(sym, tf, i + 1);
                                            double tr = MathMax(
                                                hi - lo,
                                                MathMax(MathAbs(hi - cl),
                                                        MathAbs(lo - cl)));
                                            sum += tr;
                                          }
                                          double pt =
                                              MarketInfo(sym, MODE_POINT);
                                          int dg =
                                              (int)MarketInfo(sym, MODE_DIGITS);
                                          return (sum / period) / pt /
                                                 ((dg == 5 || dg == 3) ? 10.0
   : 1.0);
                                        }

                                        int AIBC_TF_Minutes(int tf) {
                                          return TFMinutes(Period());
                                        }

                                        string AIBC_InferStrategyName(
                                            long magic, string sym) {
                                          int b = MagicBase((int)magic);
                                          if (b == ObliviousAiMagic)
                                            return "ObliviousAI";
                                          if (b == PredictedMagic)
                                            return "Predicted";
                                          if (b == BreakoutMagic)
                                            return "Breakout";
                                          if (b == FVGMagic)
                                            return "FVG";
                                          if (b == GridMagic)
                                            return "Grid";
                                          if (b == SMCMagic)
                                            return "SMC";
                                          if (b == ICTMagic)
                                            return "ICT";
                                          if (b == ReverseMagic)
                                            return "Reverse";
                                          // Fallback comment
                                          string cmt = "";
                                          int total = OrdersTotal();
                                          for (int i = 0; i < total; i++) {
                                            if (!OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES))
                                              continue;
                                            if ((long)OrderMagicNumber() !=
                                                magic)
                                              continue;
                                            if (OrderSymbol() != sym)
                                              continue;
                                            cmt = OrderComment();
                                            break;
                                          }
                                          if (StringLen(cmt) > 0)
                                            return cmt;
                                          return "Unknown";
                                        }

string AIBC_ClassifyStyle(long magic, string sym) {
   string _aibc_tmp = AIBC_InferStrategyName(magic, sym);
   string n = StringToUpper(_aibc_tmp);
   if (StringFind(n, "GRID") >= 0)
      return "GRID";
   if (StringFind(n, "REVERS") >= 0 || n == "REVERSE")
      return "REVERSAL";
   if (StringFind(n, "BREAK") >= 0 || n == "BREAKOUT")
      return "BREAKOUT";
   if (n == "PATTERN" || n == "PREDICTED" || n == "FVG" ||
       StringFind(n, "SMC") >= 0 || StringFind(n, "ICT") >= 0)
      return "BREAKOUT";
   int tfm = AIBC_TF_Minutes(AIBC_ATR_TF);
   if (tfm <= 5)
      return "SCALPING";
   return "BREAKOUT";
}

                                        int AIBC_CombinePips(
                                            int nativePips, int aiPips,
                                            string style, int mode, int tfMin) {
                                          if (nativePips <= 0)
                                            return aiPips;
                                          double w =
                                              (mode == 0
                                                   ? 0.40
                                                   : (mode == 2
                                                          ? 0.80
                                                          : 0.60)); // base
                                          string st = StringToUpper(style);
                                          if (st == "SCALPING" ||
                                              st == "REVERSAL")
                                            w -= 0.15;
                                          if (st == "BREAKOUT" ||
                                              st == "MARTINGALE" ||
                                              st == "GRID")
                                            w += 0.15;
                                          if (tfMin <= 5)
                                            w -= 0.05;
                                          if (tfMin >= 60)
                                            w += 0.05;
                                          if (w < 0.20)
                                            w = 0.20;
                                          if (w > 0.90)
                                            w = 0.90;
                                          int mix = (int)MathRound(
                                              w * aiPips +
                                              (1.0 - w) * nativePips);
                                          if (mix <= 0)
                                            mix = aiPips > 0 ? aiPips
   : nativePips;
                                          return mix;
                                        }

                                        int AIBC_FindIdx(long ticket) {
                                          for (int i = 0; i < AIBC_TrackSize;
                                               i++) {
                                            if (AIBC_Tickets[i] == ticket)
                                              return i;
                                          }
                                          if (AIBC_TrackSize < AIBC_MAX_TRACK) {
                                            AIBC_Tickets[AIBC_TrackSize] =
                                                ticket;
                                            AIBC_Attached[AIBC_TrackSize] = 0;
                                            AIBC_NativeBase[AIBC_TrackSize] = 0;
                                            AIBC_LastFinal[AIBC_TrackSize] = 0;
                                            AIBC_TrackSize++;
                                            return AIBC_TrackSize - 1;
                                          }
                                          return 0;
                                        }

                                        bool AIBC_IsMagicWatched(long magic) {
                                          bool all = true;
                                          for (int i = 0;
                                               i < ArraySize(AIBC_Magics);
                                               i++) {
                                            if (AIBC_Magics[i] != 0) {
                                              all = false;
                                              break;
                                            }
                                          }
                                          if (all)
                                            return true;
                                          for (int j = 0;
                                               j < ArraySize(AIBC_Magics);
                                               j++) {
                                            if (AIBC_Magics[j] == magic)
                                              return true;
                                          }
                                          return false;
                                        }

