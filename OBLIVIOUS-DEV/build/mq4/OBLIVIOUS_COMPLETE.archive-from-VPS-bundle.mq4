      if (sym == Symbol() || sym == "")
        return 0;
      return -1; // Not in cache
}

double Indicators_GetScore0_100(string sym, int tf, int dir, string &why)
{
      why = "";
      int total = 0, hit = 0;

      // Check all enabled indicators
      if (UI_EnableRSI()) {
        total++;
        if (dir > 0 ? iRSI(sym, tf, Auto_RSI_Period(), PRICE_CLOSE, 1) > 50
                    : iRSI(sym, tf, Auto_RSI_Period(), PRICE_CLOSE, 1) < 50) {
          hit++;
          why += "RSI ";
        }
      }
      if (UI_EnableMACD()) {
        total++;
        if (dir > 0 ? IsMACD() : !IsMACD()) {
          hit++;
          why += "MACD ";
        }
      }
      if (UI_EnableEMA()) {
        total++;
        if (dir > 0 ? IsEMA() : !IsEMA()) {
          hit++;
          why += "EMA ";
        }
      }
      if (UI_EnableMA()) {
        total++;
        if (dir > 0 ? IsMA() : !IsMA()) {
          hit++;
          why += "MA ";
        }
      }
      if (UI_EnableADX()) {
        total++;
        if (IsADX()) {
          hit++;
          why += "ADX ";
        }
      }
      if (UI_EnableCCI()) {
        total++;
        if (dir > 0 ? IsCCI() : !IsCCI()) {
          hit++;
          why += "CCI ";
        }
      }
      if (UI_EnableStochastic()) {
        total++;
        if (dir > 0 ? IsStochastic() : !IsStochastic()) {
          hit++;
          why += "STO ";
        }
      }
      if (UI_EnableMomentum()) {
        total++;
        if (dir > 0 ? IsMomentum() : !IsMomentum()) {
          hit++;
          why += "MOM ";
        }
      }
      if (UI_EnableBollinger()) {
        total++;
        if (dir > 0 ? IsBollinger() : !IsBollinger()) {
          hit++;
          why += "BB ";
        }
      }
      if (UI_EnableSuperTrend()) {
        total++;
        if (dir > 0 ? IsSuperTrend() : !IsSuperTrend()) {
          hit++;
          why += "ST ";
        }
      }
      if (UI_EnableSAR()) {
        total++;
        if (dir > 0 ? IsSAR() : !IsSAR()) {
          hit++;
          why += "SAR ";
        }
      }
      if (UI_EnableOBV()) {
        total++;
        if (dir > 0 ? IsOBV() : !IsOBV()) {
          hit++;
          why += "OBV ";
        }
      }
      if (UI_EnableIchimoku()) {
        total++;
        if (dir > 0 ? IsIchimoku() : !IsIchimoku()) {
          hit++;
          why += "ICH ";
        }
      }
      if (UI_EnableVortex()) {
        total++;
        if (dir > 0 ? IsVortex() : !IsVortex()) {
          hit++;
          why += "VRT ";
        }
      }

      if (total == 0) {
        why = "No indicators enabled";
        return 50.0;
      }
      return (100.0 * hit) / total;
}

