                                          void AI_GetNewsLines(string & l1,
   string & l2,
   string & l3) {
                                            l1 = "";
                                            l2 = "";
                                            l3 = "";
                                            string js =
                                                GetNewsDataJSON(); // expected
                                            // latest-first:
                                            // [{"event":"","impact":"","time":""},
                                            // ]
                                            if (StringLen(js) <= 0)
                                              return;
                                            int pos = 0, count = 0;
                                            string last1 = "", last2 = "",
                                                   last3 = "";
                                            while (count < 3) {
                                              int e1 = StringFind(
                                                  js, "\"Event\":\"", pos);
                                              if (e1 < 0)
                                                break;
                                              e1 += 9;
                                              int e2 = StringFind(js, "\"", e1);
                                              if (e2 < 0)
                                                break;
                                              string ev =
                                                  StringSubstr(js, e1, e2 - e1);
                                              int i1 = StringFind(
                                                  js, "\"impact\":\"", e2);
                                              string im = "";
                                              if (i1 >= 0) {
                                                i1 += 10;
                                                int i2 =
                                                    StringFind(js, "\"", i1);
                                                if (i2 > i1)
                                                  im = StringSubstr(js, i1,
   i2 - i1);
                                              }
                                              int t1 = StringFind(
                                                  js, "\"time\":\"", e2);
                                              string tm = "";
                                              int t2 = -1;
                                              if (t1 >= 0) {
                                                t1 += 8;
                                                t2 = StringFind(js, "\"", t1);
                                                if (t2 > t1)
                                                  tm = StringSubstr(js, t1,
   t2 - t1);
                                              }
                                              string line =
                                                  (tm != "" ? (tm + " — ")
   : "") +
                                                  ev +
                                                  (im != "" ? (" (" + im + ")")
   : "");
                                              // skip duplicates
                                              if (line != last1 &&
                                                  line != last2 &&
                                                  line != last3) {
                                                if (count == 0) {
                                                  l1 = line;
                                                  last1 = line;
                                                } else if (count == 1) {
                                                  l2 = line;
                                                  last2 = line;
                                                } else {
                                                  l3 = line;
                                                  last3 = line;
                                                }
                                                count++;
                                              }
                                              // advance past this item
                                              pos = (t2 > 0 ? t2 : e2) + 1;
                                            }
                                          }

