void SMC_Overlay_Draw()
{
      SMC_HasBOS = false;
      SMC_HasCHOCH = false;
      if (!(SMC || ICT) || !HasBars(30))
        return;
      color C = RGB_Current();
      int tbar = iBars(NULL, 0);
      datetime tL = Time[1];
      datetime tR = Time[0] + PeriodSeconds() * 3;
      // ---------- BOS / CHOCH ----------
      int span = DynamicPivotSpan();
      int maxlook = AdaptiveMaxLook();
      int ph = FindLastPivotHigh(5, span, maxlook);
      int pl = FindLastPivotLow(5, span, maxlook);
      if (ph > 0) {
        double lvl = High[ph];
        DrawShortHLine("Trig_smc_bos_hi_" + IntegerToString(tbar), Time[ph],
                       BarEndTime(0), lvl, 0, "BOS_High", true);
        // BOS bullish if close breaches previous high
        if (Close[0] > lvl && Close[1] <= lvl)
          SMC_HasBOS = true;
        SL("smc", "bos", "bullish");
        DrawShortHLine("Trig_smc_bos_breach_hi_" + IntegerToString(tbar),
                       Time[ph], BarEndTime(0), lvl, 0, "BOS!", true);
      }
      if (pl > 0) {
        double lvl = Low[pl];
        DrawShortHLine("Trig_smc_bos_lo_" + IntegerToString(tbar), Time[pl],
                       BarEndTime(0), lvl, 0, "BOS_Low", true);
        if (Close[0] < lvl && Close[1] >= lvl)
          SMC_HasBOS = true;
        SL("smc", "bos", "bearish");
        DrawShortHLine("Trig_smc_bos_breach_lo_" + IntegerToString(tbar),
                       Time[pl], BarEndTime(0), lvl, 0, "BOS!", true);
      }
      // CHOCH (change of character): detect if last break direction flips vs
      // previous
      static int lastTrend = 0; // +1 up, -1 down, 0 unknown
      int trendNow = lastTrend;
      if (ph > 0 && Close[0] > High[ph])
        trendNow = +1;
      if (pl > 0 && Close[0] < Low[pl])
        trendNow = -1;
      if (lastTrend != 0 && trendNow != 0 && trendNow != lastTrend) {
        // mark CHOCH near current bar close
        SMC_HasCHOCH = true;
        SL("smc", "choch", "change of character");
        DrawShortHLine("Trig_smc_choch_" + IntegerToString(tbar), Time[1],
                       BarEndTime(0), Close[1], 0, "CHOCH", true);
      }
      if (trendNow != 0)
        lastTrend = trendNow;
      // ---------- Order Blocks (approximation from impulse source candle)
      // ---------- Bullish OB: last down candle's body before bullish BOS
      // Bearish OB: last up candle's body before bearish BOS
      int lookImpulse = 40;
      // bullish
      if (ph > 0 && Close[0] > High[ph]) {
        for (int i = 1; i <= lookImpulse; i++) {
          int k = i;
          if (Close[k] > Open[k])
            break;                  // stop when candle is up
          if (Close[k] < Open[k]) { // candidate down candle
            double top = Open[k];
            double bot = Close[k];
            MAKE_BOX("Trig_smc_ob_bull_" + IntegerToString(tbar), top, bot, C);
            Box_AddCenteredLabel("Trig_smc_ob_bull_" + IntegerToString(tbar),
                                 "OB"); /*SMC OB*/
            break;
          }
        }
      }
      // bearish
      if (pl > 0 && Close[0] < Low[pl]) {
        for (int i = 1; i <= lookImpulse; i++) {
          int k = i;
          if (Close[k] < Open[k])
            break;                  // stop when candle is down
          if (Close[k] > Open[k]) { // candidate up candle
            double top = Close[k];
            double bot = Open[k];
            MAKE_BOX("Trig_smc_ob_bear_" + IntegerToString(tbar), top, bot, C);
            Box_AddCenteredLabel("Trig_smc_ob_bear_" + IntegerToString(tbar),
                                 "OB"); /*SMC OB*/
            break;
          }
        }
      }
      // ---------- Liquidity (EQH/EQL) ----------
      int eqLook = 100;
      double tol = 2 * Point; // equal within 2 points
      // Equal Highs: find two recent pivot highs within tolerance
      int lastPH = -1;
      for (int i = 5; i < MathMin(eqLook, Bars - 5); i++) {
        if (PivotHigh(span, span, i)) {
          if (lastPH >= 0 && MathAbs(High[i] - High[lastPH]) <= tol) {
            double lvl = 0.5 * (High[i] + High[lastPH]);
            datetime t1 = Time[i];
            datetime t2 = Time[lastPH];
            if (t2 < t1) {
              datetime tmp = t1;
              t1 = t2;
              t2 = tmp;
            }
            DrawShortHLine("Trig_smc_eqh_" + IntegerToString(iBars(NULL, 0)) +
                               "_" + IntegerToString(i),
                           t2, BarEndTime(0), lvl, 0, "EQH", true);
            break;
          }
          lastPH = i;
        }
      }
      // Equal Lows
      int lastPL = -1;
      for (int i = 5; i < MathMin(eqLook, Bars - 5); i++) {
        if (PivotLow(span, span, i)) {
          if (lastPL >= 0 && MathAbs(Low[i] - Low[lastPL]) <= tol) {
            double lvl = 0.5 * (Low[i] + Low[lastPL]);
            datetime t1 = Time[i];
            datetime t2 = Time[lastPL];
            if (t2 < t1) {
              datetime tmp = t1;
              t1 = t2;
              t2 = tmp;
            }
            DrawShortHLine("Trig_smc_eql_" + IntegerToString(iBars(NULL, 0)) +
                               "_" + IntegerToString(i),
                           t2, BarEndTime(0), lvl, 0, "EQL", true);
            break;
          }
          lastPL = i;
        }
      }
      double atr = iATR(NULL, 0, 14, 0);
      double spread = (Ask - Bid) / _Point;
      double maxSpread = iStdDevOnArray(Close, 0, 20, 0, MODE_SMA, 0);
      if (spread > maxSpread * 2.0) {
        Bridge_SendLog(2, "FVG", "Spread too high, skipping");
        return;
      }
      if (Bridge_IsConnected()) {
        string aiPayload;
        if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
          if (StringFind(aiPayload, "fvg=0") >= 0) {
            Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
            return;
          }
        }
      }
}

void FVG_Overlay_Draw()
{
      if (!FVG || !HasBars(5)) {
        FVG_Liquidity_Clear();
        return;
      }
      color C = RGB_Current();
      int tbar = iBars(NULL, 0);
      datetime tL = Time[2];
      datetime tR = Time[0] + PeriodSeconds() * 3;
      // Configuration (can be linked to inputs)
      double minPts = DynamicFVGMinPoints(); // minimum gap size in points
      int N = 200;                           // scan back N bars
      int maxRects = 3;                      // draw up to 3 active FVGs
      double atr = iATR(NULL, 0, 14, 0);
      double spread = (Ask - Bid) / _Point;
      double maxSpread = iStdDevOnArray(Close, 0, 20, 0, MODE_SMA, 0);
      if (spread > maxSpread * 2.0) {
        Bridge_SendLog(2, "FVG", "Spread too high, skipping");
        return;
      }
      if (Bridge_IsConnected()) {
        string aiPayload;
        if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
          if (StringFind(aiPayload, "fvg=0") >= 0) {
            Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
            return;
          }
        }
      }
      int found = 0;
      for (int i = 2; i <= MathMin(N, Bars - 3) && found < maxRects; i++) {
        // bullish FVG: Low[i] > High[i+2]
        if (Low[i] - High[i + 2] >= minPts) {
          double top = Low[i];
          double bot = High[i + 2];
          string id = "Trig_fvg_bull_" + IntegerToString(tbar) + "_" +
                      IntegerToString(i);
          MAKE_BOX(id, top, bot, C);
          Box_AddCenteredLabel(id, "FVG"); /*FVG*/
          found++;
        }
        // bearish FVG: High[i] < Low[i+2]
        if (spread > maxSpread * 2.0) {
          Bridge_SendLog(2, "FVG", "Spread too high, skipping");
          return;
        }
        if (Bridge_IsConnected()) {
          string aiPayload;
          if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
            if (StringFind(aiPayload, "fvg=0") >= 0) {
              Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
              return;
            }
          }
        }
        if (Low[i + 2] - High[i] >= minPts) {
          double top = Low[i + 2];
          double bot = High[i];
          string id = "Trig_fvg_bear_" + IntegerToString(tbar) + "_" +
                      IntegerToString(i);
          MAKE_BOX(id, top, bot, C);
          Box_AddCenteredLabel(id, "FVG"); /*FVG*/
          found++;
        }
      }
      // Dim boxes that have been filled (extend-until-fill visual)
      FVG_Registry_MarkFilled();
}

void DrawPnL_Label(string prefix, int x, int y, int corner)
{
      string name = prefix + "_PNL";
      double total = ProfitToday_Total();
      double pct = ProfitToday_Percent();
      color clr = (total >= 0 ? clrLime : clrRed);

      string text = StringFormat("PnL: %s%.2f (%.1f%%)",
                                 (total >= 0 ? "+" : ""), total, pct);

      if (ObjectFind(0, name) < 0) {
        ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, name, OBJPROP_CORNER, corner);
        ObjectSetInteger(0, name, OBJPROP_ANCHOR, ANCHOR_LEFT_UPPER);
      }
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
      ObjectSetString(0, name, OBJPROP_FONT, "Consolas");
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 10);
}

void DrawPnL_DDLabel(string prefix, int x, int y, int corner)
{
      string name = prefix + "_DD";
      double dd = PnL_CurrentDrawdown();
      double ddd = PnL_DailyDrawdown();
      color clr = (dd > 10 ? clrOrangeRed : clrGold);

      string text = StringFormat("DD: %.1f%% | Daily: %.1f%%", dd, ddd);

      if (ObjectFind(0, name) < 0) {
        ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, name, OBJPROP_CORNER, corner);
        ObjectSetInteger(0, name, OBJPROP_ANCHOR, ANCHOR_LEFT_UPPER);
      }
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
      ObjectSetString(0, name, OBJPROP_FONT, "Consolas");
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 10);
}

bool DrawdownTooHigh() {
   double equity   = AccountEquity();
   double balance  = AccountBalance();
   if (balance <= 0) return false;
   double ddPct    = 100.0 * (balance - equity) / balance;
   return (ddPct >= MaxDailyDDPercent);
}
