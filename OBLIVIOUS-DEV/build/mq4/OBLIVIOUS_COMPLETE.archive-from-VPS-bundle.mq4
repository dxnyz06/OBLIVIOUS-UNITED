                      void Daily_ResetIfNewDay() {
                        datetime t = TimeCurrent();
                        string td = TimeToString(t, TIME_DATE);
                        string sd = TimeToString(__DayStamp, TIME_DATE);
                        if (td != sd) {
                          __DayStamp = t;
                          __DayStartEquity = AccountEquity();
                        }
                      }

                      double DailyPnLPercent() {
                        Daily_ResetIfNewDay();
                        double base = __DayStartEquity;
                        if (base <= 0)
                          return 0.0;
                        return (AccountEquity() - base) / base;
                      }

                      int AIP2_LTF() {
                        int tf = Period();
                        if (tf >= PERIOD_H1)
                          return PERIOD_M15;
                        if (tf >= PERIOD_M15)
                          return PERIOD_M5;
                        return PERIOD_M1;
                      }

                      int AIP2_BarsWin() { return 10; }

                      double AIP2_Median(double &arr[], int n) {
                        return EB_Median(arr,
                                         n); // Reuse from EdgeBiased
                      }

                      double AIP2_TickMid() {
                        double b = MarketInfo(Symbol(), MODE_BID);
                        double a = MarketInfo(Symbol(), MODE_ASK);
                        if (b == 0 && a == 0)
                          return iClose(Symbol(), AIP2_LTF(), 0);
                        if (a > 0 && b > 0)
                          return 0.5 * (a + b);
                        if (a > 0)
                          return a;
                        return b;
                      }

                      double AIP2_Mid() {
                        double b = MarketInfo(Symbol(), MODE_BID);
                        double a = MarketInfo(Symbol(), MODE_ASK);
                        if (a > 0 && b > 0)
                          return 0.5 * (a + b);
                        if (a > 0)
                          return a;
                        if (b > 0)
                          return b;
                        return iClose(Symbol(), AIP2_LTF(), 0);
                      }

                      bool AIP2_GetOTEBands(int tf, bool isLong, double &pLo,
                                            double &pHi) {
                        double loB = 0, hiB = 0, tol = 0;
                        bool ok =
                            OTEBandFromHistory(true, tf, 15, loB, hiB, tol);
                        if (!ok)
                          return false;
                        if (!isLong) {
                          double a1 = 1.0 - hiB, a2 = 1.0 - loB;
                          loB = MathMin(a1, a2);
                          hiB = MathMax(a1, a2);
                        }
                        int iH = iHighest(Symbol(), tf, MODE_HIGH, 30, 1);
                        int iL = iLowest(Symbol(), tf, MODE_LOW, 30, 1);
                        double H = iHigh(Symbol(), tf, iH),
                               L = iLow(Symbol(), tf, iL);
                        double a = EB_PriceFromFrac(H, L, loB);
                        double b = EB_PriceFromFrac(H, L, hiB);
                        pLo = MathMin(a, b);
                        pHi = MathMax(a, b);
                        return true;
                      }

                      bool AIP2_BandHitByRange(int tf, double bandLo,
                                               double bandHi) {
                        double H = iHigh(Symbol(), tf, 0),
                               L = iLow(Symbol(), tf, 0);
                        if (bandHi < bandLo) {
                          double t = bandHi;
                          bandHi = bandLo;
                          bandLo = t;
                        }
                        return (H >= bandLo && L <= bandHi);
                      }

                      double AIP2_InnerBufLive() {
                        int tf = AIP2_LTF();
                        int W = (int)MathMax(20, AIP2_BarsWin());
                        double rr[];
                        ArrayResize(rr, W);
                        for (int i = 1; i <= W; i++) {
                          double h = iHigh(Symbol(), tf, i),
                                 l = iLow(Symbol(), tf, i),
                                 pc = iClose(Symbol(), tf, i + 1);
                          rr[i - 1] = MathMax(
                              h - l, MathMax(MathAbs(h - pc), MathAbs(l - pc)));
                        }
                        // MAD of TR as robust buffer
                        double med = AIP2_Median(rr, W);
                        double d[];
                        ArrayResize(d, W);
                        for (int j = 0; j < W; j++)
                          d[j] = MathAbs(rr[j] - med);
                        double mad = AIP2_Median(d, W);
                        double spr = MarketInfo(Symbol(), MODE_SPREAD) * Point;
                        double stp =
                            MarketInfo(Symbol(), MODE_STOPLEVEL) * Point;
                        return MathMax(mad, MathMax(spr, stp));
                      }

                      bool AIP2_OTESeparationOK() {
                        // Check that buy and sell OTE bands
                        // are not overlapping
                        double loB = 0, hiB = 0, loS = 0, hiS = 0;
                        if (!AIP2_GetOTEBands(Period(), true, loB, hiB))
                          return true;
                        if (!AIP2_GetOTEBands(Period(), false, loS, hiS))
                          return true;
                        double gap = MathMin(loS, loB) - MathMax(hiB, hiS);
                        return (gap > 0 ||
                                MathAbs(gap) < AIP2_InnerBufLive() * 0.5);
                      }

                      bool AIP2_TouchedBothOTE_LTF() {
                        int tfL = AIP2_LTF();
                        double loB = 0, hiB = 0, loS = 0, hiS = 0;
                        if (!AIP2_GetOTEBands(tfL, true, loB, hiB))
                          return false;
                        if (!AIP2_GetOTEBands(tfL, false, loS, hiS))
                          return false;
                        return true; // If both bands exist,
                                     // condition met
                      }

                      bool AIP2_T0_RangeTouchOK(int side) {
                        int tfH =
                            (Period() >= PERIOD_H1 ? Period() : PERIOD_H1);
                        int tfL =
                            (Period() <= PERIOD_M15 ? Period() : PERIOD_M15);
                        double loH = 0, hiH = 0, loL = 0, hiL = 0, loHo = 0,
                               hiHo = 0, loLo = 0, hiLo = 0;
                        if (!AIP2_GetOTEBands(tfH, side > 0, loH, hiH))
                          return false;
                        if (!AIP2_GetOTEBands(tfL, side > 0, loL, hiL))
                          return false;
                        bool hitSide = AIP2_BandHitByRange(tfH, loH, hiH) &&
                                       AIP2_BandHitByRange(tfL, loL, hiL);
                        // ensure we are NOT also hitting
                        // opposite OTE bands on this live
                        // bar
                        bool hitOpp = false;
                        if (AIP2_GetOTEBands(tfH, side < 0, loHo, hiHo) &&
                            AIP2_GetOTEBands(tfL, side < 0, loLo, hiLo)) {
                          hitOpp = AIP2_BandHitByRange(tfH, loHo, hiHo) ||
                                   AIP2_BandHitByRange(tfL, loLo, hiLo);
                        }
                        if (!hitSide || hitOpp)
                          return false;
                        // separation + dual-touch pre-news
                        // already enforced elsewhere; keep
                        // them by reusing
                        // AIP2_OTESeparationOK +
                        // AIP2_TouchedBothOTE_LTF
                        if (!AIP2_OTESeparationOK())
                          return false;
                        if (!AIP2_TouchedBothOTE_LTF())
                          return false;
                        return true;
                      }

                      void AIP2_T0_ResetIfNewBar() {
                        static datetime lb = 0;
                        if (Time[0] != lb) {
                          lb = Time[0];
                        }
                      }

                      bool AIP2_T0_SequentialTouchesOK(int side) {
                        AIP2_T0_ResetIfNewBar();
                        int tfH =
                            (Period() >= PERIOD_H1 ? Period() : PERIOD_H1);
                        int tfL =
                            (Period() <= PERIOD_M15 ? Period() : PERIOD_M15);
                        double loH = 0, hiH = 0, loL = 0, hiL = 0, oloH = 0,
                               ohiH = 0, oloL = 0, ohiL = 0;
                        if (!AIP2_GetOTEBands(tfH, side > 0, loH, hiH))
                          return false;
                        if (!AIP2_GetOTEBands(tfL, side > 0, loL, hiL))
                          return false;
                        if (AIP2_t0_side != side) {
                          AIP2_t0_ltf = false;
                          AIP2_t0_htf = false;
                          AIP2_t0_side = side;
                        }
                        bool hitLTF = AIP2_BandHitByRange(AIP2_LTF(), loL, hiL);
                        bool hitHTF = AIP2_BandHitByRange(AIP2_LTF(), loH, hiH);
                        if (hitLTF)
                          AIP2_t0_ltf = true;
                        if (AIP2_t0_ltf && hitHTF)
                          AIP2_t0_htf = true;
                        bool hitOpp = false;
                        if (AIP2_GetOTEBands(tfH, side < 0, oloH, ohiH) &&
                            AIP2_GetOTEBands(tfL, side < 0, oloL, ohiL)) {
                          hitOpp =
                              AIP2_BandHitByRange(AIP2_LTF(), oloH, ohiH) ||
                              AIP2_BandHitByRange(AIP2_LTF(), oloL, ohiL);
                        }
                        if (hitOpp)
                          return false;
                        if (!AIP2_OTESeparationOK())
                          return false;
                        if (!AIP2_TouchedBothOTE_LTF())
                          return false;
                        return AIP2_t0_ltf && AIP2_t0_htf;
                      }

                      void AIP2_T0_ResetSeq(int side) {
                        AIP2_seq_bar = iTime(Symbol(), AIP2_LTF(), 0);
                        AIP2_seq_side = side;
                        AIP2_seq_ltf = false;
                        AIP2_seq_htf = false;
                        AIP2_seq_armed = false;
                      }

                      bool AIP2_T0_TickSequentialOK(int side) {
                        int tfL = AIP2_LTF();
                        int tfH =
                            (Period() >= PERIOD_H1 ? Period() : PERIOD_H1);
                        datetime bt = iTime(Symbol(), tfL, 0);
                        if (bt != AIP2_seq_bar || AIP2_seq_side != side) {
                          AIP2_T0_ResetSeq(side);
                        }
                        double loL = 0, hiL = 0, loH = 0, hiH = 0;
                        if (!AIP2_GetOTEBands(tfL, side > 0, loL, hiL))
                          return false;
                        if (!AIP2_GetOTEBands(tfH, side > 0, loH, hiH))
                          return false;
                        // Opposite bands (live, for hard
                        // reject)
                        double oloL = 0, ohiL = 0, oloH = 0, ohiH = 0;
                        bool hasOppL =
                            AIP2_GetOTEBands(tfL, side < 0, oloL, ohiL);
                        bool hasOppH =
                            AIP2_GetOTEBands(tfH, side < 0, oloH, ohiH);
                        double px = AIP2_TickMid();
                        // If we are inside opposite bands
                        // on this tick -> invalid
                        if ((hasOppL && px >= MathMin(oloL, ohiL) &&
                             px <= MathMax(oloL, ohiL)) ||
                            (hasOppH && px >= MathMin(oloH, ohiH) &&
                             px <= MathMax(oloH, ohiH)))
                          return false;
                        // Sequential touches: LTF first,
                        // then HTF
                        if (!AIP2_seq_ltf) {
                          if (px >= MathMin(loL, hiL) &&
                              px <= MathMax(loL, hiL)) {
                            AIP2_seq_ltf = true;
                          }
                        } else if (!AIP2_seq_htf) {
                          if (px >= MathMin(loH, hiH) &&
                              px <= MathMax(loH, hiH)) {
                            AIP2_seq_htf = true;
                          }
                        }
                        // Keep global structural guards
                        if (!AIP2_TouchedBothOTE_LTF())
                          return false;
                        if (!AIP2_OTESeparationOK())
                          return false;
                        return (AIP2_seq_ltf && AIP2_seq_htf);
                      }

                      bool AIP2_GetBand1_LTF_10tips(int side, double &lo,
                                                    double &hi) {
                        int tf = AIP2_LTF();
                        int N = 10;
                        int idxH = iHighest(Symbol(), tf, MODE_HIGH, N, 0);
                        int idxL = iLowest(Symbol(), tf, MODE_LOW, N, 0);
                        double HH = iHigh(Symbol(), tf, idxH);
                        double LL = iLow(Symbol(), tf, idxL);
                        // MAD of true range over last N for
                        // adaptive width
                        double tr[];
                        ArrayResize(tr, N);
                        for (int i = 0; i < N; i++) {
                          double h = iHigh(Symbol(), tf, i),
                                 l = iLow(Symbol(), tf, i),
                                 pc = iClose(Symbol(), tf, i + 1);
                          tr[i] = MathMax(
                              h - l, MathMax(MathAbs(h - pc), MathAbs(l - pc)));
                        }
                        double med = AIP2_Median(tr, N);
                        for (int j = 0; j < N; j++)
                          tr[j] = MathAbs(tr[j] - med);
                        double w = AIP2_Median(tr, N);
                        double spr = MarketInfo(Symbol(), MODE_SPREAD) * Point;
                        double stp =
                            MarketInfo(Symbol(), MODE_STOPLEVEL) * Point;
                        double width = MathMax(w, MathMax(spr, stp));
                        if (side > 0) {
                          lo = LL;
                          hi = LL + width;
                        } else {
                          lo = HH - width;
                          hi = HH;
                        }
                        return true;
                      }

                      bool AIP2_GetBand2_HTF_far(int side, double &lo,
                                                 double &hi, double &minD,
                                                 double &maxD) {
                        int tfH =
                            (Period() >= PERIOD_H1 ? Period() : PERIOD_H1);
                        int W = (int)MathMax(30, AIP2_BarsWin() * 2);
                        int idxH = iHighest(Symbol(), tfH, MODE_HIGH, W, 1);
                        int idxL = iLowest(Symbol(), tfH, MODE_LOW, W, 1);
                        double HH = iHigh(Symbol(), tfH, idxH);
                        double LL = iLow(Symbol(), tfH, idxL);
                        double R = HH - LL;
                        if (R <= 0)
                          R = Point * 10;
                        // choose a fib pocket away from
                        // Band1
                        double a = LL + 0.382 * R,
                               b = LL + 0.618 * R; // buy pocket
                        double c = HH - 0.618 * R,
                               d = HH - 0.382 * R; // sell pocket
                        // HTF width via MAD(TR) over W
                        int M = (int)MathMin(W, 60);
                        double tr[];
                        ArrayResize(tr, M);
                        for (int i = 1; i <= M; i++) {
                          double h = iHigh(Symbol(), tfH, i),
                                 l = iLow(Symbol(), tfH, i),
                                 pc = iClose(Symbol(), tfH, i + 1);
                          tr[i - 1] = MathMax(
                              h - l, MathMax(MathAbs(h - pc), MathAbs(l - pc)));
                        }
                        double med = AIP2_Median(tr, M);
                        for (int j = 0; j < M; j++)
                          tr[j] = MathAbs(tr[j] - med);
                        double width = AIP2_Median(tr, M);
                        if (side > 0) {
                          lo = a;
                          hi = b;
                        } else {
                          lo = c;
                          hi = d;
                        }
                        // distance bounds (auto-adaptive)
                        double inner = AIP2_InnerBufLive();
                        // outer multiplier from ATR slope
                        // proxy
                        double om = 1.0;
                        { // compute om ~ 1 + normalized ATR
                          // slope on HTF
                          int look = 15;
                          double atr1 = 0, atr2 = 0;
                          for (int k = 1; k <= look; k++) {
                            double h = iHigh(Symbol(), tfH, k),
                                   l = iLow(Symbol(), tfH, k),
                                   pc = iClose(Symbol(), tfH, k + 1);
                            atr1 += MathMax(h - l, MathMax(MathAbs(h - pc),
                                                           MathAbs(l - pc)));
                          }
                          for (int k = look + 1; k <= 2 * look; k++) {
                            double h = iHigh(Symbol(), tfH, k),
                                   l = iLow(Symbol(), tfH, k),
                                   pc = iClose(Symbol(), tfH, k + 1);
                            atr2 += MathMax(h - l, MathMax(MathAbs(h - pc),
                                                           MathAbs(l - pc)));
                          }
                          atr1 /= look;
                          atr2 /= look;
                          double base = MathMax(1e-8, MathAbs(atr2 - atr1));
                          om = 1.0 + MathMin(1.0, MathAbs(atr1 - atr2) /
                                                      (2.0 * base));
                        }
                        minD = inner * om; // at least inner scaled
                        maxD = 0.5 * R;    // dynamic: half of HTF swing
                        // expand band with width (kept for
                        // drawing/validation via
                        // range-touch)
                        lo = lo;
                        hi = hi; // already set via fib
                        // pocket; width used
                        // implicitly by pocket
                        // thickness
                        return true;
                      }

                      bool AIP2_BandsDistanceOK_dyn(double lo1, double hi1,
                                                    double lo2, double hi2,
                                                    double minD, double maxD) {
                        double c1 = 0.5 * (lo1 + hi1), c2 = 0.5 * (lo2 + hi2);
                        double d = MathAbs(c1 - c2);
                        return (d >= minD && d <= maxD);
                      }

                      bool AIP2_GetBands10_50_dynamic(
                          int side, double &b1_lo, double &b1_hi, double &b2_lo,
                          double &b2_hi) {
                        int tf = AIP2_LTF();
                        int N = 10;
                        int idxH = iHighest(Symbol(), tf, MODE_HIGH, N, 0);
                        int idxL = iLowest(Symbol(), tf, MODE_LOW, N, 0);
                        double HH = iHigh(Symbol(), tf, idxH);
                        double LL = iLow(Symbol(), tf, idxL);
                        double tr[];
                        ArrayResize(tr, N);
                        for (int i = 0; i < N; i++) {
                          double h = iHigh(Symbol(), tf, i),
                                 l = iLow(Symbol(), tf, i),
                                 pc = iClose(Symbol(), tf, i + 1);
                          tr[i] = MathMax(
                              h - l, MathMax(MathAbs(h - pc), MathAbs(l - pc)));
                        }
                        double med = AIP2_Median(tr, N);
                        for (int j = 0; j < N; j++)
                          tr[j] = MathAbs(tr[j] - med);
                        double width = AIP2_Median(tr, N);
                        double spr = MarketInfo(Symbol(), MODE_SPREAD) * Point;
                        double stp =
                            MarketInfo(Symbol(), MODE_STOPLEVEL) * Point;
                        width = MathMax(width, MathMax(spr, stp));
                        if (side > 0) { // BUY
                          b1_lo = LL;
                          b1_hi = LL + width;
                          b2_lo = LL + width;
                          b2_hi = LL + 1.5 * width; // +50% offset
                        } else {                    // SELL
                          b1_lo = HH - width;
                          b1_hi = HH;
                          b2_lo = HH - 1.5 * width;
                          b2_hi = HH - width;
                        }
                        return true;
                      }

                      bool AIP2_ArmImmediateStop(int side, int magic,
                                                 double volume) {
                        int tf = AIP2_LTF();
                        double buf = AIP2_InnerBufLive();
                        double anchorH = iHigh(Symbol(), tf, 0);
                        double anchorL = iLow(Symbol(), tf, 0);
                        int type = (side > 0 ? OP_BUYSTOP : OP_SELLSTOP);
                        double price =
                            (side > 0 ? anchorH + buf : anchorL - buf);
                        double sl = 0,
                               tp = 0; // gestione SL/TP
                        // dinamica a cura della
                        // logica esistente
                        int slippage = Slippage;
                        int ticket = SafeOrderSend(
                            Symbol(), type, volume,
                            NormalizeDouble(price, Digits), slippage, 0, 0, "",
                            magic, 0, clrNONE);
                        return (ticket > 0);
                      }

                      double AIP2_TR_at(int tf, int shift) {
                        double pc = iClose(Symbol(), tf, shift + 1),
                               hi = iHigh(Symbol(), tf, shift),
                               lo = iLow(Symbol(), tf, shift);
                        double a = hi - lo, b = MathAbs(hi - pc),
                               c = MathAbs(lo - pc);
                        return MathMax(a, MathMax(b, c));
                      }

                      double AIP2_MedianArr(double &a[], int n) {
                        if (n <= 0)
                          return 0.0;
                        double t[];
                        ArrayResize(t, n);
                        for (int i = 0; i < n; i++)
                          t[i] = a[i];
                        ArraySort(t, WHOLE_ARRAY, 0, MODE_ASCEND);
                        return t[n / 2];
                      }

