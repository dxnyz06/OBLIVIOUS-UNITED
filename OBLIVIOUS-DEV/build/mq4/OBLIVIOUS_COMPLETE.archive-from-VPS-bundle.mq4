void VTPSL_OnTick() {
                                        for (int i = OrdersTotal() - 1; i >= 0;
                                             i--) {
                                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
                                          if (OrderSymbol() != Symbol()) continue;
                                          if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
                                          string prefix =
                                              "VTPSL_" +
                                              IntegerToString(OrderTicket());
                                          string tpKey = prefix + "_TP";
                                          string slKey = prefix + "_SL";
                                          if (!GlobalVariableCheck(tpKey))
                                            continue;
                                          double vtp = GlobalVariableGet(tpKey);
                                          double vsl = GlobalVariableGet(slKey);
                                          double price = (OrderType() == OP_BUY)
   ? Bid
   : Ask;
                                          bool hitTP =
                                              (vtp > 0 &&
                                               ((OrderType() == OP_BUY &&
                                                 price >= vtp) ||
                                                (OrderType() == OP_SELL &&
                                                 price <= vtp)));
                                          bool hitSL =
                                              (vsl > 0 &&
                                               ((OrderType() == OP_BUY &&
                                                 price <= vsl) ||
                                                (OrderType() == OP_SELL &&
                                                 price >= vsl)));
                                          if (hitTP || hitSL) {
                                            string reason = hitTP ? "VirtualTP"
   : "VirtualSL";
                                            bool closed = OrderClose(
                                                OrderTicket(), OrderLots(),
                                                price, 10,
                                                hitTP ? clrLime : clrRed);
                                            if (closed) {
                                              GlobalVariableDel(tpKey);
                                              GlobalVariableDel(slKey);
                                              SmartLog("INFO", "VTPSL",
                                                       reason +
                                                           " hit ticket #" +
                                                           IntegerToString(
   OrderTicket()));
                                            }
                                          }
                                        }
}

