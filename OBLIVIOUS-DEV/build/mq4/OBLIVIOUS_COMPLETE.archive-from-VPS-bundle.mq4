void DispatchPatternStrategies() {
   // ============================================================
   // LEVEL 3: Pattern Context  always active, no AllowStrategyToTrade gate
   // Pattern functions detect setups and contribute to g_pat_consensus.
   // NO TRADES are opened inside pattern detection functions.
   // ============================================================
   g_pat_bull_count = 0;
   g_pat_bear_count = 0;
   g_pat_confidence = 0.0;

   // Alpha + Crown patterns (always run)  
   PatternAlpha_Logic();    // engulfing + MACD confluence
   PatternCrown_Logic();    // crown/head-and-shoulders detection

   // Candlestick patterns (always active  no input gate required)
   Strategy_Engulfing_Logic();
   Strategy_Hammer_Logic();
   Strategy_Doji_Logic();
   Strategy_MorningStar_Logic();
   Strategy_InsideBar_Logic();
   Strategy_PinBar_Logic();
   Strategy_Marubozu_Logic();
   Strategy_HaramiPattern_Logic();
   Strategy_ThreeBarPattern_Logic();
   Strategy_BreakoutPattern_Logic();
   Strategy_OrderBlockPattern_Logic();
   Strategy_StructureBreakPattern_Logic();
   Strategy_LiquidityGrabPattern_Logic();
   Strategy_FVGPattern_Logic();
   Strategy_ThreeWhiteSoldiers_Logic();

   // Compute pattern consensus: -100 (all bear) to +100 (all bull)
   int total = g_pat_bull_count + g_pat_bear_count;
   g_pat_consensus = (total > 0) ? (100.0 * (g_pat_bull_count - g_pat_bear_count) / total) : 0.0;

   // Pattern Engine produces support signals for the 6 owner strategies:
   // pattern_direction_support, pattern_confidence, pattern_trigger_quality
   // NO trades are opened here — Pattern Engine is always active, non-owner.
   int pSig = (g_pat_consensus > PatternsConfidence * 0.5) ? 1 : (g_pat_consensus < -(PatternsConfidence * 0.5)) ? -1 : 0;
   double pConf = MathAbs(g_pat_consensus) + IndicatorAlignmentBonus(pSig) * 0.3;
   g_pat_direction_support  = pSig;
   g_pat_confidence_support = clamp100(pConf);
   g_pat_trigger_quality    = (pConf >= PatternsConfidence) ? 1.0 : (pConf / MathMax(1.0, (double)PatternsConfidence));
}

bool ICT_DetectBreakerBlock(string sym, int tf, int dir, int lookback,
                              double &breakerHigh, double &breakerLow) {
   breakerHigh = 0; breakerLow = 0;
   for (int i = 2; i < lookback; i++) {
      double h = iHigh(sym, tf, i);
      double l = iLow(sym, tf, i);
      double close = iClose(sym, tf, i);
      double prevH = iHigh(sym, tf, i + 1);
      double prevL = iLow(sym, tf, i + 1);
      // Bearish breaker: was bullish OB, then price broke below
      if (dir == 1 && close < prevL && h > prevH) {
         breakerHigh = h; breakerLow = l; return true;
      }
      // Bullish breaker: was bearish OB, price broke above
      if (dir == -1 && close > prevH && l < prevL) {
         breakerHigh = h; breakerLow = l; return true;
      }
   }
   return false;
}

bool ICT_DetectMitigationBlock(string sym, int tf, int dir, int lookback,
                                 double &mitHigh, double &mitLow) {
   mitHigh = 0; mitLow = 0;
   for (int i = 2; i < lookback; i++) {
      double h = iHigh(sym, tf, i);
      double l = iLow(sym, tf, i);
      double open = iOpen(sym, tf, i);
      double close = iClose(sym, tf, i);
      // Unmitigated OB: bearish candle for bullish run, bullish candle for bearish
      bool isBullish = (close > open);
      bool isBearish = (close < open);
      if (dir == 1 && isBearish) {  // look for bearish OB below current price
         if (l < Bid) { mitHigh = h; mitLow = l; return true; }
      }
      if (dir == -1 && isBullish) {
         if (h > Ask) { mitHigh = h; mitLow = l; return true; }
      }
   }
   return false;
}

bool ICT_DetectDisplacement(string sym, int tf, int shift) {
   double atr = iATR(sym, tf, 14, shift + 1);
   if (atr <= 0) return false;
   double body = MathAbs(iClose(sym, tf, shift) - iOpen(sym, tf, shift));
   double range = iHigh(sym, tf, shift) - iLow(sym, tf, shift);
   // Displacement: large body (>60% of range) and range > 1.5x ATR
   return (body > range * 0.6 && range > atr * 1.5);
}

double ICT_DetectInducement(string sym, int tf, int dir, int lookback) {
   // Inducement = equal highs (for sell inducement) or equal lows (for buy)
   double ref = 0; int count = 0;
   for (int i = 1; i < lookback; i++) {
      double level = (dir == 1) ? iLow(sym, tf, i) : iHigh(sym, tf, i);
      if (ref == 0) { ref = level; count = 1; continue; }
      if (MathAbs(level - ref) < iATR(sym, tf, 14, i) * 0.1) {
         count++;
         if (count >= 2) return ref;  // equal level found = inducement
      } else { ref = level; count = 1; }
   }
   return 0;
}

// Returns 1=premium (sell zone), -1=discount (buy zone), 0=equilibrium
int ICT_ComputePremiumDiscount(string sym, int tf, int lookback) {
   double rangH = iHigh(sym, tf, iHighest(sym, tf, MODE_HIGH, lookback, 1));
   double rangL = iLow(sym,  tf, iLowest( sym, tf, MODE_LOW,  lookback, 1));
   double equilibrium = (rangH + rangL) / 2.0;
   double current = (Ask + Bid) / 2.0;
   if (current > equilibrium + (rangH - rangL) * 0.1) return  1;  // premium
   if (current < equilibrium - (rangH - rangL) * 0.1) return -1;  // discount
   return 0;
}

bool ICT_DetectAMD(string sym, int tf, int &amdDir) {
   amdDir = 0;
   double sessH = iHigh(sym, tf, iHighest(sym, tf, MODE_HIGH, 8, 1));
   double sessL = iLow(sym,  tf, iLowest( sym, tf, MODE_LOW,  8, 1));
   double current = Bid;
   // Manipulation = price swept liquidity (above high or below low)
   // Distribution = reversal back into range
   if (current < sessL) { amdDir = 1;  return true; }  // swept lows -> buy dist
   if (current > sessH) { amdDir = -1; return true; }  // swept highs -> sell dist
   return false;
}

bool ICT_DetectJudasSwing(string sym, int tf) {
   // Judas: aggressive move at killzone start, then reverses
   if (!IsActiveSession()) return false;
   double atr = iATR(sym, tf, 14, 1);
   if (atr <= 0) return false;
   double h = iHigh(sym, tf, 1); double l = iLow(sym, tf, 1);
   double open = iOpen(sym, tf, 1); double close = iClose(sym, tf, 1);
   double range = h - l;
   // Strong wick reversal: range > ATR and body < 30% of range = pinbar-like
   return (range > atr && MathAbs(close - open) < range * 0.3);
}

double ICT_ComputePOIScore(string sym, int tf, int dir, double poiPrice) {
   double atr = iATR(sym, tf, 14, 1);
   if (atr <= 0) return 0;
   double dist = MathAbs(((dir == 1) ? Ask : Bid) - poiPrice);
   double distScore = MathMax(0, 50.0 - (dist / atr) * 25.0);
   // Bonus for premium/discount alignment
   int pdZone = ICT_ComputePremiumDiscount(sym, tf, 20);
   double pdBonus = (dir == 1 && pdZone == -1) ? 25 : (dir == -1 && pdZone == 1) ? 25 : 0;
   // Bonus for session alignment
   double sessBonus = IsActiveSession() ? 25 : 0;
   return MathMin(100.0, distScore + pdBonus + sessBonus);
}

