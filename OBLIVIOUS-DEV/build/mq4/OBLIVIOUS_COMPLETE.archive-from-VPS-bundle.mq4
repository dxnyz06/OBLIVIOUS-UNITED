   void UpdateAISignalCache() {
     static datetime lastAIUpdate = 0;
     if (TimeCurrent() - lastAIUpdate < g_NewsUpdateIntervalSec) return;
     lastAIUpdate = TimeCurrent();
     if (!Bridge_IsConnected()) return;
     string aiPayload;
     if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
       g_aiSignalDir  = (StringFind(aiPayload, "\"type\":\"BUY\"")  >= 0) ?  1 :
                        (StringFind(aiPayload, "\"type\":\"SELL\"") >= 0) ? -1 : 0;
       g_aiSignalConf = 0.6;
       g_aiSignalTime = TimeCurrent();
     }
   }

   void UpdateNewsBlockStatus() {
     static datetime lastNewsUpdate = 0;
     if (TimeCurrent() - lastNewsUpdate < g_NewsUpdateIntervalSec) return;
     lastNewsUpdate = TimeCurrent();
     if (!Bridge_IsConnected()) { news_file_present = false; return; }
     int blockTrading = 0, severity = 0, minutesToEvent = 0;
     if (Bridge_GetNewsStatus(TimeCurrent(), blockTrading, severity, minutesToEvent)) {
       news_file_present = (blockTrading > 0);
     }
   }
