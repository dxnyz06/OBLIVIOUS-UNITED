   void __AP_MoveSLtoBEIfEligible() {
   // Move SL to breakeven once favorable pips exceed dynamic threshold based on MTR
   double mtr =
   _MedianTrueRangeN(
   14) /
   Point;
   double beTrig = MathMax(
   10,
   mtr *
   0.6); // at least 10 pips, else 0.6*MTR
   double fav =
   __AP_OrderFavorablePips();
   if (fav >=
   beTrig) {
   double newSL =
   OrderOpenPrice();
   // Apply only if improves
   if (OrderType() == OP_BUY &&



   (OrderStopLoss() <=
   0 ||
   newSL >
   OrderStopLoss())) {
   LogGate(
   "BLOCK NEWS",
   StringFormat(
   "Symbol=%s Time=%s (file=file path)",
   Symbol(),
   TimeToStr(
   TimeCurrent(),
   TIME_SECONDS)));
   {
   int __ticket =
   OrderTicket();
   double
   __newSL =
   0,
   __newTP = Auto_TP_Points_Strategy(
   "__new"); /* prefetch desired sl/tp from args not trivial; logging current after select */
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "PreModify | ticket=%d symbol=%s",
   __ticket,
   OrderSymbol()));
   }
   bool _wOk = OrderModify(
   OrderTicket(),
   OrderOpenPrice(),
   newSL,
   OrderTakeProfit(),
   0,
   clrNONE);
   {
   int __ok =
   (GetLastError() == 0);



   double
   __exe =
   OrderOpenPrice(),
   __sl =
   OrderStopLoss(),
   __tp =
   OrderTakeProfit();
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d", __ok ? "PostModify OK" : "PostModify FAIL", OrderTicket(), __exe, __sl, __tp, GetLastError()));
   }
   }
   if (OrderType() == OP_SELL &&



   (OrderStopLoss() <=
   0 ||
   newSL <
   OrderStopLoss())) {
   LogGate(
   "BLOCK NEWS",
   StringFormat(
   "Symbol=%s Time=%s (file=file path)",
   Symbol(),
   TimeToStr(
   TimeCurrent(),
   TIME_SECONDS)));
   {
   int __ticket =
   OrderTicket();
   double
   __newSL =
   0,
   __newTP = Auto_TP_Points_Strategy(
   "__new"); /* prefetch desired sl/tp from args not trivial; logging current after select */
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "PreModify | ticket=%d symbol=%s",
   __ticket,
   OrderSymbol()));
   }
   bool _wOk = OrderModify(
   OrderTicket(),
   OrderOpenPrice(),
   newSL,
   OrderTakeProfit(),
   0,
   clrNONE);
   {
   int __ok =
   (GetLastError() == 0);



   double
   __exe =
   OrderOpenPrice(),
   __sl =
   OrderStopLoss(),
   __tp =
   OrderTakeProfit();
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d", __ok ? "PostModify OK" : "PostModify FAIL", OrderTicket(), __exe, __sl, __tp, GetLastError()));
   }
   }
   }
   }

   double __AP_ProfitBuffer10pcOverCosts() {
   // Ensure at least 10% over all costs (commission+swap+spread approx) to be safely positive
   double comm =
   OrderCommission();
   if (comm <
   0)
   comm =
   -comm;
   double swp =
   OrderSwap();
   if (swp <
   0)
   swp =
   -swp;
   double spr = __AP_EstimatedSpreadCost(
   OrderTicket());
   double base =
   comm +
   swp +
   spr;
   if (base <=
   0)
   base =
   0.5 *
   MarketInfo(
   OrderSymbol(),
   MODE_TICKVALUE) *
   OrderLots(); // minimal buffer
   return 0.10 *
   base; // 10% over cost baseline
   }

