double DynamicStopLoss()                                { double atr = iATR(Symbol(),Period(),14,1); return (atr > 0 ? NormalizeDouble(atr * 1.5, Digits) : 50 * Point); }
bool AllowedLevels_Grid() {
   int regime = TrendRegime(Symbol(), Period());
   if (regime == 1) return false;
   double atr = iATR(Symbol(), Period(), 14, 1);
   if (atr <= 0) return false;
   double range = iHigh(Symbol(), Period(), iHighest(Symbol(), Period(), MODE_HIGH, 40, 1)) -
                  iLow(Symbol(), Period(), iLowest(Symbol(), Period(), MODE_LOW, 40, 1));
   return (atr > 0 && range > 0 && range < atr * 6.0);
}

// ============================================================
// NEWS POLICY CENTRALIZED ENGINE
// ============================================================

void NewsPolicy_Init() {
   g_np_preMinutes = NewsCooldownMinutes;
   g_np_postMinutes = NewsHighImpactCooldownMinutes;
   g_np_highImpactWindowActive = false;
   g_np_currentImpactLevel = 0;
   g_np_newsInitialized = true;
}

void NewsPolicy_Update() {
   if (!g_np_newsInitialized) NewsPolicy_Init();
   
   int blockTrading = 0;
   int severity = 0;
   int minutesToEvent = 9999;
   datetime now = TimeCurrent();
   
   if (Bridge_GetNewsStatus(now, blockTrading, severity, minutesToEvent)) {
      g_np_currentImpactLevel = severity;
      
      if (severity >= 3) {
         if (minutesToEvent > -g_np_postMinutes && minutesToEvent < g_np_preMinutes) {
            g_np_highImpactWindowActive = true;
         } else {
            g_np_highImpactWindowActive = false;
         }
      } else {
         g_np_highImpactWindowActive = false;
      }
   } else {
      if (g_np_nextHighEventTime > 0) {
         int diffMin = (int)((g_np_nextHighEventTime - now) / 60);
         if (diffMin > -g_np_postMinutes && diffMin < g_np_preMinutes)
            g_np_highImpactWindowActive = true;
         else
            g_np_highImpactWindowActive = false;
      }
   }
}

bool NewsPolicy_CanOpen(string strategy) {
   if (!g_np_newsInitialized) NewsPolicy_Init();
   if (strategy == "Predicted") return true;
   if (g_np_highImpactWindowActive) return false;
   return true;
}

double NewsPolicy_GetPenalty(string strategy) {
   if (strategy == "Predicted") return 0.0;
   if (g_np_currentImpactLevel == 2) return 10.0;
   if (g_np_currentImpactLevel == 1) return 3.0;
   return 0.0;
}

bool NewsPolicy_IsHighImpactActive() {
   return g_np_highImpactWindowActive;
}

bool UI_BlockHighImpactNews() { return CheckHighImpactNews(); }
bool   ValidatePatternTriggers(string name, int dir, int ps) { return (ps > 0); }
bool   ConfidenceGate_AND(string name, int dir, int ps, int ai, bool aiOn, bool indOn, int &score, string &why) { score = ps; why = ""; return (ps >= 50); }
int CheckBreakoutSignal() {
   if (!Breakout || !GlobalStrategyGuards()) return 0;
   double atr = iATR(Symbol(), Period(), 14, 1);
   if (atr <= 0) return 0;
   int lookback = 20;

   // Level 2 indicator consensus  soft filter (not a hard gate)
   // Indicators heavily opposing  skip to avoid low-quality entry
   if (IndicatorOpposesTrade(1, 60.0) && IndicatorOpposesTrade(-1, 60.0)) {} // no hard block, just context
   double indBonus_B = IndicatorAlignmentBonus(0); // computed at signal time
   double recentHigh = iHigh(Symbol(), Period(), iHighest(Symbol(), Period(), MODE_HIGH, lookback, 2));
   double recentLow  = iLow(Symbol(),  Period(), iLowest(Symbol(),  Period(), MODE_LOW,  lookback, 2));
   double closeNow = Close[1], openNow = Open[1];
   double bodySize = MathAbs(closeNow - openNow);
   double momentum = MathAbs(closeNow - Close[4]);
   if (closeNow > recentHigh && bodySize > atr * 0.4 && momentum > atr * 0.6 && closeNow > openNow) return 1;
   if (closeNow < recentLow  && bodySize > atr * 0.4 && momentum > atr * 0.6 && closeNow < openNow) return -1;
   return 0;
}
// CheckBreakoutSignal_Legacy: superseded by canonical Breakout strategy pipeline

int CheckFVGSignal() {
   if (!FVG || !AllowStrategyToTrade()) return 0;
   string sym = Symbol(); int tf = Period();
   double atr = iATR(sym, tf, 14, 1);
   if (atr <= 0) return 0;
   // Bullish FVG: gap between bar[2].high and bar[0].low (bar[1] is the impulse candle)
   double gap_bull_top = iLow(sym, tf, 0);
   double gap_bull_bot = iHigh(sym, tf, 2);
   if (gap_bull_top > gap_bull_bot && (gap_bull_top - gap_bull_bot) >= atr * 0.1) {
      double price = Ask;
      if (price >= gap_bull_bot && price <= gap_bull_top) return 1;
   }
   // Bearish FVG: gap between bar[0].high and bar[2].low
   double gap_bear_top = iLow(sym, tf, 2);
   double gap_bear_bot = iHigh(sym, tf, 0);
   if (gap_bear_top > gap_bear_bot && (gap_bear_top - gap_bear_bot) >= atr * 0.1) {
      double price = Bid;
      if (price >= gap_bear_bot && price <= gap_bear_top) return -1;
   }
   return 0;
}



int CheckSMCSignal() {
   if (!SMC || !AllowStrategyToTrade()) return 0;
   string sym = Symbol(); int tf = Period();
   double atr = iATR(sym, tf, 14, 1);
   if (atr <= 0) return 0;
   int htfBias = Context_BuildHTFBias(sym, tf);
   if (htfBias == 0) return 0;
   // SMC: OB + BOS/CHOCH + Premium/Discount
   double obH = 0, obL = 0;
   if (!DetectOrderBlock(sym, tf, htfBias, 20, obH, obL)) return 0;
   int pdZone = ICT_ComputePremiumDiscount(sym, tf, 50);
   if (htfBias == 1 && pdZone == 1) return 0;  // already in premium
   if (htfBias == -1 && pdZone == -1) return 0; // already in discount
   bool bos = (htfBias == 1) ? IsBullishBOS(sym, tf, 1) : IsBearishBOS(sym, tf, 1);
   bool choch = (htfBias == 1) ? IsBullishCHOCH(sym, tf, 1) : IsBearishCHOCH(sym, tf, 1);
   if (!bos && !choch) return 0;
   double price = (htfBias == 1) ? Ask : Bid;
   if (htfBias == 1 && price >= obL && price <= obH + atr * 0.2) return 1;
   if (htfBias == -1 && price <= obH && price >= obL - atr * 0.2) return -1;
   return 0;
}

int CheckICTSignal() {
   if (!ICT || !AllowStrategyToTrade()) return 0;
   string sym = Symbol(); int tf = Period();
   double atr = iATR(sym, tf, 14, 1);
   if (atr <= 0) return 0;
   int htfBias = Context_BuildHTFBias(sym, tf);
   if (htfBias == 0) return 0;
   // ICT: Kill Zone + AMD/Judas + Turtle Soup/QM
   int gmtHour = TimeHour(TimeGMT());
   bool inLondon = (gmtHour >= 7 && gmtHour < 11);
   bool inNY = (gmtHour >= 12 && gmtHour < 16);
   if (!inLondon && !inNY) return 0;
   int amdDir = 0;
   bool hasAMD = ICT_DetectAMD(sym, tf, amdDir);
   bool hasJudas = ICT_DetectJudasSwing(sym, tf);
   if (!hasAMD && !hasJudas) {
      // Try turtle soup as fallback
      int turtleDir = 0; double turtleEntry = 0;
      bool hasTurtle = DetectTurtleSoup(sym, tf, 20, turtleDir, turtleEntry);
      if (hasTurtle && turtleDir == htfBias) return htfBias;
      int qmDir = 0; double qmLevel = 0;
      bool hasQM = DetectQuasimodo(sym, tf, qmDir, qmLevel);
      if (hasQM && qmDir == htfBias) return htfBias;
      return 0;
   }
   if (hasAMD && amdDir == htfBias) return htfBias;
   if (hasJudas) return htfBias;
   return 0;
}

int CheckReverseSignal() {
   if (!Reverse || !GlobalStrategyGuards()) return 0;
   double rsi = iRSI(Symbol(), Period(), 14, PRICE_CLOSE, 1);
   double atr = iATR(Symbol(), Period(), 14, 1);
   if (atr <= 0) return 0;
   double body  = MathAbs(Close[1] - Open[1]);

   // Level 2 indicator consensus  soft filter (not a hard gate)
   // Indicators heavily opposing  skip to avoid low-quality entry
   double indBonus_R = IndicatorAlignmentBonus(0); // computed at signal time
   double upper = High[1] - MathMax(Close[1], Open[1]);
   double lower = MathMin(Close[1], Open[1]) - Low[1];
   // RSI oversold + bullish rejection wick (hammer pattern)
   if (rsi < 30.0 && lower > body * 1.2 && lower > atr * 0.25) return 1;
   // RSI overbought + bearish rejection wick (shooting star)
   if (rsi > 70.0 && upper > body * 1.2 && upper > atr * 0.25) return -1;
   // Additional: extreme RSI + prior candle divergence
   if (rsi < 25.0 && Close[1] > Close[2] && Close[2] < Close[3]) return 1;
   if (rsi > 75.0 && Close[1] < Close[2] && Close[2] > Close[3]) return -1;
   return 0;
}
int CheckGridSignal() {
   if (!Grid || !GlobalStrategyGuards()) return 0;
   if (CountOpenOrders(GridMagic) >= MaxGridLevels) return 0;
   double atr = iATR(Symbol(), Period(), 14, 1);
   if (atr <= 0) return 0;
   int lookback = 40;

   // Level 2 indicator consensus  soft filter (not a hard gate)
   // Indicators heavily opposing  skip to avoid low-quality entry
   double indBonus_G = IndicatorAlignmentBonus(0); // computed at signal time
   double rangeHigh = iHigh(Symbol(), Period(), iHighest(Symbol(), Period(), MODE_HIGH, lookback, 1));
   double rangeLow  = iLow(Symbol(),  Period(), iLowest(Symbol(),  Period(), MODE_LOW,  lookback, 1));
   double range = rangeHigh - rangeLow;
   // Require range to be between 1.5x and 5x ATR for valid ranging
   if (range < atr * 1.5 || range > atr * 5.0) return 0;
   double priceNow = Close[0];
   double pct = (priceNow - rangeLow) / range;  // 0=bottom, 1=top
   // Buy near range bottom (lower 25%)
   if (pct <= 0.25) return 1;
   // Sell near range top (upper 25%)
   if (pct >= 0.75) return -1;
   return 0;
}
// Grid signal is handled by CheckGridSignal()
double _Neckline(int isTop, int W = 10)                 { int dir = isTop ? -1 : 1; double lvl = isTop ? High[1] : Low[1]; for (int i=2;i<=W;i++) { if(isTop && High[i]>lvl) lvl=High[i]; else if(!isTop && Low[i]<lvl) lvl=Low[i]; } return lvl; }
string __gvNameLast(long ticket)                        { return "PRTC_LAST_" + IntegerToString((int)ticket); }
string __gvNameBars(long ticket)                        { return "PRTC_BARS_" + IntegerToString((int)ticket); }
string StringTrim(string s)                             { string r=s; StringTrimLeft(r); StringTrimRight(r); return r; }
string StringUpper(string s)                            { StringToUpper(s); return s; }
int    SafeOrderSend(string sym, int cmd, double vol, double price, int slip, double sl, double tp, string comment, int magic, datetime exp, color clr) {
   // R5 — every order placed via SafeOrderSend gets a final equity-based
   // clamp (MaxRiskTradePercent) and a broker-step normalization, so no
   // strategy can sneak past Risk_Preflight by computing its own lot size.
   double v = vol;
   if (sl > 0.0 && price > 0.0) {
      double clamped = Risk_ClampLotToMaxRisk(sym, v, sl, price);
      if (clamped < 0.0) {
         PrintFormat("[Risk] SafeOrderSend blocked sym=%s vol=%.2f magic=%d below_min_after_clamp",
                     sym, v, magic);
         return -1;
      }
      v = NormalizeLots(sym, clamped);
      if (v <= 0.0) {
         PrintFormat("[Risk] SafeOrderSend blocked sym=%s normalize_zero magic=%d", sym, magic);
         return -1;
      }
   }
   return OrderSend(sym, cmd, v, price, slip, sl, tp, comment, magic, exp, clr);
}
bool   AIP2_IsImpulseLive()                             { return (MathAbs(Close[1]-Open[1]) > iATR(Symbol(),Period(),14,1)*0.5); }
bool   AIP2_BreakPreRangeLive(int side)                 { double h=High[1],l=Low[1]; if(side>0) return (Close[0]>h); return (Close[0]<l); }
int    OrderManager_Send(string sym, int dir, double lots, double sl, double tp, int magic, string comment) { int cmd=(dir>0?OP_BUY:OP_SELL); double price=(dir>0?Ask:Bid); return SafeOrderSend(sym,cmd,lots,price,Slippage,sl,tp,comment,magic,0,clrNONE); }
bool   Grid_AA_Allow()                                  { return (Grid && !IsTradeContextBusy()); }
void   Native_QueryVirtualTPSL(int m, int ticket, string sym, string name, double &tp, double &sl, int &src) { tp=OrderTakeProfit(); sl=OrderStopLoss(); src=(tp>0||sl>0?5:0); }

// --- Pattern detection helpers ---
double Detect_BullishEngulfing() {
   if (Bars < 3) return 0;
   if (Close[2] < Open[2] && Close[1] > Open[1] &&
       Open[1] <= Close[2] && Close[1] >= Open[2]) return 75.0;
   return 0;
}
double Detect_BearishEngulfing() {
   if (Bars < 3) return 0;
   if (Close[2] > Open[2] && Close[1] < Open[1] &&
       Open[1] >= Close[2] && Close[1] <= Open[2]) return 75.0;
   return 0;
}
double Detect_Hammer() {
   if (Bars < 2) return 0;
   double rng = High[1] - Low[1];
   if (rng <= 0) return 0;
   double body = MathAbs(Close[1] - Open[1]);
   double lw = MathMin(Open[1], Close[1]) - Low[1];
   if (lw >= rng * 0.6 && body <= rng * 0.3) return 70.0;
   return 0;
}
double Detect_ShootingStar() {
   if (Bars < 2) return 0;
   double rng = High[1] - Low[1];
   if (rng <= 0) return 0;
   double body = MathAbs(Close[1] - Open[1]);
   double uw = High[1] - MathMax(Open[1], Close[1]);
   if (uw >= rng * 0.6 && body <= rng * 0.3) return 70.0;
   return 0;
}
double Detect_Doji() {
   if (Bars < 2) return 0;
   double rng = High[1] - Low[1];
   if (rng <= 0) return 0;
   double body = MathAbs(Close[1] - Open[1]);
   if (body <= rng * 0.1) return 60.0;
   return 0;
}
double Detect_MorningStar() {
   if (Bars < 4) return 0;
   if (Close[3] < Open[3] && MathAbs(Close[2]-Open[2]) < (High[2]-Low[2])*0.3 &&
       Close[1] > Open[1] && Close[1] > (Open[3]+Close[3])*0.5) return 80.0;
   return 0;
}
double Detect_EveningStar() {
   if (Bars < 4) return 0;
   if (Close[3] > Open[3] && MathAbs(Close[2]-Open[2]) < (High[2]-Low[2])*0.3 &&
       Close[1] < Open[1] && Close[1] < (Open[3]+Close[3])*0.5) return 80.0;
   return 0;
}
double Detect_ThreeWhiteSoldiers() {
   if (Bars < 4) return 0;
   if (Close[1] > Open[1] && Close[2] > Open[2] && Close[3] > Open[3] &&
       Close[1] > Close[2] && Close[2] > Close[3]) return 85.0;
   return 0;
}
double Detect_ThreeBlackCrows() {
   if (Bars < 4) return 0;
   if (Close[1] < Open[1] && Close[2] < Open[2] && Close[3] < Open[3] &&
       Close[1] < Close[2] && Close[2] < Close[3]) return 85.0;
   return 0;
}
double Detect_PiercingLine() {
   if (Bars < 3) return 0;
   double mid2 = (Open[2]+Close[2])*0.5;
   if (Close[2] < Open[2] && Close[1] > Open[1] &&
       Open[1] < Low[2] && Close[1] > mid2 && Close[1] < Open[2]) return 70.0;
   return 0;
}
double Detect_DarkCloudCover() {
   if (Bars < 3) return 0;
   double mid2 = (Open[2]+Close[2])*0.5;
   if (Close[2] > Open[2] && Close[1] < Open[1] &&
       Open[1] > High[2] && Close[1] < mid2 && Close[1] > Open[2]) return 70.0;
   return 0;
}
double Detect_Harami(int dir) {
   if (Bars < 3) return 0;
   if (dir > 0) {
      if (Close[2] < Open[2] && Close[1] > Open[1] &&
          Open[1] > Close[2] && Close[1] < Open[2]) return 65.0;
   } else {
      if (Close[2] > Open[2] && Close[1] < Open[1] &&
          Open[1] < Close[2] && Close[1] > Open[2]) return 65.0;
   }
   return 0;
}
