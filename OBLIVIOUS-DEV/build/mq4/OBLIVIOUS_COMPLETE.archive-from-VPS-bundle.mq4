                                              bool AIBC_ParseTPs(string line2,
   int &tp1, int &tp2,
   int &tp3) {
                                            tp1 = tp2 = tp3 = 0;
                                            string parts[];
                                            int n =
                                                StringSplit(line2, ';', parts);
                                            if (n < 3)
                                              return false;
                                            for (int i = 0; i < n; i++) {
                                              string kv[];
                                              if (StringSplit(parts[i], '=',
   kv) == 2) {
                                                if (kv[0] == "tp1")
                                                  tp1 = (int)StringToInteger(
                                                      kv[1]);
                                                if (kv[0] == "tp2")
                                                  tp2 = (int)StringToInteger(
                                                      kv[1]);
                                                if (kv[0] == "tp3")
                                                  tp3 = (int)StringToInteger(
                                                      kv[1]);
                                              }
                                            }
                                            return (tp1 > 0 && tp2 > 0 &&
                                                    tp3 > 0);
                                          }

                                          // delta=+110chars from

                                          double AIP2_EmergencySL() {
                                            double atr =
                                                iATR(Symbol(), Period(), 14, 1);
                                            if (atr <= 0)
                                              atr = 100 * Point;
                                            return NormalizeDouble(
                                                atr * 3.0,
                                                Digits); // 3x ATR emergency
                                            // stop
                                          }

                                          double ProfitToday() {
                                            double profit = 0;
                                            for (int i =
                                                     OrdersHistoryTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_HISTORY)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    TimeDay(OrderCloseTime()) == TimeDay(



   TimeCurrent())) {
                                                  profit += OrderProfit() +
   OrderSwap() +
   OrderCommission();
                                                }
                                              }
                                            }
                                            return profit;
                                          }

                                          double ProfitThisWeek() {
                                            double profit = 0;
                                            datetime weekStart =
                                                TimeCurrent() -
                                                TimeDayOfWeek(TimeCurrent()) *
                                                    86400;
                                            for (int i =
                                                     OrdersHistoryTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_HISTORY)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    OrderCloseTime() >=
                                                        weekStart) {
                                                  profit += OrderProfit() +
   OrderSwap() +
   OrderCommission();
                                                }
                                              }
                                            }
                                            return profit;
                                          }

                                          double ProfitThisMonth() {
                                            double profit = 0;
                                            for (int i =
                                                     OrdersHistoryTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_HISTORY)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    TimeMonth(
                                                        OrderCloseTime()) == TimeMonth(



   TimeCurrent()) &&
                                                    TimeYear(
                                                        OrderCloseTime()) == TimeYear(



   TimeCurrent())) {
                                                  profit += OrderProfit() +
   OrderSwap() +
   OrderCommission();
                                                }
                                              }
                                            }
                                            return profit;
                                          }

                                          int CountPositionsByMagic(int magic) {
                                            int count = 0;
                                            for (int i = OrdersTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i,
   SELECT_BY_POS) &&
                                                  OrderSymbol() == Symbol() &&
                                                  OrderMagicNumber() == magic)
                                                count++;
                                            }
                                            return count;
                                          }

                                          double Strategy_CalcTP(
                                              string symbol, int dir,
                                              double atrMult) {
                                            double atr = iATR(symbol, 0, 14, 0);
                                            if (atr <= 0)
                                              atr = PipValue(symbol) * 30;
                                            double price =
                                                (dir == OP_BUY)
                                                    ? MarketInfo(symbol,
   MODE_ASK)
                                                    : MarketInfo(symbol,
   MODE_BID);
                                            if (dir == OP_BUY)
                                              return NormalizeDouble(
                                                  price + atr * atrMult,
                                                  (int)MarketInfo(symbol,
   MODE_DIGITS));
                                            if (dir == OP_SELL)
                                              return NormalizeDouble(
                                                  price - atr * atrMult,
                                                  (int)MarketInfo(symbol,
   MODE_DIGITS));
                                            return 0;
                                          }

                                          double Strategy_CalcSL(
                                              string symbol, int dir,
                                              double atrMult) {
                                            double atr = iATR(symbol, 0, 14, 0);
                                            if (atr <= 0)
                                              atr = PipValue(symbol) * 30;
                                            double price =
                                                (dir == OP_BUY)
                                                    ? MarketInfo(symbol,
   MODE_ASK)
                                                    : MarketInfo(symbol,
   MODE_BID);
                                            if (dir == OP_BUY)
                                              return NormalizeDouble(
                                                  price - atr * atrMult,
                                                  (int)MarketInfo(symbol,
   MODE_DIGITS));
                                            if (dir == OP_SELL)
                                              return NormalizeDouble(
                                                  price + atr * atrMult,
                                                  (int)MarketInfo(symbol,
   MODE_DIGITS));
                                            return 0;
                                          }

                                          void Mart_UpdateAllTP(string symbol,
   int magic,
   int dir) {
                                            double newTP = Mart_CalcBreakevenTP(
                                                symbol, dir, magic);
                                            if (newTP <= 0)
                                              return;

                                            for (int i = OrdersTotal() - 1;
                                                 i >= 0; i--) {
                                              if (!OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES))
                                                continue;
                                              if (OrderMagicNumber() != magic ||
                                                  OrderSymbol() != symbol)
                                                continue;
                                              if (OrderType() != dir)
                                                continue;

                                              OrderManager_Modify(
                                                  OrderTicket(),
                                                  OrderStopLoss(), newTP);
                                            }
                                          }

                                          double EB_ATR_Slope_TS() {
                                            int N = (int)MathMin(
                                                200, EB_BarsForWindowTF());
                                            int p = (int)MathMax(
                                                5,
                                                MathMin(50,
                                                        EB_BarsForWindowTF() /
   2));
                                            double a[];
                                            ArrayResize(a, N);
                                            for (int i = 0; i < N; i++)
                                              a[i] = iATR(Symbol(), Period(), p,
                                                          i);

                                            int M = (int)MathMin(N, 60);
                                            if (M < 10)
                                              return 0;

                                            int P = (M * (M - 1)) / 2;
                                            if (P <= 0)
                                              return 0;

                                            double s[];
                                            ArrayResize(s, P);
                                            int k = 0;
                                            for (int i = 0; i < M; i++) {
                                              for (int j = i + 1; j < M; j++) {
                                                double dt = (double)(j - i);
                                                if (dt > 0)
                                                  s[k++] = (a[i] - a[j]) / dt;
                                              }
                                            }
                                            if (k <= 0)
                                              return 0;
                                            return EB_Median(s, k);
                                          }

                                          void Strategy_SmartTrailBreakout() {
                                            if (!SmartPanel)
                                              return;
                                            if (!Gate_CanTradeNow())
                                              return;

                                            int direction =
                                                GetSmartBreakoutDirection();
                                            double confidence =
                                                CalculateSmartBreakoutConfidence();

                                            if (!ConfirmSignal(direction,
   confidence))
                                              return;

                                            double lots =
                                                Active_ManualLot();
                                            double sl =
                                                CalculateSmartBreakoutSL();
                                            double tp =
                                                CalculateSmartBreakoutTP();
                                            double price =
                                                direction > 0 ? Ask : Bid;
                                            int type = direction > 0 ? OP_BUY
   : OP_SELL;

                                            if (Orders_HasPosition())
                                              return;

                                            Orders_SendSafe(
                                                type, lots, price, sl, tp,
                                                "SmartTrailBreakout");
                                          }

