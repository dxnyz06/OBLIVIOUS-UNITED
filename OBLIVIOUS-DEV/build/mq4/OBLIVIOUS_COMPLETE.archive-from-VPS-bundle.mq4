string FormatPauseDuration(int seconds)
{
      if (seconds < 60)
        return IntegerToString(seconds) + "s";
      if (seconds < 3600)
        return IntegerToString(seconds / 60) + "m " +
               IntegerToString(seconds % 60) + "s";
      return IntegerToString(seconds / 3600) + "h " +
             IntegerToString((seconds % 3600) / 60) + "m";
}

string GetPerformanceRecommendations()
{
      string rec = "";
      for (int i = 0; i < KPI_MAX_METRICS; i++) {
        if (KPI_metrics[i].strategy_name != "" &&
            KPI_metrics[i].avg_execution_time > KPI_SLOW_THRESHOLD)
          rec += StringFormat("- %s: avg %.1fms exceeds threshold\n",
                              KPI_metrics[i].strategy_name,
                              KPI_metrics[i].avg_execution_time);
      }
      if (rec == "")
        rec = "- All strategies within parameters\n";
      return rec;
}

double GetSlippage(double slippagePips)
{
      return slippagePips * Point * (Digits == 3 || Digits == 5 ? 10 : 1);
}

double ValuePerPointPerLot()
{
      double tickValue = MarketInfo(Symbol(), MODE_TICKVALUE);
      double tickSize = MarketInfo(Symbol(), MODE_TICKSIZE);
      if (tickSize > 0)
        return tickValue * Point / tickSize;
      return tickValue;
}

void EnsureMinPipsSLTP(int &slPips, int &tpPips, double rr=2.0, int atrPeriod=14)
{
      double atr = iATR(Symbol(), 0, atrPeriod, 1);
      if (atr <= 0)
        return;
      int atrPts = (int)MathRound(atr / Point);
      int pip2pt = (Digits == 3 || Digits == 5) ? 10 : 1;
      int atrPips =  (int)(SpreadPoints());
      int minSLp = (int)MathMax((int)MathRound(1.2 * atrPips), 2);
      int minTPp = (int)MathMax((int)MathRound(rr * minSLp), 3);
      if (slPips <= 0 || slPips < minSLp)
        slPips = minSLp;
      if (tpPips <= 0 || tpPips < minTPp)
        tpPips = minTPp;
}

double EnsureMinPriceSLTP(int type, double &sl, double &tp, double rr=2.0, int atrPeriod=14)
{
      double atr = iATR(Symbol(), 0, atrPeriod, 1);
      if (atr <= 0) return 0;
      double entry = (type == OP_BUY) ? Ask : Bid;
      double spread = MarketInfo(Symbol(), MODE_SPREAD) * Point;
      double minDist = MathMax(atr * 0.5, spread * 2.0);
      if (type == OP_BUY) {
        if (sl > 0 && (entry - sl) < minDist) sl = entry - minDist;
        if (tp > 0 && (tp - entry) < minDist * rr) tp = entry + minDist * rr;
      } else {
        if (sl > 0 && (sl - entry) < minDist) sl = entry + minDist;
        if (tp > 0 && (entry - tp) < minDist * rr) tp = entry - minDist * rr;
      }
      return minDist;
}

void CloseProfitablePositions() {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          if (OrderSymbol() == Symbol() && OrderProfit() > 0) {
            double closePrice = (OrderType() == OP_BUY)
                                    ? MarketInfo(Symbol(), MODE_BID)
                                    : MarketInfo(Symbol(), MODE_ASK);
            RefreshRates();
            {
              int __ticket = OrderTicket();
              double __lots = OrderLots();
              SmartLogWrap(
                  "CLOSE",
                  StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s",
                               __ticket, __lots, OrderSymbol()));
            }
            if (!OrderClose(OrderTicket(), OrderLots(), closePrice,
                            GetAdaptiveSlippagePoints(), clrRed)) {
              {
                int __err = GetLastError();
                bool __isok = (__err == 0);
                SmartLogWrap(
                    "CLOSE",
                    StringFormat("%s | ticket=%d price=%.5f lots=%.2f err=%d",
                                 __isok ? "PostClose OK" : "PostClose FAIL",
                                 OrderTicket(), OrderClosePrice(), OrderLots(),
                                 __err));
              }
              PrintFormat("? Errore chiusura ordine profitable %d: %d",
                          OrderTicket(), GetLastError());
            } else {
              PrintFormat("? Ordine profitable chiuso: %d", OrderTicket());
            }
          }
        }
      }
}

void CloseProfitableOrders() {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          if (OrderSymbol() == Symbol() && OrderType() <= OP_SELL &&
              OrderProfit() > 0) {
            double closePrice = OrderType() == OP_BUY ? Bid : Ask;
            bool _wRes = OrderClose(OrderTicket(), OrderLots(), closePrice, 3, clrNONE);
          }
        }
      }
}

