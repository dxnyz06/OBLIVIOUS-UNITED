void DrawAISignalsPreview(string prefix, int x, int y, string filename, int rowsWanted)
{
      AISignalRow rws[];
      int n = ReadTopBlocks7(filename, rws, rowsWanted);
      // De-dup newest-on-top: keep only first unique rows
      static string __lastSigKeys[];
      bool used[];
      ArrayResize(used, n);
      for (int i0 = 0; i0 < n; i0++)
        used[i0] = false;
      int mapIdx[];
      ArrayResize(mapIdx, 0);
      for (int i0 = 0; i0 < n; i0++) {
        string key = rws[i0].symbol + "|" + rws[i0].type + "|" + rws[i0].lot +
                     "|" + rws[i0].sl + "|" + rws[i0].tp + "|" + rws[i0].entry +
                     "|" + rws[i0].tm;
        bool dup = false;
        for (int k = 0; k < ArraySize(__lastSigKeys); k++)
          if (__lastSigKeys[k] == key) {
            dup = true;
            break;
          }
        if (!dup) {
          int msz = ArraySize(mapIdx);
          ArrayResize(mapIdx, msz + 1);
          mapIdx[msz] = i0;
        }
      }
      // Keep only up to rowsWanted of these unique entries
      int showN = (int)MathMin(rowsWanted, ArraySize(mapIdx));
      for (int i = 0; i < rowsWanted; i++) {
        for (int c = 0; c < 7; c++) {
          string nm =
              prefix + "_R" + IntegerToString(i) + "C" + IntegerToString(c);
          if (i >= n) {
            if (ObjectFind(0, nm) >= 0)
              ObjectDelete(0, nm);
            // update buffer with shown keys (newest-first)
            ArrayResize(__lastSigKeys, showN);
            for (int u = 0; u < showN; u++) {
              int ii2 = mapIdx[u];
              __lastSigKeys[u] = rws[ii2].symbol + "|" + rws[ii2].type + "|" +
                                 rws[ii2].lot + "|" + rws[ii2].sl + "|" +
                                 rws[ii2].tp + "|" + rws[ii2].entry + "|" +
                                 rws[ii2].tm;
            }
          }
        }
      }
      int colW[7];
      colW[0] = 10;
      colW[1] = 6;
      colW[2] = 6;
      colW[3] = 7;
      colW[4] = 7;
      colW[5] = 9;
      colW[6] = 16;
      int colX[7];
      colX[0] = x;
      for (int c = 1; c < 7; c++) {
        colX[c] = colX[c - 1] + colW[c - 1] * 8 + 8;
      }
      for (int i = 0; i < n; i++) {
        string vals[7];
        vals[0] = rws[i].symbol;
        vals[1] = rws[i].type;
        vals[2] = rws[i].lot;
        vals[3] = rws[i].sl;
        vals[4] = rws[i].tp;
        vals[5] = rws[i].entry;
        vals[6] = rws[i].tm;
        for (int c = 0; c < 7; c++) {
          string nm =
              prefix + "_R" + IntegerToString(i) + "C" + IntegerToString(c);
          string txt = StringTrim(vals[c]);
          if (StringLen(txt) == 0) {
            if (ObjectFind(0, nm) >= 0)
              ObjectDelete(0, nm);
            continue;
          }
          if (ObjectFind(0, nm) < 0)
            ObjectCreate(0, nm, OBJ_LABEL, 0, 0, 0);
          ObjectSetInteger(0, nm, OBJPROP_XDISTANCE, colX[c]);
          ObjectSetInteger(0, nm, OBJPROP_YDISTANCE, y + 16 * i);
          ObjectSetInteger(0, nm, OBJPROP_FONTSIZE, 9);
          ObjectSetString(0, nm, OBJPROP_TEXT, txt);
          if (c == 1)
            ObjectSetInteger(0, nm, OBJPROP_COLOR, TypeColor(txt));
          else
            ObjectSetInteger(0, nm, OBJPROP_COLOR, clrWhite);
          if (c != 1)
            ObjectSetString(0, nm, OBJPROP_FONT, "Courier New");
        }
      }
}

