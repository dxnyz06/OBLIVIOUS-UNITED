void SendDataToWebDashboard(){
      // Export EA state to file for web dashboard consumption via kernel32.dll
      string fullPath = TerminalInfoString(TERMINAL_DATA_PATH) +
                        "\\MQL4\\Files\\web_dashboard.json";
      int h = CreateFileA(fullPath, K32_GENERIC_WRITE, 0, 0, K32_CREATE_ALWAYS,
                          K32_FILE_ATTR_NORMAL, 0);
      if (h == K32_INVALID_HANDLE)
        return;
      string json =
          StringFormat("{\"balance\":%.2f,\"equity\":%.2f,\"orders\":%d}",
                       AccountBalance(), AccountEquity(), OrdersTotal());
      uchar buf[];
      StringToCharArray(json, buf, 0, WHOLE_ARRAY, CP_ACP);
      int written = 0;
      WriteFile(h, buf, ArraySize(buf) - 1, written, 0);
      CloseHandle(h);
}

void __dup_SendDataToWebDashboard() {
      string ea_data = StringFormat(
          "{\"type\":\"ea_data_complete\","
          "\"balance\":%.2f,\"equity\":%.2f,\"orders\":%d,"
          "\"ai_predicted\":%s,\"fvg\":%s,\"timestamp\":\"%s\"}",
          AccountBalance(), AccountEquity(), OrdersTotal(),
          Predicted ? "true" : "false",
          FVG ? "true" : "false",
          TimeToString(TimeCurrent(), TIME_SECONDS));
      // Nota: in una versione con WebSocket attivo si potrebbe inviare ea_data
      // a un backend remoto (qui la trasmissione ÃƒÃ†ÃƒÃ‚Â¨ disattivata e i dati
      // vengono solo loggati localmente)
      static datetime last_web_log = 0;
      if (TimeCurrent() - last_web_log >
          300) { // Log every 5 minutes to avoid spam
        SL_AddMessage("Data synchronized with Oblivious AI Web Dashboard");
        last_web_log = TimeCurrent();
      }
}

void __dup3_SendDataToWebDashboard() {
      // Prepare real-time data packet
