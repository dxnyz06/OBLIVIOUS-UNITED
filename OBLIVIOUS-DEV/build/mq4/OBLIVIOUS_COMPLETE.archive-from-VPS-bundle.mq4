void AddToSmartLog(string msg)
{
      if (ArraySize(g_smartLogBuffer) < SMARTLOG_MAX_ENTRIES) {
        ArrayResize(g_smartLogBuffer, ArraySize(g_smartLogBuffer) + 1);
        g_smartLogBuffer[ArraySize(g_smartLogBuffer) - 1] = msg;
      } else {
        g_smartLogBuffer[g_smartLogHead] = msg;
        g_smartLogHead = (g_smartLogHead + 1) % SMARTLOG_MAX_ENTRIES;
      }
      g_smartLogCount++;
}

