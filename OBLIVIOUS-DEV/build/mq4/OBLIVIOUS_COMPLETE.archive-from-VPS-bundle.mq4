                                          void ApplyProfitLock() {
                                            if (IsTPSL_AI()) {
                                              if (AI_SyncSLTP_OpenOrders())
                                                return;
                                            }
                                            double accountEquity =
                                                AccountEquity();
                                            double accountBalance =
                                                AccountBalance();
                                            double currentProfit =
                                                accountEquity - accountBalance;
                                            // Attiviamo un lock dei
                                            // profitti con trailing se
                                            // superiamo il
                                            // ProfitLockPercent
                                            double lockThreshold =
                                                accountBalance *
                                                (ProfitLockPercent / 100.0);
                                            static double lockedProfit = 0.0;
                                            if (currentProfit > lockThreshold) {
                                              lockedProfit = MathMax(
                                                  lockedProfit, currentProfit);
                                              double trailingStopLevel =
                                                  lockedProfit - lockThreshold;
                                              for (int i = OrdersTotal() - 1;
                                                   i >= 0; i--) {
                                                if (OrderSelect(i,
   SELECT_BY_POS,
   MODE_TRADES) &&
                                                    OrderSymbol() == Symbol()) {
                                                  double price =
                                                      (OrderType() == OP_BUY)
                                                          ? Bid
                                                          : Ask;
                                                  if ((OrderType() == OP_BUY &&
                                                       price - OrderOpenPrice() <
                                                           -trailingStopLevel) ||
                                                      (OrderType() == OP_SELL &&
                                                       OrderOpenPrice() - price <
                                                           -trailingStopLevel)) {
                                                      {
                                                        int __ticket =
   OrderTicket();
                                                        double __lots =
   OrderLots();
                                                        SmartLogWrap(
   "CLOSE",
   StringFormat(
   "PreClose "
   "| "
   "ticket=%d "
   "lots=%.2f "
   "symbol=%s",
   __ticket,
   __lots,
   OrderSymbol()));
                                                      }
                                                      bool _wOk = OrderClose(
                                                          OrderTicket(),
                                                          OrderLots(), price,
                                                          GetAdaptiveSlippagePoints(),
                                                          clrRed);
                                                      {
                                                        int __err =
   GetLastError();
                                                        bool __isok =
   (__err == 0);
                                                        SmartLogWrap(
   "CLOSE",
   StringFormat(
   "%s | "
   "ticket=%d "
   "price=%."
   "5f "
   "lots=%.2f "
   "err=%d",
   __isok ? "Post"
   "Clos"
   "e OK"
   : "Post"
   "Clos"
   "e "
   "FAI"
   "L",
   OrderTicket(),
   OrderClosePrice(),
   OrderLots(),
   __err));
                                                      }
                                                    }
                                                }
                                              }
                                            }
                                          }

                                          double RR_AA_CalcTargetPrice(
                                              bool isBuy, double entry,
                                              double sl) {
                                            int n = AA_AutoN();
                                            int L1 = (int)MathMax(10, (int)(n));
                                            double swing =
                                                isBuy
                                                    ? iHigh(Symbol(), Period(),
   iHighest(Symbol(),
   Period(),
   MODE_HIGH,
   L1, 2))
                                                    : iLow(Symbol(), Period(),
                                                           iLowest(Symbol(),
   Period(),
   MODE_LOW, L1,
   2));
                                            int L2 = (int)MathMax(L1 + 10,
   (int)(1.5 * n));
                                            double donch =
                                                isBuy
                                                    ? iHigh(Symbol(), Period(),
   iHighest(Symbol(),
   Period(),
   MODE_HIGH,
   L2, 2))
                                                    : iLow(Symbol(), Period(),
                                                           iLowest(Symbol(),
   Period(),
   MODE_LOW, L2,
   2));
                                            double h2 = iHigh(Symbol(),
   Period(), 2),
                                                   l2 = iLow(Symbol(), Period(),
   2);
                                            double impulse =
                                                (isBuy ? (entry + (h2 - l2))
                                                       : (entry - (h2 - l2)));
                                            double t =
                                                isBuy
                                                    ? MathMax(swing,
   MathMax(donch,
   impulse))
                                                    : MathMin(swing,
   MathMin(donch,
   impulse));
                                            return t;
                                          }

