bool IsKAMA() {
      int n = 10;
      if (Bars < n + 2)
        return false;
      double dir = MathAbs(iClose(NULL, 0, 0) - iClose(NULL, 0, n));
      double vol = 0;
      for (int i = 0; i < n; i++)
        vol += MathAbs(iClose(NULL, 0, i) - iClose(NULL, 0, i + 1));
      double er = (vol > 0) ? dir / vol : 0;
      double fastSC = 2.0 / (2.0 + 1.0), slowSC = 2.0 / (30.0 + 1.0);
      double sc = er * (fastSC - slowSC) + slowSC;
      sc = sc * sc;
      static double kama = 0;
      if (kama == 0)
        kama = iClose(NULL, 0, n);
      kama = kama + sc * (iClose(NULL, 0, 0) - kama);
      return (kama < iClose(NULL, 0, 0));
}

