                                          void ResetTradeLabelsDaily() {
                                            datetime now = TimeCurrent();
                                            int today = TimeDay(now);
                                            if (today != lastResetDay) {
                                              int total = ObjectsTotal();
                                              for (int i = total - 1; i >= 0;
                                                   i--) {
                                                string name = ObjectName(i);
                                                if (StringFind(name,
