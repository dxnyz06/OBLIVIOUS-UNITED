bool PerformanceOptimizer_IsNewBar(string symbol, int timeframe)
{
      int idx = PerformanceOptimizer_FindSymbol(symbol);
      if (idx < 0)
        return true; // Unknown symbol, assume new bar

      datetime currentBar = iTime(symbol, timeframe, 0);
      if (currentBar == 0)
        return false;

      if (currentBar != g_perf_lastBar[idx]) {
        g_perf_lastBar[idx] = currentBar;
        return true;
      }
      return false;
}

double AA_RegimeScale(int regime = 1)   {
      return ModeScale(); }

void AA_DetectRegime()
{
      double atr = iATR(Symbol(), Period(), 14, 0);
      double atrMA = 0;
      for (int i = 1; i <= 50; i++)
        atrMA += iATR(Symbol(), Period(), 14, i);
      atrMA /= 50.0;

      if (atrMA <= 0) {
        g_adapt.regime = 1;
        g_adapt.vol_factor = 1.0;
        return;
      }
      double ratio = atr / atrMA;

      if (ratio < 0.6) {
        g_adapt.regime = 0;
        g_adapt.vol_factor = 0.7;
      } // LOW
      else if (ratio < 1.2) {
        g_adapt.regime = 1;
        g_adapt.vol_factor = 1.0;
      } // NORMAL
      else if (ratio < 2.0) {
        g_adapt.regime = 2;
        g_adapt.vol_factor = 1.3;
      } // HIGH
      else {
        g_adapt.regime = 3;
        g_adapt.vol_factor = 1.6;
      } // EXTREME
}

void AA_UpdateAdaptiveParams()
{
      AA_DetectRegime();
      double k = AA_RegimeScale(g_adapt.regime);

      // RSI
      int rsi_base = 14;
      if (Period() <= PERIOD_M5)
        rsi_base = 10;
      if (Period() >= PERIOD_H4)
        rsi_base = 20;
      g_adapt.rsi_period = MathMax(6, (int)MathRound(rsi_base * k));

      // EMA
      g_adapt.ema_fast = MathMax(5, (int)MathRound(12 * k));
      g_adapt.ema_slow = MathMax(8, (int)MathRound(26 * k));

      // CCI
      g_adapt.cci_period = MathMax(8, (int)MathRound(20 * k));

      // Bollinger
      g_adapt.bb_period = MathMax(10, (int)MathRound(20 * k));
      g_adapt.bb_dev = (g_adapt.regime >= 2) ? 2.5 : 2.0;

      // Momentum
      g_adapt.mom_period = MathMax(5, (int)MathRound(14 * k));

      // SuperTrend ATR
      g_adapt.super_atr_period = MathMax(5, (int)MathRound(10 * k));
}

