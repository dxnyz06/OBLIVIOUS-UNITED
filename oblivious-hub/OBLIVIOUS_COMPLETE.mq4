        return 4.0;
      }
      if (symbol == "US100" || symbol == "NAS100") {
        return 3.0;
      }
      if (symbol == "US30") {
        return 3.0;
      }
      if (symbol == "EURUSD") {
        return 2.0;
      }
      if (symbol == "GBPUSD") {
        return 2.0;
      }
      return 2.0; // default
}

