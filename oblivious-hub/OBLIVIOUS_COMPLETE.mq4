bool ConfirmBands(bool isBuy)
{

      int per = (int)Auto_BB_Period();
      double dev = Auto_BB_Dev();
      // Bands values current/prev
      double up0 = iBands(_Symbol, PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_UPPER, 0);
      double dn0 = iBands(_Symbol, PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_LOWER, 0);
      double md0 = iBands(_Symbol, PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_MAIN, 0);
      double up1 = iBands(_Symbol, PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_UPPER, 1);
      double dn1 = iBands(_Symbol, PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_LOWER, 1);
      double md1 = iBands(_Symbol, PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_MAIN, 1);
      double c0 = Close[0], c1 = Close[1];
      // Bandwidth slope (expanding/contracting)
      double bw0 = up0 - dn0;
      double bw1 = up1 - dn1;
      bool widening = (bw0 > bw1 * 0.98);
      bool md_up = (md0 > md1);
      bool md_dn = (md0 < md1);
      if (isBuy) {
        // cross from below lower band to inside/up, or above mid with mid
        // rising & bands widening
        if (c1 <= dn1 && c0 > dn0)
          return true;
        if (c0 > md0 && md_up && widening)
          return true;
        return false;
      } else {
        if (c1 >= up1 && c0 < up0)
          return true;
        if (c0 < md0 && md_dn && widening)
          return true;
        return false;
      }
}

bool ConfirmBBWidth(bool isBuy){
      int p = Auto_MA_Period();
      double sd =
          iStdDev(Symbol(), PERIOD_CURRENT, p, 0, MODE_SMA, PRICE_CLOSE, 1);
      double sma = iMA(Symbol(), PERIOD_CURRENT, p, 0, MODE_SMA, PRICE_CLOSE, 1);
      double w = (sma != 0 ? sd / sma : 0);
      static double ema = EMPTY_VALUE;
      ema = (ema == EMPTY_VALUE ? w : (0.2 * w + 0.8 * ema));
      return (w > ema);
}

bool ConfirmTrueRange(bool isBuy)
{

      double h = iHigh(Symbol(), 0, 1), l = iLow(Symbol(), 0, 1),
             pc = iClose(Symbol(), 0, 2);
      double tr = MathMax(h - l, MathMax(MathAbs(h - pc), MathAbs(l - pc)));
      static double ema_tr = EMPTY_VALUE;
      ema_tr = (ema_tr == EMPTY_VALUE ? tr : 0.2 * tr + 0.8 * ema_tr);
      return (tr > ema_tr);
}

bool ConfirmStandardDeviation(bool isBuy)
{

      int p = Auto_MA_Period();
      double sd = iStdDev(Symbol(), 0, p, 0, MODE_SMA, PRICE_CLOSE, 1);
      static double ema_sd = EMPTY_VALUE;
      ema_sd = (ema_sd == EMPTY_VALUE ? sd : 0.2 * sd + 0.8 * ema_sd);
      return (sd > ema_sd);
}

bool ConfirmUlcerIndex(bool isBuy)
{

      int p = Auto_MA_Period();
      double maxC = -1e10, sumSq = 0;
      for (int i = p; i >= 1; --i) {
        double c = iClose(Symbol(), 0, i);
        if (c > maxC)
          maxC = c;
        double dd = (maxC > 0 ? 100.0 * (c - maxC) / maxC : 0);
        sumSq += dd * dd;
      }
      double ui = MathSqrt(sumSq / p);
      static double ema_ui = EMPTY_VALUE;
      ema_ui = (ema_ui == EMPTY_VALUE ? ui : 0.2 * ui + 0.8 * ema_ui);
      return (ui <= ema_ui);
}

bool ConfirmChandelier(bool isBuy){

      int p = Auto_FRACTALS_Period();
      int ap = Auto_ATR_Period();
      double mult = Auto_GridATRMult();
      int ih = iHighest(Symbol(), PERIOD_CURRENT, MODE_HIGH, p, 1);
      int il = iLowest(Symbol(), PERIOD_CURRENT, MODE_LOW, p, 1);
      double HH = iHigh(Symbol(), PERIOD_CURRENT, ih);
      double LL = iLow(Symbol(), PERIOD_CURRENT, il);
      double atr = iATR(Symbol(), PERIOD_CURRENT, ap, 1);
      double longLine = HH - mult * atr;
      double shortLine = LL + mult * atr;
      double c = iClose(Symbol(), PERIOD_CURRENT, 1);
      return isBuy ? (c > longLine) : (c < shortLine);
}

bool ConfirmChandelierExit(bool isBuy)   {
      double atr = iATR(Symbol(), 0, 22, 0) * 3;
      double hh = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, 22, 1));
      double ll = iLow(Symbol(), 0, iLowest(Symbol(), 0, MODE_LOW, 22, 1));
      return (isBuy ? (Bid > (ll + atr)) : (Bid < (hh - atr))); }

bool ConfirmVortex(bool isBuy)
{

      int p = Auto_ATR_Period();
      double sumTR = 0, sumP = 0, sumN = 0;
      for (int i = 1; i <= p; i++) {
        double high = iHigh(Symbol(), 0, i), low = iLow(Symbol(), 0, i);
        double prevClose = iClose(Symbol(), 0, i + 1);
        double tr = MathMax(high - low, MathMax(MathAbs(high - prevClose),
                                                MathAbs(low - prevClose)));
        sumTR += tr;
        sumP += MathAbs(high - iLow(Symbol(), 0, i + 1));
        sumN += MathAbs(low - iHigh(Symbol(), 0, i + 1));
      }
      double VIp = (sumTR > 0 ? sumP / sumTR : 0.5);
      double VIn = (sumTR > 0 ? sumN / sumTR : 0.5);
      static double dEMA = EMPTY_VALUE;
      double diff = MathAbs(VIp - VIn);
      dEMA = (dEMA == EMPTY_VALUE ? diff : 0.2 * diff + 0.8 * dEMA);
      return isBuy ? (VIp > VIn && diff >= dEMA) : (VIn > VIp && diff >= dEMA);
}

bool ConfirmADX(bool isBuy)
{

      double adx =
          iADX(Symbol(), 0, Auto_ADX_Period(), PRICE_CLOSE, MODE_MAIN, 1);
      double plus =
          iADX(Symbol(), 0, Auto_ADX_Period(), PRICE_CLOSE, MODE_PLUSDI, 1);
      double minus =
          iADX(Symbol(), 0, Auto_ADX_Period(), PRICE_CLOSE, MODE_MINUSDI, 1);
      if (adx < Auto_ADX_Threshold())
        return true; // Low ADX = no filter
      return isBuy ? (plus > minus) : (minus > plus);
}

bool ConfirmAroon(bool isBuy){

      int p = Auto_FRACTALS_Period();
      int upBars = p, dnBars = p;
      int ih = iHighest(Symbol(), PERIOD_CURRENT, MODE_HIGH, p, 1);
      int il = iLowest(Symbol(), PERIOD_CURRENT, MODE_LOW, p, 1);
      double hh = iHigh(Symbol(), PERIOD_CURRENT, ih),
             ll = iLow(Symbol(), PERIOD_CURRENT, il);
      for (int i = 1; i <= p; i++) {
        if (High[i] == hh) {
          upBars = i;
          break;
        }
      }
      for (int j = 1; j <= p; j++) {
        if (Low[j] == ll) {
          dnBars = j;
          break;
        }
      }
      double up = 100.0 * (p - upBars) / p, down = 100.0 * (p - dnBars) / p;
      double diff = MathAbs(up - down);
      static double dEMA = EMPTY_VALUE;
      dEMA = (dEMA == EMPTY_VALUE ? diff : 0.2 * diff + 0.8 * dEMA);
      return isBuy ? (up > down && diff >= dEMA) : (down > up && diff >= dEMA); }

bool ConfirmDMI(bool isBuy)
{

      double plus =
          iADX(Symbol(), 0, Auto_ADX_Period(), PRICE_CLOSE, MODE_PLUSDI, 1);
      double minus =
          iADX(Symbol(), 0, Auto_ADX_Period(), PRICE_CLOSE, MODE_MINUSDI, 1);
      double gap = MathAbs(plus - minus);
      return isBuy ? (plus > minus && gap >= Auto_DMI_Gap_Threshold())
                   : (minus > plus && gap >= Auto_DMI_Gap_Threshold());
}

bool ConfirmOBV(bool isBuy)
{

      static double obv = 0;
      double c1 = iClose(Symbol(), 0, 1), c2 = iClose(Symbol(), 0, 2);
      if (c1 > c2)
        obv += (double)iVolume(Symbol(), 0, 1);
      else if (c1 < c2)
        obv -= (double)iVolume(Symbol(), 0, 1);
      static double ema_obv = EMPTY_VALUE;
      ema_obv = (ema_obv == EMPTY_VALUE ? obv : 0.2 * obv + 0.8 * ema_obv);
      return isBuy ? (obv > ema_obv) : (obv < ema_obv);
}

bool ConfirmMFI(bool isBuy)
{

      int p = Auto_MA_Period();
      double v = iMFI(Symbol(), 0, p, 1);
      static double ema_mfi = EMPTY_VALUE;
      ema_mfi = (ema_mfi == EMPTY_VALUE ? v : 0.2 * v + 0.8 * ema_mfi);
      return isBuy ? (v >= ema_mfi) : (v <= ema_mfi);
}

bool ConfirmCMF(bool isBuy)
{

      // Chaikin Money Flow: sum of MFV / sum of Volume over period
      int p = 21;
      double sumMFV = 0, sumVol = 0;
      for (int i = 1; i <= p; i++) {
        double h = iHigh(Symbol(), 0, i), l = iLow(Symbol(), 0, i),
               c = iClose(Symbol(), 0, i);
        double hl = h - l;
        double mfv = (hl > 0) ? ((c - l) - (h - c)) / hl *
                                    (double)iVolume(Symbol(), 0, i)
                              : 0;
        sumMFV += mfv;
        sumVol += (double)iVolume(Symbol(), 0, i);
      }
      double cmf = (sumVol > 0 ? sumMFV / sumVol : 0);
      return isBuy ? (cmf > 0) : (cmf < 0);
}

bool ConfirmAvgVolume(bool isBuy)
{

      double curVol = (double)iVolume(Symbol(), 0, 1);
      double avgVol = 0;
      for (int i = 1; i <= 20; i++)
        avgVol += (double)iVolume(Symbol(), 0, i);
      avgVol /= 20.0;
      return (curVol > avgVol * 0.8);
}

bool ConfirmAVWAP(bool isBuy)
{

      double vwap = _SessionVWAP(Symbol(), (ENUM_TIMEFRAMES)Period(), 1440);
      double c = iClose(Symbol(), 0, 1);
      return isBuy ? (c > vwap) : (c < vwap);
}

bool ConfirmVWAP(bool isBuy)   {
      return true; }

bool ConfirmForceIndex(bool isBuy)
{

      double fi = iForce(Symbol(), 0, 13, MODE_SMA, PRICE_CLOSE, 1);
      return isBuy ? (fi > 0) : (fi < 0);
}

int Confirm_EMA(int direction)
{
      if (!EMA)
        return direction;
      double emaFast = iMA(Symbol(), 0, 8, 0, MODE_EMA, PRICE_CLOSE, 0);
      double emaSlow = iMA(Symbol(), 0, 21, 0, MODE_EMA, PRICE_CLOSE, 0);
      if (direction > 0 && emaFast > emaSlow)
        return direction;
      if (direction < 0 && emaFast < emaSlow)
        return direction;
      return 0;
}

int Confirm_SMA(int direction)
{
      if (!SMA)
        return direction;
      double sma50 = iMA(Symbol(), 0, 50, 0, MODE_SMA, PRICE_CLOSE, 0);
      double sma200 = iMA(Symbol(), 0, 200, 0, MODE_SMA, PRICE_CLOSE, 0);
      if (direction > 0 && sma50 > sma200)
        return direction;
      if (direction < 0 && sma50 < sma200)
        return direction;
      return 0;
}

int Confirm_RSI(int direction)
{
      if (!RSI)
        return direction;
      double rsi = iRSI(Symbol(), 0, 14, PRICE_CLOSE, 0);
      // FASE 7 (Patch 5): adaptive thresholds invece di 30/70 fissi.
      int __rsi_os = GetAdaptive_RSI_OS();
      int __rsi_ob = GetAdaptive_RSI_OB();
      if (direction > 0 && rsi > __rsi_os && rsi < __rsi_ob)
        return direction;
      if (direction < 0 && rsi > __rsi_os && rsi < __rsi_ob)
        return direction;
      return 0;
}

int Confirm_MACD(int direction)
{
      if (!MACD)
        return direction;
      double macdMain =
          iMACD(Symbol(), 0, 12, 26, 9, PRICE_CLOSE, MODE_MAIN, 0);
      double macdSignal =
          iMACD(Symbol(), 0, 12, 26, 9, PRICE_CLOSE, MODE_SIGNAL, 0);
      if (direction > 0 && macdMain > macdSignal)
        return direction;
      if (direction < 0 && macdMain < macdSignal)
        return direction;
      return 0;
}

int Confirm_Stochastic(int direction)
{
      if (!Stochastic)
        return direction;
      double stochK =
          iStochastic(Symbol(), 0, 14, 3, 3, MODE_SMA, 0, MODE_MAIN, 0);
      double stochD =
          iStochastic(Symbol(), 0, 14, 3, 3, MODE_SMA, 0, MODE_SIGNAL, 0);
      if (direction > 0 && stochK > stochD && stochK < 80)
        return direction;
      if (direction < 0 && stochK < stochD && stochK > 20)
        return direction;
      return 0;
}

int Confirm_BB(int direction)
{
      if (!BollingerBands)
        return direction;
      double upper = iBands(Symbol(), 0, 20, 2, 0, PRICE_CLOSE, MODE_UPPER, 0);
      double lower = iBands(Symbol(), 0, 20, 2, 0, PRICE_CLOSE, MODE_LOWER, 0);
      double px = iClose(Symbol(), 0, 0);
      if (direction > 0 && px < upper)
        return direction;
      if (direction < 0 && px > lower)
        return direction;
      return 0;
}

int Confirm_ADX(int direction)
{
      if (!ADX)
        return direction;
      double adx = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0);
      double plus = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_PLUSDI, 0);
      double minus = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MINUSDI, 0);
      if (adx < 20)
        return 0; // No trend
      if (direction > 0 && plus > minus)
        return direction;
      if (direction < 0 && minus > plus)
        return direction;
      return 0;
}

int Confirm_CCI(int direction)
{
      if (!CCI)
        return direction;
      double cci = iCCI(Symbol(), 0, 14, PRICE_TYPICAL, 0);
      if (direction > 0 && cci > -100)
        return direction;
      if (direction < 0 && cci < 100)
        return direction;
      return 0;
}

int Confirm_ATR(int direction)
{
      if (!ATRFilter)
        return direction;
      double atr = iATR(Symbol(), 0, 14, 0);
      double pip = (Digits == 3 || Digits == 5) ? Point * 10 : Point;
      if (atr < MinATRPips * pip)
        return 0; // Volatility too low
      return direction;
}

int Confirm_Ichimoku(int direction)
{
      if (!Ichimoku)
        return direction;
      double senkouA = iIchimoku(Symbol(), 0, 9, 26, 52, MODE_SENKOUSPANA, 0);
      double senkouB = iIchimoku(Symbol(), 0, 9, 26, 52, MODE_SENKOUSPANB, 0);
      double px = iClose(Symbol(), 0, 0);
      if (direction > 0 && px > MathMax(senkouA, senkouB))
        return direction;
      if (direction < 0 && px < MathMin(senkouA, senkouB))
        return direction;
      return 0;
}

int Confirm_SAR(int direction)
{
      if (!SAR)
        return direction;
      double sar = iSAR(Symbol(), 0, 0.02, 0.2, 0);
      double px = iClose(Symbol(), 0, 0);
      if (direction > 0 && px > sar)
        return direction;
      if (direction < 0 && px < sar)
        return direction;
      return 0;
}

int Confirm_Fractal(int direction)
{
      if (!Fractal)
        return direction;
      double fracUp = iFractals(Symbol(), 0, MODE_UPPER, 3);
      double fracDn = iFractals(Symbol(), 0, MODE_LOWER, 3);
      if (direction > 0 && fracDn > 0)
        return direction;
      if (direction < 0 && fracUp > 0)
        return direction;
      return 0;
}

int ConfirmAll(int direction)
{
      if (direction == 0)
        return 0;
      direction = Confirm_EMA(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_SMA(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_RSI(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_MACD(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_Stochastic(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_BB(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_ADX(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_CCI(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_ATR(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_Ichimoku(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_SAR(direction);
      if (direction == 0)
        return 0;
      direction = Confirm_Fractal(direction);
      return direction;
}

int GetTri_Signal()
{
      if (IsTriangleAscendingPattern())
        return 1;
      if (IsTriangleDescendingPattern())
        return -1;
      if (IsTriangleSymmetricalPattern()) {
        // decide by short-term momentum
        double atr = iATR(Symbol(), Period(), Auto_ATR_Period(), 1);
        double rng = High[1] - Low[1];
        return (rng > 1.1 * atr ? (Close[1] > Open[1] ? 1 : -1) : 0);
      }
      return 0;
}

double VIDYA_Signal(int shift) {
      double v = CalculateVIDYA(14, shift);
      double c = Close[shift];
      if (c > v)
        return 1.0; // Bullish
      if (c < v)
        return -1.0; // Bearish
      return 0.0;
}

bool CheckPropFirmLimits() {
      double equity = AccountEquity();
      double balance = AccountBalance();
      double maxDDPercent = MaxTotalDDPercent;
      // EquityLockPercent removed - use PeakProfitRetracePercent for protection
      double peakRetrace = PeakProfitRetracePercent;

      if (maxDDPercent > 0) {
        double dd = (balance - equity) / balance * 100;
        if (dd > maxDDPercent) {
          LogError("ÃƒÃ‚Â¢ÃƒÃ‚ÃƒÃ¢ Drawdown limite superato");
          return false;
        }
      }
      if (peakRetrace > 0) {
        double peak = GlobalVariableGet("PeakEquity");
        if (peak > 0 && (peak - equity) / peak * 100 > peakRetrace) {
          LogError("ÃƒÃ‚Â¢ÃƒÃ‚ÃƒÃ¢ Equity lock retrace superato");
          return false;
        }
      }
      return true;
}

bool ConfirmAO(bool isBuy){

      double ao = iAO(Symbol(), PERIOD_CURRENT, 1);
      static double ema = EMPTY_VALUE;
      ema = (ema == EMPTY_VALUE ? ao : (0.2 * ao + 0.8 * ema));
      return isBuy ? (ao >= ema) : (ao <= ema);
}

bool ConfirmATRExp(bool isBuy){

      int p = Auto_ATR_Period();
      double a = iATR(Symbol(), PERIOD_CURRENT, p, 1);
      static double ema = EMPTY_VALUE;
      ema = (ema == EMPTY_VALUE ? a : (0.2 * a + 0.8 * ema));
      return (a > ema);
}

bool ConfirmBBWidthRatio(bool isBuy){

      int per = (int)Auto_BB_Period();
      double dev = Auto_BB_Dev();
      double up0 = iBands(Symbol(), PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_UPPER, 0);
      double dn0 = iBands(Symbol(), PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_LOWER, 0);
      double md0 = iBands(Symbol(), PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_MAIN, 0);
      double up1 = iBands(Symbol(), PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_UPPER, 1);
      double dn1 = iBands(Symbol(), PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_LOWER, 1);
      double md1 = iBands(Symbol(), PERIOD_CURRENT, per, dev, 0, PRICE_CLOSE,
                          MODE_MAIN, 1);
      double bw0 = up0 - dn0;
      double bw1 = up1 - dn1;
      double ratio = (md0 != 0.0 ? bw0 / MathMax(MathAbs(md0), 1e-6) : 0.0);
      double ratio1 = (md1 != 0.0 ? bw1 / MathMax(MathAbs(md1), 1e-6) : 0.0);
      bool expanding = (ratio > ratio1 * 0.98);
      return expanding;
}

bool ConfirmMTKeltner(bool isBuy, string sym=NULL, int tf=0, int emaLen=20, double k=1.0, int trLen=14){
      if (sym == NULL)
        sym = Symbol();
      if (tf == 0)
        tf = Period();
      double mid = iMA(sym, tf, emaLen, 0, MODE_EMA, PRICE_CLOSE, 1);
      double atr = iATR(sym, tf, trLen, 1);
      double up = mid + k * atr, lo = mid - k * atr;
      double c = iClose(sym, tf, 1);
      return isBuy ? (c > up) : (c < lo);
}

bool ConfirmMultiTimeframeTrend(bool isBuy) {
      // Check H4 and D1 trend alignment via EMA crossover
      double ema20_h4 =
          iMA(Symbol(), PERIOD_H4, 20, 0, MODE_EMA, PRICE_CLOSE, 1);
      double ema50_h4 =
          iMA(Symbol(), PERIOD_H4, 50, 0, MODE_EMA, PRICE_CLOSE, 1);
      double ema20_d1 =
          iMA(Symbol(), PERIOD_D1, 20, 0, MODE_EMA, PRICE_CLOSE, 1);
      double ema50_d1 =
          iMA(Symbol(), PERIOD_D1, 50, 0, MODE_EMA, PRICE_CLOSE, 1);
      bool h4up = (ema20_h4 > ema50_h4);
      bool d1up = (ema20_d1 > ema50_d1);
      return isBuy ? (h4up || d1up) : (!h4up || !d1up);
}

bool ConfirmPriceAction(bool isBuy){
      if (!UI_UsePriceActionFilter())
        return true; // gated: when OFF, don't block
      if (Bars < 3)
        return false;
      int sh = 1;
      double o = Open[sh], c = Close[sh], h = High[sh], l = Low[sh];
      double rng = h - l;
      if (rng <= Point * 2)
        return false;
      int atrP = Auto_ATR_Period();
      if (atrP <= 1)
        atrP = 14;
      double atr = iATR(Symbol(), Period(), atrP, sh);
      if (atr <= 0)
        return false;
      double k = Auto_PA_ThresholdATR();
      k *= Auto_PA_Sensitivity();
      double __bodyMin, __wickMax, __impulseMin;
      Auto_PA_Thresholds(__bodyMin, __wickMax, __impulseMin);
      // multiplier depends on volatility regime
      double body = MathAbs(c - o);
      double bodyRatio = (rng > 0 ? body / rng : 0);
      if (isBuy) {
        bool bullish = (c > o);
        double upImpulse = c - l;
        double upperWick = h - c;
        if (!bullish)
          return false;
        if (bodyRatio < __bodyMin)
          return false;
        if (upperWick > rng * __wickMax)
          return false;
        if (upImpulse < k * atr * __impulseMin)
          return false;
        if (!(c > High[sh + 1]))
          return false;
        return true;
      } else {
        bool bearish = (c < o);
        double downImpulse = h - c;
        double lowerWick = (o > l ? o - l : c - l);
        if (!bearish)
          return false;
        if (bodyRatio < __bodyMin)
          return false;
        if (lowerWick > rng * __wickMax)
          return false;
        if (downImpulse < k * atr * __impulseMin)
          return false;
        if (!(c < Low[sh + 1]))
          return false;
        return true;
      }
}

bool ConfirmSignal(int direction, double confidence) {
      double minConf = GetMinConfidence("AI");
      if (confidence < minConf) {
        LogDebug("Confidence troppo bassa");
        return false;
      }

      int ema = GetEMADirection();
      int rsi = GetRSISignal();
      int adx = GetADXDirection();
      int st = SuperTrendSignal();

      int votes = 0;
      if (ema == direction) votes++;
      if (rsi == direction) votes++;
      if (adx == direction) votes++;
      if (st  == direction) votes++;
      if (votes >= 2) return true;
      LogDebug("Conferme insufficienti");
      return false;
}

   int CombinedAISignal() {
   if (!g_ai_connected)
   return 0;
   if (MathAbs(
   g_ai_direction) !=
   1)
   return 0;
   long delta =
   (long)(TimeCurrent() -
   g_ai_timestamp);
   if (delta >
   300) {
   g_ai_connected =
   false;
   return 0;
   } // stale > 5 min
   return g_ai_direction;
   }

   double CombinedAIConfidence(
   int &
   dir) {
   dir =
   0;
   if (!g_ai_connected)
   return 0.0;
   if (MathAbs(
   g_ai_direction) !=
   1)
   return 0.0;
   long delta =
   (long)(TimeCurrent() -
   g_ai_timestamp);
   if (delta >
   300) {
   g_ai_connected =
   false;
   return 0.0;
   }
   dir =
   g_ai_direction;
   return MathMin(
   g_ai_confidence,
   100.0);
   }

   void PredictedBridge_Read() {
   // Read high-impact news messages from kernel32 pipe
   // Stores result in g_aip_rawMsg, g_aip_timestamp
   if (!g_bridge_connected)
   return;
   char buf
   [];
   ArrayResize(
   buf,
   4096);
   uint bytesRead =
   0;
   bool ok = (bool)ReadFile(
   g_hPipeIn,
   buf,
   4095,
   bytesRead,
   0);
   if (!ok ||
   bytesRead <=
   0)
   return;
   string msg =
   "";
   for (
   uint bi =
   0;
   bi <
   bytesRead;
   bi++) {
   if (buf[bi] >=
   32 &&
   buf[bi] <
   127)
   msg += CharToStr(
   buf[bi]);
   }
   if (StringLen(
   msg) >
   0) {
   g_aip_rawMsg =
   msg;
   g_aip_timestamp =
   TimeCurrent();
   }
   }

   void Predicted_ParseHighImpactNews() {
   // Parse g_aip_rawMsg for high-impact news direction + confidence
   // Message format expected: "PREDICTED|dir=+1|impact=HIGH|conf=85|cur=EUR"
   g_aip_direction =
   0;
   g_aip_impact =
   0;
   g_aip_confidence =
   0.0;
   if (StringLen(
   g_aip_rawMsg) <=
   0)
   return;
   if (StringFind(
   g_aip_rawMsg,
   "PREDICTED") <
   0)
   return;
   // Parse direction
   int posDir = StringFind(
   g_aip_rawMsg,
   "dir=");
   if (posDir >=
   0) {
   string dirStr = StringSubstr(
   g_aip_rawMsg,
   posDir +
   4,
   2);
   if (StringFind(
   dirStr,
   "+1") >=
   0)
   g_aip_direction =
   +1;
   else if (
   StringFind(
   dirStr,
   "-1") >=
   0)
   g_aip_direction =
   -1;
   }
   // Parse impact
   if (StringFind(
   g_aip_rawMsg,
   "impact=HIGH") >=
   0)
   g_aip_impact =
   3;
   else if (
   StringFind(
   g_aip_rawMsg,
   "impact=MED") >=
   0)
   g_aip_impact =
   2;
   else if (
   StringFind(
   g_aip_rawMsg,
   "impact=LOW") >=
   0)
   g_aip_impact =
   1;
   // Parse confidence
   int posConf = StringFind(
   g_aip_rawMsg,
   "conf=");
   if (posConf >=
   0) {
   string confStr = StringSubstr(
   g_aip_rawMsg,
   posConf +
   5,
   3);
   g_aip_confidence =
   (double)StringToInteger(
   confStr);
   }
   // Validate freshness
   long delta =
   TimeCurrent() -
   g_aip_timestamp;
   if (delta >
   180) { // stale > 3 min
   g_aip_direction =
   0;
   g_aip_confidence =
   0.0;
   }
   }

