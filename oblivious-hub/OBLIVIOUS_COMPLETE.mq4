string GenerateErrorDescription(int errorCode)
{
      switch (errorCode) {
      case 0:
        return "No error";
      case 1:
        return "No error but result unknown";
      case 2:
        return "Common error";
      case 3:
        return "Invalid trade parameters";
      case 4:
        return "Trade server busy";
      case 5:
        return "Old version of client terminal";
      case 6:
        return "No connection to trade server";
      case 7:
        return "Not enough rights";
      case 8:
        return "Too frequent requests";
      case 9:
        return "Malfunctional trade operation";
      case 64:
        return "Account disabled";
      case 65:
        return "Invalid account";
      case 128:
        return "Trade timeout";
      case 129:
        return "Invalid price";
      case 130:
        return "Invalid stops";
      case 131:
        return "Invalid trade volume";
      case 132:
        return "Market is closed";
      case 133:
        return "Trade is disabled";
      case 134:
        return "Not enough money";
      case 135:
        return "Price changed";
      case 136:
        return "Off quotes";
      case 137:
        return "Broker is busy";
      case 138:
        return "Requote";
      case 139:
        return "Order is locked";
      case 140:
        return "Buy orders only allowed";
      case 141:
        return "Too many requests";
      case 145:
        return "Modification denied (too close)";
      case 146:
        return "Trade context is busy";
      case 147:
        return "Expirations are denied by broker";
      case 148:
        return "Too many open/pending orders";
      case 4109:
        return "Trade is not allowed";
      default:
        return "Error " + IntegerToString(errorCode);
      }
}

bool HandleError(int error_code, string function_name, int severity = 2)
{
      string desc = GenerateErrorDescription(error_code);
      string msg =
          StringFormat("[%s] err=%d: %s", function_name, error_code, desc);
      LogError(msg);
      // Auto-recover on transient errors
      if (error_code == ERR_REQUOTE || error_code == ERR_PRICE_CHANGED ||
          error_code == ERR_TRADE_CONTEXT_BUSY ||
          error_code == ERR_SERVER_BUSY) {
        SAFE_SLEEP(1000);
        RefreshRates();
        return true;
      }
      return false;
}

bool AttemptRecovery(int error_code, string function_name, int retry_count)
{
      bool ok = false;
      switch (error_code) {
      case ERR_TRADE_CONTEXT_BUSY:
        SAFE_SLEEP(1000);
        RefreshRates();
        ok = true;
        break;
      case ERR_REQUOTE:
      case ERR_PRICE_CHANGED:
        RefreshRates();
        ok = true;
        break;
      case ERR_TRADE_TIMEOUT:
        if (retry_count < 3) {
          SAFE_SLEEP(2000);
          ok = true;
        }
        break;
      case ERR_SERVER_BUSY:
        SAFE_SLEEP(5000);
        ok = true;
        break;
      default:
        ok = false;
      }
      if (ok)
        PrintFormat("[Recovery] OK for %s (err=%d attempt=%d)", function_name,
                    error_code, retry_count);
      else
        PrintFormat("[Recovery] FAIL for %s (err=%d attempt=%d)", function_name,
                    error_code, retry_count);
      return ok;
}

string GetSystemHealth()
{
      return StringFormat("Errors=%d AvgTick=%.1fms MaxTick=%.1fms Ticks=%d",
                          g_health.totalErrors, g_health.avgTickTimeMs,
                          g_health.maxTickTimeMs, g_health.tickCount);
}

string GetErrorReport(datetime from_time = 0)
{
      return StringFormat(
          "=== ERROR REPORT ===\nSystem Health: %.1f%%\nErrors: %d\n",
          system_health_score, g_health.totalErrors);
}

void UpdateSystemHealth(int severity)
{
      // severity: 0=info, 1=warning, 2=error, 3=critical
      switch (severity) {
      case 0:
        system_health_score = MathMax(95.0, system_health_score - 0.1);
        break;
      case 1:
        system_health_score = MathMax(85.0, system_health_score - 0.5);
        break;
      case 2:
        system_health_score = MathMax(70.0, system_health_score - 2.0);
        break;
      case 3:
        system_health_score = MathMax(50.0, system_health_score - 10.0);
        break;
      }
}

int FindMetricIndex(string name)
{
      for (int i = 0; i < g_perfMetricCount; i++)
        if (g_perfMetrics[i].name == name)
          return i;
      return -1;
}

int FindOrCreateMetricIndex(string strategy_name) {
      int existing_index = FindMetricIndex(strategy_name);
      if (existing_index >= 0)
        return existing_index;
      for (int i = 0; i < MAX_PERF_METRICS; i++) {
        if (g_perfMetrics[i].name == "") {
          g_perfMetrics[i].name = strategy_name;
          g_perfMetrics[i].startUs = 0;
          g_perfMetrics[i].totalMs = 0.0;
          g_perfMetrics[i].count = 0;
          g_perfMetrics[i].maxMs = 0.0;
          return i;
        }
      }
      return -1;
}

void StartMeasurement(string name)
{
      int idx = FindOrCreateMetricIndex(name);
      if (idx < 0)
        return;
      g_perfMetrics[idx].startUs = GetMicrosecondCount();
}

void EndMeasurement(string strategy_name, bool success = true)
{
      int idx = KPI_FindIndex(strategy_name);
      if (idx < 0 || KPI_active[idx] != strategy_name)
        return;
      double elapsed = (double)(GetTickCount() - KPI_start_ticks[idx]);
      KPI_metrics[idx].execution_time_ms = elapsed;
      KPI_metrics[idx].end_time = TimeCurrent();
      KPI_metrics[idx].total_executions++;
      int n = KPI_metrics[idx].total_executions;
      if (n == 1) {
        KPI_metrics[idx].min_execution_time = elapsed;
        KPI_metrics[idx].max_execution_time = elapsed;
        KPI_metrics[idx].avg_execution_time = elapsed;
      } else {
        KPI_metrics[idx].min_execution_time =
            MathMin(KPI_metrics[idx].min_execution_time, elapsed);
        KPI_metrics[idx].max_execution_time =
            MathMax(KPI_metrics[idx].max_execution_time, elapsed);
        KPI_metrics[idx].avg_execution_time =
            ((KPI_metrics[idx].avg_execution_time * (n - 1)) + elapsed) / n;
      }
      if (success)
        KPI_metrics[idx].orders_processed++;
      KPI_metrics[idx].success_rate =
          (KPI_metrics[idx].orders_processed * 100.0) / n;
      KPI_total_cpu += elapsed;
      KPI_active[idx] = "";
      if (elapsed > 100.0)
        PrintFormat("[KPI] WARNING: %s took %.1f ms", strategy_name, elapsed);
}

double GetAverageExecutionTime(string name)
{
      int idx = FindMetricIndex(name);
      if (idx < 0 || g_perfMetrics[idx].count == 0)
        return 0;
      return g_perfMetrics[idx].totalMs / g_perfMetrics[idx].count;
}

string GeneratePerformanceReport() {
      string report = "=== PERFORMANCE REPORT ===\n";
      report += StringFormat("Report Period: up to %s\n\n", TimeToString(TimeCurrent()));
      report += "Name                 | Count | AvgMs | MaxMs |\n";
      report += "-------------------- | ----- | ----- | ----- |\n";
      for (int i = 0; i < g_perfMetricCount && i < MAX_PERF_METRICS; i++) {
        if (g_perfMetrics[i].name != "" && g_perfMetrics[i].count > 0) {
          double avg = (g_perfMetrics[i].count > 0) ? g_perfMetrics[i].totalMs / g_perfMetrics[i].count : 0;
          report += StringFormat("%-20s | %5d | %5.2f | %5.2f |\n",
              g_perfMetrics[i].name, g_perfMetrics[i].count, avg, g_perfMetrics[i].maxMs);
        }
      }
      report += "\nPerformance Recommendations:\n";
      report += GetPerformanceRecommendations();
      return report;
}

double Mid(double a, double b)   {
      return (a + b) * 0.5; }

double Percentile(double &arr[], int n, double p)  // p in [0,1]
{
      if (n <= 0)
        return 0.0;
      ArraySort(arr, n, 0, MODE_ASCEND);
      double idx = p * (n - 1);
      int lo = (int)MathFloor(idx);
      int hi = (int)MathCeil(idx);
      if (lo < 0)
        lo = 0;
      if (hi >= n)
        hi = n - 1;
      if (lo == hi)
        return arr[lo];
      double frac = idx - lo;
      return arr[lo] + frac * (arr[hi] - arr[lo]);
}

double PercentileRange(int lookback, double q)
{
      int n = (int)MathMin(lookback, Bars - 1);
      if (n <= 1)
        return RangeAt(1);
      double arr[512];
      ArrayInitialize(arr, 0.0);
      int cnt = 0;
      int cap = (int)MathMin(n, 512);
      for (int i = 1; i <= cap; i++)
        arr[cnt++] = RangeAt(i);
      // sort
      for (int i = 0; i < cnt; i++)
        for (int j = i + 1; j < cnt; j++)
          if (arr[j] < arr[i]) {
            double t = arr[i];
            arr[i] = arr[j];
            arr[j] = t;
          }
      if (cnt == 0)
        return RangeAt(1);
      int idx = (int)MathFloor(q * (cnt - 1));
      if (idx < 0)
        idx = 0;
      if (idx >= cnt)
        idx = cnt - 1;
      return arr[idx];
}

