void SL_AddMessage(string msg) {
      for (int _i = SL_LINES - 1; _i > 0; _i--)
        SL_buf[_i] = SL_buf[_i - 1];
      SL_buf[0] = msg;
      if (SmartPanel) SL_Redraw(); }

