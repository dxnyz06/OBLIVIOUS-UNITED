   void Strategy_Engulfing_Logic() {
   if (!true)
   return;
   double O1 = iOpen(
   NULL,
   0,
   1);
   double C1 = iClose(
   NULL,
   0,
   1);
   double O2 = iOpen(
   NULL,
   0,
   2);
   double C2 = iClose(
   NULL,
   0,
   2);
   double body1 =
   MathAbs(
   C1 -
   O1);
   double body2 =
   MathAbs(
   C2 -
   O2);
   int dir =
   0;
   double conf =
   55.0;
   if (C1 >
   O1 &&
   C2 <
   O2 &&
   C1 >
   O2 &&
   O1 <
   C2 &&
   body1 >
   body2) {
   dir =
   1;
   conf =
   68.0;
   } else if (
   C1 <
   O1 &&
   C2 >
   O2 &&
   C1 <
   O2 &&
   O1 >
   C2 &&
   body1 >
   body2) {
   dir =
   -1;
   conf =
   68.0;
   }
   if (dir == 0)



   return;
   conf = MathMin(
   conf,
   88.0);
   if (conf >= PatternsConfidence) {
      if (dir == 1) g_pat_bull_count++; else g_pat_bear_count++;
      g_pat_confidence = MathMax(g_pat_confidence, conf);
   }
   }

