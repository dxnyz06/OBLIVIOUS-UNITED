                                          bool AI_QueryVirtualTPSL(
                                              const int magic, const int ticket,
                                              const string symbol,
                                              const string sname, double &tp,
                                              double &sl, int &srcCode) {
                                            srcCode = 0;
                                            bool got = false;
                                            // by ticket
                                            string k_tp1 = StringFormat(
                                                "AI_TP_%d", ticket);
                                            string k_sl1 = StringFormat(
                                                "AI_SL_%d", ticket);
                                            if (tp <= 0 &&
                                                GlobalVariableCheck(k_tp1)) {
                                              double v =
                                                  GlobalVariableGet(k_tp1);
                                              if (v > 0) {
                                                tp = v;
                                                got = true;
                                                srcCode = 1;
                                              }
                                            }
                                            if (sl <= 0 &&
                                                GlobalVariableCheck(k_sl1)) {
                                              double v =
                                                  GlobalVariableGet(k_sl1);
                                              if (v > 0) {
                                                sl = v;
                                                got = true;
                                                srcCode = 1;
                                              }
                                            }
                                            // by symbol+magic
                                            string k_tp2 = StringFormat(
                                                "AI_TP_%s_%d", symbol, magic);
                                            string k_sl2 = StringFormat(
                                                "AI_SL_%s_%d", symbol, magic);
                                            if (tp <= 0 &&
                                                GlobalVariableCheck(k_tp2)) {
                                              double v =
                                                  GlobalVariableGet(k_tp2);
                                              if (v > 0) {
                                                tp = v;
                                                got = true;
                                                srcCode = 1;
                                              }
                                            }
                                            if (sl <= 0 &&
                                                GlobalVariableCheck(k_sl2)) {
                                              double v =
                                                  GlobalVariableGet(k_sl2);
                                              if (v > 0) {
                                                sl = v;
                                                got = true;
                                                srcCode = 1;
                                              }
                                            }
                                            // by symbol+strategy
                                            string k_tp3 = StringFormat(
                                                "AI_TP_%s_%s", symbol, sname);
                                            string k_sl3 = StringFormat(
                                                "AI_SL_%s_%s", symbol, sname);
                                            if (tp <= 0 &&
                                                GlobalVariableCheck(k_tp3)) {
                                              double v =
                                                  GlobalVariableGet(k_tp3);
                                              if (v > 0) {
                                                tp = v;
                                                got = true;
                                                srcCode = 1;
                                              }
                                            }
                                            if (sl <= 0 &&
                                                GlobalVariableCheck(k_sl3)) {
                                              double v =
                                                  GlobalVariableGet(k_sl3);
                                              if (v > 0) {
                                                sl = v;
                                                got = true;
                                                srcCode = 1;
                                              }
                                            }
                                            // Objects: AI_TP_*/AI_SL_* as
                                            // HLINE/TREND
                                            string candidates[6];
                                            candidates[0] = StringFormat("AI_TP_%d", ticket);
                                            candidates[1] = StringFormat("AI_TP_%s_%d", symbol, magic);
                                            candidates[2] = StringFormat("AI_TP_%s_%s", symbol, sname);
                                            candidates[3] = StringFormat("AI_SL_%d", ticket);
                                            candidates[4] = StringFormat("AI_SL_%s_%d", symbol, magic);
                                            candidates[5] = StringFormat("AI_SL_%s_%s", symbol, sname);
                                            for (int i = 0; i < 6; i++) {
                                              string id = candidates[i];
                                              if (ObjectFind(0, id) >= 0) {
                                                int type =
                                                    (int)ObjectGetInteger(
                                                        0, id, OBJPROP_TYPE);
                                                if (type == OBJ_HLINE ||
                                                    type == OBJ_TREND) {
                                                  double p1 = ObjectGetDouble(
                                                      0, id, OBJPROP_PRICE1);
                                                  double p2 =
                                                      (type == OBJ_TREND
                                                           ? ObjectGetDouble(
   0, id,
   OBJPROP_PRICE2)
                                                           : p1);
                                                  double pv =
                                                      (p1 > 0 ? p1 : p2);
                                                  if (pv > 0) {
                                                    if (StringFind(id, "AI_TP_",
   0) == 0 &&
                                                        tp <= 0) {
                                                      tp = pv;
                                                      got = true;
                                                      srcCode = 2;
                                                    }
                                                    if (StringFind(id, "AI_SL_",
   0) == 0 &&
                                                        sl <= 0) {
                                                      sl = pv;
                                                      got = true;
                                                      srcCode = 2;
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                            return got;
                                          }

                                          // void AccountProfit() removed: conflicts with built-in

   double AdjustTP_RRGuard(string strategy, bool isBuy, double entryPrice, double sl, double tp) {
   // Exclusions
   if (strategy == "Grid") return tp;
   if (sl <= 0 || tp <= 0 || entryPrice <= 0) return tp;
   const double
   risk = MathAbs(
   entryPrice -
   sl);
   double reward =
   MathAbs(
   tp -
   entryPrice);
   if (risk <
   Point *
   2)
   return tp;
   // 1) Enforce adaptive RR
   const double
   minRR = GetAdaptiveRR(
   strategy);
   const double
   need =
   risk *
   minRR;
   double newTP =
   tp;
   if (reward <
   need) {
   if (isBuy)
   newTP =
   entryPrice +
   need;
   else
   newTP =
   entryPrice -
   need;
   reward = MathAbs(
   newTP -
   entryPrice);
   Print(
   strategy,
   " | RR-Guard applied -> minRR=",
   DoubleToString(
   minRR,
   2));
   }
   // 2) Cover minimal costs (spread + commission + worst-case swap)
   const double spreadPts =
   MarketInfo(
   Symbol(),
   MODE_SPREAD) *
   Point;
   const double
   commission =
   0.0; // commission not directly accessible in MQL4
   double worstSwap =
   0.0;
   const int swapMode =
   (isBuy
   ? MODE_SWAPLONG
   : MODE_SWAPSHORT);
   const double
   sw = MarketInfo(
   Symbol(),
   swapMode);
   if (sw <
   0)
   worstSwap =
   -sw;
   const double minNet =
   (risk *
   1.10) +
   spreadPts +
   commission +
   worstSwap;
   if (reward <
   minNet) {
   const double extra =
   (minNet -
   reward);
   if (isBuy)
   newTP +=
   extra;
   else
   newTP -=
   extra;
   Print(
   strategy,
   " | Net-Guard applied (costs+10%)");
   }
   // Normalize to symbol digits
   return NormalizeDouble(
   newTP,
   Digits);
   }
   // === END: Auto-Adaptive RR Guard ===
