// [INCOMPLETE_SIG] int SafeOrderSend(string symbol, int cmd, double volume, double price,
// [INCOMPLETE_SIG]                   int slippage, double stoploss, double takeprofit,

bool OrderSend_IfAllowed(int cmd, double lots, double price, double sl, double tp, string comment=""){
      if (!CheckRiskLimits())
        return false;
      if (!CheckSpreadControl())
        return false;
      int ticket =
          SafeOrderSend(Symbol(), cmd, lots, price, GetAdaptiveSlippagePoints(),
                        sl, tp, comment, ObliviousAiMagic, 0, clrNONE);
      return (ticket > 0);
}

void CloseOrderReverseSignal(int direction, string strategy) {
      // Closes existing orders when signal direction changes
      if (strategy != "FVG" && strategy != "SMC" && strategy != "ICT" &&
          strategy != "Predicted") {
        return;
      }
      // direction: 1=BUY, -1=SELL
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
          if (OrderSymbol() == Symbol() && OrderMagicNumber() == MagicNumber) {
            // Se l'ordine ÃƒÃ†ÃƒÃ‚Â¨ opposto al nuovo segnale, chiudilo
            if ((direction == 1 && OrderType() == OP_SELL)
              || (direction == -1 && OrderType() == OP_BUY)) {
                AI_BridgeManager();
                if (IsTPSL_AI() && true) {
                  {
    // Global safety: only allowed from risk engine, kill-switch, or emergency
                    int __ticket = OrderTicket();
                    double __lots = OrderLots();
                    SmartLogWrap(
                        "CLOSE",
                        StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s",
                                     __ticket, __lots, OrderSymbol()));
                  }
                  // ) OrderClose(OrderTicket(), OrderLots(), closePrice,
                  // GetAdaptiveSlippagePoints(), clrRed);
                  {
                    int __err = GetLastError();
                    bool __isok = (__err == 0);
                    SmartLogWrap(
                        "CLOSE",
                        StringFormat(
                            "%s | ticket=%d price=%.5f lots=%.2f err=%d",
                            __isok ? "PostClose OK" : "PostClose FAIL",
                            OrderTicket(), OrderClosePrice(), OrderLots(),
                            __err));
                  }
                }
                PrintFormat("?? Ordine %d chiuso per cambio segnale",
                            OrderTicket());
              }
          }
        }
      }
}

