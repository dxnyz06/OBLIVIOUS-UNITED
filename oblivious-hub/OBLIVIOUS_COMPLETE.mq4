   // They are the canonical single definitions for each function.

//| 8. bridge kernel32 / news / AI / parsing / polling / cache sync

void AIBC_RefreshMagics()
{
      // Build unique list of magics from current open trades on this account
      // (all symbols)
      int maxN = 128;
      long used[];
      ArrayResize(used, 0);
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        long m = (long)OrderMagicNumber();
        bool seen = false;
        for (int j = 0; j < ArraySize(used); j++) {
          if (used[j] == m) {
            seen = true;
            break;
          }
        }
        if (!seen) {
          int sz = ArraySize(used);
          ArrayResize(used, sz + 1);
          used[sz] = m;
          if (sz + 1 >= maxN)
            break;
        }
      }
      if (ArraySize(used) == 0) {
        // No trades to infer: use {0} which means "tutti i magic" come nel
        // design originale
        ArrayResize(AIBC_Magics, 1);
        AIBC_Magics[0] = 0;
      } else {
        ArrayResize(AIBC_Magics, ArraySize(used));
        for (int k = 0; k < ArraySize(used); k++)
          AIBC_Magics[k] = (int)used[k];
      }
}

