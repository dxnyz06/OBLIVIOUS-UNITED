                      void PositionManager_Init() {
                        g_positionCount = 0;
                        PositionManager_SyncFromBroker();
                        PrintFormat("[PositionManager] Init: %d "
                                    "active positions",
                                    g_positionCount);
                      }

                      void PositionManager_SyncFromBroker() {
                        // Mark all as inactive
                        for (int i = 0; i < g_positionCount; i++)
                          g_positions[i].active = false;

                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderType() > OP_SELL)
                            continue; // Skip pending

                          string cmnt = OrderComment();
                          if (StringFind(cmnt, OM_COMMENT_PREFIX) < 0)
                            continue;

                          int ticket = OrderTicket();
                          int idx = PositionManager_FindByTicket(ticket);

                          if (idx < 0) {
                            // New position
                            idx = PositionManager_AddSlot();
                            if (idx < 0)
                              continue;
                            g_positions[idx].highWaterMark = OrderOpenPrice();
                            g_positions[idx].beApplied = false;
                          }

                          g_positions[idx].ticket = ticket;
                          g_positions[idx].symbol = OrderSymbol();
                          g_positions[idx].cmd = OrderType();
                          g_positions[idx].lots = OrderLots();
                          g_positions[idx].openPrice = OrderOpenPrice();
                          g_positions[idx].sl = OrderStopLoss();
                          g_positions[idx].tp = OrderTakeProfit();
                          g_positions[idx].magic = OrderMagicNumber();
                          g_positions[idx].openTime = OrderOpenTime();
                          g_positions[idx].active = true;

                          // Update high water mark
                          double currentPrice =
                              (OrderType() == OP_BUY)
                                  ? MarketInfo(OrderSymbol(), MODE_BID)
                                  : MarketInfo(OrderSymbol(), MODE_ASK);

                          if (OrderType() == OP_BUY &&
                              currentPrice > g_positions[idx].highWaterMark)
                            g_positions[idx].highWaterMark = currentPrice;
                          if (OrderType() == OP_SELL &&
                              (g_positions[idx].highWaterMark == 0 ||
                               currentPrice < g_positions[idx].highWaterMark))
                            g_positions[idx].highWaterMark = currentPrice;
                        }

                        // Compact: remove inactive slots
                        PositionManager_Compact();
                      }

                      void PositionManager_ManageAll() {
                        PositionManager_SyncFromBroker();

                        for (int i = 0; i < g_positionCount; i++) {
                          if (!g_positions[i].active)
                            continue;

                          // Apply breakeven if enabled
                          if (EnableBreakEven && !g_positions[i].beApplied)
                            PositionManager_ApplyBreakeven(i);

                          // Apply trailing if enabled
                          if (EnableTrailingStop)
                            PositionManager_ApplyTrailing(i);
                        }
                      }

                      int PositionManager_FindByTicket(int ticket) {
                        for (int i = 0; i < g_positionCount; i++) {
                          if (g_positions[i].ticket == ticket &&
                              g_positions[i].active)
                            return i;
                        }
                        return -1;
                      }

                      void PositionManager_Compact() {
                        int writeIdx = 0;
                        for (int readIdx = 0; readIdx < g_positionCount;
                             readIdx++) {
                          if (g_positions[readIdx].active) {
                            if (writeIdx != readIdx)
                              g_positions[writeIdx] = g_positions[readIdx];
                            writeIdx++;
                          }
                        }
                        g_positionCount = writeIdx;
                      }

                      int PositionManager_CountByMagic(int magic,
                                                       string symbol = "") {
                        return OrderManager_CountByMagic(magic, symbol);
                      }

                      int PositionManager_GetCount() { return g_positionCount; }

                      void PositionManager_Deinit() { g_positionCount = 0; }

                      void PnLTracker_OnClosed(int ticket) {
                        if (!OrderSelect(ticket, SELECT_BY_TICKET))
                          return;
                        double pnl =
                            OrderProfit() + OrderSwap() + OrderCommission();
                        g_pnl_realized += pnl;
                        g_pnl_closedToday++;

                        SmartLog("CLOSE", "PnL",
                                 StringFormat("Ticket:%d | PnL:%.2f "
                                              "| Total Today:%.2f "
                                              "(%d trades)",
                                              ticket, pnl, g_pnl_realized,
                                              g_pnl_closedToday));
                      }

                      void PnLTracker_OnOpened(int ticket) {
                        g_pnl_openedToday++;
                        SmartLog_NewEntrySnapshotForTicket(ticket);
                      }

                      int PnLTracker_ClosedCount() { return 0; }

                      int PnLTracker_OpenedCount() { return 0; }

                      int AIP2_iHighestClosed(int tf, int count) {
                        return iHighest(Symbol(), tf, MODE_CLOSE, count, 0);
                      }

                      int AIP2_iLowestClosed(int tf, int count) {
                        return iLowest(Symbol(), tf, MODE_CLOSE, count, 0);
                      }

                      bool AIP2_ComputeClosed10(double &lo, double &hi) {
                        int tf = AIP2_LTF();
                        int N = 10;
                        lo = iClose(Symbol(), tf, AIP2_iLowestClosed(tf, N));
                        hi = iClose(Symbol(), tf, AIP2_iHighestClosed(tf, N));
                        return (hi > lo);
                      }

                      bool AIP2_ComputeClosed20(double &lo, double &hi) {
                        int tf = AIP2_LTF();
                        int N = 20;
                        lo = iClose(Symbol(), tf, AIP2_iLowestClosed(tf, N));
                        hi = iClose(Symbol(), tf, AIP2_iHighestClosed(tf, N));
                        return (hi > lo);
                      }

                      void ManageOpenPositions() {
                        ManageTrailingStop();
                        ManageBreakEven();
                        DailyEmergencyCloseIfNeeded();
                      }

                      void ManagePendingOrders() {
                        if (!IsTPSL_AI()) {
                          return;
                        }
                        bool newsHigh = HighImpactNewsActive();
                        int totalOrders = OrdersTotal();
                        for (int i = totalOrders - 1; i >= 0; i--) {
                          if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
                            if (OrderType() == OP_BUYSTOP ||
                                OrderType() == OP_SELLSTOP ||
                                OrderType() == OP_BUYLIMIT ||
                                OrderType() == OP_SELLLIMIT) {
                              if (newsHigh) {
                                LogGate("BLOCK NEWS",
                                        StringFormat("Symbol=%s Time=%s "
                                                     "(file=file pATH)",
                                                     Symbol(),
                                                     TimeToStr(TimeCurrent(),
   TIME_SECONDS)));
Print("Bridge: Cancellazione ordine pendente per news ad alto impatto: ", OrderTicket());
if (!OrderDelete(OrderTicket()) ) {
Print("Errore cancellazione ordine pendente: ", GetLastError());
}
                              }
                            }
                          }
                        }
                      }

                      string GetActivePositionsJSON() {
                        string positions = "";
                        int position_count = 0;
                        for (int i = 0; i < OrdersTotal(); i++) {
                          if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
                            if (OrderSymbol() == Symbol()) {
                              if (position_count > 0)
                                positions += ",";
                              positions += StringFormat(
                                  "{\"ticket\":%d,\"symbol\":\"%s\",\"type\":\"%s\","
                                  "\"open_price\":%.5f,\"lots\":%.2f,\"profit\":%.2f,"
                                  "\"open_time\":\"%s\"}",
                                  OrderTicket(), OrderSymbol(),
                                  OrderType() == OP_BUY ? "BUY" : "SELL",
                                  OrderOpenPrice(), OrderLots(), OrderProfit(),
                                  TimeToString(OrderOpenTime(), TIME_SECONDS));
                              position_count++;
                            }
                          }
                        }
                        return positions;
                      }

                      bool PlacePendingOrder(int type, double price,
                                             double slPips, double tpPips) {
                        if (!IsTPSL_AI()) {
                          return false;
                        }
                        double lotSize = CalculateLotSize();
                        double sl = (type == OP_BUYSTOP || type == OP_BUYLIMIT)
                                        ? price - slPips * Point
                                        : price + slPips * Point;
                        double tp = (type == OP_BUYSTOP || type == OP_BUYLIMIT)
                                        ? price + tpPips * Point
                                        : price - tpPips * Point;
                        int ticket = SafeOrderSend(Symbol(), type, lotSize, price, Slippage, sl, tp, "AI Pending", PredictedMagic, 0, clrBlue);
                        if (ticket < 0) { Print("Errore ordine pendente: ", GetLastError()); return false; }
                        Print("Bridge: Ordine pendente ticket: ", ticket);
                        return true;
                      }

bool IsOrderBlock()  {
                                        return (IsBullishOrderBlock() ||
                                                IsBearishOrderBlock()); }

bool IsBullishOrderBlock()  {
                                        if (Bars < 5)
                                          return false;
                                        bool bear = Close[3] < Open[3];
                                        bool bullBreak = Close[1] > High[3];
                                        return (bear && bullBreak); }

bool IsBearishOrderBlock()  {
                                        if (Bars < 5)
                                          return false;
                                        bool bull = Close[3] > Open[3];
                                        bool bearBreak = Close[1] < Low[3];
                                        return (bull && bearBreak); }

                                        void __dup_CloseLosingPositions() {
                                          for (int i = OrdersTotal() - 1;
                                               i >= 0; i--) {
                                            if (OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES)) {
                                              if (OrderSymbol() == Symbol() &&
                                                  OrderProfit() < 0) {
                                                double closePrice =
                                                    (OrderType() == OP_BUY)
                                                        ? MarketInfo(Symbol(),
   MODE_BID)
                                                        : MarketInfo(Symbol(),
   MODE_ASK);
                                                RefreshRates();
                                                {
                                                  int __ticket = OrderTicket();
                                                  double __lots = OrderLots();
                                                  SmartLogWrap(
                                                      "CLOSE",
                                                      StringFormat(
                                                          "PreClose | "
                                                          "ticket=%d lots=%.2f "
                                                          "symbol=%s",
                                                          __ticket, __lots,
                                                          OrderSymbol()));
                                                }
                                                if (!OrderClose(
                                                        OrderTicket(),
                                                        OrderLots(), closePrice,
                                                        GetAdaptiveSlippagePoints(),
                                                        clrRed)) {
                                                  {
                                                    int __err = GetLastError();
                                                    bool __isok = (__err == 0);
                                                    SmartLogWrap(
                                                        "CLOSE",
                                                        StringFormat(
   "%s | ticket=%d "
   "price=%.5f "
   "lots=%.2f err=%d",
   __isok
   ? "PostClose OK"
   : "PostClose "
   "FAIL",
   OrderTicket(),
   OrderClosePrice(),
   OrderLots(),
   __err));
                                                  }
                                                  PrintFormat(
                                                      "? Errore chiusura "
                                                      "ordine losing %d: %d",
                                                      OrderTicket(),
                                                      GetLastError());
                                                } else {
                                                  PrintFormat("? Ordine losing "
   "chiuso: %d",
   OrderTicket());
                                                }
                                              }
                                            }
                                          }
                                        }

                                        int AIBC_OpenPipe() {
                                          // [R3] Transport neutralised. Always
                                          // returning -1 keeps the AIBC pulse
                                          // loop running (it gracefully sets
                                          // "KO: pipe" status) without ever
                                          // opening a named pipe alongside the
                                          // live ZMQ bridge.
                                          return -1;
                                        }

                                          bool AIP2_ComputeBands_Closed10() {
                                            int tf = AIP2_LTF();
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt == AIP2_fix_bar)
                                              return true; // already
                                            // computed for
                                            // this bar
                                            int N = 10;
                                            int idxH = iHighest(
                                                Symbol(), tf, MODE_HIGH, N,
                                                1); // shift 1 => CLOSED
                                            // bars only
                                            int idxL = iLowest(Symbol(), tf,
   MODE_LOW, N, 1);
                                            double HH =
                                                iHigh(Symbol(), tf, idxH);
                                            double LL =
                                                iLow(Symbol(), tf, idxL);
                                            // width from TR of last 10
                                            // CLOSED bars (shifts 1..10)
                                            double tr[];
                                            ArrayResize(tr, N);
                                            for (int i = 1; i <= N; i++) {
                                              double h = iHigh(Symbol(), tf, i),
                                                     l = iLow(Symbol(), tf, i),
                                                     pc = iClose(Symbol(), tf,
   i + 1);
                                              tr[i - 1] = MathMax(
                                                  h - l,
                                                  MathMax(MathAbs(h - pc),
                                                          MathAbs(l - pc)));
                                            }
                                            // robust MAD
                                            double med = 0.0;
                                            { // median
                                              double tmp[];
                                              ArrayResize(tmp, N);
                                              for (int k = 0; k < N; k++)
                                                tmp[k] = tr[k];
                                              ArraySort(tmp, WHOLE_ARRAY, 0,
                                                        MODE_ASCEND);
                                              med = tmp[N / 2];
                                            }
                                            for (int j = 0; j < N; j++)
                                              tr[j] = MathAbs(tr[j] - med);
                                            double mad = 0.0;
                                            {
                                              double tmp2[];
                                              ArrayResize(tmp2, N);
                                              for (int k = 0; k < N; k++)
                                                tmp2[k] = tr[k];
                                              ArraySort(tmp2, WHOLE_ARRAY, 0,
                                                        MODE_ASCEND);
                                              mad = tmp2[N / 2];
                                            }
                                            double spr =
                                                MarketInfo(Symbol(),
                                                           MODE_SPREAD) *
                                                Point;
                                            double stp =
                                                MarketInfo(Symbol(),
                                                           MODE_STOPLEVEL) *
                                                Point;
                                            double width =
                                                MathMax(mad, MathMax(spr, stp));
                                            // BUY side bands
                                            AIP2_b1_lo_buy = LL;
                                            AIP2_b1_hi_buy = LL + width;
                                            AIP2_b2_lo_buy = LL + width;
                                            AIP2_b2_hi_buy =
                                                LL + 1.5 * width; // +50% locked
                                            // for this bar
                                            // SELL side bands
                                            AIP2_b1_lo_sell = HH - width;
                                            AIP2_b1_hi_sell = HH;
                                            AIP2_b2_lo_sell = HH - 1.5 * width;
                                            AIP2_b2_hi_sell = HH - width;
                                            AIP2_fix_bar = bt;
                                            return true;
                                          }

                                          bool AIP2_GetBandsClosed10_50(
                                              int side, double &b1_lo,
                                              double &b1_hi, double &b2_lo,
                                              double &b2_hi) {
                                            if (!AIP2_ComputeBands_Closed10())
                                              return false;
                                            if (side > 0) {
                                              b1_lo = AIP2_b1_lo_buy;
                                              b1_hi = AIP2_b1_hi_buy;
                                              b2_lo = AIP2_b2_lo_buy;
                                              b2_hi = AIP2_b2_hi_buy;
                                            } else {
                                              b1_lo = AIP2_b1_lo_sell;
                                              b1_hi = AIP2_b1_hi_sell;
                                              b2_lo = AIP2_b2_lo_sell;
                                              b2_hi = AIP2_b2_hi_sell;
                                            }
                                            return true;
                                          }

                                          bool AIP2_ComputeBand1_Closed10() {
                                            int tf = AIP2_LTF();
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt == AIP2_dyn_bar)
                                              return true;
                                            int N = 10;
                                            int idxH = iHighest(
                                                Symbol(), tf, MODE_HIGH, N, 1);
                                            int idxL = iLowest(Symbol(), tf,
   MODE_LOW, N, 1);
                                            AIP2_c10_HH =
                                                iHigh(Symbol(), tf, idxH);
                                            AIP2_c10_LL =
                                                iLow(Symbol(), tf, idxL);
                                            double tr[];
                                            ArrayResize(tr, N);
                                            for (int i = 1; i <= N; i++) {
                                              double h = iHigh(Symbol(), tf, i),
                                                     l = iLow(Symbol(), tf, i),
                                                     pc = iClose(Symbol(), tf,
   i + 1);
                                              tr[i - 1] = MathMax(
                                                  h - l,
                                                  MathMax(MathAbs(h - pc),
                                                          MathAbs(l - pc)));
                                            }
                                            double tmp[];
                                            ArrayResize(tmp, N);
                                            for (int k = 0; k < N; k++)
                                              tmp[k] = tr[k];
                                            ArraySort(tmp, WHOLE_ARRAY, 0,
                                                      MODE_ASCEND);
                                            double med = tmp[N / 2];
                                            for (int j = 0; j < N; j++)
                                              tr[j] = MathAbs(tr[j] - med);
                                            double tmp2[];
                                            ArrayResize(tmp2, N);
                                            for (int k = 0; k < N; k++)
                                              tmp2[k] = tr[k];
                                            ArraySort(tmp2, WHOLE_ARRAY, 0,
                                                      MODE_ASCEND);
                                            double mad = tmp2[N / 2];
                                            double spr =
                                                MarketInfo(Symbol(),
                                                           MODE_SPREAD) *
                                                Point;
                                            double stp =
                                                MarketInfo(Symbol(),
                                                           MODE_STOPLEVEL) *
                                                Point;
                                            AIP2_c10_w =
                                                MathMax(mad, MathMax(spr, stp));
                                            AIP2_dyn_bar = bt;
                                            return true;
                                          }

                                          bool AIP2_GetBands_Closed10_Band2Dynamic(
                                              int side, double &b1_lo,
                                              double &b1_hi, double &b2_lo,
                                              double &b2_hi) {
                                            if (!AIP2_ComputeBand1_Closed10())
                                              return false;
                                            int tf = AIP2_LTF();
                                            double curH =
                                                       iHigh(Symbol(), tf, 0),
                                                   curL = iLow(Symbol(), tf, 0);
                                            double tr0 = MathMax(
                                                curH - curL,
                                                MathMax(
                                                    MathAbs(curH -
   iClose(Symbol(), tf,
   1)),
                                                    MathAbs(curL -
   iClose(Symbol(), tf,
   1))));
                                            double width2 =
                                                MathMax(AIP2_c10_w, tr0);
                                            if (side > 0) {
                                              b1_lo = AIP2_c10_LL;
                                              b1_hi = AIP2_c10_LL + AIP2_c10_w;
                                              b2_lo = b1_hi;
                                              b2_hi = b1_hi + 0.2 * width2;
                                            } else {
                                              b1_lo = AIP2_c10_HH - AIP2_c10_w;
                                              b1_hi = AIP2_c10_HH;
                                              b2_lo = b1_lo - 0.5 * width2;
                                              b2_hi = b1_lo;
                                            }
                                            return true;
                                          }

                                          bool AIP2_ComputeBand1_Closed20(
                                              int tf, double &LL20,
                                              double &HH20, double &width1) {
                                            int N = 20;
                                            int idxH =
                                                AIP2_iHighestClosed(tf, N);
                                            int idxL =
                                                AIP2_iLowestClosed(tf, N);
                                            HH20 = iHigh(Symbol(), tf, idxH);
                                            LL20 = iLow(Symbol(), tf, idxL);
                                            double tr[];
                                            ArrayResize(tr, N);
                                            for (int i = 1; i <= N; i++)
                                              tr[i - 1] = AIP2_TR_at(tf, i);
                                            double med = AIP2_MedianArr(tr, N);
                                            for (int j = 0; j < N; j++)
                                              tr[j] = MathAbs(tr[j] - med);
                                            double mad = AIP2_MedianArr(tr, N);
                                            double spr =
                                                MarketInfo(Symbol(),
                                                           MODE_SPREAD) *
                                                Point;
                                            double stp =
                                                MarketInfo(Symbol(),
                                                           MODE_STOPLEVEL) *
                                                Point;
                                            width1 =
                                                MathMax(mad, MathMax(spr, stp));
                                            return true;
                                          }

                                          bool AIP2_GetBands_Closed20_B2Dyn20(
                                              int side, int tf, double &b1_lo,
                                              double &b1_hi, double &b2_lo,
                                              double &b2_hi) {
                                            double LL20 = 0, HH20 = 0, w1 = 0;
                                            if (!AIP2_ComputeBand1_Closed20(
                                                    tf, LL20, HH20, w1))
                                              return false;
                                            double curH =
                                                       iHigh(Symbol(), tf, 0),
                                                   curL = iLow(Symbol(), tf, 0);
                                            double pc = iClose(Symbol(), tf, 1);
                                            double tr0 = MathMax(
                                                curH - curL,
                                                MathMax(MathAbs(curH - pc),
                                                        MathAbs(curL - pc)));
                                            double w2 = MathMax(w1, tr0);
                                            if (side > 0) {
                                              b1_lo = LL20;
                                              b1_hi = LL20 + w1;
                                            } else {
                                              b1_lo = HH20 - w1;
                                              b1_hi = HH20;
                                            }
                                            double LL21 = MathMin(LL20, curL);
                                            double HH21 = MathMax(HH20, curH);
                                            if (side > 0) {
                                              double base = b1_hi;
                                              b2_lo = base;
                                              b2_hi = base + 0.2 * w2;
                                              if (b2_hi > HH21)
                                                b2_hi = HH21;
                                            } else {
                                              double base = b1_lo;
                                              b2_hi = base;
                                              b2_lo = base - 0.2 * w2;
                                              if (b2_lo < LL21)
                                                b2_lo = LL21;
                                            }
                                            return true;
                                          }

                                          bool AIP2_TickSeq_Closed10_Band50() {
                                            int tf = AIP2_LTF();
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt != AIP2_c10_bar)
                                              AIP2_C10_Reset();
                                            if (!AIP2_ComputeBands_Closed10())
                                              return false;
                                            double px = AIP2_TickMid();
                                            // SELL side (pre-range break
                                            // must hold outside)
                                            double s1_lo = AIP2_b1_lo_sell,
                                                   s1_hi = AIP2_b1_hi_sell,
                                                   s2_lo = AIP2_b2_lo_sell,
                                                   s2_hi = AIP2_b2_hi_sell;
                                            if (!AIP2_c10_hit1_sell &&
                                                px >= MathMin(s1_lo, s1_hi) &&
                                                px <= MathMax(s1_lo, s1_hi))
                                              AIP2_c10_hit1_sell = true;
                                            if (AIP2_c10_hit1_sell) {
                                              if (!AIP2_c10_armed_sell) {
                                                // arm SELL STOP exactly at
                                                // Band2 lower edge (fixed
                                                // for the bar)
                                                double price = NormalizeDouble(
                                                    s2_lo, Digits);
                                                int slippage = Slippage;
                                                int type = OP_SELLSTOP;
                                                bool exists = false;
                                                for (int i = 0;
                                                     i < OrdersTotal(); i++) {
                                                  if (OrderSelect(
                                                          i, SELECT_BY_POS,
                                                          MODE_TRADES)) {
                                                    if (OrderSymbol() == Symbol() &&



                                                        OrderMagicNumber() == PredictedMagic &&



                                                        OrderType() == type) {
                                                      exists = true;
                                                      break;
                                                    }
                                                  }
                                                }
                                                if (!exists) {
                                                  SafeOrderSend(
                                                      Symbol(), type,
                                                      NormalizeDouble(
                                                          MarketInfo(
   Symbol(),
   MODE_MINLOT),
                                                          2),
                                                      price, slippage, 0, 0,
                                                      "AIP2-C10",
                                                      PredictedMagic, 0,
                                                      clrNONE);
                                                }
                                                AIP2_c10_armed_sell = true;
                                              }
                                              if (px <= s2_lo)
                                                AIP2_c10_hit2_sell = true;
                                            }
                                            // BUY side
                                            double b1_lo = AIP2_b1_lo_buy,
                                                   b1_hi = AIP2_b1_hi_buy,
                                                   b2_lo = AIP2_b2_lo_buy,
                                                   b2_hi = AIP2_b2_hi_buy;
                                            if (!AIP2_c10_hit1_buy &&
                                                px >= MathMin(b1_lo, b1_hi) &&
                                                px <= MathMax(b1_lo, b1_hi))
                                              AIP2_c10_hit1_buy = true;
                                            if (AIP2_c10_hit1_buy) {
                                              if (!AIP2_c10_armed_buy) {
                                                double price = NormalizeDouble(
                                                    b2_hi, Digits);
                                                int slippage = Slippage;
                                                int type = OP_BUYSTOP;
                                                bool exists = false;
                                                for (int i = 0;
                                                     i < OrdersTotal(); i++) {
                                                  if (OrderSelect(
                                                          i, SELECT_BY_POS,
                                                          MODE_TRADES)) {
                                                    if (OrderSymbol() == Symbol() &&



                                                        OrderMagicNumber() == PredictedMagic &&



                                                        OrderType() == type) {
                                                      exists = true;
                                                      break;
                                                    }
                                                  }
                                                }
                                                if (!exists) {
                                                  SafeOrderSend(
                                                      Symbol(), type,
                                                      NormalizeDouble(
                                                          MarketInfo(
   Symbol(),
   MODE_MINLOT),
                                                          2),
                                                      price, slippage, 0, 0,
                                                      "AIP2-C10",
                                                      PredictedMagic, 0,
                                                      clrNONE);
                                                }
                                                AIP2_c10_armed_buy = true;
                                              }
                                              if (px >= b2_hi)
                                                AIP2_c10_hit2_buy = true;
                                            }
                                            // Structural guards kept
                                            // externally in arming entry
                                            // point
                                            return (AIP2_c10_hit2_buy ||
                                                    AIP2_c10_hit2_sell);
                                          }

                                          void AIP2_ManageDualSides_T0_Closed10_B2Dyn() {
                                            int tf = AIP2_LTF();
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt != AIP2_live_bar)
                                              AIP2_ResetLiveState();
                                            if (!AIP2_IsImpulseLive())
                                              return;
                                            if (!AIP2_OTESeparationOK())
                                              return;
                                            if (!AIP2_TouchedBothOTE_LTF())
                                              return;
                                            bool sideBuyOK =
                                                AIP2_BreakPreRangeLive(+1);
                                            bool sideSelOK =
                                                AIP2_BreakPreRangeLive(-1);
                                            double vol = NormalizeDouble(
                                                MarketInfo(Symbol(),
                                                           MODE_MINLOT),
                                                2);
                                            double px =
                                                MarketInfo(Symbol(), MODE_BID);
                                            if (px <= 0)
                                              px = iClose(Symbol(), tf, 0);
                                            // SELL
                                            if (sideSelOK) {
                                              double s1_lo, s1_hi, s2_lo, s2_hi;
                                              if (AIP2_GetBands_Closed10_Band2Dynamic(
                                                      -1, s1_lo, s1_hi, s2_lo,
                                                      s2_hi)) {
                                                if (!AIP2_b1_hit_sell &&
                                                    px >=
                                                        MathMin(s1_lo, s1_hi) &&
                                                    px <= MathMax(s1_lo, s1_hi))
                                                  AIP2_b1_hit_sell = true;
                                                if (AIP2_b1_hit_sell) {
                                                  if (!AIP2_arm_sell) {
                                                    if (AIP2_EnsurePendingAtEdge(
   -1, s2_lo, s2_hi,
   vol))
                                                      AIP2_arm_sell = true;
                                                  }
                                                  if (px <= s2_lo)
                                                    AIP2_b2_hit_sell = true;
                                                }
                                              }
                                            }
                                            // BUY
                                            if (sideBuyOK) {
                                              double b1_lo, b1_hi, b2_lo, b2_hi;
                                              if (AIP2_GetBands_Closed10_Band2Dynamic(
                                                      +1, b1_lo, b1_hi, b2_lo,
                                                      b2_hi)) {
                                                if (!AIP2_b1_hit_buy &&
                                                    px >=
                                                        MathMin(b1_lo, b1_hi) &&
                                                    px <= MathMax(b1_lo, b1_hi))
                                                  AIP2_b1_hit_buy = true;
                                                if (AIP2_b1_hit_buy) {
                                                  if (!AIP2_arm_buy) {
                                                    if (AIP2_EnsurePendingAtEdge(
   +1, b2_lo, b2_hi,
   vol))
                                                      AIP2_arm_buy = true;
                                                  }
                                                  if (px >= b2_hi)
                                                    AIP2_b2_hit_buy = true;
                                                }
                                              }
                                            }
                                          }

                                          void AIP2_Manager_Closed20_B2Dyn20() {
                                            int tf = Period();
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt != AIP2_bar_state)
                                              AIP2_ResetBarState();
                                            // Requisiti: news ad alto
                                            // impatto + AI attivo +
                                            // confidenza sufficiente
                                            if (lastHighImpactNewsTime <= 0)
                                              return;
                                            if (!Predicted)
                                              return;
                                            double ai_conf =
                                                GetCurrentAISignalConfidence();
                                            if (ai_conf < AiPredMinConf)
                                              return;
                                            double vol = NormalizeDouble(
                                                MarketInfo(Symbol(),
                                                           MODE_MINLOT),
                                                2);
                                            double px = AIP2_Mid();
                                            // SELL side
                                            if (AIP2_PreRangeBreakLive(-1, tf,
   40)) {
                                              double s1_lo, s1_hi, s2_lo, s2_hi;
                                              if (AIP2_GetBands_Closed20_B2Dyn20(
                                                      -1, tf, s1_lo, s1_hi,
                                                      s2_lo, s2_hi)) {
                                                if (!AIP2_b1_sell &&
                                                    px >=
                                                        MathMin(s1_lo, s1_hi) &&
                                                    px <= MathMax(s1_lo, s1_hi))
                                                  AIP2_b1_sell = true;
                                                if (AIP2_b1_sell) {
                                                  if (!AIP2_arm_sell) {
                                                    if (AIP2_EnsurePendingAtEdge(
   -1,
   s2_lo, s2_hi, vol))
                                                      AIP2_arm_sell = true;
                                                  }
                                                  if (px <= s2_lo)
                                                    AIP2_b2_sell = true;
                                                }
                                              }
                                            }
                                            // BUY side
                                            if (AIP2_PreRangeBreakLive(+1, tf,
   40)) {
                                              double b1_lo, b1_hi, b2_lo, b2_hi;
                                              if (AIP2_GetBands_Closed20_B2Dyn20(
                                                      +1, tf, b1_lo, b1_hi,
                                                      b2_lo, b2_hi)) {
                                                if (!AIP2_b1_buy &&
                                                    px >=
                                                        MathMin(b1_lo, b1_hi) &&
                                                    px <= MathMax(b1_lo, b1_hi))
                                                  AIP2_b1_buy = true;
                                                if (AIP2_b1_buy) {
                                                  if (!AIP2_arm_buy) {
                                                    if (AIP2_EnsurePendingAtEdge(
   +1,
   b2_lo, b2_hi, vol))
                                                      AIP2_arm_buy = true;
                                                  }
                                                  if (px >= b2_hi)
                                                    AIP2_b2_buy = true;
                                                }
                                              }
                                            }
                                          }

int CountOpenOrders(int magic = 0) {
                                            // FASE 8 FIX: include ANCHE i
                                            // pending (LIMIT/STOP) per
                                            // garantire che
                                            // MaxOpenTradesPerStrat non venga
                                            // bypassato dai pending vivi che
                                            // poi diventano live trade.
                                            string sym = Symbol();
                                            int cnt = 0;
                                            for (int i = 0; i < OrdersTotal();
                                                 i++) {
                                              if (!OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES))
                                                continue;
                                              if (OrderSymbol() != sym)
                                                continue;
                                              if (magic != 0 &&
                                                  OrderMagicNumber() != magic)
                                                continue;
                                              int _ot = OrderType();
                                              // OP_BUY (0), OP_SELL (1),
                                              // OP_BUYLIMIT (2), OP_SELLLIMIT (3),
                                              // OP_BUYSTOP (4), OP_SELLSTOP (5)
                                              if (_ot >= OP_BUY && _ot <= OP_SELLSTOP)
                                                cnt++;
                                            }
                                            return cnt;
                                          }

                                          bool CanOpenTrade() {
                                            return IsSafeToTrade() &&
                                                   !IsDuplicateOrder(
                                                       OP_BUY,
                                                       ObliviousAiMagic) &&
                                                   !IsDuplicateOrder(
                                                       OP_SELL,
                                                       ObliviousAiMagic);
                                          }

                                          bool Strategy_MaxPositionsReached(
                                              int magic, string symbol,
                                              int maxPos) {
                                            return OrderManager_CountByMagic(
                                                       magic, symbol) >= maxPos;
                                          }

                                          void Strategy_AI_Execute(
                                              string symbol, int dir) {
                                            int magic = PredictedMagic;
                                            if (Strategy_MaxPositionsReached(
                                                    magic, symbol, 2))
                                              return;

                                            double sl, tp;

                                            //--- Try AI-provided TP/SL ---
                                            double aiTP =
                                                AIBridge_GetVirtualTP();
                                            double aiSL =
                                                AIBridge_GetVirtualSL();

                                            if (aiTP > 0 && aiSL > 0) {
                                              tp = aiTP;
                                              sl = aiSL;
                                            } else {
                                              //--- Try OTE-based SL/TP ---
                                              double oteLo = 0, oteHi = 0;
                                              if (AIP2_GetOTEBands(
                                                      Period(), dir > 0, oteLo,
                                                      oteHi)) {
                                                double entry =
                                                    (dir > 0)
                                                        ? MarketInfo(symbol,
   MODE_ASK)
                                                        : MarketInfo(symbol,
   MODE_BID);
                                                double buf =
                                                    AIP2_InnerBufLive();
                                                sl = (dir > 0) ? oteLo - buf
   : oteHi + buf;
                                                double risk =
                                                    MathAbs(entry - sl);
                                                tp = (dir > 0)
                                                         ? entry + risk * 2.5
                                                         : entry - risk * 2.5;
                                              } else {
                                                tp = Strategy_CalcTP(symbol,
   dir, 2.5);
                                                sl = Strategy_CalcSL(symbol,
   dir, 1.5);
                                              }
                                            }

                                            double slPips = PriceToPips(
                                                symbol,
                                                MathAbs(
                                                    (dir == OP_BUY
                                                         ? MarketInfo(symbol,
   MODE_ASK)
                                                         : MarketInfo(
   symbol,
   MODE_BID)) -
                                                    sl));
                                            double lots = Strategy_ComputeLots(
                                                symbol, RiskPercent, slPips);

                                            int ticket = OrderManager_Send(
                                                symbol, dir, lots, sl, tp,
                                                magic, "Predicted");

                                            if (ticket >= 0) {
                                              // Register virtual TP/SL if
                                              // in virtual mode
                                              double aiTrail =
                                                  AIBridge_GetVirtualTrail();
                                              if (VirtualTPSL_IsActive() &&
                                                  (aiTP > 0 || aiSL > 0))
                                                VirtualTPSL_Register(
                                                    ticket, symbol, dir, aiTP,
                                                    aiSL, aiTrail);

                                              // Killzone bonus logging
                                              string kzInfo =
                                                  ICT_InAnyKillzone() ? " [KZ]"
   : "";
                                              PrintFormat(
                                                  "[Strategy_AI] ENTERED "
                                                  "%s %s | Conf: %.2f%% | "
                                                  "Ticket: %d%s",
                                                  symbol,
                                                  (dir == OP_BUY ? "BUY"
   : "SELL"),
                                                  AIBridge_GetConfidence() *
                                                      100,
                                                  ticket, kzInfo);
                                            }
                                          }

// All non-owner pattern detectors (engulfing/MACD trend confluence,
// candlestick patterns, structure / liquidity / FVG patterns) live in the
// Pattern Engine and contribute only to g_pat_consensus /
// g_pat_bull_count / g_pat_bear_count via DispatchPatternStrategies().
// Owner strategies (Predicted / Breakout / FVG / Grid / SMC / ICT /
// Reverse) are the only paths that may open trades.

                                          void Strategy_Breakout_Execute(
                                              string symbol, int dir) {
                                            int magic = BreakoutMagic;
                                            if (Strategy_MaxPositionsReached(
                                                    magic, symbol, 2))
                                              return;

                                            double atr = iATR(symbol, 0, 14, 0);
                                            double tp = Strategy_CalcTP(
                                                symbol, dir,
                                                3.0); // Wide TP for
                                            // breakouts
                                            double sl = Strategy_CalcSL(
                                                symbol, dir, 1.5);

                                            double slPips = PriceToPips(
                                                symbol,
                                                MathAbs(
                                                    (dir == OP_BUY
                                                         ? MarketInfo(symbol,
   MODE_ASK)
                                                         : MarketInfo(
   symbol,
   MODE_BID)) -
                                                    sl));
                                            double lots = Strategy_ComputeLots(
                                                symbol, RiskPercent, slPips);

                                            int ticket = OrderManager_Send(
                                                symbol, dir, lots, sl, tp,
                                                magic, "Breakout");
                                            if (ticket >= 0 &&
                                                VirtualTPSL_IsActive())
                                              VirtualTPSL_Register(
                                                  ticket, symbol, dir, tp, sl,
                                                  atr * 2.0);
                                          }

                                          void Strategy_Emperor_Execute(
                                              string symbol, int dir) {
                                              return; // Max 1 position

                                            // Emperor uses tight SL and
                                            // wide TP (high RRR ÃƒÃ‚Â¢—°ÃƒÃ‚Â¥ 3:1)
                                            double tp = Strategy_CalcTP(
                                                symbol, dir, 4.0);
                                            double sl = Strategy_CalcSL(
                                                symbol, dir, 1.2);

                                            double slPips = PriceToPips(
                                                symbol,
                                                MathAbs(
                                                    (dir == OP_BUY
                                                         ? MarketInfo(symbol,
   MODE_ASK)
                                                         : MarketInfo(
   symbol,
   MODE_BID)) -
                                                    sl));
                                            double lots = Strategy_ComputeLots(
                                                symbol, RiskPercent * 1.5,
                                                slPips); // Slightly
                                            // higher risk
                                            // for
                                            // high-conviction

                                            int ticket = OrderManager_Send(
                                                symbol, dir, lots, sl, tp,
                                                SMCMagic, "SMC");
                                            if (ticket > 0) {
                                              VirtualTPSL_Register(
                                                  ticket, symbol, dir, tp, sl,
                                                  iATR(symbol, 0, 14, 0) * 1.0);
                                              PrintFormat("[SMC_ICT] %s %s ticket=%d",
                                                  symbol,
                                                  (dir == OP_BUY ? "BUY" : "SELL"),
                                                  ticket);
                                            }
                                          }

                                          void Strategy_FVG_Execute(
                                              string symbol, int dir) {
                                            int magic = FVGMagic;
                                            if (Strategy_MaxPositionsReached(
                                                    magic, symbol, 2))
                                              return;

                                            double atr = iATR(symbol, 0, 14, 0);
                                            double tp, sl;

                                            //--- Try ICT-based SL/TP ---
                                            ADV_FVG_ZONE
                                            fvg;
                                            ADV_OB_ZONE
                                            ob;
                                            bool hasFVG = ADV_FindFVG_Pro(
                                                Period(), dir, 30, false, fvg,
                                                ob);

                                            if (hasFVG && ob.valid) {
                                              // SL behind the OB, TP at 2.5
                                              // R:R
                                              sl = (dir > 0)
                                                       ? ob.bot - atr * 0.2
                                                       : ob.top + atr * 0.2;
                                              double entry =
                                                  (dir > 0)
                                                      ? MarketInfo(symbol,
   MODE_ASK)
                                                      : MarketInfo(symbol,
   MODE_BID);
                                              double risk = MathAbs(entry - sl);
                                              tp = (dir > 0)
                                                       ? entry + risk * 2.5
                                                       : entry - risk * 2.5;
                                            } else {
                                              tp = Strategy_CalcTP(symbol, dir,
   2.0);
                                              sl = Strategy_CalcSL(symbol, dir,
   1.0);
                                            }

                                            double slPips = PriceToPips(
                                                symbol,
                                                MathAbs(
                                                    (dir == OP_BUY
                                                         ? MarketInfo(symbol,
   MODE_ASK)
                                                         : MarketInfo(
   symbol,
   MODE_BID)) -
                                                    sl));
                                            double lots = Strategy_ComputeLots(
                                                symbol, RiskPercent, slPips);

                                            int ticket = OrderManager_Send(
                                                symbol, dir, lots, sl, tp,
                                                magic, "FVG");
                                            if (ticket >= 0 &&
                                                VirtualTPSL_IsActive())
                                              VirtualTPSL_Register(ticket,
   symbol, dir,
   tp, sl, atr);
                                          }

                                          void Strategy_Reverse_Execute(
                                              string symbol, int dir) {
                                            int magic = ReverseMagic;
                                            if (Strategy_MaxPositionsReached(
                                                    magic, symbol, 2))
                                              return;

                                            // Mean reversion: TP at BB
                                            // middle, SL at 2x ATR
                                            int idx =
                                                IndicatorManager_FindSymbol(
                                                    symbol);
                                            double bbMid =
                                                (idx >= 0)
                                                    ? g_indCache[idx].bbMiddle
                                                    : 0;

                                            double tp, sl;
                                            if (bbMid > 0) {
                                              tp = NormalizeDouble(bbMid,
   Digits);
                                              sl = Strategy_CalcSL(symbol, dir,
   2.0);
                                            } else {
                                              tp = Strategy_CalcTP(symbol, dir,
   1.5);
                                              sl = Strategy_CalcSL(symbol, dir,
   2.0);
                                            }

                                            double slPips = PriceToPips(
                                                symbol,
                                                MathAbs(
                                                    (dir == OP_BUY
                                                         ? MarketInfo(symbol,
   MODE_ASK)
                                                         : MarketInfo(
   symbol,
   MODE_BID)) -
                                                    sl));
                                            double lots = Strategy_ComputeLots(
                                                symbol, RiskPercent * 0.75,
                                                slPips); // Reduced risk
                                            // for
                                            // reversals

                                            int ticket = OrderManager_Send(
                                                symbol, dir, lots, sl, tp,
                                                magic, "Reverse");
                                            if (ticket >= 0 &&
                                                VirtualTPSL_IsActive())
                                              VirtualTPSL_Register(ticket,
   symbol, dir,
   tp, sl, 0);
                                          }

                                          void Strategy_SMC_Execute(
                                              string symbol, int dir) {
                                            int magic = SMCMagic;
                                            if (Strategy_MaxPositionsReached(
                                                    magic, symbol, 2))
                                              return;

                                            double atr = iATR(symbol, 0, 14, 0);
                                            double tp, sl;

                                            //--- Try ICT-based SL/TP from
                                            // confluence ---
                                            ICT_SCORE_RESULT
                                            res;
                                            double score =
                                                ICT_ComputeConfluence(dir, 40,
   res);

                                            if (res.hasOB) {
                                              // SL behind the OB zone
                                              sl = (dir > 0)
                                                       ? res.ob.bot - atr * 0.3
                                                       : res.ob.top + atr * 0.3;
                                              tp = Strategy_CalcTP(
                                                  symbol, dir,
                                                  3.0); // Better R:R with
                                              // ICT
                                            } else {
                                              tp = Strategy_CalcTP(symbol, dir,
   2.5);
                                              sl = Strategy_CalcSL(symbol, dir,
   1.2);
                                            }

                                            double slPips = PriceToPips(
                                                symbol,
                                                MathAbs(
                                                    (dir == OP_BUY
                                                         ? MarketInfo(symbol,
   MODE_ASK)
                                                         : MarketInfo(
   symbol,
   MODE_BID)) -
                                                    sl));
                                            double lots = Strategy_ComputeLots(
                                                symbol, RiskPercent, slPips);

                                            int ticket = OrderManager_Send(
                                                symbol, dir, lots, sl, tp,
                                                magic, "SMC");
                                            if (ticket >= 0 &&
                                                VirtualTPSL_IsActive())
                                              VirtualTPSL_Register(
                                                  ticket, symbol, dir, tp, sl,
                                                  atr * 1.5);
                                          }

                                          void StrategyArbitration_Execute(
                                              int stratId, string symbol,
                                              int dir) {
                                            // PATCH I (DEPRECATED): arbitration
                                            // chiamava Strategy_*_Execute con
                                            // OrderManager_Send -> market
                                            // diretto, bypassando il LIMIT-first
                                            // delle 5 owner non-grid/predicted.
                                            // Predicted resta market (hub-driven)
                                            // ma e' gestito da DispatchPredicted
                                            // Strategy. Le altre passano da
                                            // Strategy_*_Logic() (LIMIT-first).
                                            if (stratId == STRAT_PREDICTED) {
                                              Strategy_AI_Execute(symbol, dir);
                                            }
                                            // FVG/SMC/ICT/Reverse/Breakout:
                                            // intentional no-op qui. La logica
                                            // owner LIMIT-first vive dentro le
                                            // rispettive *_Logic() chiamate dal
                                            // dispatcher principale di OnTick.
                                          }

                                          bool Arb_HasOpposingPosition(
                                              string symbol, int dir,
                                              int stratId) {
                                            for (int i = OrdersTotal() - 1;
                                                 i >= 0; i--) {
                                              if (!OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES))
                                                continue;
                                              if (OrderSymbol() != symbol)
                                                continue;
                                              if (OrderType() > OP_SELL)
                                                continue;

                                              string cmnt = OrderComment();
                                              if (StringFind(
                                                      cmnt, OM_COMMENT_PREFIX) <
                                                  0)
                                                continue;

                                              // Check if opposing direction
                                              if (dir == OP_BUY &&
                                                  OrderType() == OP_SELL)
                                                return true;
                                              if (dir == OP_SELL &&
                                                  OrderType() == OP_BUY)
                                                return true;
                                            }
                                            return false;
                                          }

                                          void ManageGridPositions() {
                                            // FASE 9 (Patch 3): DEPRECATED.
                                            // Sostituita da Grid_AutoAverage
                                            // (FASE 6.2) che apre nuovi
                                            // livelli con trigger ATR-based
                                            // + DD guards.
                                            return;
                                          }

                                          // void OrderOpenTime(); // removed - conflicts with built-in

                                            double __SMC_ClosePos(int shift) {
                                              double h = High[shift],
                                                     l = Low[shift];
                                              double rng = h - l;
                                              if (rng <= 0.0)
                                                return (0.0);
                                              return ((Close[shift] - l) / rng);
                                            }

                                            // Robust stats: median + MAD della
                                            // close-position [0..1] su lookback
                                            // dinamico

                                            void __SMC_ClosePosStats(
                                                int lookback, double &med,
                                                double &mad) {
                                              int lb = lookback;
                                              if (lb <= 0) {
                                                med = 0.0;
                                                mad = 0.0;
                                                return;
                                              }
                                              lb = MathMin(lb, Bars - 1);
                                              if (lb <= 1) {
                                                med = __SMC_ClosePos(1);
                                                mad = 0.0;
                                                return;
                                              }

                                              double arr[];
                                              ArrayResize(arr, lb);
                                              ArrayInitialize(arr, 0.0);
                                              for (int i = 0; i < lb; i++)
                                                arr[i] = __SMC_ClosePos(i + 1);

                                              ArraySort(arr, WHOLE_ARRAY, 0,
                                                        MODE_ASCEND);
                                              int mid = lb / 2;
                                              med = (lb % 2 == 0)
                                                        ? (arr[mid - 1] +
                                                           arr[mid]) /
   2.0
                                                        : arr[mid];

                                              // MAD
                                              for (int j = 0; j < lb; j++)
                                                arr[j] = MathAbs(arr[j] - med);

                                              ArraySort(arr, WHOLE_ARRAY, 0,
                                                        MODE_ASCEND);
                                              mad = (lb % 2 == 0)
                                                        ? (arr[mid - 1] +
                                                           arr[mid]) /
   2.0
                                                        : arr[mid];
                                            }




// OpenBuy / OpenSell: no-arg strategy wrappers for Predicted
bool OpenBuy()
{
   double lot = DynamicLotSize();
   double atr = iATR(Symbol(), 0, 14, 1);
   if (atr <= 0.0) return false;
   double sl = NormalizePrice(Bid - atr * 1.5);
   double tp = NormalizePrice(Bid + atr * 2.0);
   return OpenTrade(OP_BUY, lot, sl, tp);
}

bool OpenSell()
{
   double lot = DynamicLotSize();
   double atr = iATR(Symbol(), 0, 14, 1);
   if (atr <= 0.0) return false;
   double sl = NormalizePrice(Ask + atr * 1.5);
   double tp = NormalizePrice(Ask - atr * 2.0);
   return OpenTrade(OP_SELL, lot, sl, tp);
}

void DrawHLine_TP(string prefix, double price)
{
      DrawHLine(prefix + "_TP", price, clrWhite, STYLE_DASH, 1);
}

void Overlay_DrawTPSL_Segments(const int segBars = 16, const int segOffsetStep = 2)
{
      // cleanup previous overlay objects
      for (int i = ObjectsTotal(0, -1, -1) - 1; i >= 0; --i) {
        string oid = ObjectName(0, i);
        if (StringFind(oid, "OVSEG_", 0) == 0)
          ObjectDelete(0, oid);
      }
      // 7 canonical strategies map
      string names[7] = {
          "Predicted", "Grid",    "Breakout",
          "FVG",       "SMC", "ICT", "Reverse"};
      int magics[7];
      magics[0] = PredictedMagic;        // Predicted
      magics[1] = GridMagic;             // Grid
      magics[2] = BreakoutMagic;         // Breakout
      magics[3] = FVGMagic;     // FVG
      magics[4] = SMCMagic; // SMC
      magics[5] = ICTMagic; // ICT
      magics[6] = ReverseMagic;          // Reverse
      int secs = PeriodSeconds();
      // simple ATR for vertical offset
      int per = 14;
      double atr = 0.0;
      for (int b = 0; b < per; ++b) {
        double hi = iHigh(Symbol(), 0, b), lo = iLow(Symbol(), 0, b),
               pc = iClose(Symbol(), 0, b + 1);
        double tr =
            MathMax(hi - lo, MathMax(MathAbs(hi - pc), MathAbs(lo - pc)));
        atr += tr;
      }
      atr = (per > 0 ? atr / per : 0.0);
      double dy = atr * 0.25;
      int drawnCount[6];
      ArrayInitialize(drawnCount, 0);
      for (int pos = OrdersTotal() - 1; pos >= 0; --pos) {
        if (!OrderSelect(pos, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        int m = OrderMagicNumber();
        int idx = -1;
        for (int k = 0; k < 6; k++) {
          if (m == magics[k]) {
            idx = k;
            break;
          }
        }
        if (idx < 0)
          continue;
        string sname = names[idx];
        int ticket = OrderTicket();
        double tp = OrderTakeProfit();
        double sl = OrderStopLoss();
        int modeAI = TPSL_CurrentMode();
        TPSL_LogModeIfChanged();
        int srcCode = 0;
        int aiSrc = 0, natSrc = 0;
        double init_tp = tp, init_sl = sl;
        if (modeAI == 1) {
          // AI mode: only AI virtual sources
          tp = 0;
          sl = 0;
          AI_QueryVirtualTPSL(m, ticket, Symbol(), sname, tp, sl, aiSrc);
          srcCode = aiSrc;
        } else {
          // Native mode: prefer native virtual, then order, then points
          Native_QueryVirtualTPSL(m, ticket, Symbol(), sname, tp, sl, natSrc);
          if (natSrc > 0)
            srcCode = natSrc;
          else if (init_tp > 0 || init_sl > 0)
            srcCode = 5; // ORDER
        }
        if (srcCode == 0) {
          // The legacy `AI_InternalPointsToPrice()` helper was never
          // implemented; the POINTS source path stays inert and srcCode
          // simply remains 0 if no Native/AI/ORDER source resolved.
          // Hub-driven REFINE_TPSL (R7) is now the canonical path for
          // dynamic TP/SL refinement.
        }
        // Log source changes per ticket (dedup)
        string gvkey = StringFormat("OVSRC_%d", ticket);
        double last = -1;
        if (!GlobalVariableCheck(gvkey))
          GlobalVariableSet(gvkey, -1);
        last = GlobalVariableGet(gvkey);
        if ((int)last != srcCode && srcCode > 0) {
          GlobalVariableSet(gvkey, srcCode);
          string srcTag = TPSL_SourceTag(srcCode);
          AddToSmartLog(StringFormat("[TPSL] SOURCE=%s | TICKET=%d | %s", srcTag,
                              ticket, sname));
        }
        // segment time window aligned to the right edge
        int offsetBars = drawnCount[idx] * segOffsetStep;
        datetime t2 = Time[0] - secs * offsetBars;
        datetime t1 = t2 - secs * segBars;
        datetime tm = (datetime)(t1 + (t2 - t1) / 2);
        color col = RGB_Current();
        if (tp > 0.0) {
          string id = StringFormat("OVSEG_TP_%d_%d", m, ticket);
          ObjectCreate(0, id, OBJ_TREND, 0, t1, tp, t2, tp);
          ObjectSetInteger(0, id, OBJPROP_STYLE, STYLE_DASH);
          ObjectSetInteger(0, id, OBJPROP_WIDTH, 2);
          ObjectSetInteger(0, id, OBJPROP_COLOR, col);
          ObjectSetInteger(0, id, OBJPROP_BACK, false);
          string tpid = StringFormat("OVSEG_TXT_TP_%d_%d", m, ticket);
          ObjectCreate(0, tpid, OBJ_TEXT, 0, t2, tp + dy);
          ObjectSetInteger(0, tpid, OBJPROP_COLOR, col);
          ObjectSetString(0, tpid, OBJPROP_FONT, "Arial");
          ObjectSetInteger(0, tpid, OBJPROP_FONTSIZE, 7);
          ObjectSetString(0, tpid, OBJPROP_TEXT, "TP");
          string nm = StringFormat("OVSEG_TXT_TPNAME_%d_%d", m, ticket);
          ObjectCreate(0, nm, OBJ_TEXT, 0, tm, tp);
          ObjectSetInteger(0, nm, OBJPROP_COLOR, col);
          ObjectSetString(0, nm, OBJPROP_FONT, "Arial");
          ObjectSetInteger(0, nm, OBJPROP_FONTSIZE, 7);
          ObjectSetString(0, nm, OBJPROP_TEXT, sname);
        }
        if (sl > 0.0) {
          string id2 = StringFormat("OVSEG_SL_%d_%d", m, ticket);
          ObjectCreate(0, id2, OBJ_TREND, 0, t1, sl, t2, sl);
          ObjectSetInteger(0, id2, OBJPROP_STYLE, STYLE_DASH);
          ObjectSetInteger(0, id2, OBJPROP_WIDTH, 2);
          ObjectSetInteger(0, id2, OBJPROP_COLOR, col);
          ObjectSetInteger(0, id2, OBJPROP_BACK, false);
          string slid = StringFormat("OVSEG_TXT_SL_%d_%d", m, ticket);
          ObjectCreate(0, slid, OBJ_TEXT, 0, t2, sl - dy);
          ObjectSetInteger(0, slid, OBJPROP_COLOR, col);
          ObjectSetString(0, slid, OBJPROP_FONT, "Arial");
          ObjectSetInteger(0, slid, OBJPROP_FONTSIZE, 7);
          ObjectSetString(0, slid, OBJPROP_TEXT, "SL");
          string nm2 = StringFormat("OVSEG_TXT_SLNAME_%d_%d", m, ticket);
          ObjectCreate(0, nm2, OBJ_TEXT, 0, tm, sl);
          ObjectSetInteger(0, nm2, OBJPROP_COLOR, col);
          ObjectSetString(0, nm2, OBJPROP_FONT, "Arial");
          ObjectSetInteger(0, nm2, OBJPROP_FONTSIZE, 7);
          ObjectSetString(0, nm2, OBJPROP_TEXT, sname);
        }
        drawnCount[idx]++;
      }
}

void ClearTPSLOverlay()
{
      int total = ObjectsTotal(0, -1, -1);
      for (int i = total - 1; i >= 0; --i) {
        string nm = ObjectName(0, i);
        if (StringFind(nm, "TPSL_", 0) == 0)
          ObjectDelete(0, nm);
      }
}

void UpdateTPSLOverlay()
{
      if (!TriggerPanel) {
        ClearTPSLOverlay();
        return;
      }
      if (Bars < 6)
        return;
      int dir = ComputeModeDrivenBiasOverlay();
      if (dir == 0) {
        ClearTPSLOverlay();
        return;
      }
      // Horizontal span: from start of bar[5] to END of bar[0]
      datetime tL = Time[5];
      datetime tR = BarEndTime(0);
      // Vertical span: exact wicks (max/min) across the 6-bar window
      int hiIdx = iHighest(Symbol(), Period(), MODE_HIGH, 6, 0);
      int loIdx = iLowest(Symbol(), Period(), MODE_LOW, 6, 0);
      double hi6 = High[hiIdx];
      double lo6 = Low[loIdx];
      // Visual baseline: mid price; does not require an open order
      double base = (Bid + Ask) * 0.5;
      // Colors with simulated ~60% transparency
      color bg = (color)ChartGetInteger(0, CHART_COLOR_BACKGROUND, 0);
      ChartSetInteger(0, CHART_COLOR_GRID, bg);
      ChartSetInteger(0, CHART_COLOR_ASK, clrBlack);
      ChartSetInteger(0, CHART_COLOR_STOP_LEVEL, clrBlack);
      ChartSetInteger(0, CHART_COLOR_VOLUME, clrBlack);
      ChartSetInteger(0, CHART_COLOR_CHART_LINE, clrBlack);
ChartSetInteger(0, CHART_COLOR_GRID, bg);
ChartSetInteger(0, CHART_COLOR_CANDLE_BULL, clrBlack);
ChartSetInteger(0, CHART_COLOR_CANDLE_BEAR, clrBlack);
color col = AccentColor();
ChartSetInteger(0, CHART_COLOR_CHART_UP, col);
ChartSetInteger(0, CHART_COLOR_CHART_DOWN, col);
ChartSetInteger(0, CHART_COLOR_FOREGROUND, col);
ChartSetInteger(0, CHART_COLOR_CANDLE_BULL, clrBlack);
ChartSetInteger(0, CHART_COLOR_CANDLE_BEAR, clrBlack);
   color tpClr = BlendToBG(AccentColor(), bg, 0.60);
   color slClr = BlendToBG(clrRed,          bg, 0.60);
   double tpTop, tpBot, slTop, slBot;
   if(dir > 0) { // BUY: TP up to hi6; SL down to lo6
        tpTop = MathMax(hi6, base);
        tpBot = base;
        slTop = base;
        slBot = MathMin(lo6, base);
   } else {      // SELL: TP down to lo6; SL up to hi6
        tpTop = base;
        tpBot = MathMin(lo6, base);
        slTop = MathMax(hi6, base);
        slBot = base;
   }
   string NTP = "TPSL_TP_RECT_PANEL";
   string NSL = "TPSL_SL_RECT_PANEL";
   // Create / update TP rectangle
   if(ObjectFind(0, NTP) < 0)  ObjectCreate(0, NTP, OBJ_RECTANGLE, 0, tL, tpTop, tR, tpBot);
   else {
        ObjectSetInteger(0, NTP, OBJPROP_TIME, 0, tL);
        ObjectSetInteger(0, NTP, OBJPROP_TIME, 1, tR);
        ObjectSetDouble(0, NTP, OBJPROP_PRICE, 0, tpTop);
        ObjectSetDouble(0, NTP, OBJPROP_PRICE, 1, tpBot);
   }
   ObjectSetInteger(0, NTP, OBJPROP_COLOR, tpClr);
   ObjectSetInteger(0, NTP, OBJPROP_STYLE, STYLE_SOLID);
   ObjectSetInteger(0, NTP, OBJPROP_WIDTH, 1);
   ObjectSetInteger(0, NTP, OBJPROP_BACK,  true);
   // Create / update SL rectangle
   if(ObjectFind(0, NSL) < 0)  ObjectCreate(0, NSL, OBJ_RECTANGLE, 0, tL, slTop, tR, slBot);
   else {
        ObjectSetInteger(0, NSL, OBJPROP_TIME, 0, tL);
        ObjectSetInteger(0, NSL, OBJPROP_TIME, 1, tR);
        ObjectSetDouble(0, NSL, OBJPROP_PRICE, 0, slTop);
        ObjectSetDouble(0, NSL, OBJPROP_PRICE, 1, slBot);
   }
   ObjectSetInteger(0, NSL, OBJPROP_COLOR, slClr);
   ObjectSetInteger(0, NSL, OBJPROP_STYLE, STYLE_SOLID);
   ObjectSetInteger(0, NSL, OBJPROP_WIDTH, 1);
   ObjectSetInteger(0, NSL, OBJPROP_BACK,  true);
   ChartRedraw();
}

int GetAdaptiveSlippagePoints() {
      // Base floor/ceiling
      int floorPts = 3; // never below 0.3 pip on 5-digit
      int ceilPts = 30; // never above 3 pips on 5-digit
      // Current spread in points
      int spr =  (int)(MarketInfo(Symbol(), MODE_SPREAD));
      if (spr <= 0)
        spr = 10;
      // Volatility proxy: ATR(14) on base TF in points
      int tf = Use_TF();
      double atr = iATR(Symbol(), tf, Auto_ATR_Period(), 0);
      double atrPts = (atr > 0 ? atr / Point : spr);
      // Mode scaling
      double modeK = 1.0;
      if (Mode == Aggressive)
        modeK = 1.4;
      else if (Mode == Conservative)
        modeK = 0.8;
      // Market speed proxy: recent tick range (fallback simple)
      double lastH = iHigh(Symbol(), tf, 0);
      double lastL = iLow(Symbol(), tf, 0);
      double barRangePts = ((lastH - lastL) / Point);
      if (barRangePts <= 0)
        barRangePts = atrPts;
      // Base from spread and volatility
      double base = spr * 1.0;            // at least equal to current spread
      double volAdj = 0.15 * barRangePts; // add 15% of current bar range
      double raw = (base + volAdj) * modeK;
      // Clamp
      int slip = (int)MathRound(raw);
      if (slip < floorPts)
        slip = floorPts;
      if (slip > ceilPts)
        slip = ceilPts;
      return slip;
}

