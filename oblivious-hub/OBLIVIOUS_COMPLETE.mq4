bool IsPivots() {
      double h = iHigh(NULL, PERIOD_D1, 1), l = iLow(NULL, PERIOD_D1, 1),
             c = iClose(NULL, PERIOD_D1, 1);
      double pivot = (h + l + c) / 3.0;
      return (iClose(NULL, 0, 0) > pivot);
}

bool IsQQE() {
      double rsi0 = iRSI(NULL, 0, 14, PRICE_CLOSE, 0),
             rsi1 = iRSI(NULL, 0, 14, PRICE_CLOSE, 1);
      double emaRSI = rsi0 * 0.2 + rsi1 * 0.8;      // simple EMA smooth
      double atrRSI = MathAbs(rsi0 - rsi1) * 4.236; // Wilders multiplier
      static double trail = 50;                     // trailing level
      if (emaRSI > trail)
        trail = MathMax(trail, emaRSI - atrRSI);
      else
        trail = MathMin(trail, emaRSI + atrRSI);
      return (emaRSI > trail);
}

bool IsReflex() {
      int n = 20;
      if (Bars < n + 2)
        return false;
      double sum = 0;
      for (int i = 1; i <= n; i++)
        sum += iClose(NULL, 0, 0) - iClose(NULL, 0, i);
      double reflex = sum / n; // average price change over lookback
      return (reflex > 0);
}

