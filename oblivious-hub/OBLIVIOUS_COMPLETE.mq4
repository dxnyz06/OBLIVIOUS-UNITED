bool IsFibo() {
      int hBar = iHighest(NULL, 0, MODE_HIGH, 50, 0),
          lBar = iLowest(NULL, 0, MODE_LOW, 50, 0);
      double h = iHigh(NULL, 0, hBar), l = iLow(NULL, 0, lBar);
      double fib382 = h - (h - l) * 0.382;
      return (iClose(NULL, 0, 0) > fib382);
}

