      return g_exposure[idx].totalLots;
}

double ExposureManager_GetBuyLots(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].buyLots;
}

double ExposureManager_GetSellLots(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].sellLots;
}

double ExposureManager_GetUnrealizedPnL(string symbol)
{
