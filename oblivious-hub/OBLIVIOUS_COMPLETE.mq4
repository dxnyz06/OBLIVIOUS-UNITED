                                          int AIBC_GetMode() {
                                            double med = __AIBC_MedianAbsRet(),
                                                   mad = __AIBC_MADAbsRet(),
                                                   cur = __AIBC_AbsReturns(0);
                                            if (mad <= 0)
                                              return 1;
                                            if (cur > med + mad)
                                              return 0;
                                            if (cur < med - mad)
                                              return 2;
                                            return 1;
                                          }

