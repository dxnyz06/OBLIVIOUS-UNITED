bool UI_EnableGrid() { return Grid; }
bool UI_EnableBreakout() { return Breakout; }

bool UI_EnableSMC() { return SMC; }
bool UI_EnableICT() { return ICT; }
bool UI_EnableReverse() { return Reverse; }

// GetStrategyLot: all non-Grid strategies use ManualLot (no auto-sizing)
double GetStrategyLot(string strategy = "") {
   return NormalizeLotToMarket(Active_ManualLot()); }

bool __AP_ChallengeMaxDDReached(double maxDDPct) {
   double eq = AccountEquity(), bal = AccountBalance();
   if (bal <= 0) return false;
   double dd = (bal - eq) / bal * 100.0;
   return (dd >= maxDDPct); }

double BayesianSuperTrendFilter(int atrPeriod = 10, double atrMult = 3.0,
                                int maPeriod = 50, double prior = 0.5, double thresh = 0.65) {
   double atr = iATR(Symbol(), Period(), atrPeriod, 0);
   if (atr <= 0) return 0.0;
   double ma = iMA(Symbol(), Period(), maPeriod, 0, MODE_SMA, PRICE_CLOSE, 0);
   double price = Close[0];
   if (price > ma + atrMult * atr) return 1.0;
   if (price < ma - atrMult * atr) return -1.0;
   return 0.0;
}

int GetTrendDirection(ENUM_TIMEFRAMES tf = PERIOD_CURRENT) {
   double atr = iATR(Symbol(), tf, 14, 0);
   if (atr <= 0) return 0;
   double ma = iMA(Symbol(), tf, 50, 0, MODE_SMA, PRICE_CLOSE, 0);
   double price = iClose(Symbol(), tf, 0);
   if (price > ma + atr * 0.5) return 1;
   if (price < ma - atr * 0.5) return -1;
   return 0;
}

double Filter_ATRFilter_Score_v2(int dir) {
   double atr  = iATR(Symbol(), Period(), Auto_ATR_Period(), 1);
   double atr14 = iATR(Symbol(), Period(), 14, 1);
   if (atr14 <= 0) return 50.0;
   double ratio = atr / atr14;
   double score = 50.0 + (ratio - 1.0) * 40.0;
   return MathMax(10.0, MathMin(90.0, score));
}

double Filter_VolumeFilter_Score_v2(int dir) {
   double vol  = (double)iVolume(Symbol(), Period(), 1);
   double volMA = iMA(Symbol(), Period(), 20, 0, MODE_SMA, PRICE_CLOSE, 1);
   if (volMA <= 0) return 50.0;
   double ratio = vol / volMA;
   return MathMax(10.0, MathMin(90.0, 50.0 + (ratio - 1.0) * 25.0));
}

double Filter_MultiTFTrend_Score_v2(int dir) {
   int m5  = (iClose(Symbol(), PERIOD_M5,  1) > iMA(Symbol(), PERIOD_M5,  50, 0, MODE_SMA, PRICE_CLOSE, 1)) ? 1 : -1;
   int h1  = (iClose(Symbol(), PERIOD_H1,  1) > iMA(Symbol(), PERIOD_H1,  50, 0, MODE_SMA, PRICE_CLOSE, 1)) ? 1 : -1;
   int h4  = (iClose(Symbol(), PERIOD_H4,  1) > iMA(Symbol(), PERIOD_H4,  50, 0, MODE_SMA, PRICE_CLOSE, 1)) ? 1 : -1;
   int aligned = (m5 == dir ? 1 : 0) + (h1 == dir ? 1 : 0) + (h4 == dir ? 1 : 0);
   return 50.0 + aligned * 13.0;
}

double Filter_Session_Score_v2(int dir) {
   int h = TimeHour(TimeCurrent());
   bool active = ((h >= 7 && h < 17) || (h >= 13 && h < 22));
   return active ? 70.0 : 40.0;
}


// ============================================================
// SPREAD FILTER UNIFIED ENGINE
// ============================================================

void SpreadFilter_Update() {
   double spread = (Ask - Bid) / Point;
   g_sf_currentSpread = spread;
   
   g_sf_history[g_sf_historyIdx] = spread;
   g_sf_historyIdx = (g_sf_historyIdx + 1) % SPREAD_HISTORY_SIZE;
   if (g_sf_historyCount < SPREAD_HISTORY_SIZE) g_sf_historyCount++;
   
   if (g_sf_historyCount < 3) {
      g_sf_avgSpread = spread;
      g_sf_medianSpread = spread;
      g_sf_anomalyScore = 0;
      g_sf_stabilityScore = 100;
      return;
   }
   
   double sum = 0;
   int i;
   for (i = 0; i < g_sf_historyCount; i++) sum += g_sf_history[i];
   g_sf_avgSpread = sum / g_sf_historyCount;
   
   double sorted[];
   ArrayResize(sorted, g_sf_historyCount);
   for (i = 0; i < g_sf_historyCount; i++) sorted[i] = g_sf_history[i];
   ArraySort(sorted);
   g_sf_medianSpread = sorted[g_sf_historyCount / 2];
   
   if (g_sf_medianSpread > 0) {
      double deviation = MathAbs(spread - g_sf_medianSpread) / g_sf_medianSpread;
      g_sf_anomalyScore = MathMin(100.0, deviation * 100.0);
   }
   
   double threshold = MathMax(g_sf_avgSpread * 1.3, MaxSpreadPoints * 0.8);
   if (spread <= threshold) {
      g_sf_stableTickCount++;
   } else {
      g_sf_stableTickCount = 0;
   }
   g_sf_stabilityScore = MathMin(100.0, g_sf_stableTickCount * 20.0);
}

bool SpreadFilter_IsHardBlocked() {
   if (MaxSpreadPoints <= 0) return false;
   return (g_sf_currentSpread > MaxSpreadPoints);
}

double SpreadFilter_GetAnomalyScore() {
   return g_sf_anomalyScore;
}

double SpreadFilter_GetStabilityScore() {
   return g_sf_stabilityScore;
}

bool SpreadFilter_IsSoftBlocked() {
   if (g_sf_anomalyScore > 80.0 && g_sf_stabilityScore < 20.0) return true;
   return false;
}

double SpreadFilter_GetConfidencePenalty() {
   double penalty = 0;
   if (g_sf_anomalyScore > 50) penalty += (g_sf_anomalyScore - 50) * 0.3;
   if (g_sf_stabilityScore < 40) penalty += (40 - g_sf_stabilityScore) * 0.2;
   return MathMin(30.0, penalty);
}

double Filter_Spread_Score_v2(int dir) {
   double spread = (Ask - Bid) / _Point;
   if (MaxSpreadPoints > 0 && spread > MaxSpreadPoints) return 20.0;
   return 70.0;
}

double Filter_Regime_Score_v2(int dir) {
   double adx = iADX(Symbol(), Period(), 14, PRICE_CLOSE, MODE_MAIN, 1);
   if (adx > (double)GetAdaptive_ADX_Trend()) return (dir != 0 ? 70.0 : 40.0);
   return 50.0;
}

// --- Additional helper functions ---
bool   CheckSpreadControl()                              { return ((Ask - Bid) / _Point <= MaxSpreadPoints); }
bool   MarketFiltersActive()                             { return (CheckSpreadControl() && !IsTradeContextBusy()); }
double ComputeStrategyConfidence(string name) {
   double base = 50.0;
   double indBonus = IndicatorAlignmentBonus(1);
   double patBonus = MathAbs(g_pat_consensus) * 0.15;
   if (name == "Predicted")            base = 65.0;
   else if (name == "FVG")             base = 60.0;
   else if (name == "SMC") base = 60.0;
   else if (name == "ICT") base = 55.0;
   else if (name == "Breakout")        base = 55.0;
   else if (name == "Grid")            base = 52.0;
   else if (name == "Reverse")         base = 53.0;
   return MathMin(95.0, base + indBonus + patBonus);
}

