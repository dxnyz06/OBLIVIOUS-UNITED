}

bool ConfirmRSI(bool isBuy)
{


      // Get parameters based on mode
      int rsi_period_used;
      if (IsTPSL_AI()) {
        // Auto-adaptive mode
        int dummy_macd_fast, dummy_macd_slow, dummy_macd_signal;
        int dummy_stoch_k, dummy_stoch_d, dummy_stoch_slow;
        int dummy_bb_period;
        double dummy_bb_dev;
        int dummy_cci_period, dummy_ma_period;
        int dummy_st_period;
        double dummy_st_mult;
        int dummy_adx_period, dummy_atr_period, dummy_fractals_period,
            dummy_momentum_period;
        GetAdaptiveParameters(
            dummy_macd_fast, dummy_macd_slow, dummy_macd_signal, dummy_stoch_k,
            dummy_stoch_d, dummy_stoch_slow, dummy_bb_period, dummy_bb_dev,
            dummy_cci_period, dummy_ma_period, dummy_st_period, dummy_st_mult,
            rsi_period_used, dummy_adx_period, dummy_atr_period,
            dummy_fractals_period, dummy_momentum_period);
      } else {
        // Manual mode - use input parameters
        rsi_period_used = Auto_RSI_Period();
      }
      const int N = 30;
      double rsiArr[];
      ArrayResize(rsiArr, N);
      for (int i = 0; i < N; i++) rsiArr[i] = iRSI(NULL, PERIOD_CURRENT, rsi_period_used, PRICE_CLOSE, i);
      double vol, adx, tfF, sess;
      GetMarketRegime(vol, adx, tfF, sess);
      double hi =
          Percentile(rsiArr, N, (adx > Auto_ADX_Threshold() ? 0.75 : 0.85));
      double lo =
          Percentile(rsiArr, N, (adx > Auto_ADX_Threshold() ? 0.25 : 0.15));
      double r0 = rsiArr[0], r1 = rsiArr[1];
      if (isBuy)
        return (r0 > r1) && (r0 > lo) && (r0 < hi);
      else
        return (r0 < r1) && (r0 < hi) && (r0 > lo);
}

bool ConfirmMACD(bool isBuy)
{

      double main_val = iMACD(Symbol(), 0, Auto_MACD_Fast(), Auto_MACD_Slow(),
                              Auto_MACD_Signal(), PRICE_CLOSE, MODE_MAIN, 1);
      double sig_val = iMACD(Symbol(), 0, Auto_MACD_Fast(), Auto_MACD_Slow(),
                             Auto_MACD_Signal(), PRICE_CLOSE, MODE_SIGNAL, 1);
      return isBuy ? (main_val > sig_val) : (main_val < sig_val);
}

bool ConfirmCCI(bool isBuy)
{

      const int N = 30;
      double cArr[];
      ArrayResize(cArr, N);
      for (int i = 0; i < N; i++) cArr[i] = iCCI(NULL, PERIOD_CURRENT, Auto_CCI_Period(), PRICE_TYPICAL, i);
      double vol, adx, tfF, sess;
      GetMarketRegime(vol, adx, tfF, sess);
      // Dynamic thresholds: base on percentiles
      double upper = Percentile(cArr, N, 0.80);
      double lower = Percentile(cArr, N, 0.20);
      double c0 = cArr[0], c1 = cArr[1];
      if (isBuy) {
        bool crossZeroUp = (c1 <= 0 && c0 > 0);
        bool aboveDyn = (c0 > upper * (adx > Auto_ADX_Threshold()
                                           ? 0.6
                                           : 1.0)); // relax in trends
        bool rising = (c0 > c1);
        return crossZeroUp || (aboveDyn && rising);
      } else {
        bool crossZeroDn = (c1 >= 0 && c0 < 0);
        bool belowDyn = (c0 < lower * (adx > Auto_ADX_Threshold() ? 0.6 : 1.0));
        bool falling = (c0 < c1);
        return crossZeroDn || (belowDyn && falling);
      }
}

bool ConfirmStochastic(bool isBuy)
{

      double k = iStochastic(Symbol(), 0, Auto_STOCH_K(), Auto_STOCH_D(),
                             Auto_STOCH_Slowing(), MODE_SMA, 0, MODE_MAIN, 1);
