void AA_ManageTicket(string ns, int ticket, int tf, int magic)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      if (OrderSymbol() != Symbol())
        return;
      if (OrderMagicNumber() != magic)
        return;
      int t = OrderType();
      if (t != OP_BUY && t != OP_SELL)
        return;

      int dir = (t == OP_BUY ? +1 : -1);
      double entry = OrderOpenPrice();
      double sl = OrderStopLoss();
      double tp = OrderTakeProfit();

      AA_EnsureTicketTargets(ns, ticket, tf, dir, entry, sl);

      double T1 = AA_GVGet(AA_GVKey(ns, ticket, "T1"), 0);
      double T2 = AA_GVGet(AA_GVKey(ns, ticket, "T2"), 0);
      double T3 = AA_GVGet(AA_GVKey(ns, ticket, "T3"), 0);
      double TM = AA_GVGet(AA_GVKey(ns, ticket, "TM"), 0);
      int stage = (int)AA_GVGet(AA_GVKey(ns, ticket, "STAGE"), 0);

      RefreshRates();
      double px = (dir > 0 ? Bid : Ask);

      bool hit1 = (T1 > 0 && (dir > 0 ? px >= T1 : px <= T1));
      bool hit2 = (T2 > 0 && (dir > 0 ? px >= T2 : px <= T2));
      bool hit3 = (T3 > 0 && (dir > 0 ? px >= T3 : px <= T3));
      bool hitM = (TM > 0 && (dir > 0 ? px >= TM : px <= TM));

      // SL to breakeven at each target (once BE is set, keep it)
      if ((hit1 && stage < 1) || (hit2 && stage < 2) || (hit3 && stage < 3)) {
        double be = entry;
        double curSL = OrderStopLoss();

        // Only improve SL (never worsen)
        bool need = false;
        if (dir > 0) {
          if (curSL < be)
            need = true;
        } else {
          if (curSL > be || curSL == 0.0)
            need = true;
        }

        if (need) {
          bool _wRes = AA_OrderModify(ticket, entry, AA_ClampPrice(be), tp);
          AA_GVSet(AA_GVKey(ns, ticket, "BE"), 1.0);
        }

        if (hit3)
          stage = 3;
        else if (hit2)
          stage = 2;
        else
          stage = 1;

        AA_GVSet(AA_GVKey(ns, ticket, "STAGE"), stage);
      }

      // Final target: close full
      if (hitM && stage < 4) {
        AA_CloseOrderFull(ticket);
        AA_ClearTicketGV(ns, ticket);
        AA_GVSet(AA_GVKey(ns, ticket, "STAGE"), 4.0);
      }
}

double __GetAdaptiveATRk(){
      int tf = Period();
      double v = __VolRatio();
      double k;
      if (tf <= PERIOD_M5)
        k = 0.30;
      else if (tf <= PERIOD_M15)
        k = 0.25;
      else if (tf <= PERIOD_H1)
        k = 0.20;
      else
        k = 0.15;
      if (v > 2.0)
        k += 0.05;
      else if (v < 0.8)
        k -= 0.05;
      if (k < 0.10)
        k = 0.10;
      if (k > 0.40)
        k = 0.40;
      return k;
}

bool IndicatorsTriggered() {
      double adx = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0);
      double ema20 = iMA(Symbol(), 0, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
      double ema50 = iMA(Symbol(), 0, 50, 0, MODE_EMA, PRICE_CLOSE, 0);
      return (adx > 20 && ema20 != ema50);
}

void IndicatorManager_Init() {
      // Seed indicator cache on startup so first-tick data is valid
      if (Bars > 0) {
        g_adapt.regime = 1; // Default: normal volatility
        g_adapt.isTrend =
            (iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0) > 25);
      }
      SmartLog("INFO", "INDMGR", "Indicator manager initialised");
}

void IndicatorManager_Update() {
      // Recompute adaptive indicators on each new bar or after forced refresh
      static datetime lastBar = 0;
      if (Time[0] != lastBar || g_indicatorNeedRefresh) {
        lastBar = Time[0];
        g_indicatorNeedRefresh = false;
      }
}

