bool IsFVGPattern() {
      if (iBars(Symbol(), 0) < 4) return false;
      double h1 = iHigh(Symbol(), 0, 3), l3 = iLow(Symbol(), 0, 1);
      double l1 = iLow(Symbol(), 0, 3),  h3 = iHigh(Symbol(), 0, 1);
      return (l3 > h1) || (h3 < l1);
}

double GetFVGConfidence() {
      if (!IsFVGPattern()) return 0;
      double atr = iATR(Symbol(), 0, 14, 1);
      if (atr <= 0) return 50.0;
      double gap = MathAbs(iLow(Symbol(), 0, 1) - iHigh(Symbol(), 0, 3));
      return MathMin(90.0, 50.0 + (gap / atr) * 30.0);
}

bool HTFConfirmDefault() {
      int htfTF = PERIOD_H4;
      double htfClose = iClose(Symbol(), htfTF, 1);
      double htfOpen  = iOpen(Symbol(),  htfTF, 1);
      double lClose   = iClose(Symbol(), PERIOD_CURRENT, 1);
      double lOpen    = iOpen(Symbol(),  PERIOD_CURRENT, 1);
      bool htfBull = (htfClose > htfOpen);
      bool htfBear = (htfClose < htfOpen);
      bool ltfBull = (lClose > lOpen);
      bool ltfBear = (lClose < lOpen);
      return (htfBull && ltfBull) || (htfBear && ltfBear);
}

int GetFVGPatternSignal() {
      double h1 = iHigh(Symbol(), 0, 3);
      double l3 = iLow(Symbol(), 0, 1);
      if (l3 > h1) return +1;
      return -1;
}

bool BoxRangeDetector(int lookback = 20, double thresholdFactor = 1.2) {
      if (iBars(Symbol(), 0) < lookback + 2) return false;
      double atr = iATR(Symbol(), 0, 14, 1);
      if (atr <= 0) return false;
      int hiIdx = iHighest(Symbol(), 0, MODE_HIGH, lookback, 1);
      int loIdx = iLowest(Symbol(), 0, MODE_LOW,  lookback, 1);
      double rangeHigh = iHigh(Symbol(), 0, hiIdx);
      double rangeLow  = iLow(Symbol(), 0, loIdx);
      double rangeSize = rangeHigh - rangeLow;
      return (rangeSize <= atr * thresholdFactor * lookback * 0.1);
}

// CupAndHANDLEPattern: REMOVED  was a recursive alias of CupAndHandlePattern (MQL4 case-insensitive)

bool CupAndHandlePattern(int period=60, double minCupDepth=0.003, double maxHandleRatio=0.38) {
      if (iBars(Symbol(), 0) < period + 5) return false;
      int cupStart = period;
      double cupHigh = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, cupStart / 2, cupStart));
      double cupLow  = iLow(Symbol(),  0, iLowest(Symbol(),  0, MODE_LOW,  cupStart / 2, cupStart / 2 + 1));
      double cupDepth = (cupHigh - cupLow) / (cupHigh > 0 ? cupHigh : 1.0);
      if (cupDepth < minCupDepth) return false;
      double handleHigh = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, cupStart / 4, 1));
      double handleDepth = (cupHigh - handleHigh) / (cupHigh - cupLow + 0.000001);
      return (handleDepth <= maxHandleRatio);
}

bool ComputeModeDrivenBiasOverlay() {
      double htfClose = iClose(Symbol(), PERIOD_H1, 1);
      double htfOpen  = iOpen(Symbol(),  PERIOD_H1, 1);
      double htfClose4 = iClose(Symbol(), PERIOD_H4, 1);
      double htfOpen4  = iOpen(Symbol(),  PERIOD_H4, 1);
      bool h1Bull = (htfClose > htfOpen);
      bool h4Bull = (htfClose4 > htfOpen4);
      return (h1Bull == h4Bull);
}

int GetPatternSignal() {
      // Generic Pattern Engine signal probe used by legacy callers.
      // Walks the FVG branch first (highest-quality continuation cue) and
      // falls back to the broad CheckProPatterns() ensemble. Pattern-named
      // sub-modules have been merged into the generic ensemble and no
      // longer expose dedicated branches here.
      int signal = 0;
      double confidence = 0.0;
      if (IsFVGPattern()) {
        confidence = GetFVGConfidence();
        if (confidence >= PatternsConfidence) {
          bool htfOK = HTFConfirmDefault();
          if (!htfOK)
            return 0;
        }
        if (!SpreadOk())
          return 0;
        signal = GetFVGPatternSignal();
      }
      if (signal == 0)
        signal = CheckProPatterns();
      return signal;
}

int Check_PeakProfitLock(string sym, int tf, double &confidence)
{
      // If equity has retraced significantly from peak, block new trades
      double balance = AccountBalance();
      double equity = AccountEquity();
      if (balance <= 0) {
        confidence = 0;
        return 0;
      }
      double ddPct = (balance - equity) / balance * 100.0;
      confidence = MathMin(100, MathMax(0, 100 - ddPct * 10));
      // If DD > PeakProfitRetracePercent, block
      if (ddPct > PeakProfitRetracePercent)
        return -1; // block
      return +1;   // allow
}

int Check_PivotPoints(string sym, int tf, double &confidence)
{
      // Daily pivot points
      if (iBars(sym, PERIOD_D1) < 2) {
        confidence = 0;
        return 0;
      }
      double prevH = iHigh(sym, PERIOD_D1, 1);
      double prevL = iLow(sym, PERIOD_D1, 1);
      double prevC = iClose(sym, PERIOD_D1, 1);
      double PP = (prevH + prevL + prevC) / 3.0;
      double R1 = 2.0 * PP - prevL;
      double S1 = 2.0 * PP - prevH;
      double R2 = PP + (prevH - prevL);
      double S2 = PP - (prevH - prevL);
      double price = iClose(sym, tf, 0);
      double atr = iATR(sym, tf, 14, 0);
      // How close to nearest level
      double distPP = MathAbs(price - PP);
      double distR1 = MathAbs(price - R1);
      double distS1 = MathAbs(price - S1);
      double minDist = MathMin(distPP, MathMin(distR1, distS1));
      confidence =
          MathMin(100, (atr > 0 ? (1.0 - minDist / (atr + 0.00001)) * 60 : 30));
      if (price > R1)
        return +1; // above R1 = bullish
      if (price < S1)
        return -1; // below S1 = bearish
      if (price > PP)
        return +1;
      return -1;
}

bool ADV_HasLiquiditySweep(int tf, int dir, double poolLevel, int maxLookback, int &sweepShift)
{
      sweepShift = -1;
      if (poolLevel <= 0.0)
        return false;

      int bars = iBars(Symbol(), tf);
      if (bars < 10)
        return false;

      int maxShift = (int)MathMin(maxLookback, bars - 3);
      for (int s = 1; s <= maxShift; s++) {
        double tol = ADV_Tol_ICT(tf, s);
        double h = iHigh(Symbol(), tf, s);
        double l = iLow(Symbol(), tf, s);
        double c = iClose(Symbol(), tf, s);

        if (dir > 0) {
          // Bullish: price raids below pool then reclaims above
          bool raided = (l < (poolLevel - tol));
          bool reclaimed = (c > (poolLevel + 0.2 * tol));
          if (raided && reclaimed) {
            sweepShift = s;
            return true;
          }
        } else {
          // Bearish: price raids above pool then reclaims below
          bool raided = (h > (poolLevel + tol));
          bool reclaimed = (c < (poolLevel - 0.2 * tol));
          if (raided && reclaimed) {
            sweepShift = s;
            return true;
          }
        }
      }
      return false;
}

int GetPatternBias(int shift=0)
{
      int bull = 0, bear = 0;

      if (CheckHammer(shift))
        bull++;
      if (CheckBullishEngulfing(shift))
        bull++;
      if (CheckHaramiBullish(shift))
        bull++;
      if (CheckMorningStar(shift))
        bull++;
      if (CheckThreeWhiteSoldiers(shift))
        bull++;
      if (CheckThreeInsideUp(shift))
        bull++;
      if (CheckThreeOutsideUp(shift))
        bull++;
      if (CheckPiercingLine(shift))
        bull++;
      if (CheckRisingWindow(shift))
        bull++;
      if (CheckTweezerBottom(shift))
        bull++;

      if (CheckShootingStar(shift))
        bear++;
      if (CheckBearishEngulfing(shift))
        bear++;
      if (CheckHaramiBearish(shift))
        bear++;
      if (CheckEveningStar(shift))
        bear++;
      if (CheckThreeBlackCrows(shift))
        bear++;
      if (CheckThreeInsideDown(shift))
        bear++;
      if (CheckThreeOutsideDown(shift))
        bear++;
      if (CheckDarkCloudCover(shift))
        bear++;
      if (CheckFallingWindow(shift))
        bear++;
      if (CheckTweezerTop(shift))
        bear++;

      if (bull > bear)
        return +1;
      if (bear > bull)
        return -1;
      return 0;
}

