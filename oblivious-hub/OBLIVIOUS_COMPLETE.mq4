                                          double ProfitToday() {
                                            double profit = 0;
                                            for (int i =
                                                     OrdersHistoryTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_HISTORY)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    TimeDay(OrderCloseTime()) == TimeDay(



   TimeCurrent())) {
                                                  profit += OrderProfit() +
   OrderSwap() +
   OrderCommission();
                                                }
                                              }
                                            }
                                            return profit;
                                          }

                                          double ProfitThisWeek() {
                                            double profit = 0;
                                            datetime weekStart =
                                                TimeCurrent() -
                                                TimeDayOfWeek(TimeCurrent()) *
                                                    86400;
                                            for (int i =
                                                     OrdersHistoryTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_HISTORY)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    OrderCloseTime() >=
                                                        weekStart) {
                                                  profit += OrderProfit() +
   OrderSwap() +
   OrderCommission();
                                                }
                                              }
                                            }
                                            return profit;
                                          }

                                          double ProfitThisMonth() {
                                            double profit = 0;
                                            for (int i =
                                                     OrdersHistoryTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_HISTORY)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    TimeMonth(
                                                        OrderCloseTime()) == TimeMonth(



   TimeCurrent()) &&
                                                    TimeYear(
                                                        OrderCloseTime()) == TimeYear(



   TimeCurrent())) {
                                                  profit += OrderProfit() +
   OrderSwap() +
   OrderCommission();
                                                }
                                              }
                                            }
                                            return profit;
                                          }

                                          int CountPositionsByMagic(int magic) {
