void UpdateDashboard() {
      // --- Aggiornamento barre di confidence ---
      double conf_AI_Predicted = GetStrategyConfidence("Predicted");
      int bar_width_AI_Predicted =
          (int)MathMin(100, MathMax(0, conf_AI_Predicted));
      ObjectSetInteger(0, "Dashboard_AI_Predicted_Bar", OBJPROP_XSIZE,
                       bar_width_AI_Predicted);
      ObjectSetText(
          "Dashboard_AI_Predicted",
          "AI Predicted: " +
              (IsStrategyActive("Predicted") ? "ATTIVA" : "SPENTA") + " - " +
              DoubleToString(conf_AI_Predicted, 1) + "%",
          10, "Verdana",
          (IsStrategyActive("Predicted") ? clrGreen : clrRed));
      // === 6 CANONICAL STRATEGIES - confidence bars ===
      string dashStrats[7] = {"Predicted","Breakout","FVG","Grid","SMC","ICT","Reverse"};
      string dashLabels[7] = {"Predicted","Breakout","FVG","Grid","SMC","ICT","Reverse"};
      string dashBars[6]   = {"Dashboard_Predicted_Bar","Dashboard_Breakout_Bar",
                               "Dashboard_FVG_Bar","Dashboard_Grid_Bar","Dashboard_SMC_ICT_Bar","Dashboard_Reverse_Bar"};
      string dashObjs[6]   = {"Dashboard_Predicted","Dashboard_Breakout",
                               "Dashboard_FVG","Dashboard_Grid","Dashboard_SMC_ICT","Dashboard_Reverse"};
      for (int _ds=0; _ds<6; _ds++) {
         double _conf = GetStrategyConfidence(dashStrats[_ds]);
         int _bw = (int)MathMin(100, MathMax(0, _conf));
         ObjectSetInteger(0, dashBars[_ds], OBJPROP_XSIZE, _bw);
         bool _active = IsStrategyActive(dashStrats[_ds]);
         ObjectSetText(dashObjs[_ds],
            dashLabels[_ds] + ": " + (_active ? "ATTIVA" : "SPENTA") +
            " - " + DoubleToString(_conf, 1) + "%",
            10, "Verdana", (_active ? clrGreen : clrRed));
      }
      int y_offset = 20;
      // BLOCCO 1: Info account
      string acc_info = StringFormat("Account: %s  Broker: %s  Leva: 1:%d  Spread: %d",
                                     AccountName(), AccountCompany(),
                                     (int)AccountLeverage(),
                                     (int)MarketInfo(Symbol(), MODE_SPREAD));
      ObjectCreate(0, "AccountInfo", OBJ_LABEL, 0, 0, 0);
      ObjectSetText("AccountInfo", acc_info, 10, "Arial", clrWhite);
      ObjectSetInteger(0, "AccountInfo", OBJPROP_YDISTANCE, y_offset);
      y_offset += 20;
      double _balance    = AccountBalance();
      double _equity     = AccountEquity();
      double _margin     = AccountMargin();
      double _freeMargin = AccountFreeMargin();
      double _dd = (_balance > 0) ? (100.0 * (_balance - _equity) / _balance) : 0;
      string acc_stats = StringFormat("Balance: %.2f  Equity: %.2f  Margin: %.2f  FreeMargin: %.2f  DD: %.2f%%",
                                      _balance, _equity, _margin, _freeMargin, _dd);
      ObjectCreate(0, "AccountStats", OBJ_LABEL, 0, 0, 0);
      ObjectSetText("AccountStats", acc_stats, 10, "Arial", clrWhite);
      ObjectSetInteger(0, "AccountStats", OBJPROP_YDISTANCE, y_offset);
      y_offset += 20;
      // BLOCCO 2: Sessione e mercato
}

