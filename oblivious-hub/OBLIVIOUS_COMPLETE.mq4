                                          //   live headlines when the news
                                          //   feed is actually fresh; show
                                          //   an honest placeholder when the
                                          //   hub/news feed is stale.
                                          bool live = News_FeedIsLive();
                                          if (live) {
                                            AI_GetNewsLines(n1, n2, n3);
                                          } else {
                                            n1 = "no live news feed";
                                            n2 = "";
