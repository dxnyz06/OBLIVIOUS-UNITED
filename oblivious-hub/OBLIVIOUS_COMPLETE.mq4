bool IsLondonSession() {
   int h = TimeHour(TimeCurrent());
   return (h >= 8 && h < 17);
}

bool IsNewYorkSession() {
   int h = TimeHour(TimeCurrent());
   return (h >= 13 && h < 22);
}

bool IsAsianSession() {
   int h = TimeHour(TimeCurrent());
   return (h >= 0 && h < 9);
}


