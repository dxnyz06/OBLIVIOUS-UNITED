double __PipValuePerLot(){
      double tickval = MarketInfo(Symbol(), MODE_TICKVALUE);
      double ticksize = MarketInfo(Symbol(), MODE_TICKSIZE);
      if (ticksize <= 0)
        return 0.0;
      // pips vs points handling simplified: assume 1 pip = 10 points when
      // 5-digit
      double point = MarketInfo(Symbol(), MODE_POINT);
      double pip_points = (Digits == 3 || Digits == 5) ? 10.0 : 1.0;
      double pip = point * pip_points;
      return (pip > 0 ? tickval * (pip / MarketInfo(Symbol(), MODE_TICKSIZE))
                      : 0.0);
}

double __PointValuePerLot() {
      double tv = MarketInfo(Symbol(), MODE_TICKVALUE);
      double ts = MarketInfo(Symbol(), MODE_TICKSIZE);
      return (ts > 0 ? tv / ts : 0);
}

double NormalizeLotToMarket(double lots)
{
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double step = MarketInfo(Symbol(), MODE_LOTSTEP);
      if (step <= 0)
        step = 0.01;
      lots = MathFloor(lots / step) * step;
      if (lots < minLot)
        lots = minLot;
      if (lots > maxLot)
        lots = maxLot;
      return NormalizeDouble(lots, 2);
}

double ADV_NormalizeLots(double lots)
{
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double step = MarketInfo(Symbol(), MODE_LOTSTEP);
      if (step <= 0.0)
        step = 0.01;

      lots = MathMax(minLot, MathMin(maxLot, lots));
      lots = MathFloor(lots / step) * step;
      return NormalizeDouble(lots, 2);
}

double __RoundLot(double lots)
{
      return NormalizeLotToMarket(lots);
}

double NormalizeLots(string symbol, double lots)
{
      double minLot = MarketInfo(symbol, MODE_MINLOT);
      double maxLot = MarketInfo(symbol, MODE_MAXLOT);
      double lotStep = MarketInfo(symbol, MODE_LOTSTEP);

      if (lotStep <= 0)
        lotStep = 0.01;
      if (minLot <= 0)
        minLot = 0.01;
      if (maxLot <= 0)
        maxLot = 100.0;

      lots = MathMax(minLot, MathMin(maxLot, lots));
      lots = MathFloor(lots / lotStep) * lotStep;

      return NormalizeDouble(lots, 2);
}

double LevelRiskPercent(int levelIndex)
{
      int N = (int)MathMax(1, (int)MathFloor(Active_MaxRiskForSymbol()));
      double baseRiskBudget = Active_MaxRiskForSymbol();
      double baseUnit =
          (TotalMultiplierSum(N) > 0 ? baseRiskBudget / TotalMultiplierSum(N)
                                     : baseRiskBudget);
      return baseUnit * MathMax(1, levelIndex);
}

double CurrentLevelRiskPercent(int magic, bool isBuy)
{
      int lvl = NextScaleLevel(magic, isBuy);
      return LevelRiskPercent(lvl);
}

bool CheckRiskLimits() {
                          // limiti di drawdown giornaliero e totale per account
                          // di tipo prop firm.
                          if (!ChallengePassage)
                            return true; // Se non attivo, nessun limite
                          double dailyDD = GetDailyDDLimit();
                          if (dailyDD <= 0)
                            return true; // Nessun limite per LIVE_ACCOUNT
                          double pnlToday = 0;
                          datetime todayStart = iTime(Symbol(), PERIOD_D1, 0);
                          for (int i = OrdersHistoryTotal() - 1; i >= 0; i--) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_HISTORY)) {
                              if (OrderCloseTime() >= todayStart) {
                                pnlToday += OrderProfit() + OrderSwap() +
                                            OrderCommission();
                              }
                            }
                          }
                          double floatingPnl = 0;
                          for (int i = OrdersTotal() - 1; i >= 0; i--) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
                              floatingPnl += OrderProfit() + OrderSwap() +
                                             OrderCommission();
                            }
                          }
                          if ((pnlToday + floatingPnl) <= -dailyDD) {
                            Print("BLOCCO ORDINI: Limite DD giornaliero "
                                  "superato (",
                                  dailyDD, ")");
                            return false;
                          }
                          return true;
}


bool CheckMultiSymbolRisk() {
                          // CHALLENGE PASSAGE
                          // per rispettare i limiti di
                          // drawdown giornaliero e totale per
                          // account di tipo prop firm.
                          if (!ChallengePassage)
                            return true;
                          double totalRisk = 0;
                          for (int i = 0; i < OrdersTotal(); i++) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
totalRisk += MathAbs(OrderProfit());
                            }
                          }
                          return totalRisk <= GetDailyDDLimit();
}

