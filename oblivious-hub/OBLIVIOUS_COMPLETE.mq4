                                          double CalculateGridProfit() {
                                            double profit = 0;
                                            for (int i = OrdersTotal() - 1;
                                                 i >= 0; i--) {
                                              if (OrderSelect(i,
   SELECT_BY_POS) &&
                                                  OrderSymbol() == Symbol())
                                                profit += OrderProfit() +
                                                          OrderSwap() +
                                                          OrderCommission();
                                            }
                                            return profit;
                                          }

