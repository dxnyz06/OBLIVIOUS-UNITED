                        return g_pnl_peakEquity;
                      }

                      double PnL_CurrentDrawdown() {
                        double peak = PnL_PeakEquity();
                        if (peak <= 0)
                          return 0;
                        return (peak - AccountEquity()) / peak * 100.0;
                      }

                      double PnL_DailyDrawdown() {
                        if (g_pnl_dayStartEquity <= 0)
                          return 0;
                        double dd = g_pnl_dayStartEquity - AccountEquity();
                        return MathMax(0, dd / g_pnl_dayStartEquity * 100.0);
                      }

                      double PnLTracker_DayStartEquity() {
                        return AccountEquity();
                      }

                      double MaxAbsoluteDrawdown() {
                        return Active_MaxTotalDDPercent();
                      }

                      double MaxDailyDrawdown() {
                        return Active_MaxDailyDDPercent();
                      }


