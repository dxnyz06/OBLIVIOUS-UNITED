                                          }

                                          void __AP_PeakTPControl_All() {
                                            // Iterate current symbol's open
                                            // orders and apply the hybrid

                                            int total = OrdersTotal();
                                            for (int i = total - 1; i >= 0;
                                                 i--) {
                                              if (!OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES))
                                                continue;
                                              if (OrderSymbol() != Symbol())
                                                continue;
                                              if (OrderType() != OP_BUY &&
                                                  OrderType() != OP_SELL)
                                                continue;
                                              __AP_PeakTPControl_ForTicket();
                                            }
                                          }

                                          void __AP_PeakTPControl_ForTicket() {
                                            // Called per-order, any mode
                                            // (Manual) 1) Update
                                            // peak favorable pips
                                            __AP_UpdatePeakPips();
                                            double peakPips = SpreadPoints();
                                            double curPips = SpreadPoints();
                                            double net = OrderProfit() +
                                                         OrderSwap() +
                                                         OrderCommission();
                                            double need =
                                                __AP_ProfitBuffer10pcOverCosts();
                                            // 2) Move SL to BE if eligible
                                            // (risk-free first)
                                            __AP_MoveSLtoBEIfEligible();
                                            // 3) Closing rules (only if net
                                            // >= buffer ? never close into
                                            // a net loss)
                                            if (net >= need) {
                                              // Deep retrace closures based
                                              // on peak a) drop to 80% of
                                              // peak (give back 20%) ->
                                              // close
                                              if (peakPips > 0 &&
                                                  curPips <= 0.8 * peakPips) {
                                                // Close position
                                                int tk = OrderTicket();
                                                double lots = OrderLots();
                                                {
                                                  int __ticket = OrderTicket();
                                                  double __lots = OrderLots();
                                                  SmartLogWrap(
                                                      "CLOSE",
                                                      StringFormat(
                                                          "PreClose | "
                                                          "ticket=%d "
                                                          "lots=%.2f "
                                                          "symbol=%s",
                                                          __ticket, __lots,
                                                          OrderSymbol()));
                                                }
                                                bool ok = OrderClose(
                                                    tk, lots,
                                                    (OrderType() == OP_BUY
                                                         ? Bid
                                                         : Ask),
                                                    GetAdaptiveSlippagePoints(),
                                                    clrNONE);
                                                {
                                                  int __err = GetLastError();
                                                  bool __isok = (__err == 0);
                                                  SmartLogWrap(
                                                      "CLOSE",
                                                      StringFormat(
                                                          "%s | ticket=%d "
                                                          "price=%.5f "
                                                          "lots=%.2f "
                                                          "err=%d",
                                                          __isok ? "PostClose "
   "OK"
   : "PostClose "
   "FAIL",
                                                          OrderTicket(),
                                                          OrderClosePrice(),
                                                          OrderLots(), __err));
                                                }
                                                if (ok) {
                                                  __AP_ClearPeakPips(tk);
                                                  Print("[PeakTP] Close at "
                                                        "80% of peak "
                                                        "(protect profit)");
                                                }
                                                return;
                                              }
                                              // b) fallback: if retrace
                                              // goes to 30% of peak ->
                                              // close
                                              if (peakPips > 0 &&
                                                  curPips <= 0.3 * peakPips) {
                                                int tk2 = OrderTicket();
                                                double lots2 = OrderLots();
                                                {
                                                  int __ticket = OrderTicket();
                                                  double __lots = OrderLots();
                                                  SmartLogWrap(
                                                      "CLOSE",
                                                      StringFormat(
                                                          "PreClose | "
                                                          "ticket=%d "
                                                          "lots=%.2f "
                                                          "symbol=%s",
                                                          __ticket, __lots,
                                                          OrderSymbol()));
                                                }
                                                bool ok2 = OrderClose(
                                                    tk2, lots2,
                                                    (OrderType() == OP_BUY
                                                         ? Bid
                                                         : Ask),
                                                    GetAdaptiveSlippagePoints(),
                                                    clrNONE);
                                                {
                                                  int __err = GetLastError();
                                                  bool __isok = (__err == 0);
                                                  SmartLogWrap(
                                                      "CLOSE",
                                                      StringFormat(
                                                          "%s | ticket=%d "
                                                          "price=%.5f "
                                                          "lots=%.2f "
                                                          "err=%d",
                                                          __isok ? "PostClose "
   "OK"
   : "PostClose "
   "FAIL",
                                                          OrderTicket(),
                                                          OrderClosePrice(),
                                                          OrderLots(), __err));
                                                }
                                                if (ok2) {
                                                  __AP_ClearPeakPips(tk2);
                                                  Print("[PeakTP] Close at "
                                                        "30% of peak (last "
                                                        "resort profit)");
                                                }
                                                return;
                                              }
                                            }
                                            // else: do not close, wait for
                                            // net profit to be above buffer
                                          }

                                          void __AP_PeakTPControl_Run() {
                                            int total = OrdersTotal();
                                            // Debounce time ~ 90s on M15 or
                                            // less, 45s on higher Use_TF()
                                            int debounceSec =
                                                (Period() <= PERIOD_M15 ? 90
   : 45);
                                            int timeoutSec =
                                                (Period() <= PERIOD_M15
                                                     ? 20 * 60
                                                     : 10 * 60); // allow a
                                            // timed
                                            // exit if
                                            // stuck
                                            for (int i = total - 1; i >= 0;
                                                 i--) {
                                              if (!OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES))
                                                continue;
                                              if (OrderSymbol() != Symbol())
                                                continue;
                                              int type = OrderType();
                                              if (type != OP_BUY &&
                                                  type != OP_SELL)
                                                continue;
                                              int ticket = OrderTicket();
                                              string kPeak = StringFormat(
                                                  "PTP_PEAK_%d", ticket);
                                              string kState = StringFormat(
                                                  "PTP_STATE_%d",
                                                  ticket); // 2=R2,1=R1,0=R0
                                              string kOsc = StringFormat(
                                                  "PTP_OSC_%d",
                                                  ticket); // oscillation
                                              // counter
                                              string kFirst80 = StringFormat(
                                                  "PTP_F80_%d",
                                                  ticket); // time of
                                              // first
                                              // <=0.80
                                              // cross
                                              string kPeakTs = StringFormat(
                                                  "PTP_PTS_%d",
                                                  ticket); // time of last
                                              // peak update
                                              double entry = OrderOpenPrice();
                                              double px =
                                                  (type == OP_BUY ? Bid : Ask);
                                              double peak =
                                                  __PTP_GetDbl(kPeak, entry);
                                              // Update peak
                                              bool newPeak = false;
                                              if (type == OP_BUY && px > peak) {
                                                peak = px;
                                                newPeak = true;
                                              }
                                              if (type == OP_SELL &&
                                                  px < peak) {
                                                peak = px;
                                                newPeak = true;
                                              }
                                              if (newPeak) {
                                                __PTP_SetDbl(kPeak, peak);
                                                __PTP_SetInt(
                                                    kPeakTs,
                                                    (int)TimeCurrent());
                                              }
                                              double peakGain =
                                                  (type == OP_BUY
                                                       ? (peak - entry)
                                                       : (entry - peak));
                                              double currGain =
                                                  (type == OP_BUY
                                                       ? (px - entry)
                                                       : (entry - px));
                                              if (peakGain <= Point * 1.5)
                                                continue; // not enough run
                                              // yet
                                              double ratio =
                                                  currGain / peakGain; // 0..1
                                              if (ratio < 0)
                                                ratio = 0;
                                              if (ratio > 1)
                                                ratio = 1;
                                              // Determine region
                                              int region =
                                                  (ratio >= 0.85
                                                       ? 2
                                                       : (ratio >= 0.50 ? 1
   : 0));
                                              int prevRegion =
                                                  __PTP_GetInt(kState, region);
                                              if (region != prevRegion) {
                                                // count oscillations
                                                // between R2 and R1 (ignore
                                                // R0 transitions)
                                                if ((prevRegion == 2 &&
                                                     region == 1) ||
                                                    (prevRegion == 1 &&
                                                     region == 2)) {
                                                  int osc =
                                                      __PTP_GetInt(kOsc, 0);
                                                  osc++; __PTP_SetInt(kOsc, osc);
                                                }
                                                __PTP_SetInt(kState, region);
                                                // mark first 0.80 cross
                                                // time
                                                if (ratio <= 0.80 &&
                                                    __PTP_GetInt(kFirst80, 0) == 0) {



                                                  __PTP_SetInt(
                                                      kFirst80,
                                                      (int)TimeCurrent());
                                                }
                                              }
                                              // reset first80 if back to
                                              // >=0.85
                                              if (ratio >= 0.85) {
                                                __PTP_SetInt(kFirst80, 0);
                                              }
                                              // Emergency close
                                              // ITER 15 USER FIX: threshold lowered
                                              // from 0.40 to 0.20 so trades aren't
                                              // panic-closed on normal intrabar
                                              // pullbacks. With TP ladder ratcheting
                                              // SL upwards, the safety net only
                                              // kicks in on catastrophic 80%+
                                              // retracements from peak.
                                              if (ratio < 0.20 &&
                                                  __PTP_NetOK()) {
                                                double _closePrice = (type == OP_BUY) ? Bid : Ask;
                                                SmartLogWrap("CLOSE", StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s", OrderTicket(), OrderLots(), OrderSymbol()));
                                                bool ok = (type == OP_BUY)
                                                    ? OrderClose(ticket, OrderLots(), Bid, GetAdaptiveSlippagePoints(), clrNONE)
                                                    : OrderClose(ticket, OrderLots(), Ask, GetAdaptiveSlippagePoints(), clrNONE);
                                                {
                                                  int __err = GetLastError();
                                                  bool __isok = (__err == 0);
                                                  SmartLogWrap(
                                                      "CLOSE",
                                                      StringFormat(
                                                          "%s | ticket=%d "
                                                          "price=%.5f "
                                                          "lots=%.2f "
                                                          "err=%d",
                                                          __isok ? "PostClose "
   "OK"
   : "PostClose "
   "FAIL",
                                                          OrderTicket(),
                                                          OrderClosePrice(),
                                                          OrderLots(), __err));
                                                }
                                                if (ok) {
                                                  GlobalVariableDel(kPeak);
                                                  GlobalVariableDel(kState);
                                                  GlobalVariableDel(kOsc);
                                                  GlobalVariableDel(kFirst80);
                                                  GlobalVariableDel(kPeakTs);
                                                }
                                                continue;
                                              }
                                              // Regular close condition
                                              // with hysteresis & debounce
                                              int oscCount =
                                                  __PTP_GetInt(kOsc, 0);
                                              int f80 =
                                                  __PTP_GetInt(kFirst80, 0);
                                              bool enoughTime =
                                                  (f80 > 0 && (TimeCurrent() -
   (datetime)f80) >=
   debounceSec);
                                              bool timedExit = false;
                                              int pts = __PTP_GetInt(
                                                  kPeakTs, (int)TimeCurrent());
                                              if (pts > 0 &&
                                                  (TimeCurrent() -
                                                   (datetime)pts) >= timeoutSec)
                                                timedExit = true;
                                              if (ratio <= 0.80 &&
                                                  __PTP_NetOK() &&
                                                  (oscCount >= 2 ||
                                                   enoughTime || timedExit)) {
                                                SmartLogWrap("CLOSE", StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s", OrderTicket(), OrderLots(), OrderSymbol()));
                                                bool ok = (type == OP_BUY)
                                                    ? OrderClose(ticket, OrderLots(), Bid, GetAdaptiveSlippagePoints(), clrNONE)
                                                    : OrderClose(ticket, OrderLots(), Ask, GetAdaptiveSlippagePoints(), clrNONE);
                                                {
                                                  int __err = GetLastError();
                                                  bool __isok = (__err == 0);
                                                  SmartLogWrap(
                                                      "CLOSE",
                                                      StringFormat(
                                                          "%s | ticket=%d "
                                                          "price=%.5f "
                                                          "lots=%.2f "
                                                          "err=%d",
                                                          __isok ? "PostClose "
   "OK"
   : "PostClose "
   "FAIL",
                                                          OrderTicket(),
                                                          OrderClosePrice(),
                                                          OrderLots(), __err));
                                                }
                                                if (ok) {
                                                  GlobalVariableDel(kPeak);
                                                  GlobalVariableDel(kState);
                                                  GlobalVariableDel(kOsc);
                                                  GlobalVariableDel(kFirst80);
                                                  GlobalVariableDel(kPeakTs);
                                                }
                                                continue;
                                              }
                                            }
                                          }

                                          bool __AP_ChallengePassageOn() { return ChallengePassage; }

                                          bool __AP_ProfitLockOK() {
                                            if (!__AP_ChallengePassageOn())
                                              return true;
                                            static double peak = 0;
                                            if (AccountEquity() > peak)
                                              peak = AccountEquity();
                                            // Retrace protection: equity < peak * (1 - PeakProfitRetracePercent/100)
                                            double trail =
                                                peak * (1.0 - PeakProfitRetracePercent / 100.0);
                                            if (AccountEquity() < trail) {
                                              Print("[AP] Profit lock: "
                                                    "equity < 98% of peak. "
                                                    "Pausing new entries.");
                                              return false;
                                            }
                                            return true;
                                          }

