bool IsDuringNews(string filePath, int blockMinutes) {
                    // Bridge-based news check (replaces //
                    // mechanism] filePath parameter is
                    // ignored (deprecated, kept for
                    // compatibility)
                    datetime now = TimeCurrent();
                    int blockTrading = 0, severity = 0, minutesToEvent = 0;

                    if (Bridge_GetNewsStatus(now, blockTrading, severity,
                                             minutesToEvent)) {
                      // Check if we're within blockMinutes of
                      // a news event
                      if (blockTrading == 1 && minutesToEvent >= 0 &&
                          minutesToEvent <= blockMinutes) {
                        return true;
                      }
                    }
                    // Fallback: conservative - do not block
                    // trading if EXE not available
                    return false;
}

