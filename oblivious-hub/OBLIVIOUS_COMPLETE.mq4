bool RestoreROState(string strategy, double &val1, double &val2, double &val3) { return false; }
int KPI_FindIndex(string name)
{
      for (int i = 0; i < KPI_MAX_METRICS; i++)
        if (KPI_metrics[i].strategy_name == name)
          return i;
      return -1;
}

int KPI_FindOrCreate(string name)
{
      int idx = KPI_FindIndex(name);
      if (idx >= 0)
        return idx;
      for (int i = 0; i < KPI_MAX_METRICS; i++) {
        if (KPI_metrics[i].strategy_name == "" ||
            KPI_metrics[i].strategy_name == NULL) {
          KPI_metrics[i].strategy_name = name;
          KPI_metrics[i].start_time = TimeCurrent();
          KPI_metrics[i].total_executions = 0;
          KPI_metrics[i].orders_processed = 0;
          KPI_metrics[i].success_rate = 0;
          KPI_metrics[i].avg_execution_time = 0;
          KPI_metrics[i].min_execution_time = 99999;
          KPI_metrics[i].max_execution_time = 0;
          return i;
        }
      }
      return -1;
}

double KPI_GetAvgTime(string strategy_name)
{
      int idx = KPI_FindIndex(strategy_name);
      return (idx >= 0) ? KPI_metrics[idx].avg_execution_time : 0.0;
}

double KPI_GetSuccessRate(string strategy_name)
{
      int idx = KPI_FindIndex(strategy_name);
      return (idx >= 0) ? KPI_metrics[idx].success_rate : 0.0;
}

string KPI_GenerateReport()
{
      string report = "=== PERFORMANCE REPORT ===\n";
      report += StringFormat("Total CPU Time Used: %.2f ms\n", KPI_total_cpu);
      report +=
          StringFormat("Report Period: %s to %s\n\n",
                       TimeToStr(KPI_last_report, TIME_DATE | TIME_MINUTES),
                       TimeToStr(TimeCurrent(), TIME_DATE | TIME_MINUTES));

      report += "Strategy Performance:\n";
      report += "Name                 | Exec   | Avg(ms) | Min(ms) | Max(ms) | "
                "Success% |\n";
      report += "-------------------- | ------ | ------- | ------- | ------- | "
                "-------- |\n";

      for (int i = 0; i < KPI_MAX_METRICS; i++) {
        if (KPI_metrics[i].strategy_name != "" &&
            KPI_metrics[i].total_executions > 0) {
          report += StringFormat(
              "%-20s | %6d | %7.2f | %7.2f | %7.2f | %8.1f |\n",
              KPI_metrics[i].strategy_name, KPI_metrics[i].total_executions,
              KPI_metrics[i].avg_execution_time,
              KPI_metrics[i].min_execution_time,
              KPI_metrics[i].max_execution_time, KPI_metrics[i].success_rate);
        }
      }

      // Recommendations
      report += "\nPerformance Recommendations:\n";
      for (int i = 0; i < KPI_MAX_METRICS; i++) {
        if (KPI_metrics[i].strategy_name != "" &&
            KPI_metrics[i].avg_execution_time > KPI_SLOW_THRESHOLD)
          report += StringFormat("- %s: avg %.1fms exceeds threshold\n",
                                 KPI_metrics[i].strategy_name,
                                 KPI_metrics[i].avg_execution_time);
      }

      return report;
}

void KPI_PrintReport()
{
      string report = KPI_GenerateReport();
      Print(report);
      KPI_last_report = TimeCurrent();
}

void KPI_Reset()
{
      for (int i = 0; i < KPI_MAX_METRICS; i++) {
        KPI_metrics[i].strategy_name = "";
        KPI_metrics[i].total_executions = 0;
        KPI_active[i] = "";
      }
      KPI_total_cpu = 0;
      KPI_last_report = TimeCurrent();
}

