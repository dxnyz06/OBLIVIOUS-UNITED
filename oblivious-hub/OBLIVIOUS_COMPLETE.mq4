   0 &&
   C > O) {
   dir =
   1;
   conf =
   65.0;
   } else if (
   uWick >
   body *
   2 &&
   lWick <
   body *
   0.5 &&
   rng >
   0 &&
   C < O) {
   dir =
   -1;
   conf =
   65.0;
   }
   if (dir == 0)



   return;
   conf = MathMin(
