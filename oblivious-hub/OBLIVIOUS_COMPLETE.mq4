      if (idx < 0)
        return 0;
      return g_exposure[idx].unrealizedPnL;
}

double ExposureManager_GetTotalLots()
{
      return g_totalAccountLots;
}

double ExposureManager_GetTotalPnL()
{
      return g_totalUnrealizedPnL;
}

int ExposureManager_Find(string symbol)
{
      for (int i = 0; i < g_exposureCount; i++) {
        if (g_exposure[i].symbol == symbol)
          return i;
      }
      return -1;
}

int ExposureManager_FindOrAdd(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx >= 0)
        return idx;

      if (g_exposureCount >= EXP_MAX_SYMBOLS)
        return -1;

      g_exposure[g_exposureCount].symbol = symbol;
      g_exposure[g_exposureCount].buyLots = 0;
      g_exposure[g_exposureCount].sellLots = 0;
      g_exposure[g_exposureCount].netLots = 0;
      g_exposure[g_exposureCount].totalLots = 0;
      g_exposure[g_exposureCount].unrealizedPnL = 0;
      g_exposure[g_exposureCount].buyCount = 0;
      g_exposure[g_exposureCount].sellCount = 0;
      g_exposureCount++;

      return g_exposureCount - 1;
}

double Lot_MinLot()       {
      return MarketInfo(Symbol(), MODE_MINLOT); }

double Lot_MaxLot()       {
      return MarketInfo(Symbol(), MODE_MAXLOT); }

double Lot_LotStep()      {
      return MarketInfo(Symbol(), MODE_LOTSTEP); }

double Lot_TickValue()    {
      return MarketInfo(Symbol(), MODE_TICKVALUE); }

double Lot_TickSize()     {
      return MarketInfo(Symbol(), MODE_TICKSIZE); }

double Lot_Normalize(double lots)
{
      double step = Lot_LotStep();
      if (step <= 0)
        step = 0.01;
      lots = MathFloor(lots / step) * step;
      lots = MathMax(lots, Lot_MinLot());
      lots = MathMin(lots, Lot_MaxLot());
      return NormalizeDouble(lots, 2);
}

double Lot_Fixed(double fixedLot)
{
      return Lot_Normalize(fixedLot);
}

double Lot_RiskBased(string sym, double riskPercent, double slPips)
{
      if (slPips <= 0)
        return Lot_MinLot();
      double equity = AccountEquity();
      double riskMoney = equity * riskPercent / 100.0;
      double tickVal = MarketInfo(sym, MODE_TICKVALUE);
      double tickSz = MarketInfo(sym, MODE_TICKSIZE);
      double pt = MarketInfo(sym, MODE_POINT);
      int dg = (int)MarketInfo(sym, MODE_DIGITS);
      double pipFactor = (dg == 5 || dg == 3) ? 10.0 : 1.0;
      double slPoints = slPips * pipFactor;
      double pipValue =
          (tickSz > 0 ? tickVal / tickSz * pt * pipFactor : tickVal);
      if (pipValue <= 0)
        pipValue = tickVal;
      double lots = riskMoney / (slPips * pipValue);
      return Lot_Normalize(lots);
}

double Lot_EquityProportional(double equityPerLot)
{
      if (equityPerLot <= 0)
        equityPerLot = 10000;
      double lots = AccountEquity() / equityPerLot;
      return Lot_Normalize(lots);
}

double Lot_Martingale(double baseLot, double multiplier, int maxLevel)
{
      // Count consecutive losses
      int losses = 0;
      for (int i = OrdersHistoryTotal() - 1; i >= 0 && losses < maxLevel; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();
        if (pnl < 0)
          losses++;
        else
          break;
      }
      double lots = baseLot * MathPow(multiplier, MathMin(losses, maxLevel));
      return Lot_Normalize(lots);
}

double Lot_AntiMartingale(double baseLot, double multiplier, int maxLevel)
{
      int wins = 0;
      for (int i = OrdersHistoryTotal() - 1; i >= 0 && wins < maxLevel; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();
        if (pnl > 0)
          wins++;
        else
          break;
      }
      double lots = baseLot * MathPow(multiplier, MathMin(wins, maxLevel));
      return Lot_Normalize(lots);
}

double Lot_Kelly(double baseLot, int lookback)
{
      int wins = 0, total = 0;
      double avgWin = 0, avgLoss = 0;

      for (int i = OrdersHistoryTotal() - 1; i >= 0 && total < lookback; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();
        total++;
        if (pnl > 0) {
          wins++;
          avgWin += pnl;
        } else
          avgLoss += MathAbs(pnl);
      }

      if (total < 10 || wins == 0 || (total - wins) == 0)
        return Lot_Normalize(baseLot);

      double winRate = (double)wins / total;
      avgWin /= wins;
      avgLoss /= (total - wins);

      if (avgLoss <= 0)
        return Lot_Normalize(baseLot);
      double kellyFraction = winRate - (1.0 - winRate) / (avgWin / avgLoss);
      kellyFraction =
          MathMax(0.01, MathMin(0.25, kellyFraction)); // Clamp to 1-25%

      double lots =
          baseLot * (kellyFraction / 0.02); // Normalize around 2% base
      return Lot_Normalize(lots);
}

double Lot_Adaptive(string sym, double riskPercent, int atrPeriod)
{
      double atr = iATR(sym, 0, atrPeriod, 0);
      double pt = MarketInfo(sym, MODE_POINT);
      int dg = (int)MarketInfo(sym, MODE_DIGITS);
      double pipFactor = (dg == 5 || dg == 3) ? 10.0 : 1.0;
      double slPips = atr / (pt * pipFactor) * 1.5; // 1.5x ATR as SL
      return Lot_RiskBased(sym, riskPercent, slPips);
}

double Lot_Grid(double baseLot, int level, double scaleFactor)
{
      double lots = baseLot + (level - 1) * scaleFactor * baseLot;
      return Lot_Normalize(lots);
}

double Lot_Compute(string sym = "", int mode = 0, double riskPercent = 1.0, double slPips = 20.0,
                   double baseLot = 0.01, int level = 1) {
    if (sym == "") sym = Symbol();
    if (mode == 1) return Lot_RiskBased(sym, riskPercent, slPips);
    if (mode == 2) return Lot_Grid(baseLot, level, 0.5);
    return DynamicLotSize(); }

double CalculateLotSize() {
      return 0.01; }

double CalculateDynamicLot(double risk_percent, double atr_value) {
      double equity = AccountBalance();
      double risk_amount = equity * (risk_percent / 100.0);
      if (atr_value <= 0)
        atr_value = 0.0001;
      double lot = risk_amount / (atr_value * 10);
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      if (lot < minLot)
        lot = minLot;
      if (lot > maxLot)
        lot = maxLot;
      return NormalizeDouble(lot, 2);
}

double CalculateStrategyLotSize(string strategy){
      // DynamicLotSize signature: (double sl_price = 0.0, string strat = "").
      // Pass 0.0 for sl_price so the legacy call by strategy name still
      // routes through the correct overload selection.
      return DynamicLotSize(0.0, strategy);
}

double CalculateTradeLotSize(double sl_points){
      return LotsHybrid(sl_points);
}

// GetLot: all strategies use ManualLot regardless of bridge mode
double GetLot(string strategy) {
