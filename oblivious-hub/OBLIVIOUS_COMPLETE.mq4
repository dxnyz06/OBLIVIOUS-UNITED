}

bool PreBreakoutGuard(bool buySide) {
      double atr = iATR(Symbol(), 0, 14, 1);
      double range = High[1] - Low[1];
      return (range >= atr * 0.5);
}

double __BaselineRangeBefore(int lookback = 20) {
      double hi = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, lookback, 1));
      double lo = iLow(Symbol(), 0, iLowest(Symbol(), 0, MODE_LOW, lookback, 1));
      return hi - lo;
}

void DispatchPatternStrategies() {
   // ============================================================
   // LEVEL 3: Pattern Context  always active, no AllowStrategyToTrade gate
   // Pattern functions detect setups and contribute to g_pat_consensus.
   // NO TRADES are opened inside pattern detection functions.
   // ============================================================
   g_pat_bull_count = 0;
   g_pat_bear_count = 0;
   g_pat_confidence = 0.0;

   // Engulfing + MACD trend confluence (always run, internal pattern module)
   Pattern_TrendConfluence_Logic();

   // Candlestick patterns (always active  no input gate required)
   Strategy_Engulfing_Logic();
   Strategy_Hammer_Logic();
   Strategy_Doji_Logic();
   Strategy_MorningStar_Logic();
   Strategy_InsideBar_Logic();
   Strategy_PinBar_Logic();
   Strategy_Marubozu_Logic();
   Strategy_HaramiPattern_Logic();
   Strategy_ThreeBarPattern_Logic();
   Strategy_BreakoutPattern_Logic();
   Strategy_OrderBlockPattern_Logic();
   Strategy_StructureBreakPattern_Logic();
   Strategy_LiquidityGrabPattern_Logic();
   Strategy_FVGPattern_Logic();
   Strategy_ThreeWhiteSoldiers_Logic();

   // Compute pattern consensus: -100 (all bear) to +100 (all bull)
   int total = g_pat_bull_count + g_pat_bear_count;
   g_pat_consensus = (total > 0) ? (100.0 * (g_pat_bull_count - g_pat_bear_count) / total) : 0.0;

   // Pattern Engine produces support signals for the 6 owner strategies:
   // pattern_direction_support, pattern_confidence, pattern_trigger_quality
   // NO trades are opened here — Pattern Engine is always active, non-owner.
   int pSig = (g_pat_consensus > PatternsConfidence * 0.5) ? 1 : (g_pat_consensus < -(PatternsConfidence * 0.5)) ? -1 : 0;
   double pConf = MathAbs(g_pat_consensus) + IndicatorAlignmentBonus(pSig) * 0.3;
   g_pat_direction_support  = pSig;
   g_pat_confidence_support = clamp100(pConf);
   g_pat_trigger_quality    = (pConf >= PatternsConfidence) ? 1.0 : (pConf / MathMax(1.0, (double)PatternsConfidence));
}

bool ICT_DetectBreakerBlock(string sym, int tf, int dir, int lookback,
                              double &breakerHigh, double &breakerLow) {
   breakerHigh = 0; breakerLow = 0;
   for (int i = 2; i < lookback; i++) {
      double h = iHigh(sym, tf, i);
      double l = iLow(sym, tf, i);
      double close = iClose(sym, tf, i);
      double prevH = iHigh(sym, tf, i + 1);
      double prevL = iLow(sym, tf, i + 1);
      // Bearish breaker: was bullish OB, then price broke below
      if (dir == 1 && close < prevL && h > prevH) {
         breakerHigh = h; breakerLow = l; return true;
      }
      // Bullish breaker: was bearish OB, price broke above
      if (dir == -1 && close > prevH && l < prevL) {
         breakerHigh = h; breakerLow = l; return true;
      }
   }
   return false;
}

bool ICT_DetectMitigationBlock(string sym, int tf, int dir, int lookback,
                                 double &mitHigh, double &mitLow) {
   mitHigh = 0; mitLow = 0;
   for (int i = 2; i < lookback; i++) {
      double h = iHigh(sym, tf, i);
      double l = iLow(sym, tf, i);
      double open = iOpen(sym, tf, i);
      double close = iClose(sym, tf, i);
      // Unmitigated OB: bearish candle for bullish run, bullish candle for bearish
      bool isBullish = (close > open);
      bool isBearish = (close < open);
      if (dir == 1 && isBearish) {  // look for bearish OB below current price
         if (l < Bid) { mitHigh = h; mitLow = l; return true; }
      }
      if (dir == -1 && isBullish) {
         if (h > Ask) { mitHigh = h; mitLow = l; return true; }
      }
   }
   return false;
}

bool ICT_DetectDisplacement(string sym, int tf, int shift) {
   double atr = iATR(sym, tf, 14, shift + 1);
   if (atr <= 0) return false;
   double body = MathAbs(iClose(sym, tf, shift) - iOpen(sym, tf, shift));
   double range = iHigh(sym, tf, shift) - iLow(sym, tf, shift);
   // Displacement: large body (>60% of range) and range > 1.5x ATR
   return (body > range * 0.6 && range > atr * 1.5);
}

double ICT_DetectInducement(string sym, int tf, int dir, int lookback) {
   // Inducement = equal highs (for sell inducement) or equal lows (for buy)
   double ref = 0; int count = 0;
   for (int i = 1; i < lookback; i++) {
      double level = (dir == 1) ? iLow(sym, tf, i) : iHigh(sym, tf, i);
      if (ref == 0) { ref = level; count = 1; continue; }
      if (MathAbs(level - ref) < iATR(sym, tf, 14, i) * 0.1) {
         count++;
         if (count >= 2) return ref;  // equal level found = inducement
      } else { ref = level; count = 1; }
   }
   return 0;
}

// Returns 1=premium (sell zone), -1=discount (buy zone), 0=equilibrium
int ICT_ComputePremiumDiscount(string sym, int tf, int lookback) {
   double rangH = iHigh(sym, tf, iHighest(sym, tf, MODE_HIGH, lookback, 1));
   double rangL = iLow(sym,  tf, iLowest( sym, tf, MODE_LOW,  lookback, 1));
   double equilibrium = (rangH + rangL) / 2.0;
   double current = (Ask + Bid) / 2.0;
   if (current > equilibrium + (rangH - rangL) * 0.1) return  1;  // premium
   if (current < equilibrium - (rangH - rangL) * 0.1) return -1;  // discount
   return 0;
}

bool ICT_DetectAMD(string sym, int tf, int &amdDir) {
   amdDir = 0;
   double sessH = iHigh(sym, tf, iHighest(sym, tf, MODE_HIGH, 8, 1));
   double sessL = iLow(sym,  tf, iLowest( sym, tf, MODE_LOW,  8, 1));
   double current = Bid;
   // Manipulation = price swept liquidity (above high or below low)
   // Distribution = reversal back into range
   if (current < sessL) { amdDir = 1;  return true; }  // swept lows -> buy dist
   if (current > sessH) { amdDir = -1; return true; }  // swept highs -> sell dist
   return false;
}

bool ICT_DetectJudasSwing(string sym, int tf) {
   // Judas: aggressive move at killzone start, then reverses
   if (!IsActiveSession()) return false;
   double atr = iATR(sym, tf, 14, 1);
   if (atr <= 0) return false;
   double h = iHigh(sym, tf, 1); double l = iLow(sym, tf, 1);
   double open = iOpen(sym, tf, 1); double close = iClose(sym, tf, 1);
   double range = h - l;
   // Strong wick reversal: range > ATR and body < 30% of range = pinbar-like
   return (range > atr && MathAbs(close - open) < range * 0.3);
}

double ICT_ComputePOIScore(string sym, int tf, int dir, double poiPrice) {
   double atr = iATR(sym, tf, 14, 1);
   if (atr <= 0) return 0;
   double dist = MathAbs(((dir == 1) ? Ask : Bid) - poiPrice);
   double distScore = MathMax(0, 50.0 - (dist / atr) * 25.0);
   // Bonus for premium/discount alignment
   int pdZone = ICT_ComputePremiumDiscount(sym, tf, 20);
   double pdBonus = (dir == 1 && pdZone == -1) ? 25 : (dir == -1 && pdZone == 1) ? 25 : 0;
   // Bonus for session alignment
   double sessBonus = IsActiveSession() ? 25 : 0;
   return MathMin(100.0, distScore + pdBonus + sessBonus);
}

// ============================================================================
// SECTION HYBRID: HYBRID ENGINE (Level 2.5 — internal, always-on, NON-OWNER)
// ----------------------------------------------------------------------------
// Reads structure primitives (sweep, MSS/BOS, displacement, FVG, OB, breaker,
// mitigation, AMD, judas, SMT, premium/discount, killzone) and the outputs of
// the other three engines (Pattern / Indicator / Filter) and AI context. From
// these it recognises 10 multi-step models (4 reversal + 4 continuation + 2
// advanced) and produces a soft, structured support payload consumed by the
// six non-Predicted owner strategies (Breakout, FVG, Grid, SMC, ICT, Reverse).
//
// Architectural rules (mirrors Pattern / Indicator / Filter engines):
//   - NEVER opens trades.
//   - NEVER owns a magic number.
//   - NEVER hard-vetoes a trade. It produces bias / confidence / quality /
//     penalty / hold / cancel hints. Owners merge them softly.
//   - NEVER applied to Predicted as primary engine. Predicted reads at most
//     a context note (not used to gate its decisions).
//   - Lives next to the other engines, NOT inside the strategies.
//
// Entry point: UpdateHybridEngine() — called once per tick from
// Orchestrator_OnTick, after Pattern/Filter/Indicator/AI engines and BEFORE
// any owner strategy dispatch.
//
// Public read surface: g_hyb_* globals (always safe to read).
// Refinement helpers (called by owners):
//   Hybrid_RefineConfidence(base, strat) -> double
//   Hybrid_RefineBias      (base, strat) -> int
//   Hybrid_QualityFor      (strat)       -> double
//   Hybrid_ShouldDiscourage(strat)       -> bool   (SOFT cancel hint)
// ============================================================================

// (Hybrid model id and class #defines live near top of file in SECTION 02
// so they are visible to early callers in SMC / ICT / ExecuteStrategies.)
//
// Internal Hybrid Engine policy baselines (NOT inputs — the only user-tunable
// knob is `HybridMinConfidence`, mirroring Indicators/Filters/Patterns
// inputs). The actual thresholds used at runtime are derived from these
// baselines by `Hyb_QualityMinNow()` / `Hyb_PenaltyMaxNow()` which
// auto-adapt to:
//   1) symbol class    (FX major / metal / index / crypto / other)
//   2) session context (in killzone vs out, weekend, etc.)
// so the engine becomes stricter on liquid/clean markets and on prime
// killzones, and more permissive on noisy assets / off-hours — without
// adding any user input.
const int HYB_QUALITY_MIN_BASE  = 55;  // baseline model quality soft threshold
const int HYB_PENALTY_MAX_BASE  = 70;  // baseline penalty above which we soft-discourage

// Symbol-class taxonomy used by the adaptive thresholds.
// FASE 7 (Patch 5): HYB_SYM_* macros spostate in cima al file
// (sezione INPUT/USER PARAMETERS) per visibilita' globale. Definizioni
// originali rimosse da qui; valori identici.

// Cached classification (computed once per symbol).
int    g_hyb_sym_class       = -1;
string g_hyb_sym_class_for   = "";

int Hyb_SymbolClass() {
   string s = Symbol();
   if (g_hyb_sym_class >= 0 && g_hyb_sym_class_for == s) return g_hyb_sym_class;
   string u = s; StringToUpper(u);
   int cls = HYB_SYM_OTHER;
   if      (StringFind(u, "XAU") >= 0 || StringFind(u, "XAG") >= 0 ||
            StringFind(u, "XPT") >= 0 || StringFind(u, "XPD") >= 0 ||
            StringFind(u, "GOLD") >= 0 || StringFind(u, "SILVER") >= 0) cls = HYB_SYM_METAL;
   else if (StringFind(u, "BTC") >= 0 || StringFind(u, "ETH") >= 0 ||
            StringFind(u, "LTC") >= 0 || StringFind(u, "XRP") >= 0 ||
            StringFind(u, "SOL") >= 0 || StringFind(u, "BNB") >= 0)     cls = HYB_SYM_CRYPTO;
   else if (StringFind(u, "US100") >= 0 || StringFind(u, "US500") >= 0 ||
            StringFind(u, "US30")  >= 0 || StringFind(u, "NAS")   >= 0 ||
            StringFind(u, "SPX")   >= 0 || StringFind(u, "DJ")    >= 0 ||
            StringFind(u, "GER")   >= 0 || StringFind(u, "DAX")   >= 0 ||
            StringFind(u, "UK100") >= 0 || StringFind(u, "FTSE")  >= 0 ||
            StringFind(u, "JP225") >= 0 || StringFind(u, "NIK")   >= 0) cls = HYB_SYM_INDEX;
   else {
      // FX heuristic: 6 letters, common majors set
      string majors[7] = {"EURUSD","GBPUSD","USDJPY","AUDUSD","NZDUSD","USDCHF","USDCAD"};
      for (int i = 0; i < 7; i++) {
         if (StringFind(u, majors[i]) >= 0) { cls = HYB_SYM_FX_MAJOR; break; }
      }
   }
   g_hyb_sym_class = cls;
   g_hyb_sym_class_for = s;
   return cls;
}

// Killzone / prime session detector (uses existing session helpers if
// available; otherwise a clean time-based fallback in server time).
bool Hyb_InKillzone() {
   // Existing session helpers (declared elsewhere in the file).
   // London open killzone: ~07:00–10:00 UTC ; NY open: ~12:00–15:00 UTC
   // We accept a slightly wider band to absorb DST drift.
   int h = TimeHour(TimeCurrent());
   bool london_kz = (h >= 7  && h <  11);
   bool ny_kz     = (h >= 12 && h <  16);
   return (london_kz || ny_kz);
}

// Adaptive quality-min: stricter on clean markets / prime sessions,
// looser on noisy assets / off-hours.
int Hyb_QualityMinNow() {
   int q = HYB_QUALITY_MIN_BASE;
   int cls = Hyb_SymbolClass();
   if      (cls == HYB_SYM_FX_MAJOR) q += 3;   // 58
   else if (cls == HYB_SYM_INDEX)    q += 0;   // 55
   else if (cls == HYB_SYM_METAL)    q -= 3;   // 52
   else if (cls == HYB_SYM_CRYPTO)   q -= 5;   // 50
   if (Hyb_InKillzone()) q += 2; else q -= 2;
   if (q < 45) q = 45;
   if (q > 70) q = 70;
   return q;
}

// Adaptive penalty-max: tighter on clean markets / prime sessions, more
// tolerant on noisy assets / off-hours so we don't kill decent setups.
int Hyb_PenaltyMaxNow() {
   int p = HYB_PENALTY_MAX_BASE;
   int cls = Hyb_SymbolClass();
   if      (cls == HYB_SYM_FX_MAJOR) p -= 2;   // 68
   else if (cls == HYB_SYM_INDEX)    p += 0;   // 70
   else if (cls == HYB_SYM_METAL)    p += 2;   // 72
   else if (cls == HYB_SYM_CRYPTO)   p += 5;   // 75
   if (Hyb_InKillzone()) p -= 2; else p += 2;
   if (p < 60) p = 60;
   if (p > 85) p = 85;
   return p;
}

// ---- Public Hybrid-Engine state (read-only outside the engine) ------------
double   g_hyb_confidence            = 0.0;   // 0..100
int      g_hyb_bias                  = 0;     // -1 / 0 / +1
double   g_hyb_quality_score         = 0.0;   // 0..100 — model build quality
double   g_hyb_penalty_score         = 0.0;   // 0..100 — invalidation pressure
int      g_hyb_model_id              = HYB_MODEL_NONE;
int      g_hyb_model_class           = HYB_CLASS_NONE;
string   g_hyb_model_name            = "none";
bool     g_hyb_sweep_detected        = false;
double   g_hyb_displacement_score    = 0.0;
bool     g_hyb_mss_detected          = false;
bool     g_hyb_bos_detected          = false;
double   g_hyb_retracement_quality   = 0.0;
double   g_hyb_entry_zone_score      = 0.0;
double   g_hyb_liquidity_target_score= 0.0;
double   g_hyb_invalidation_score    = 0.0;
double   g_hyb_freshness_score       = 0.0;
double   g_hyb_confluence_score      = 0.0;
bool     g_hyb_hold_continue         = false; // soft "hold to next leg"
bool     g_hyb_cancel_signal         = false; // soft "cancel pending setup"
datetime g_hyb_last_update           = 0;

// Per-model best-direction snapshot (used by owners when relevant)
int      g_hyb_dir_best              = 0;     // direction the best model fired in

// SMT availability flag (set on first probe; controls fallback path)
bool     g_hyb_smt_available_known   = false;
bool     g_hyb_smt_available         = false;

// ---- helpers --------------------------------------------------------------
// Map an internal alias-derived correlation pair for SMT probing.
// Returns "" if no good correlation pair is known for the current symbol.
// Returns a stable, lowercase, identifier-safe name for a Hybrid
// model class id (used in ai_query setup_id construction).
string Hyb_ClassName(int cls) {
   if (cls == HYB_CLASS_REVERSAL)     return "reversal";
   if (cls == HYB_CLASS_CONTINUATION) return "continuation";
   if (cls == HYB_CLASS_ADVANCED)     return "advanced";
   return "none";
}

string Hyb_SMT_PairFor(string sym) {
   string s = sym;
   StringToUpper(s);
   if (StringFind(s, "EURUSD") >= 0)  return "GBPUSD";
   if (StringFind(s, "GBPUSD") >= 0)  return "EURUSD";
   if (StringFind(s, "AUDUSD") >= 0)  return "NZDUSD";
   if (StringFind(s, "NZDUSD") >= 0)  return "AUDUSD";
   if (StringFind(s, "USDJPY") >= 0)  return "USDCHF";
   if (StringFind(s, "USDCHF") >= 0)  return "USDJPY";
   if (StringFind(s, "XAUUSD") >= 0)  return "XAGUSD"; // gold/silver
   if (StringFind(s, "US100")  >= 0)  return "US500";
   if (StringFind(s, "US500")  >= 0)  return "US100";
   if (StringFind(s, "BTC")    >= 0)  return "ETHUSD";
   if (StringFind(s, "ETH")    >= 0)  return "BTCUSD";
   return "";
}

// Probe SMT divergence in a way that is safe for symbols whose paired feed
// is not available in the broker — returns a robust "not available" signal
// rather than fake data. dir output: -1/+1 if usable; 0 if unusable.
bool Hyb_TrySMT(int &dir) {
   dir = 0;
   if (g_hyb_smt_available_known && !g_hyb_smt_available) return false;
   string pair = Hyb_SMT_PairFor(Symbol());
   if (StringLen(pair) == 0) {
      g_hyb_smt_available_known = true;
      g_hyb_smt_available = false;
      return false;
   }
   // MarketInfo symbol existence probe
   double pip = MarketInfo(pair, MODE_POINT);
   if (pip <= 0) {
      g_hyb_smt_available_known = true;
      g_hyb_smt_available = false;
      return false;
   }
   g_hyb_smt_available_known = true;
   g_hyb_smt_available = true;
   int d = 0;
   if (DetectSMTDivergence(Symbol(), pair, Period(), d)) { dir = d; return true; }
   return false;
}

// Killzone / macro-time scoring (boosts bias when we sit in a high-quality
// macro window). Uses already-existing session helpers and adds a few well-
// known ICT killzones. Values are bounded 0..100.
double Hyb_MacroTimeScore() {
   int hour = Hour();
   double score = 0.0;
   if (IsLondonSession())   score += 35.0;
   if (IsNewYorkSession())  score += 35.0;
   if (IsAsianSession())    score += 15.0;
   // London open killzone (07:00-10:00) and NY open killzone (12:00-15:00)
   if (hour >= 7  && hour <= 10) score += 20.0;   // London KZ
   if (hour >= 12 && hour <= 15) score += 20.0;   // NY KZ AM
   if (hour >= 14 && hour <= 16) score += 10.0;   // NY lunch / power-hour transition
   return MathMin(100.0, score);
}

// OTE retracement quality: bigger near 0.62-0.79 of last swing range.
double Hyb_OTEQuality(int dir, int lookback) {
   double swH = iHigh(Symbol(), Period(), iHighest(Symbol(), Period(), MODE_HIGH, lookback, 1));
   double swL = iLow (Symbol(), Period(), iLowest (Symbol(), Period(), MODE_LOW,  lookback, 1));
   double rng = swH - swL;
   if (rng <= 0) return 0.0;
   double mid = (Bid + Ask) * 0.5;
   double pct = (dir == 1) ? (swH - mid) / rng : (mid - swL) / rng;
   if (pct < 0.382) return 25.0 * (pct / 0.382);
   if (pct < 0.62)  return 50.0 + 25.0 * (pct - 0.382) / (0.62 - 0.382);
   if (pct <= 0.79) return 100.0;                     // sweet spot
   if (pct <= 0.92) return 100.0 - 60.0 * (pct - 0.79) / (0.92 - 0.79);
   return 25.0;
}

// Liquidity-target proxy: distance to next session high/low normalised on ATR.
double Hyb_LiqTargetScore(int dir) {
   double atr = iATR(Symbol(), Period(), 14, 1);
   if (atr <= 0) return 0.0;
   int lb = 30;
   double swH = iHigh(Symbol(), Period(), iHighest(Symbol(), Period(), MODE_HIGH, lb, 1));
   double swL = iLow (Symbol(), Period(), iLowest (Symbol(), Period(), MODE_LOW,  lb, 1));
   double tgt = (dir == 1) ? swH : swL;
   double dst = MathAbs(((dir == 1) ? Ask : Bid) - tgt);
   if (dst <= 0) return 100.0;
   double rrLike = dst / atr;
   if (rrLike >= 3.0) return 100.0;
   if (rrLike >= 1.5) return 60.0 + 40.0 * (rrLike - 1.5) / 1.5;
   return 60.0 * (rrLike / 1.5);
}

// Freshness: a sweep / displacement that just printed scores high; an old
// one decays linearly to 0 over `decay_bars` bars.
double Hyb_FreshnessScore(int last_bar_idx, int decay_bars) {
   if (last_bar_idx < 0) return 0.0;
   if (last_bar_idx == 0) return 100.0;
   if (last_bar_idx >= decay_bars) return 0.0;
   return 100.0 * (1.0 - (double)last_bar_idx / (double)decay_bars);
}

// =================== Hybrid model detectors (10) ============================
// Each returns true if the model fires for `dir` (+1 long, -1 short),
// updates `score` (0..100). On false, score MUST be set to 0.

bool Hybrid_DetectSweepMSSFVG(int dir, double &score) {
   score = 0.0;
   double swLvl = 0, swConf = 0;
   if (!ICT_DetectLiquiditySweep(dir, swLvl, swConf)) return false;
   double mssConf = 0;
   if (!ICT_DetectMarketStructureShift(dir, mssConf)) return false;
   bool disp = ICT_DetectDisplacement(Symbol(), Period(), 1);
   bool fvgB = false; double gh = 0, gl = 0, fvgC = 0;
   if (!ICT_DetectFairValueGap(1, fvgB, gh, gl, fvgC)) return false;
   if (dir == 1 && !fvgB) return false;
   if (dir == -1 && fvgB) return false;
   score = (swConf * 0.30) + (mssConf * 0.30) + (fvgC * 0.20) + (disp ? 20.0 : 5.0);
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectBreakerOTE(int dir, double &score) {
   score = 0.0;
   double swLvl = 0, swConf = 0;
   if (!ICT_DetectLiquiditySweep(dir, swLvl, swConf)) return false;
   double mssConf = 0;
   if (!ICT_DetectMarketStructureShift(dir, mssConf)) return false;
   double bH = 0, bL = 0;
   if (!ICT_DetectBreakerBlock(Symbol(), Period(), dir, 30, bH, bL)) return false;
   double oteQ = Hyb_OTEQuality(dir, 30);
   score = (swConf * 0.25) + (mssConf * 0.25) + (oteQ * 0.30) + 20.0;
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectUnicorn(int dir, double &score) {
   // Unicorn = Breaker block + FVG overlapping it.
   score = 0.0;
   double bH = 0, bL = 0;
   if (!ICT_DetectBreakerBlock(Symbol(), Period(), dir, 30, bH, bL)) return false;
   bool fvgB = false; double gh = 0, gl = 0, fvgC = 0;
   if (!ICT_DetectFairValueGap(1, fvgB, gh, gl, fvgC)) return false;
   if (dir == 1 && !fvgB) return false;
   if (dir == -1 && fvgB) return false;
   // Geometric overlap test (gap inside or touching breaker zone)
   bool overlap = (gh >= bL && gl <= bH);
   if (!overlap) return false;
   score = 50.0 + (fvgC * 0.25) + 25.0;
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectJudasFVG(int dir, double &score) {
   score = 0.0;
   if (!ICT_DetectJudasSwing(Symbol(), Period())) return false;
   double swLvl = 0, swConf = 0;
   if (!ICT_DetectLiquiditySweep(dir, swLvl, swConf)) return false;
   bool fvgB = false; double gh = 0, gl = 0, fvgC = 0;
   if (!ICT_DetectFairValueGap(1, fvgB, gh, gl, fvgC)) return false;
   if (dir == 1 && !fvgB) return false;
   if (dir == -1 && fvgB) return false;
   double macro = Hyb_MacroTimeScore();
   score = 30.0 + (swConf * 0.25) + (fvgC * 0.20) + (macro * 0.25);
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectOBFVGConfluence(int dir, double &score) {
   score = 0.0;
   bool obB = false; double obH = 0, obL = 0, obStr = 0;
   if (!ICT_DetectOrderBlock(2, obB, obH, obL, obStr)) return false;
   if (dir == 1 && !obB) return false;
   if (dir == -1 && obB) return false;
   bool fvgB = false; double gh = 0, gl = 0, fvgC = 0;
   if (!ICT_DetectFairValueGap(1, fvgB, gh, gl, fvgC)) return false;
   if (dir == 1 && !fvgB) return false;
   if (dir == -1 && fvgB) return false;
   bool overlap = (gh >= obL && gl <= obH);
   double pdAlign = 0.0;
   int pd = ICT_ComputePremiumDiscount(Symbol(), Period(), 25);
   if (dir == 1 && pd == -1) pdAlign = 25.0;       // discount for buys
   if (dir == -1 && pd ==  1) pdAlign = 25.0;      // premium for sells
   score = 30.0 + (obStr * 0.20) + (fvgC * 0.15) + (overlap ? 15.0 : 0.0) + pdAlign;
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectOBMitigationOTE(int dir, double &score) {
   score = 0.0;
   double mH = 0, mL = 0;
   if (!ICT_DetectMitigationBlock(Symbol(), Period(), dir, 30, mH, mL)) return false;
   double oteQ = Hyb_OTEQuality(dir, 30);
   bool disp = ICT_DetectDisplacement(Symbol(), Period(), 1);
   score = 30.0 + (oteQ * 0.40) + (disp ? 30.0 : 10.0);
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectLiquidityBreakerFVG(int dir, double &score) {
   score = 0.0;
   double swLvl = 0, swConf = 0;
   if (!ICT_DetectLiquiditySweep(dir, swLvl, swConf)) return false;
   double bH = 0, bL = 0;
   if (!ICT_DetectBreakerBlock(Symbol(), Period(), dir, 30, bH, bL)) return false;
   bool fvgB = false; double gh = 0, gl = 0, fvgC = 0;
   if (!ICT_DetectFairValueGap(1, fvgB, gh, gl, fvgC)) return false;
   if (dir == 1 && !fvgB) return false;
   if (dir == -1 && fvgB) return false;
   score = 25.0 + (swConf * 0.25) + (fvgC * 0.20) + 30.0;
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectAMDExpansion(int dir, double &score) {
   score = 0.0;
   int amdDir = 0;
   if (!ICT_DetectAMD(Symbol(), Period(), amdDir)) return false;
   if (amdDir != dir) return false;
   bool disp = ICT_DetectDisplacement(Symbol(), Period(), 1);
   double macro = Hyb_MacroTimeScore();
   score = 35.0 + (disp ? 35.0 : 10.0) + (macro * 0.25);
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectSMT_MSS_FVG(int dir, double &score) {
   // Real path if SMT pair is reachable; otherwise prudent fallback that
   // requires MSS+FVG and tags freshness / confluence (no fake SMT score).
   score = 0.0;
   double mssConf = 0;
   if (!ICT_DetectMarketStructureShift(dir, mssConf)) return false;
   bool fvgB = false; double gh = 0, gl = 0, fvgC = 0;
   if (!ICT_DetectFairValueGap(1, fvgB, gh, gl, fvgC)) return false;
   if (dir == 1 && !fvgB) return false;
   if (dir == -1 && fvgB) return false;
   int smtDir = 0;
   bool smtOk = Hyb_TrySMT(smtDir);
   double smtBoost;
   if (smtOk) {
      // Real SMT divergence; score requires alignment with `dir`.
      if (smtDir != dir) return false;
      smtBoost = 30.0;
   } else {
      // Fallback: no SMT data — use displacement as a poor-man surrogate.
      // Mark setup but cap the contribution so we never sell fake capability.
      bool disp = ICT_DetectDisplacement(Symbol(), Period(), 1);
      smtBoost = disp ? 10.0 : 0.0;
   }
   score = 25.0 + (mssConf * 0.25) + (fvgC * 0.20) + smtBoost;
   if (score > 100.0) score = 100.0;
   return true;
}

bool Hybrid_DetectMacroTime_LiquidityFVG(int dir, double &score) {
   score = 0.0;
   double macro = Hyb_MacroTimeScore();
   if (macro < 40.0) return false;                 // require at least a session
   double swLvl = 0, swConf = 0;
   if (!ICT_DetectLiquiditySweep(dir, swLvl, swConf)) return false;
   bool fvgB = false; double gh = 0, gl = 0, fvgC = 0;
   if (!ICT_DetectFairValueGap(1, fvgB, gh, gl, fvgC)) return false;
   if (dir == 1 && !fvgB) return false;
   if (dir == -1 && fvgB) return false;
   bool disp = ICT_DetectDisplacement(Symbol(), Period(), 1);
   score = 20.0 + (macro * 0.30) + (swConf * 0.20) + (fvgC * 0.15) + (disp ? 15.0 : 0.0);
   if (score > 100.0) score = 100.0;
   return true;
}

// =================== Hybrid Engine main update =============================
//
// Probes every model in both directions and keeps the best. Updates the
// public g_hyb_* state. Sets soft hold/cancel hints based on penalty
// pressure (penalty is high when a model fires but invalidation primitives
// — opposite-direction sweep, premium/discount mismatch, missing
// displacement — are also visible).
void UpdateHybridEngine() {
   // Reset
   g_hyb_confidence            = 0.0;
   g_hyb_bias                  = 0;
   g_hyb_quality_score         = 0.0;
   g_hyb_penalty_score         = 0.0;
   g_hyb_model_id              = HYB_MODEL_NONE;
   g_hyb_model_class           = HYB_CLASS_NONE;
   g_hyb_model_name            = "none";
   g_hyb_sweep_detected        = false;
   g_hyb_displacement_score    = 0.0;
   g_hyb_mss_detected          = false;
   g_hyb_bos_detected          = false;
   g_hyb_retracement_quality   = 0.0;
   g_hyb_entry_zone_score      = 0.0;
   g_hyb_liquidity_target_score= 0.0;
   g_hyb_invalidation_score    = 0.0;
   g_hyb_freshness_score       = 0.0;
   g_hyb_confluence_score      = 0.0;
   g_hyb_hold_continue         = false;
   g_hyb_cancel_signal         = false;
   g_hyb_dir_best              = 0;

   // Pre-compute reusable signals
   double tmp = 0;
   g_hyb_displacement_score = ICT_DetectDisplacement(Symbol(), Period(), 1) ? 100.0 : 30.0;
   double swLvlUp = 0, swConfUp = 0;
   double swLvlDn = 0, swConfDn = 0;
   bool sweepUp = ICT_DetectLiquiditySweep( 1, swLvlUp, swConfUp);
   bool sweepDn = ICT_DetectLiquiditySweep(-1, swLvlDn, swConfDn);
   g_hyb_sweep_detected = (sweepUp || sweepDn);
   double mssConfUp = 0, mssConfDn = 0;
   bool mssUp = ICT_DetectMarketStructureShift( 1, mssConfUp);
   bool mssDn = ICT_DetectMarketStructureShift(-1, mssConfDn);
   g_hyb_mss_detected = (mssUp || mssDn);
   g_hyb_bos_detected = g_hyb_mss_detected; // primitive treats them together
   g_hyb_retracement_quality = MathMax(Hyb_OTEQuality(1, 30), Hyb_OTEQuality(-1, 30));

   // Iterate the 10 models in both directions; keep the best score.
   double bestScore = 0.0;
   int    bestDir   = 0;
   int    bestId    = HYB_MODEL_NONE;
   int    bestClass = HYB_CLASS_NONE;
   string bestName  = "none";

   double s; bool fired;
   for (int d = -1; d <= 1; d += 2) {
      // ---- Reversal models ----
      fired = Hybrid_DetectSweepMSSFVG(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_SWEEP_MSS_FVG; bestClass=HYB_CLASS_REVERSAL; bestName="sweep_mss_fvg";
      }
      fired = Hybrid_DetectBreakerOTE(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_BREAKER_OTE; bestClass=HYB_CLASS_REVERSAL; bestName="breaker_ote";
      }
      fired = Hybrid_DetectUnicorn(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_UNICORN; bestClass=HYB_CLASS_REVERSAL; bestName="unicorn";
      }
      fired = Hybrid_DetectJudasFVG(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_JUDAS_FVG; bestClass=HYB_CLASS_REVERSAL; bestName="judas_fvg";
      }
      // ---- Continuation models ----
      fired = Hybrid_DetectOBFVGConfluence(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_OB_FVG_CONFLUENCE; bestClass=HYB_CLASS_CONTINUATION; bestName="ob_fvg";
      }
      fired = Hybrid_DetectOBMitigationOTE(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_OB_MIT_OTE; bestClass=HYB_CLASS_CONTINUATION; bestName="ob_mit_ote";
      }
      fired = Hybrid_DetectLiquidityBreakerFVG(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_LIQ_BREAKER_FVG; bestClass=HYB_CLASS_CONTINUATION; bestName="liq_breaker_fvg";
      }
      fired = Hybrid_DetectAMDExpansion(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_AMD_EXPANSION; bestClass=HYB_CLASS_CONTINUATION; bestName="amd_exp";
      }
      // ---- Advanced models ----
      fired = Hybrid_DetectSMT_MSS_FVG(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_SMT_MSS_FVG; bestClass=HYB_CLASS_ADVANCED; bestName="smt_mss_fvg";
      }
      fired = Hybrid_DetectMacroTime_LiquidityFVG(d, s);
      if (fired && s > bestScore) {
         bestScore=s; bestDir=d; bestId=HYB_MODEL_MACRO_LIQ_FVG; bestClass=HYB_CLASS_ADVANCED; bestName="macro_liq_fvg";
      }
   }

   // No model fired: stay neutral, leave hints empty.
   if (bestId == HYB_MODEL_NONE) {
      g_hyb_last_update = TimeCurrent();
      return;
   }

   g_hyb_dir_best        = bestDir;
   g_hyb_bias            = bestDir;
   g_hyb_model_id        = bestId;
   g_hyb_model_class     = bestClass;
   g_hyb_model_name      = bestName;
   g_hyb_quality_score   = bestScore;

   // Auxiliary scores for the public payload
   g_hyb_entry_zone_score        = Hyb_OTEQuality(bestDir, 30);
   g_hyb_liquidity_target_score  = Hyb_LiqTargetScore(bestDir);
   g_hyb_freshness_score         = (bestDir != 0) ? 80.0 : 0.0; // bar 1 model
   g_hyb_confluence_score        = MathMin(100.0,
                                          (g_hyb_entry_zone_score + g_hyb_liquidity_target_score) * 0.5);
   g_hyb_invalidation_score      = MathMin(100.0,
                                          (((bestDir == 1) && (sweepDn)) ||
                                           ((bestDir == -1) && (sweepUp))) ? 70.0 : 20.0);

   // Confidence: weighted blend of model quality + zone + target + macro-time
   double macro = Hyb_MacroTimeScore();
   g_hyb_confidence = MathMin(100.0,
      0.55 * g_hyb_quality_score +
      0.15 * g_hyb_entry_zone_score +
      0.15 * g_hyb_liquidity_target_score +
      0.15 * macro);

   // Penalty: opposite-dir sweep counter-evidence + low macro time + no displacement
   double penalty = 0.0;
   if ((bestDir == 1  && sweepDn) || (bestDir == -1 && sweepUp))      penalty += 35.0;
   if (macro < 30.0)                                                 penalty += 25.0;
   if (g_hyb_displacement_score < 50.0)                              penalty += 20.0;
   if (g_hyb_invalidation_score > 60.0)                              penalty += 20.0;
   g_hyb_penalty_score = MathMin(100.0, penalty);

   // Soft hold/cancel hints (use adaptive thresholds: stricter on clean
   // markets / killzones, looser on noisy assets / off-hours).
   int qmin_now = Hyb_QualityMinNow();
   int pmax_now = Hyb_PenaltyMaxNow();
   g_hyb_hold_continue  = (bestClass == HYB_CLASS_CONTINUATION &&
                          g_hyb_quality_score   >= qmin_now &&
                          g_hyb_penalty_score    < pmax_now);
   g_hyb_cancel_signal  = (g_hyb_penalty_score   >= pmax_now &&
                          g_hyb_confidence       <  HybridMinConfidence);

   g_hyb_last_update = TimeCurrent();
}

// =================== Refinement helpers (consumed by owners) ===============
//
// Each helper takes the strategy-native value and returns a refined one.
// All effects are SOFT — never bring confidence below 0 or above 100, never
// flip a non-zero bias to its opposite without independent corroboration.

double Hybrid_RefineConfidence(double base_conf, string strat) {
   // No usable model -> small neutral nudge based on penalty so we don't ride
   // into trades while invalidation pressure is high.
   int pmax_now = Hyb_PenaltyMaxNow();
   double out = base_conf;
   if (g_hyb_model_id == HYB_MODEL_NONE) {
      if (g_hyb_penalty_score >= pmax_now) out -= 5.0;
      if (out < 0.0)   out = 0.0;
      if (out > 100.0) out = 100.0;
      return out;
   }
   double weight = 0.20;       // default soft weight
   if (strat == "FVG")     weight = 0.30;
   if (strat == "SMC")     weight = 0.30;
   if (strat == "ICT")     weight = 0.30;
   if (strat == "Reverse") weight = 0.25;
   if (strat == "Breakout")weight = 0.20;
   if (strat == "Grid")    weight = 0.10;       // Grid is refine-only
   out = (1.0 - weight) * base_conf + weight * g_hyb_confidence;
   if (g_hyb_penalty_score >= pmax_now) out -= 10.0;
   if (out < 0.0)   out = 0.0;
   if (out > 100.0) out = 100.0;
   return out;
}

int Hybrid_RefineBias(int base_bias, string strat) {
   if (g_hyb_model_id == HYB_MODEL_NONE) return base_bias;
   if (g_hyb_confidence < HybridMinConfidence) return base_bias;
   if (base_bias == 0)                  return g_hyb_bias;          // adopt
   if (base_bias == g_hyb_bias)         return base_bias;            // confirm
   // Conflict: keep base unless hybrid is very strong AND penalty low.
   if (g_hyb_confidence >= 85.0 && g_hyb_penalty_score < 30.0) return g_hyb_bias;
   return base_bias;
}

double Hybrid_QualityFor(string strat) {
   // Strategies use this to shape ranking / lot tier — never to hard-block.
   if (g_hyb_model_id == HYB_MODEL_NONE) return 50.0;
   double q = g_hyb_quality_score;
   if (strat == "Grid") q = 0.5 * (q + 50.0); // attenuate for Grid
   return q;
}

bool Hybrid_ShouldDiscourage(string strat) {
   // FASE 2A + ITER 25 (FIX-1) — support engine, SOFT discouragement only.
   //   Returns a "discouragement HINT" boolean. Even cancel_signal alone
   //   is NOT enough — we require BOTH cancel_signal AND mid+ penalty
   //   AND low confidence (a true triple-bad combination) before we
   //   recommend discouragement. Otherwise a stale hub state would veto
   //   precision-entry setups that the structural Decision Engine has
   //   already validated.
   //   The discouragement is consumed by SupportEngines_QualityPenalty
   //   (soft penalty 0..40) + Hybrid_RefineConfidence (downgrade) —
   //   never as a hard return-false in Strategy_*_Logic.
   if (strat == "Predicted") return false;
   bool tripleBad =
      g_hyb_cancel_signal &&
      g_hyb_penalty_score >= Hyb_PenaltyMaxNow() * 0.75 &&
      g_hyb_confidence    <  HybridMinConfidence;
   if (tripleBad) {
      static datetime __hyb_tripleLog = 0;
      if (TimeCurrent() - __hyb_tripleLog > 60) {
         __hyb_tripleLog = TimeCurrent();
         PrintFormat("[Hybrid] %s SOFT_DISCOURAGE triple-bad (cancel=%d pen=%.1f conf=%.1f) - quality downgrade",
                     strat, (int)g_hyb_cancel_signal, g_hyb_penalty_score, g_hyb_confidence);
      }
      return true;   // hint only — Strategy_*_Logic does not early-return on this
   }
   if (g_hyb_penalty_score >= Hyb_PenaltyMaxNow() &&
       g_hyb_confidence    <  HybridMinConfidence) {
      static datetime __hyb_lastLog = 0;
      if (TimeCurrent() - __hyb_lastLog > 30) {
         __hyb_lastLog = TimeCurrent();
         PrintFormat("[Hybrid] %s soft-penalty (score=%.1f conf=%.1f) - quality downgrade only, no veto",
                     strat, g_hyb_penalty_score, g_hyb_confidence);
      }
   }
   return false;
}

// ============================================================
// BLOCCO 1 NEW - SUPPORT ENGINES SOFT (Hybrid / OF / Pattern /
// Filter / AI hub). Sostituisce i "if (...ShouldDiscourage...)
// return false" sparsi nei flow owner.
//
// Ritorna una PENALTY 0..40 da SOTTRARRE al quality di
// Staging_Submit. NON blocca mai il flow owner: lascia che il
// quality decida a valle (Mode_QualityFloor + dedup +
// SUPERIOR_REPLACE). Cosi' Hybrid/OF/Pattern/Filter/AI sono
// VERAMENTE soft "help, no veto".
//
// HARD GATES legittimi RIMANGONO separati (gestiti altrove):
//   - spread (IsSpreadAcceptable)
//   - margin (Gate_CanTradeNow / IsSafeToTrade)
//   - DD (IsMaxTotalDDExceeded)
//   - news high_impact_block (g_aiq_news_block_state)
//   - broker state (IsTradeAllowed / IsConnected)
//   - symbol unsafe (MarketFiltersActive)
//
// Esclude Predicted (vive su flow news separato).
// ============================================================
double SupportEngines_QualityPenalty(string strat, string &reason) {
   if (strat == "Predicted") { reason = ""; return 0.0; }
   double pen = 0.0;
   string parts = "";
   // ITER 30 — penalty weights demoted further. The stack of medium
   //   negatives kept suffocating structurally good setups (one source
   //   "hyb_midPen + of_midDanger + atr_regime + rsi_ext" already piled
   //   up ~16-18 points pre-cap, which was enough to push borderline
   //   precision setups under Adaptive_QualityFloor). New weights are
   //   ~25% lower per source and the cumulative cap drops accordingly.
   if (g_hyb_model_id != HYB_MODEL_NONE) {
      if (g_hyb_penalty_score >= Hyb_PenaltyMaxNow() &&
          g_hyb_confidence    <  HybridMinConfidence) {
         pen += 9.0;        // ITER30: 12.0 → 9.0
         parts += "hyb_lowConf+highPen,";
      } else if (g_hyb_penalty_score >= Hyb_PenaltyMaxNow() * 0.75) {
         pen += 4.0;        // ITER30: 5.0 → 4.0
         parts += "hyb_midPen,";
      }
   }
   if (OF_IsFresh()) {
      if (g_of_execution_danger >= 0.75 || g_of_cancel_signal >= 0.75) {
         pen += 9.0;        // ITER30: 12.0 → 9.0
         parts += "of_danger>=0.75,";
      } else if (g_of_execution_danger >= 0.50 || g_of_cancel_signal >= 0.50) {
         pen += 4.0;        // ITER30: 5.0 → 4.0
         parts += "of_danger>=0.50,";
      }
   }
   if (AIQ_IsFresh()) {
      if (g_aiq_cancel_signal >= 0.80) {
         pen += 6.0;        // ITER30: 8.0 → 6.0
         parts += "aiq_cancel>=0.80,";
      } else if (g_aiq_cancel_signal >= 0.60) {
         pen += 2.0;        // ITER30: 3.0 → 2.0
         parts += "aiq_cancel>=0.60,";
      }
   }
   double pConf = CalculatePatternConfidence();
   if (pConf > 0 && pConf < PatternsConfidence) {
      double gap = PatternsConfidence - pConf;
      pen += MathMin(4.0, gap * 0.15);   // ITER30: cap 6→4, slope .18→.15
      parts += StringFormat("pat_low(%.0f),", pConf);
   }
   if (!CheckFiltersRSI()) { pen += 1.5; parts += "rsi_ext,"; }    // ITER30: 2.5→1.5
   if (!CheckFiltersATR()) { pen += 3.0; parts += "atr_regime,"; } // ITER30: 4.0→3.0
   // ITER 27/28/30 — Mode-aware cumulative cap, lowered again. Cap is
   //   the absolute maximum subtraction from quality by the support
   //   engine stack — anything above it never lands on the setup.
   double cap;
   if      (Mode == Aggressive)   cap = 14.0;   // ITER30: 18.0 → 14.0
   else if (Mode == Conservative) cap = 28.0;   // ITER30: 32.0 → 28.0
   else                            cap = 20.0;  // ITER30: 25.0 → 20.0
   if (pen > cap) pen = cap;
   reason = parts;
   return pen;
}

// HARD-GATE only: ritorna true SOLO per news high-impact block
// reale o cancel_signal davvero estremo (>=0.95). Usato dai flow
// owner che richiedono comunque uno stop di emergenza dichiarato.
//
// ITER 25 (FIX-1): `g_hyb_cancel_signal` REMOVED from hard-gate set.
//   Hybrid cancel is a discouragement hint, NOT a catastrophic state.
//   It now feeds SOFT downgrade pathways (Staging_ConfirmCanDeploy
//   soft-defer + quality nudge, Hybrid_ShouldDiscourage soft hint,
//   SupportEngines_QualityPenalty soft penalty) so it shapes ranking
//   without blocking precision-entry deploys by default.
bool SupportEngines_HardGate(string strat) {
   if (strat == "Predicted") return false;
   if (AIQ_IsFresh() && g_aiq_news_block_state == "high_impact_block") return true;
   // (g_hyb_cancel_signal hard-trigger removed in ITER 25 — soft only)
   if (AIQ_IsFresh() && g_aiq_cancel_signal       >= 0.95) return true;
   if (OF_IsFresh()  && g_of_execution_danger     >= 0.95) return true;
   if (OF_IsFresh()  && g_of_cancel_signal        >= 0.95) return true;
   return false;
}

// ════════════════════════════════════════════════════════════════════
// PHASE 5 — SUPPORT ENGINES AUDIT REPORT
// Called once in OnInit to enumerate every legitimate HARD gate left
// in the engine. Any additional hard-block introduced anywhere else
// will trigger a SmartLog WARNING line, making regressions visible.
//
// Legitimate HARD blockers (catastrophic only — NOT subject to soft):
//   1. News high-impact block (AIQ news state)
//   2. Cancel signal extreme >=0.95 (HYB / AIQ / OF)
//   3. Execution danger extreme >=0.95 (OF)
//   4. Spread > MaxSpreadPoints (IsSpreadAcceptable)
//   5. Margin failure (Gate_CanTradeNow / IsSafeToTrade)
//   6. Daily/Total DD lock (IsMaxTotalDDExceeded)
//   7. Broker disconnect / trade not allowed
//
// Everything else MUST be a SupportEngines_QualityPenalty soft penalty.
// ════════════════════════════════════════════════════════════════════
void SupportEngines_AuditReport() {
   int hardCount = 0;
   string list   = "";
   if (true) { hardCount++; list += "1=NEWS_HIGH; "; }
   if (true) { hardCount++; list += "2=CANCEL>=0.95; "; }
   if (true) { hardCount++; list += "3=EXEC_DANGER>=0.95; "; }
   if (true) { hardCount++; list += "4=SPREAD>cap; "; }
   if (true) { hardCount++; list += "5=MARGIN_FAIL; "; }
   if (true) { hardCount++; list += "6=DD_LOCK; "; }
   if (true) { hardCount++; list += "7=BROKER_DISCONNECT; "; }
   SmartLog_Brain("AUDIT",
      StringFormat("SupportEngines hard-gates active: %d (target ≤7) — %s",
                   hardCount, list),
      C'120,200,255');
   PrintFormat("[AUDIT] SupportEngines hard-gates count=%d (catastrophic only)", hardCount);

   // ITER 23 (FASE G + MISSING-1) — FORCED-SOFT declaration. Greppable.
   //   Hybrid / Orderflow / Pattern / Filter (RSI+ATR) MUST be soft only.
   //   No early-return based on these is allowed in Strategy_*_Logic.
   //   Acceptance: grep this exact line in journal at startup AND grep
   //   the Strategy_*_Logic functions for `return` after Hybrid/OF/Pattern/
   //   Filter checks → must show only "soft penalty, no veto" comments.
   Print("[OBLIVIOUS][AUDIT][SUPPORT_FORCED_SOFT] hybrid=SOFT orderflow=SOFT pattern=SOFT filter_rsi=SOFT filter_atr=SOFT vwap=SOFT bst=SOFT ai_hub_signals=SOFT (no_owner_early_return)");
   PrintFormat("[OBLIVIOUS][AUDIT][SUPPORT_HARDGATE_REMOVED] FVG=removed SMC=removed ICT=removed Breakout=removed Reverse=removed Grid=removed (catastrophic_only_above)");

   // Diagnostic: every owner using a non-lifecycle shortcut → warn.
   string owners[7] = {"FVG","SMC","ICT","Breakout","Reverse","Grid","Predicted"};
   for (int i = 0; i < 7; i++) {
      if (OBL_OwnerHasShortcut(owners[i])) {
         SmartLog_Brain("AUDIT",
            StringFormat("WARNING: owner '%s' has a non-lifecycle shortcut — investigate",
                         owners[i]),
            C'255,80,80');
      }
   }
}

// ════════════════════════════════════════════════════════════════════
// PHASE 9 — RISK MODE AUDIT REPORT
// Enumerates all active risk-input parameters at startup so the user
// sees precedence and conflicts at-a-glance. Catches misconfigurations
// (e.g. ManualLot>0 AND RiskPercent>0 → ManualLot wins).
// ════════════════════════════════════════════════════════════════════
void RiskMode_AuditReport() {
   SmartLog_Brain("RISK",
      StringFormat("Lot: ManualLot=%.2f (precedence: %s); RiskPercent=%.2f%% (used when ManualLot=0)",
                   ManualLot,
                   (ManualLot > 0 ? "MANUAL_LOT" : "RISK_PERCENT"),
                   RiskPercent),
      C'120,200,255');
   SmartLog_Brain("RISK",
      StringFormat("Clamps: MaxRiskTrade=%.2f%%  MaxRiskSymbol=%.2f%%  MaxOpenPerStrat=%d",
                   MaxRiskTradePercent, MaxRiskForSymbol, MaxOpenTradesPerStrat),
      C'120,200,255');
   SmartLog_Brain("RISK",
      StringFormat("DD: MaxDaily=%.2f%%  MaxTotal=%.2f%%  ChallengePassage=%.2f%%  PeakLock=%.2f%%/retr=%.0f%%",
                   MaxDailyDDPercent, MaxTotalDDPercent,
                   ChallengePassage, PeakProfitLock, PeakProfitRetracePercent),
      C'120,200,255');
   SmartLog_Brain("RISK",
      StringFormat("Cluster/Emergency: ClusterMoney=%.2f  MinEmergProfit=%.2f%%  GlobalComment='%s'",
                   ClusterMoney, MinEmergencyProfitPercent, GlobalComment),
      C'120,200,255');
   // Conflict detection
   if (ManualLot > 0 && RiskPercent > 0) {
      SmartLog_Brain("RISK",
         "NOTE: both ManualLot and RiskPercent are set — ManualLot has precedence (RiskPercent ignored)",
         C'255,200,80');
   }
   if (MaxDailyDDPercent <= 0) {
      SmartLog_Brain("RISK",
         "WARNING: MaxDailyDDPercent=0 — no daily DD safety net active",
         C'255,80,80');
   }
}

