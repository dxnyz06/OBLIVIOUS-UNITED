   bool AI_SyncSLTP_OpenOrders() {
   bool updated =
   false;
   for (
   int i =
   OrdersTotal() -
   1;
   i >=
   0;
   i--) {
   if (!OrderSelect(
   i,
   SELECT_BY_POS,
   MODE_TRADES))
   continue;
   if (OrderSymbol() !=
   Symbol())
   continue;
   if (StringFind(
   OrderComment(),
   AI_TPSL_TAG) <
   0)
   continue;
   int cmd =
   OrderType();
   double entry =
   OrderOpenPrice();
   double sl =
   OrderStopLoss();
   double tp =
   OrderTakeProfit();
   double
   newSL =
   sl,
   newTP =
   tp;
   if (AI_RequestSLTP(
   cmd,
   entry,
   newSL,
   newTP)) {
   if (!IsTPSL_AI())
   newSL =
   sl;
   if (!IsTPSL_AI())
   newTP =
   tp;
   if (newSL !=
   sl ||
   newTP !=
   tp) {
   int digits =
   (int)MarketInfo(
   Symbol(),
   MODE_DIGITS);
   newSL =
   (newSL > 0
   ? NormalizeDouble(
   newSL,
   digits)
   : 0);
   newTP =
   (newTP > 0
   ? NormalizeDouble(
   newTP,
   digits)
   : 0);
   if (OrderModify(
   OrderTicket(),
   OrderOpenPrice(),
   newSL,
   newTP,
   OrderExpiration(),
   OrderArrowColor())) {
   updated =
   true;
   Print(StringFormat(
   "?? AI updated SL/TP | ticket=%d sl=%.5f tp=%.5f",
   OrderTicket(),
   newSL,
   newTP));
   }
   }
   }
   }
   return (
   updated);
   }

   double DynamicTakeProfit() {
