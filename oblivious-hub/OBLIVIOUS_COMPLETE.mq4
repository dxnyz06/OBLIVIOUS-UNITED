// SECTION 07: UTILITY / LOGGING / MATH / TIME / STRING / PRICE

double clamp100(double v)   {
      if (v < 0.0)
        return 0.0;
      if (v > 100.0)
        return 100.0;
      return v; }

int    ClampInt(int v, int lo, int hi)   {
      if (v < lo)
        return lo;
      if (v > hi)
        return hi;
      return v; }

double __norm01(double v)   {
      return clamp01(v <= 1.0 ? v : v / 100.0); }

double __Median(double &arr[], int n)
{
      if (n <= 0)
        return 0.0;
      ArraySort(arr, n, 0, MODE_ASCEND);
      if (n % 2 == 1)
        return arr[n / 2];
      return (arr[n / 2 - 1] + arr[n / 2]) * 0.5;
}

double __MedianOf(double &arr[], int n){
      if (n <= 0)
        return 0;
      int m = n / 2;
      for (int i = 0; i <= m; i++) {
        int minIdx = i;
        for (int j = i + 1; j < n; j++)
          if (arr[j] < arr[minIdx])
            minIdx = j;
        double t = arr[i];
        arr[i] = arr[minIdx];
        arr[minIdx] = t;
      }
      if ((n % 2) == 1)
        return arr[m];
      return 0.5 * (arr[m - 1] + arr[m]);
}

double znorm(double value, double mean, double stddev=1.0)
{
      if (stddev <= 0.0)
        return 0.0;
      return (value - mean) / stddev;
}

void __PushDouble(double &arr[], int maxSize, double val)
{
      int sz = ArraySize(arr);
      if (sz < maxSize) {
        ArrayResize(arr, sz + 1);
        arr[sz] = val;
      } else {
        // shift left
        for (int i = 0; i < sz - 1; i++)
          arr[i] = arr[i + 1];
        arr[sz - 1] = val;
      }
}


double PipsToPrice(double pips)
{
      return pips * Point * (Digits == 3 || Digits == 5 ? 10 : 1);
}

double NormalizePrice(double price)
{
      return NormalizeDouble(price, Digits);
}

double AA_PointsPerPip()
{
      return (Digits == 5 || Digits == 3) ? 10.0 : 1.0;
}

double SpreadPoints()
{
      return (double)MarketInfo(Symbol(), MODE_SPREAD);
}

bool SpreadOk()
{
      // Check spread against maximum allowed spread (from input
      // MaxSpreadPoints)
      double currentSpread = SpreadPoints();
      double maxAllowed = MaxSpreadPoints;
      if (maxAllowed <= 0)
        return true; // No limit set
      return (currentSpread <= maxAllowed);
}

double AA_SpreadPoints()  {
      return (double)MarketInfo(Symbol(), MODE_SPREAD); }

double AA_SpreadPrice()  {
      return AA_SpreadPoints() * Point; }

double AA_Tol(int tf)
{
      double atr = AA_ATR(tf, 1);
      double sp = AA_SpreadPrice();
      // tolerance grows with volatility and transaction costs
      return MathMax(sp * 2.0, atr * 0.15);
}

int ScalePointsByATR(int basePts)
{
      double atr14 = iATR(Symbol(), Period(), 14, 0);
      double atr100 = iATR(Symbol(), Period(), 100, 0);
      if (atr100 <= 0 || atr14 <= 0)
        return basePts;
      double ratio = atr14 / atr100;
      ratio = MathMax(0.5, MathMin(2.0, ratio)); // cap 0.5x - 2.0x
      return (int)MathRound(basePts * ratio);
}

double VolRatioNow()
{
      double v0 = (double)iVolume(Symbol(), Period(), 0);
      double avg = 0;
      for (int i = 1; i <= 20; i++)
        avg += (double)iVolume(Symbol(), Period(), i);
      avg /= 20.0;
      if (avg <= 0)
        return 1.0;
      return v0 / avg;
}

double PipValue(string symbol = "")
{
      if (symbol == "")
        symbol = Symbol();
      double point = MarketInfo(symbol, MODE_POINT);
      int digits = (int)MarketInfo(symbol, MODE_DIGITS);
      if (digits == 3 || digits == 5)
        return point * 10.0;
      return point;
}

void SmartLog_NewEntrySnapshotForTicket(int ticket){
      if (ticket <= 0)
        return;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      if (OrderSymbol() != Symbol())
        return;
      int type = OrderType();
      if (type != OP_BUY && type != OP_SELL)
        return;
      bool isBuy = (type == OP_BUY);
      string strat = OrderComment();
      if (StringLen(strat) == 0)
        strat = currentStrategy;
      double entry = OrderOpenPrice();
      double sl = OrderStopLoss();
      double tp = OrderTakeProfit();

      string ref = "-";
      double rr_show = 0.0;
      // compute RR only where ha senso (no grid/marti) e se SL valido
      bool allowRR = RR_AA_StrategyAllows(strat);
      if (allowRR && sl > 0) {
        double tChosen = 0;
        ref = RR_AA_TargetLabel(isBuy, entry, sl, tChosen);
        double distSL = MathAbs(entry - sl);
        double distTP =
            (tp > 0 ? MathAbs(tp - entry) : MathAbs(tChosen - entry));
        if (distSL > Point * 5 && distTP > Point * 5) {
          double rr_raw = distTP / distSL;
          rr_show = RR_AA_Round(MathMax(2.0, rr_raw));
        }
      }
      string tag = "";
      if (StringFind(strat, "Cobra", 0) >= 0) tag = "[COBRA]";
      else if (StringFind(strat, "SMC", 0) >= 0) tag = "[SMC]";
      else if (StringFind(strat, "Structure", 0) >= 0) tag = "[STRUCT]";
      else if (StringFind(strat, "Emperor", 0) >= 0) tag = "[EMPEROR]";
      else if (StringFind(strat, "Royal", 0) >= 0) tag = "[ROYAL]";
      else if (StringFind(strat, "Grid", 0) >= 0) tag = "[GRID]";
      else if (StringFind(strat, "Marting", 0) >= 0) tag = "[MARTI]";
      else tag = TagFromStrategy(strat);

      string line =
          StringFormat("%s %s SL=%.5f | TP=%.5f | RR=%s | ref=%s", tag,
                       (isBuy ? "BUY" : "SELL"), sl, tp,
                       (rr_show > 0 ? DoubleToString(rr_show, 1) : "-"), ref);
      AddToSmartLog(line);
      SL_MarkNoted(ticket);
}

void SmartLog_Create(string symbol = "")
{
      if (symbol == "")
        symbol = Symbol();
      g_smartlog_head = 0;
      g_smartlog_count = 0;
      g_smartlog_active = true;
      g_smartlog_lastFlush = 0;

      // Create log file via kernel32.dll
      g_smartlog_file = "SmartLog_" + symbol + "_" +
                        TimeToString(TimeCurrent(), TIME_DATE) + ".log";
      string fullPath = TerminalInfoString(TERMINAL_DATA_PATH) +
                        "\\MQL4\\Files" + g_smartlog_file;
      g_smartlog_fileHandle =
          CreateFileA(fullPath, K32_GENERIC_WRITE, K32_FILE_SHARE_READ, 0,
                      K32_CREATE_ALWAYS, K32_FILE_ATTR_NORMAL, 0);
      if (g_smartlog_fileHandle > 0) {
        string hdr = "=== SmartLog Initialized " + TimeToString(TimeCurrent()) +
                     " ===\n";
        uchar buf[];
        StringToCharArray(hdr, buf, 0, WHOLE_ARRAY, CP_ACP);
        int written = 0;
        WriteFile(g_smartlog_fileHandle, buf, ArraySize(buf) - 1, written, 0);
      }

      SmartLogWrap("INIT", "SmartLog created for " + symbol);
}

void SmartLog_Destroy()
{
      if (g_smartlog_fileHandle > 0) {
        string footer =
            "=== SmartLog Closed " + TimeToString(TimeCurrent()) + " ===\n";
        uchar buf[];
        StringToCharArray(footer, buf, 0, WHOLE_ARRAY, CP_ACP);
        int written = 0;
        WriteFile(g_smartlog_fileHandle, buf, ArraySize(buf) - 1, written, 0);
        CloseHandle(g_smartlog_fileHandle);
        g_smartlog_fileHandle = -1;
      }
      g_smartlog_active = false;
      g_smartlog_count = 0;
      g_smartlog_head = 0;
}

void SmartLog_AddLine(string category, string msg)
{
      string line = TimeToString(TimeCurrent(), TIME_SECONDS) + " [" +
                    category + "] " + msg;

      // Ring buffer
      g_smartlog_ring[g_smartlog_head] = line;
      g_smartlog_head = (g_smartlog_head + 1) % SMARTLOG_MAX_LINES;
      if (g_smartlog_count < SMARTLOG_MAX_LINES)
        g_smartlog_count++;

      // File output via kernel32.dll (rate-limited: max once per second)
      if (g_smartlog_fileHandle > 0) {
        datetime now = TimeCurrent();
        if (now != g_smartlog_lastFlush) {
          string lineOut = line + "\n";
          uchar buf[];
          StringToCharArray(lineOut, buf, 0, WHOLE_ARRAY, CP_ACP);
          int written = 0;
          WriteFile(g_smartlog_fileHandle, buf, ArraySize(buf) - 1, written, 0);
          FlushFileBuffers(g_smartlog_fileHandle);
          g_smartlog_lastFlush = now;
        }
      }
}

void SmartLog_Snapshot()
{
      if (!g_smartlog_active)
        return;

      double equity = AccountEquity();
      double balance = AccountBalance();
      double margin = AccountMargin();
      double freeMargin = AccountFreeMargin();
      int total = OrdersTotal();

      int buyCount = 0, sellCount = 0;
      double buyLots = 0, sellLots = 0;
      double totalPnL = 0;

      for (int i = 0; i < total; i++) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        int type = OrderType();
        if (type == OP_BUY) {
          buyCount++;
          buyLots += OrderLots();
          totalPnL += OrderProfit() + OrderSwap() + OrderCommission();
        } else if (type == OP_SELL) {
          sellCount++;
          sellLots += OrderLots();
          totalPnL += OrderProfit() + OrderSwap() + OrderCommission();
        }
      }

      string snap = StringFormat(
          "BAL:%.2f | EQ:%.2f | MAR:%.2f | Free:%.2f | PnL:%.2f | " +
              "Buy:%d(%.2f) Sell:%d(%.2f) | Spread:%.1f",
          balance, equity, margin, freeMargin, totalPnL, buyCount, buyLots,
          sellCount, sellLots, MarketInfo(Symbol(), MODE_SPREAD));

      SmartLog_AddLine("SNAPSHOT", snap);
}

void SmartLog_TickUpdate()
{
      if (!SmartPanel) {
        for (int __i = 0; __i < SL_LINES; __i++)
          ObjectDelete(0, SL_Name(__i));
        return;
      }
      static bool __sl_inited = false;
      if (!__sl_inited) {
        SmartLog_Create();
        __sl_inited = true;
      } else {
        // se gli oggetti sono stati rimossi, ricreali
        if (ObjectFind(0, SL_Name(0)) < 0)
          SmartLog_Create();
      }
      if (!SmartPanel)
        return;
      SmartLog_CaptureTrades();
      static datetime lastSnap = 0;
      if (TimeCurrent() - lastSnap >= 7) {
        SmartLog_Snapshot();
        lastSnap = TimeCurrent();
      }

      // Auto-adaptive RR post-open adjust (no inputs, no caps)
      for (int __i = 0; __i < OrdersTotal(); __i++) {
        if (!OrderSelect(__i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != Magic)
          continue;
        string __strat = OrderComment();
        if (StringLen(__strat) == 0)
          __strat = currentStrategy;
        RR_AA_ApplyToTicket(OrderTicket(), __strat);
      }

      // Dynamic SL/TP management per ticket (fully adaptive)
      for (int ___i = 0; ___i < OrdersTotal(); ___i++) {
        if (!OrderSelect(___i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != Magic)
          continue;
        string ___strat = OrderComment();
        if (StringLen(___strat) == 0)
          ___strat = currentStrategy;
        SLTP_AA_ManageTicket(OrderTicket(), ___strat);
      }

      // Per-trade snapshot line (only once per ticket)
      for (int __j = 0; __j < OrdersTotal(); __j++) {
        if (!OrderSelect(__j, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != Magic)
          continue;
        int __tk = OrderTicket();
        if (!SL_IsNoted(__tk))
          SmartLog_NewEntrySnapshotForTicket(__tk);
      }

      // ==== Tagged ORDER events (EA FULL 1) ====
      for (int _i = 0; _i < OrdersTotal(); _i++) {
        if (!OrderSelect(_i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != Magic)
          continue;
        int tk = OrderTicket();
        int idx = SL_FindTracked_EA1(tk);
        if (idx < 0) {
          SL_TrackEnsure_EA1(tk);
          SL_OnOrderOpen(tk);
        } else {
          double oldSL = SL_trackedSL_EA1[idx], oldTP = SL_trackedTP_EA1[idx];
          double newSL = OrderStopLoss(), newTP = OrderTakeProfit();
          if (MathAbs(newSL - oldSL) > Point * 0.1 ||
              MathAbs(newTP - oldTP) > Point * 0.1) {
            SL_OnOrderModify(tk, oldSL, oldTP);
            SL_trackedSL_EA1[idx] = newSL;
            SL_trackedTP_EA1[idx] = newTP;
          }
        }
      }
      int histCount = OrdersHistoryTotal();
      int scanFrom = (int)MathMax(0, histCount - 20);
      for (int _h = histCount - 1; _h >= scanFrom; _h--) {
        if (!OrderSelect(_h, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != Magic)
          continue;
        int tk = OrderTicket();
        int idx = SL_FindTracked_EA1(tk);
        if (idx >= 0 && SL_trackedOpen_EA1[idx]) {
          SL_trackedOpen_EA1[idx] = false;
          SL_OnOrderClose(tk, OrderClosePrice(), OrderProfit());
        }
      }

      // === Auto hooks: per-trade snapshot & ORDER events & SL/TP & RR ===
      for (int j = 0; j < OrdersTotal(); j++) {
        if (!OrderSelect(j, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != Magic)
          continue;
        int tk = OrderTicket();
        if (!SL_IsNoted2(tk))
          SmartLog_NewEntrySnapshotForTicket(tk);
        int idx = SL_FindTracked2(tk);
        if (idx < 0) {
          SL_TrackEnsure2(tk);
          SL_OnOrderOpen(tk);
        } else {
          double oldSL = SL_trackedSL2[idx], oldTP = SL_trackedTP2[idx];
          double newSL = OrderStopLoss(), newTP = OrderTakeProfit();
          if (MathAbs(newSL - oldSL) > Point * 0.1 ||
              MathAbs(newTP - oldTP) > Point * 0.1) {
            SL_OnOrderModify(tk, oldSL, oldTP);
            SL_trackedSL2[idx] = newSL;
            SL_trackedTP2[idx] = newTP;
          }
        }
        // Auto-adaptive managers (if present)
        if (IsStopped() == false) {
          // these calls are no-op if not defined in this EA
          RR_AA_ApplyToTicket(tk, OrderComment());
          SLTP_AA_ManageTicket(tk, OrderComment());
        }
      }
      int hc = OrdersHistoryTotal();
      int from = (int)MathMax(0, hc - 20);
      for (int h = hc - 1; h >= from; h--) {
        if (!OrderSelect(h, SELECT_BY_POS, MODE_HISTORY))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != Magic)
          continue;
        int tk = OrderTicket();
        int idx = SL_FindTracked2(tk);
        if (idx >= 0 && SL_trackedOpen2[idx]) {
          SL_trackedOpen2[idx] = false;
          SL_OnOrderClose(tk, OrderClosePrice(), OrderProfit());
        }
      }
      // === End auto hooks ===
}

void SmartLog_CaptureTrades()
{
      if (!g_smartlog_active)
        return;

      int total = OrdersTotal();
      int count = 0;
      for (int i = 0; i < total; i++) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        int type = OrderType();
        if (type != OP_BUY && type != OP_SELL)
          continue;

        double pnl = OrderProfit() + OrderSwap() + OrderCommission();
        string dir = (type == OP_BUY ? "BUY" : "SELL");
        string tag = TagFromStrategy(OrderComment());

        SmartLog_AddLine("TRADE",
                         StringFormat("%s %s | Tk:%d | Entry:%.5f SL:%.5f "
                                      "TP:%.5f | Lots:%.2f | PnL:%.2f",
                                      tag, dir, OrderTicket(), OrderOpenPrice(),
                                      OrderStopLoss(), OrderTakeProfit(),
                                      OrderLots(), pnl));
        count++;
      }

      SmartLog_AddLine("TRADES",
                       IntegerToString(count) + " open positions captured");
}

void SmartLog_UpdateBarsStatus() {}

void SmartLog_OnTimer()
{
      if (!g_smartlog_active)
        return;

      static int timerTicks = 0;
      timerTicks++;

      // Full snapshot every 60 timer calls (~1 min if timer=1s)
      if (timerTicks % 60 == 0)
        SmartLog_Snapshot();
}

int ParseLevelFromComment(string comment, int magic)
{
      // Try "~ N", " - N", " x N" patterns
      string separators[] = {" ~ ", " - ", " x "};
      for (int s = 0; s < 3; s++) {
        int pos = StringFind(comment, separators[s]);
        if (pos >= 0) {
          string numStr = StringSubstr(comment, pos + StringLen(separators[s]));
          int level =
              (int)StringToInteger(numStr) + 1; // stored as 0-based suffix
          if (level > 0)
            return level;
        }
      }
      return 1; // default seed
}

int ParseLevelFromComment_AA(string comm, int magic){
      int lvl = 1;
      int p = StringFind(comm, "L", 0);
      if (p >= 0 && p + 1 < StringLen(comm)) {
        int v = (int)StringToInteger(StringSubstr(comm, p + 1, 2));
        if (v > 0 && v < 20)
          lvl = v;
      }
      int p2 = StringFind(comm, "lvl", 0);
      if (p2 >= 0) {
        for (int k = p2 + 3; k < StringLen(comm); k++) {
          if ((comm[k] >= '0' && comm[k] <= '9')) {
            lvl = (int)StringToInteger(StringSubstr(comm, k, 2));
            break;
          }
        }
      }
      return lvl;
}

void GV_Init()
{
      // Clean up stale GVs older than 7 days to prevent unbounded growth
      int total = GlobalVariablesTotal();
      datetime cutoff = TimeCurrent() - 7 * 86400;
      for (int i = total - 1; i >= 0; i--) {
        string name = GlobalVariableName(i);
        if (StringFind(name, GV_PREFIX) == 0) {
          datetime lastAccess = GlobalVariableTime(name);
          if (lastAccess > 0 && lastAccess < cutoff)
            GlobalVariableDel(name);
        }
      }
      Print("[GV_Init] Namespace '", GV_PREFIX,
            "' initialised, stale entries purged");
}

void GV_SaveDouble(string name, double val)
{
      GlobalVariableSet(GV_PREFIX + name, val);
}

double GV_LoadDouble(string name, double defaultVal=0.0)
{
      string key = GV_PREFIX + name;
      if (GlobalVariableCheck(key))
        return GlobalVariableGet(key);
      return defaultVal;
}

void GV_SaveInt(string name, int val)
{
      GV_SaveDouble(name, (double)val);
}

int GV_LoadInt(string name, int defaultVal=0)
{
      return (int)GV_LoadDouble(name, (double)defaultVal);
}

void GV_SaveBool(string name, bool val)
{
      GV_SaveDouble(name, val ? 1.0 : 0.0);
}

bool GV_LoadBool(string name, bool defaultVal=false)
{
      return (GV_LoadDouble(name, defaultVal ? 1.0 : 0.0) > 0.5);
}

void GV_SaveString(string name, string val)
{
      string fullPath = TerminalInfoString(TERMINAL_COMMONDATA_PATH) +
                        "\\Files" + GV_PREFIX + name + ".txt";
      int h = CreateFileA(fullPath, K32_GENERIC_WRITE, 0, 0, K32_CREATE_ALWAYS,
                          K32_FILE_ATTR_NORMAL, 0);
      if (h == K32_INVALID_HANDLE)
        return;
      uchar buf[];
      StringToCharArray(val, buf, 0, WHOLE_ARRAY, CP_ACP);
      int written = 0;
      WriteFile(h, buf, ArraySize(buf) - 1, written, 0);
      CloseHandle(h);
}

string GV_LoadString(string name, string defaultVal="")
{
      string fullPath = TerminalInfoString(TERMINAL_COMMONDATA_PATH) +
                        "\\Files" + GV_PREFIX + name + ".txt";
      if (GetFileAttributesA(fullPath) == K32_INVALID_FILE_ATTR)
        return defaultVal;
      int h = CreateFileA(fullPath, K32_GENERIC_READ, K32_FILE_SHARE_READ, 0,
                          K32_OPEN_EXISTING, K32_FILE_ATTR_NORMAL, 0);
      if (h == K32_INVALID_HANDLE)
        return defaultVal;
      uchar buf[];
      ArrayResize(buf, 4096);
      int bytesRead = 0;
      ReadFile(h, buf, 4095, bytesRead, 0);
      CloseHandle(h);
      if (bytesRead <= 0)
        return defaultVal;
      buf[bytesRead] = 0;
      return CharArrayToString(buf, 0, bytesRead, CP_ACP);
}

void GV_DeletePrefix(string prefix)
{
      string fullPrefix = GV_PREFIX + prefix;
      int total = GlobalVariablesTotal();
      // Walk backwards to avoid index shifting
      for (int i = total - 1; i >= 0; i--) {
        string name = GlobalVariableName(i);
        if (StringFind(name, fullPrefix) == 0)
          GlobalVariableDel(name);
      }
}

int GV_ListByPrefix(string prefix, string &names[], double &values[])
{
      string fullPrefix = GV_PREFIX + prefix;
      int count = 0;
      int total = GlobalVariablesTotal();
      ArrayResize(names, 0);
      ArrayResize(values, 0);

      for (int i = 0; i < total; i++) {
        string name = GlobalVariableName(i);
        if (StringFind(name, fullPrefix) == 0) {
          ArrayResize(names, count + 1);
          ArrayResize(values, count + 1);
          names[count] = name;
          values[count] = GlobalVariableGet(name);
          count++;
        }
      }
      return count;
}

void GV_SetTimestamped(string name, double val)
{
      GV_SaveDouble(name, val);
      GV_SaveDouble(name + "_TS", (double)TimeCurrent());
}

double GV_GetTimestamped(string name, datetime &ts)
{
      double val = GV_LoadDouble(name, 0.0);
      ts = (datetime)GV_LoadInt(name + "_TS", 0);
      return val;
}

void RetrieveStrategyStatus(){
