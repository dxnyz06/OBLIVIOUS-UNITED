             l = iBands(Symbol(), 0, 20, 2, 0, PRICE_CLOSE, MODE_LOWER, 0);
      return ((s > 0 && Bid < l) || (s < 0 && Bid > u) || (s == 0 && (Bid < l || Bid > u))); }

