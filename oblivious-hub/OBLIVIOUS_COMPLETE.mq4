        return 0;
      double uw = High[1] - MathMax(Open[1], Close[1]),
             lw = MathMin(Open[1], Close[1]) - Low[1];
      return ((b < r * 0.1 && uw > r * 0.3 && lw > r * 0.3) ? 0.5 : 0); }

double Score_HighWaveCandle()  {
