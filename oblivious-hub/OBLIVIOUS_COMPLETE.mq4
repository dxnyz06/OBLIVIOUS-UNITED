bool SLTP_AA_ManageTicket(int ticket, string strat){
      bool a = SL_AA_ApplyToTicket(ticket, strat);
      bool b = TP_AA_ApplyToTicket(ticket, strat);
      return a && b;
}

bool SL_AA_ApplyToTicket(int ticket, string strat){
      string __tag = TagFromStrategy(strat);

      if (ticket <= 0)
        return false;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber()))
        return false;
      if (OrderSymbol() != Symbol())
        return false;
      int type = OrderType();
      if (type != OP_BUY && type != OP_SELL)
        return false;
      double entry = OrderOpenPrice();
      double sl = OrderStopLoss();
      bool isBuy = (type == OP_BUY);
      // compute adaptive swing and sigma buffer
      int n = AA_AutoN();
      int L = (int)MathMax(8, (int)(n)); // window tied to ÃƒÃ‚Â¢ÃƒÃ¢Â ÃƒÃ‚Â¡Bars
      double mR, sR;
      AA_MeanStd(mR, sR, false, n);
      double swing = isBuy
                         ? iLow(Symbol(), Period(),
                                iLowest(Symbol(), Period(), MODE_LOW, L, 2))
                         : iHigh(Symbol(), Period(),
                                 iHighest(Symbol(), Period(), MODE_HIGH, L, 2));
      double buf = sR; // one std of range as buffer (fully adaptive)
      double newSL = isBuy ? (swing - buf) : (swing + buf);
      // If no SL, set it; if trailing is favorable, tighten behind new swing
      bool improve =
          (sl <= 0) || (isBuy ? (newSL > sl + Point) : (newSL < sl - Point));
      if (improve) {
        bool ok = OrderModify(ticket, entry, newSL, OrderTakeProfit(),
                              OrderExpiration(), clrNONE);
        if (ok)
          AddToSmartLog(StringFormat(
              "%s [SL] ticket=%d swing=%.5f buf=%.5f -> SL=%.5f",
              (isBuy ? "BUY" : "SELL"), ticket, swing, buf, newSL));
        return ok;
      }
      return true;
}

bool TP_AA_ApplyToTicket(int ticket, string strat){
      string __tag = TagFromStrategy(strat);

      if (ticket <= 0)
        return false;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber()))
        return false;
      if (OrderSymbol() != Symbol())
        return false;
      int type = OrderType();
      if (type != OP_BUY && type != OP_SELL)
        return false;
      bool isBuy = (type == OP_BUY);
      int magic = OrderMagicNumber();
      int lvl = AA_LevelFromComment(OrderComment(), magic);
      if (lvl <= 0)
        lvl = 1;
      // Respect runner rule: lvl 1 runner => no TP forced
      if (lvl == 1)
        return true;
      // Skip TP auto for grid/martingala (gestite dal loro motore)
      if (StringFind(strat, "Grid", 0) >= 0) {
        return true; // Grid manages own TP
      }
      double entry = OrderOpenPrice();
      double sl = OrderStopLoss();
      double tp = OrderTakeProfit();
      if (sl <= 0)
        return false; // TP from RR needs a valid SL
      // compute RR-based TP as in RR_AA_ApplyToTicket
      double distSL = MathAbs(entry - sl);
      if (distSL < Point * 5)
        return false;
      double tprice = RR_AA_CalcTargetPrice(isBuy, entry, sl);
      double distTP = MathAbs(tprice - entry);
      if (distTP <= Point * 5)
        return false;
      double rr_raw = distTP / distSL;
      double rr_base = (rr_raw < 2.0 ? 2.0 : rr_raw);
      double rr = RR_AA_Round(rr_base);
      double newTP = isBuy ? (entry + rr * distSL) : (entry - rr * distSL);
      bool needUpdate =
          (tp <= 0) || (isBuy ? (newTP > tp + Point) : (newTP < tp - Point));
      if (needUpdate) {
        bool ok = OrderModify(ticket, entry, sl, newTP, OrderExpiration(), clrNONE);
        AddToSmartLog(
            StringFormat("%s [TP] ticket=%d rr_raw=%.2f -> rr=%.2f TP=%.5f",
                         (isBuy ? "BUY" : "SELL"), ticket, rr_raw, rr, newTP));
        return ok;
      }
      return true;
}

void ComputeAdaptiveSLTP(int &slPoints, int &tpPoints, double rr=2.0, int atrPeriod=14)
{
      double atr = iATR(Symbol(), 0, atrPeriod, 1);
      if (atr <= 0)
        return;
      int atrPts = (int)MathRound(atr / Point);
      int minSL =
          MathMax((int)MathRound(1.2 * atrPts), 8); // ~1.2*ATR or min 8 points
      int minTP = (int)MathMax((int)MathRound(rr * minSL), 12); // RR default 2.0
      if (slPoints <= 0 || slPoints < minSL)
        slPoints = minSL;
      if (tpPoints <= 0 || tpPoints < minTP)
        tpPoints = minTP;
}

bool IsLaguerreRSI() {
      double gamma = 0.7, c = iClose(NULL, 0, 0), c1 = iClose(NULL, 0, 1);
      static double L0 = 0, L1 = 0, L2 = 0, L3 = 0;
      double pL0 = L0, pL1 = L1, pL2 = L2;
      L0 = (1.0 - gamma) * c + gamma * pL0;
      L1 = -gamma * L0 + pL0 + gamma * pL1;
      L2 = -gamma * L1 + pL1 + gamma * pL2;
      L3 = -gamma * L2 + pL2 + gamma * L3;
      double cu = 0, cd = 0;
      if (L0 >= L1) {
        cu += (L0 - L1);
      } else {
        cd += (L1 - L0);
      }
      if (L1 >= L2) {
        cu += (L1 - L2);
      } else {
        cd += (L2 - L1);
      }
      if (L2 >= L3) {
        cu += (L2 - L3);
      } else {
        cd += (L3 - L2);
      }
      double lrsi = (cu + cd > 0) ? cu / (cu + cd) : 0;
      return (lrsi < 0.2);
}

bool IsLinReg() {
      int n = 14;
      if (Bars < n)
        return false;
      double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
      for (int i = 0; i < n; i++) {
        double x = i, y = iClose(NULL, 0, i);
        sumX += x;
        sumY += y;
        sumXY += x * y;
        sumX2 += x * x;
      }
      double denom = n * sumX2 - sumX * sumX;
      if (MathAbs(denom) < 1e-10)
        return false;
      double slope = (n * sumXY - sumX * sumY) / denom;
      double intercept = (sumY - slope * sumX) / n;
      double linRegValue = intercept; // value at shift=0
      return (linRegValue < iClose(NULL, 0, 0));
}

