bool IsSchaffTrendCycle() {
      double macdVal = iMACD(NULL, 0, 23, 50, 1, PRICE_CLOSE, MODE_MAIN, 0);
      double macdPrev = iMACD(NULL, 0, 23, 50, 1, PRICE_CLOSE, MODE_MAIN, 1);
      // Simplified: stochastic of MACD
      double hh = MathMax(macdVal, macdPrev), ll = MathMin(macdVal, macdPrev);
      double stc = (hh > ll) ? ((macdVal - ll) / (hh - ll)) * 100.0 : 50.0;
      return (stc < 10);
}

