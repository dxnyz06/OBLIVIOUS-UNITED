void ParseNewsLine(string line, string &text, string &impact) {
      string s = StringTrim(line);
      if (StringLen(s) == 0) {
        text = "";
        impact = "";
        return;
      }
      string up = StringUpper(s);
      impact = "";
      if (StringFind(up, "HIGH") >= 0)
        impact = "HIGH";
      else if (StringFind(up, "LOW") >= 0)
        impact = "LOW";
      else if (StringFind(up, "MED") >= 0)
        impact = "MEDIUM";
      int l = StringFind(s, "["), r = StringFind(s, "]");
      if (l >= 0 && r > l)
        text = StringTrim(StringSubstr(s, r + 1));
      else {
        l = StringFind(s, "(");
        r = StringFind(s, ")");
        if (l >= 0 && r > l)
          text = StringTrim(StringSubstr(s, r + 1));
        else
          text = s;
      }
}

