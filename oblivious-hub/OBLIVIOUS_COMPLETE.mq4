#define TS_UNARMED    0
#endif
#ifndef TS_PROTECTED
#define TS_PROTECTED  1
#endif
#ifndef TS_BE
#define TS_BE         2
#endif
#ifndef TS_TRAIL
#define TS_TRAIL      3
#endif
