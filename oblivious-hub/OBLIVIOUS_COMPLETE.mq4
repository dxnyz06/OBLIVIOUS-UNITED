color ColorBG(){
      return _ChartColor(CHART_COLOR_BACKGROUND, clrBlack); }

color ColorBear(){
      return _ChartColor(CHART_COLOR_CHART_DOWN, clrRed); }

color ColorBull(){
      return _ChartColor(CHART_COLOR_CHART_UP, clrLime); }

color ColorFG(){
      return _ChartColor(CHART_COLOR_FOREGROUND, clrSilver); }

bool     TB_ShowTrig[12];
string   TB_StrategyNames[12];
datetime TB_LastSigTime[12];
color    TB_OffColor = clrDimGray;
color    TB_OnColor  = clrLime;
color    CandleBullColor = clrLimeGreen;
color    CandleBearColor = clrRed;
int      TB_FontSize = 8;
int      TB_Spacing  = 6;

int TextWidthPxPrecise(string objId, string txt, int fontSize)
{
   string tmpObj = objId + "_TWP";
   if (ObjectFind(0, tmpObj) < 0)
      ObjectCreate(0, tmpObj, OBJ_LABEL, 0, 0, 0);
   ObjectSetString(0, tmpObj, OBJPROP_FONT, "Arial");
   ObjectSetInteger(0, tmpObj, OBJPROP_FONTSIZE, fontSize);
   ObjectSetString(0, tmpObj, OBJPROP_TEXT, txt);
   return (int)(StringLen(txt) * fontSize * 7 / 10);
}

bool TB_IsOnByName(string nm){
      int k = TB_IndexByName(nm);
      if (k < 0)
        return false;
      return TB_ShowTrig[k];
}

int TB_IndexByName(string nm){
      for (int i = 0; i < ArraySize(TB_StrategyNames); i++)
        if (TB_StrategyNames[i] == nm)
          return i;
      return -1;
}

color TB_OffCol(){
      return TB_OffColor; }

color TB_OnCol(){
      return TB_OnColor; }

int TB_TotalWidth()
{
      int total = 0;
      for (int i = 0; i < 11; i++)
        total +=
            TextWidthPxPrecise("TB_TMP", TB_StrategyNames[i], TB_FontSize) +
            TB_Spacing;
      total -= TB_Spacing;
      return total;
}

// Functions: 139

void AutoConfigureStrategies() {
      // Auto-enable strategies based on current market conditions
      double adx = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0);
      double atr = iATR(Symbol(), 0, 14, 0);
      double avgATR = iATR(Symbol(), 0, 14, 20);
      bool trending = (adx > (double)GetAdaptive_ADX_Trend());
      bool highVol = (avgATR > 0 && atr > avgATR * 1.2);
      if (trending && highVol)
        Print("[AUTOCONF] Trending+HighVol detected");
      else if (!trending)
        Print("[AUTOCONF] Ranging detected");
}

double AA_ClampPrice(double p)
{
      int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
      return NormalizeDouble(p, digits);
}

double ATRpct()
{
      double c = iClose(Symbol(), Period(), 0);
      double a = ATRv(14);
      return (c > 0 ? a / c : 0);
}

int Auto_TF()   {
      return Period(); }

int Auto_TFHigher1(){
      int tf = NextHigherTF(Period());
      return EnsureAvailableTF(Symbol(), tf);
}

int Auto_TFHigher2(){
      int tf = NextHigherTF(Auto_TFHigher1());
      return EnsureAvailableTF(Symbol(), tf);
}

