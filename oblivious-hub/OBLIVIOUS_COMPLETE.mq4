   double DynamicLotSize(double sl_price = 0.0, string strat = "") {
   // Lotto dinamico in base al rischio
   double riskPercent =
   1.0; // rischio di default 1%
   double balance =
   AccountBalance();
   double atr = EATR(
   Symbol(),
   Period(),
   14);
   double tickValue =
   MarketInfo(
   Symbol(),
   MODE_TICKVALUE);
   return MathMax(
   0.01,
   (balance *
   riskPercent /
   100) /
   (atr *
   tickValue));
   }

// AI Bridge Functions
string ProcessAITradingRequest(string symbol, string strategyName, int direction, double entryPrice) {
   if (!IsTPSL_AI()) {
      return ""; // Native mode
   }
   
   if (IsBridgeHealthy() == 0) {
      Print("[AI Bridge] Bridge is not healthy");
      return "";
   }
   
   // Build request JSON
   string requestJson = BuildAIRequestJson(symbol, strategyName, direction, entryPrice);
   
   // Process request via DLL
   string response[4096];
//    int result = ProcessAIRequest(requestJson, response, 4096, 30000); // 30 second timeout
   
   string result = "";

   if (StringLen(result) == 0) {
      string error[256];
      GetLastError();
      Print("[AI Bridge] Request failed: ", error[0]);
      return "";
   }
   
   return response[0];
}

string BuildAIRequestJson(string symbol, string strategyName, int direction, double entryPrice) {
   string json = "{";
   json += "\"symbol\":\"" + symbol + "\",";
   json += "\"timeframe\":\"" + PeriodToString(Period()) + "\",";
   json += "\"direction\":" + IntegerToString(direction) + ",";
   json += "\"entry_price\":" + DoubleToString(entryPrice, 5) + ",";
   json += "\"strategy_name\":\"" + strategyName + "\",";
   json += "\"tpsl_mode\":\"AI\",";
   json += "\"setup_score\":" + DoubleToString(GetCurrentSetupScore(), 1) + ",";
   
   // Add volatility context
   double atr = iATR(symbol, Period(), Auto_ATR_Period(), 1);
   json += "\"volatility_context\":{";
   json += "\"atr_value\":" + DoubleToString(atr, 5) + ",";
   json += "\"atr_percentile\":" + DoubleToString(GetATRPercentile(), 1) + ",";
   json += "\"volatility_regime\":\"" + GetVolatilityRegime() + "\"";
   json += "},";
   
   // Add session context
// [AUTO-FIX]    json += "\"session_context\":{";,";
   
   // Add filter supports
   json += "\"filter_supports\":{";
   json += "\"quality_score\":80.0,";
   json += "\"penalty_score\":5.0,";
   json += "\"context_score\":85.0";
   json += "},";
   
   // Add pattern supports
   json += "\"pattern_supports\":{";
   json += "\"direction_support\":" + IntegerToString(g_pat_direction_support) + ",";
   json += "\"confidence_support\":" + DoubleToString(g_pat_confidence_support, 1) + ",";
   json += "\"trigger_quality\":" + DoubleToString(g_pat_trigger_quality, 1);
   json += "}";
   
   json += "}";
   return json;
}

double GetCurrentSetupScore() {
   return 75.0; // Default setup score
}

double GetATRPercentile() {
   return 50.0; // Default ATR percentile
}

string GetVolatilityRegime() {
   double atr = iATR(Symbol(), Period(), Auto_ATR_Period(), 1);
   double atrMA = iMA(Symbol(), Period(), Auto_ATR_Period() * 3, 0, MODE_SMA, PRICE_CLOSE, 1);
   
   if (atr > atrMA * 1.5) return "High";
   if (atr < atrMA * 0.7) return "Low";
   return "Normal";
}


double GetSessionQuality() {
   return 80.0; // Default session quality
}

double GetRelativeVolume() {
   return 1.0; // Default relative volume
}

string PeriodToString(int period) {
   switch(period) {
      case PERIOD_M1: return "M1";
      case PERIOD_M5: return "M5";
      case PERIOD_M15: return "M15";
      case PERIOD_M30: return "M30";
      case PERIOD_H1: return "H1";
      case PERIOD_H4: return "H4";
      case PERIOD_D1: return "D1";
      case PERIOD_W1: return "W1";
      case PERIOD_MN1: return "MN1";
      default: return "UNKNOWN";
   }
}

   double __AP_RiskPerTrade() {
   // Base risk: 0.6% per trade; reduce in high vol or after loss streaks.
   double risk =
   0.006;
   // simple volatility proxy
   double v =
   _MedianTrueRangeN(
   14);
   double vL =
   _MedianTrueRangeN(
   64);
   if (vL >
   0 &&
   v / vL >=
   1.2)
   risk *=
   0.8; // high vol -> reduce
   return risk;
   }

//| 18. execution / order / position / open / modify / close

// [INCOMPLETE_SIGNATURE] int OrderManager_Send(string symbol, int cmd, double lots, double sl, double tp,

// [INCOMPLETE_SIGNATURE] int OrderManager_SendPending(string symbol, int cmd, double lots, double price,

void SmartLog_CloseSnapshot(int ticket)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      double pnl = OrderProfit() + OrderSwap() + OrderCommission();
      string tag = TagFromStrategy(OrderComment());
      SmartLogWrap("CLOSE",
                   StringFormat("%s | Ticket:%d | PnL:%.2f | Lots:%.2f", tag,
                                ticket, pnl, OrderLots()));
}

void SmartLog_UpdateAllPositions()
{
  for (int _i = OrdersTotal() - 1; _i >= 0; _i--)
    if (OrderSelect(_i, SELECT_BY_POS) && OrderSymbol() == Symbol())
      SmartLog_UpdatePosition(OrderTicket());
}
void SmartLog_UpdatePosition(int ticket)
{
      if (!g_smartlog_active)
        return;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      if (OrderSymbol() != Symbol())
        return;

      double pnl = OrderProfit() + OrderSwap() + OrderCommission();
      double entry = OrderOpenPrice();
      double cur = (OrderType() == OP_BUY ? Bid : Ask);
      double dist = cur - entry;
      if (OrderType() == OP_SELL)
        dist = entry - cur;

      double pip = MarketInfo(Symbol(), MODE_POINT);
      if (pip <= 0)
        pip = 0.00001;
      double pips = dist / pip;

      string tag = TagFromStrategy(OrderComment());
      SmartLog_AddLine("POS_UPD",
                       StringFormat("%s | Tk:%d | Pips:%.1f | PnL:%.2f", tag,
                                    ticket, pips, pnl));
}

bool AA_CloseOrderFull(int ticket)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      if (OrderType() != OP_BUY && OrderType() != OP_SELL)
        return false;
      RefreshRates();
      double lots = OrderLots();
      double price = (OrderType() == OP_BUY ? Bid : Ask);
      bool ok = OrderClose(ticket, lots, price, Slippage, clrNONE);
      if (!ok) {
        ResetLastError();
        RefreshRates();
        price = (OrderType() == OP_BUY ? Bid : Ask);
        ok = OrderClose(ticket, lots, price, Slippage, clrNONE);
        if (!ok)
          ResetLastError();
      }
      return ok;
}

bool AA_HasOpenOrPendingByMagic(int magic)
{
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != magic)
          continue;
        int t = OrderType();
        if (t == OP_BUY || t == OP_SELL || t == OP_BUYLIMIT ||
            t == OP_SELLLIMIT || t == OP_BUYSTOP || t == OP_SELLSTOP)
          return true;
      }
      return false;
}

bool AA_OrderModify(int ticket, double price, double sl, double tp)
{
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      // ITER 40 — CROSS-SYMBOL GUARD (CRITICAL FIX):
      //   refuse any modify on a ticket whose symbol differs from the
      //   chart's Symbol(). This was the root cause of the XAUUSD SL
      //   showing BTCUSD price (4576 on BTC, 77627 on Gold) — each
      //   chart instance was modifying tickets globally without
      //   filtering by symbol, polluting cross-symbol SL/TP values.
      if (OrderSymbol() != Symbol()) {
         static datetime __aa_csLog = 0;
         if (TimeCurrent() - __aa_csLog >= 60) {
            __aa_csLog = TimeCurrent();
            PrintFormat("[AA_OrderModify] CROSS_SYMBOL_BLOCKED ticket=%d orderSym=%s chartSym=%s — refused",
                        ticket, OrderSymbol(), Symbol());
         }
         return false;
      }
      RefreshRates();
      // ITER 39 — FULL VIRTUAL ENFORCEMENT (anti broker stop-out):
      //   user contract: "non chiudere mai in negativo" — every broker
      //   SL modification was triggering broker stop-outs (e.g. XAUUSD
      //   #603848276 closed @ entry because BE move set sl=entry).
      //   For all non-Predicted owners we FORCE sl=0 tp=0 → trade
      //   stays fully virtual. The state machine still tracks the
      //   intended SL/TP internally and closes via OrderClose.
      int aaMagic = OrderMagicNumber();
      if (aaMagic != PredictedMagic) {
         sl = 0.0;
         tp = 0.0;
      }
      datetime exp = OrderExpiration();
      bool ok = OrderModify(ticket, price, sl, tp, exp, clrNONE);
      if (!ok) {
        int err = GetLastError();
        ResetLastError();
        // retry once after refresh
        RefreshRates();
        ok = OrderModify(ticket, price, sl, tp, exp, clrNONE);
        if (!ok) {
          ResetLastError();
        }
      }
      return ok;
}

void AA_ManageOpenTrades()
{
      int magicF = AA_MagicFVG();
      int magicS = AA_MagicSMC();

      // Manage all open orders for these magics
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;

        int magic = OrderMagicNumber();
        int type = OrderType();

        // cleanup GV if a pending is still pending (no management)
        if (type == OP_BUYLIMIT || type == OP_SELLLIMIT || type == OP_BUYSTOP ||
            type == OP_SELLSTOP)
          continue;

        int ticket = OrderTicket();
        if (magic == magicF)
          AA_ManageTicket("AA_FVG", ticket, Period(), magicF);
        else if (magic == magicS)
          AA_ManageTicket("AA_SMC", ticket,
                          (Period() <= PERIOD_M5 ? PERIOD_M1 : PERIOD_M5),
                          magicS);
      }

      // Cleanup GV for closed tickets (best-effort)
      // (Avoid unbounded GV growth)
      // Note: MT4 has no direct "closed orders iteration" without history scan;
      // keep minimal.
}

void AA_FVG_Execute(int dir)
{
      ADV_FVG_ZONE z;
      ADV_OB_ZONE ob;
      int tfPOI = (Period() <= PERIOD_M5 ? PERIOD_M15 : Period());
      int lookback = (int)MathMax(50, Auto_ATR_Period() * Auto_ADX_Period());
      if (!ADV_FindFVG_Pro(tfPOI, dir, lookback, false, z, ob))
        return;

      int tfLTF = Period();
      double atr = AA_ATR(tfLTF, 1);
      if (atr <= 0.0)
        atr = 10 * ADV_Pip();
      double buffer = MathMax(AA_Tol(tfLTF), atr * 0.25);

      double sl = (dir > 0 ? (z.bot - buffer) : (z.top + buffer));

      // lots from existing sizing function if present, else fallback to fixed
      // input lot
      double lots = GetCurrentStrategyLot();
      if (lots <= 0.0)
        lots = Lots;

      // EB engine via limit ladder inside the zone
      AA_FVG_PlaceEB(dir, z, sl, lots);
}

void AA_SMC_Execute(int dir)
{
      int tfPOI = PERIOD_M15;
      int tfLTF = (Period() <= PERIOD_M5 ? PERIOD_M1 : PERIOD_M5);

      ADV_FVG_ZONE poi;
      ADV_OB_ZONE ob;
      int lookback = (int)MathMax(80, Auto_ATR_Period() * Auto_ADX_Period());
      if (!ADV_FindFVG_ICT(tfPOI, dir, lookback, poi, ob))
        return;

      double atr = AA_ATR(tfLTF, 1);
      if (atr <= 0.0)
        atr = 10 * ADV_Pip();
      double buffer = MathMax(AA_Tol(tfLTF), atr * 0.25);
      double sl = (dir > 0 ? (poi.bot - buffer) : (poi.top + buffer));

      double lots = GetCurrentStrategyLot();
      if (lots <= 0.0)
        lots = Lots;

      int magic = AA_MagicSMC();
      if (AA_HasOpenOrPendingByMagic(magic))
        return;

      // Entry reference for targets (ICT OTE preference)
      double entryRef = poi.mid;

      double t1, t2, t3, tmax;
      AA_ComputeTargets(tfLTF, dir, entryRef, sl, t1, t2, t3, tmax);

      // Place LIMIT mini-grid inside POI zone (runner + others to TMax)
      EB_PlaceEdgeBiasedLimits(Symbol(), magic, (dir > 0), poi.top, poi.bot,
                               AA_ClampPrice(sl), AA_ClampPrice(tmax), lots);
}

double Score_OpeningMarubozu()  {
      double r = High[1] - Low[1];
      if (r <= 0)
        return 0;
      bool bull = Close[1] > Open[1];
      double tail = bull ? (Open[1] - Low[1]) : (High[1] - Open[1]);
      return ((tail < r * 0.02) ? 0.6 : 0); }

bool SMC_OrderBlockValidation(double ob_level, bool is_bullish)
  {
      // Validazione autoadaptive dell'Order Block:
      // - Displacement (body vs ATR) + Participation (volume vs median)
      // - Senza moltiplicatori fissi: confronto con mediane robuste di finestra
      // recente
      int p = Auto_ATR_Period();
      int q = Auto_ADX_Period();
      int n = p + q;
      n = MathMax(3, n);
      if (Bars < n + 10)
        return (false);

      int sh = 1; // ultima barra chiusa
      double atr = iATR(Symbol(), PERIOD_CURRENT, p, sh);
      if (atr <= 0.0)
        atr = iATR(Symbol(), PERIOD_CURRENT, p, 0);
      if (atr <= 0.0)
        return (false);

      // Baseline volume/body
      double vols[];
      ArrayResize(vols, n);
      double bods[];
      ArrayResize(bods, n);
      for (int i = 0; i < n; i++) {
        int s = sh + i;
        vols[i] = (double)iVolume(Symbol(), PERIOD_CURRENT, s);
        bods[i] = MathAbs(Close[s] - Open[s]);
      }
      double vmed = __Median(vols, n);
      double bmed = __Median(bods, n);
      if (vmed <= 0.0)
        vmed = vols[0];
      if (bmed <= 0.0)
        bmed = bods[0];

      // Score di riferimento (mediana dei prodotti normalizzati)
      double scores[];
      ArrayResize(scores, n);
      for (int j = 0; j < n; j++) {
        double vr = (vmed > 0.0 ? vols[j] / vmed : 1.0);
        double br = (atr > 0.0 ? bods[j] / atr : 1.0);
        scores[j] = vr * br;
      }
      double s_med = __Median(scores, n);

      // Score corrente (displacement candle)
      double v0 = (double)iVolume(Symbol(), PERIOD_CURRENT, sh);
      double b0 = MathAbs(Close[sh] - Open[sh]);
      double vr0 = (vmed > 0.0 ? v0 / vmed : 1.0);
      double br0 = (atr > 0.0 ? b0 / atr : 1.0);
      double s0 = vr0 * br0;

      // Direzione coerente (ordine block bullish -> displacement bullish,
      // viceversa)
      bool dirOK = is_bullish ? (Close[sh] > Open[sh]) : (Close[sh] < Open[sh]);
      if (!dirOK)
        return (false);

      // Outlier positivo rispetto alla baseline, scalato da regime/Mode (no
      // numeri fissi)
      double need = Auto_VolFactor() * ModeScale();
      return (s0 > (s_med * need));
  }

void SMC_ScanOrderBlocks(string symbol)
{
      double atr = iATR(symbol, 0, 14, 0);
      if (atr <= 0)
        return;

      for (int i = 3; i < 15; i++) {
        double body_i = iClose(symbol, 0, i) - iOpen(symbol, 0, i);
        double body_next = iClose(symbol, 0, i - 1) - iOpen(symbol, 0, i - 1);

        // Impulse: next candle body > 1.5 ATR
        if (MathAbs(body_next) < atr * 1.5)
          continue;

        // Bullish OB: bearish candle followed by strong bullish impulse
        if (body_i < 0 && body_next > 0) {
          // Cross-reference with ICT OB engine for quality
          ADV_OB_ZONE advOB;
          double ictBonus = 0;
          if (ADV_FindOrderBlock(Period(), i - 1, +1, advOB))
            ictBonus = 20.0;

          SMC_AddOrderBlock(iHigh(symbol, 0, i), iLow(symbol, 0, i), 1, i,
                            ictBonus);
        }

        // Bearish OB: bullish candle followed by strong bearish impulse
        if (body_i > 0 && body_next < 0) {
          ADV_OB_ZONE advOB;
          double ictBonus = 0;
          if (ADV_FindOrderBlock(Period(), i - 1, -1, advOB))
            ictBonus = 20.0;

          SMC_AddOrderBlock(iHigh(symbol, 0, i), iLow(symbol, 0, i), -1, i,
                            ictBonus);
        }
      }
}

void SMC_AddOrderBlock(double high, double low, int dir, int barIdx, double ictScore=0)
{
      // Check for duplicates
      for (int i = 0; i < g_ictObCount; i++) {
        if (g_orderBlocks[i].active &&
            MathAbs(g_orderBlocks[i].high - high) < Point * 10 &&
            MathAbs(g_orderBlocks[i].low - low) < Point * 10)
          return;
      }

      if (g_ictObCount >= SMC_MAX_OB) {
        for (int i = 0; i < SMC_MAX_OB - 1; i++)
          g_orderBlocks[i] = g_orderBlocks[i + 1];
        g_ictObCount = SMC_MAX_OB - 1;
      }

      g_orderBlocks[g_ictObCount].high = high;
      g_orderBlocks[g_ictObCount].low = low;
      g_orderBlocks[g_ictObCount].direction = dir;
      g_orderBlocks[g_ictObCount].age = 0;
      g_orderBlocks[g_ictObCount].active = true;
      g_orderBlocks[g_ictObCount].mitigated = false;
      g_orderBlocks[g_ictObCount].ictScore = ictScore;
      g_ictObCount++;
}

int SMC_OrderBlockEntry(string symbol)
{
      double close = iClose(symbol, 0, 0);

      for (int i = 0; i < g_ictObCount; i++) {
        if (!g_orderBlocks[i].active || g_orderBlocks[i].mitigated)
          continue;
        g_orderBlocks[i].age++;

        // Expire old OBs (adaptive: ICT-confirmed last longer)
        int maxAge = (g_orderBlocks[i].ictScore > 0 ? 60 : 40);
        if (g_orderBlocks[i].age > maxAge) {
          g_orderBlocks[i].active = false;
          continue;
        }

        // Bullish OB: price returns to zone and bounces
        if (g_orderBlocks[i].direction > 0) {
          if (close >= g_orderBlocks[i].low && close <= g_orderBlocks[i].high) {
            if (iClose(symbol, 0, 0) > iOpen(symbol, 0, 0)) {
              // ICT killzone bonus
              bool kzActive = ICT_InAnyKillzone();
              if (kzActive || g_orderBlocks[i].ictScore > 0) {
                g_orderBlocks[i].mitigated = true;
                return 1;
              }
            }
          }
        }

        // Bearish OB: price returns to zone and rejects
        if (g_orderBlocks[i].direction < 0) {
          if (close >= g_orderBlocks[i].low && close <= g_orderBlocks[i].high) {
            if (iClose(symbol, 0, 0) < iOpen(symbol, 0, 0)) {
              bool kzActive = ICT_InAnyKillzone();
              if (kzActive || g_orderBlocks[i].ictScore > 0) {
                g_orderBlocks[i].mitigated = true;
                return -1;
              }
            }
          }
        }
      }

      return 0;
}

double ComputeLotsFromOrderParams(int cmd, int magic, double sl_points){
      // detect next level by side + comment suffix
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      int level = 0;
      for (int i = 0; i < OrdersTotal(); i++) {
        if (!OrderSelect(i, SELECT_BY_POS))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != magic)
          continue;
        int t = OrderType();
        bool dir = (t == OP_BUY || t == OP_BUYLIMIT || t == OP_BUYSTOP);
        if (dir != isBuy)
          continue;
        int parsed = ParseLevelFromComment(OrderComment(), magic);
        if (parsed <= 0)
          parsed = 1; // fallback seed if not present
        if (parsed > level)
          level = parsed;
      }
      level = level + 1; // next
                         // next
      // base from hybrid (Manual lot + risk cap if SL known)
      double base_manual = Active_ManualLot();
      double risk_lots = LotsByRisk(sl_points);
      double base = (risk_lots > 0 ? MathMin(base_manual, risk_lots) : base_manual);
      if (risk_lots > 0 && risk_lots < base_manual) {
        SmartLog("INFO", "RISK",
                 "Risk cap applied (req=" + DoubleToString(base_manual, 2) +
                     ", risk=" + DoubleToString(risk_lots, 2) + ")");
      }
      // per-strategy branch
      double lots = base;
      if (MagicBase(magic) == GridMagic) {
        int maxL = AllowedLevels_Grid();
        if (level > maxL) {
          SmartLog("INFO", "GRID",
                   "Cycle cap reached: level=" + IntegerToString(level) +
                       " > max=" + IntegerToString(maxL));
          return 0.0;
        }
        // FASE 6.1 (Patch 1): firma reale = 2 args.
        // LotsGrid_ByLevelScaled usa GridLotMultiplier^level
        // INTERNAMENTE (es. base 0.10 * 2.0^L: L0=0.10 L1=0.20 L2=0.40
        // L3=0.80). Prima si usava LotsGrid_ByLevel (lineare costante)
        // -> GridLotMultiplier input era decorativo.
        lots = LotsGrid_ByLevelScaled(base, level);
        // generic linear 1x,2x,3x
        int maxL_gen = (int)MathFloor(Active_MaxRiskForSymbol());
        if (level > maxL_gen) {
          SmartLog("INFO", "RISK",
                   "Active_MaxRiskForSymbol() reached: level=" +
                       IntegerToString(level) +
                       " > max=" + IntegerToString(maxL_gen));
          return 0.0;
        }
        lots = base * level;
      }
      // Apply market lot cap ONLY to seed
      if (level == 1) {
        double cap_market = MarketInfo(Symbol(), MODE_MAXLOT);
        if (lots > cap_market) {
          double reqLots = lots;
          lots = cap_market;
          SmartLog(
              "INFO", "CAP",
              "Seed clamped by market cap (req=" + DoubleToString(reqLots, 2) +
                  ", applied=" + DoubleToString(lots, 2) + ")");
        }
      }
      // broker constraints + rounding after cap
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double step = MarketInfo(Symbol(), MODE_LOTSTEP);
      if (step <= 0)
        step = 0.01;
      lots = MathFloor(lots / step) * step;
      if (lots < minLot)
        lots = minLot;
      if (lots > maxLot)
        lots = maxLot;
      return lots;
}

bool RiskEngine_CanOpenTrade(string symbol, int cmd, double lots)
{
      if (!g_risk.canTrade)
        return false;

      // Additional per-trade checks

      // Margin check for this specific trade
      double freeMargin = AccountFreeMarginCheck(symbol, cmd, lots);
      if (freeMargin <= 0) {
        g_risk.blockReason = StringFormat(
            "Insufficient margin for %.2f lots on %s", lots, symbol);
        return false;
      }

      // Lot size broker limits
      double maxLot = MarketInfo(symbol, MODE_MAXLOT);
      if (maxLot > 0 && lots > maxLot) {
        g_risk.blockReason =
            StringFormat("Lots %.2f > broker max %.2f", lots, maxLot);
        return false;
      }

      double minLot = MarketInfo(symbol, MODE_MINLOT);
      if (minLot > 0 && lots < minLot) {
        g_risk.blockReason =
            StringFormat("Lots %.2f < broker min %.2f", lots, minLot);
        return false;
      }

      return true;
}

bool RiskEngine_IsMarketOpen(string symbol)
{
      double tradeAllowed = MarketInfo(symbol, MODE_TRADEALLOWED);
      return (tradeAllowed > 0);
}

int ExposureManager_GetOrderCount(string symbol)
{
      int idx = ExposureManager_Find(symbol);
      if (idx < 0)
        return 0;
      return g_exposure[idx].buyCount + g_exposure[idx].sellCount;
}

bool StateManager_ShouldCloseAll()
{
      return (g_systemState == STATE_EMERGENCY_CLOSE);
}

bool Orders_Select(int index, int selectType=SELECT_BY_POS, int pool=MODE_TRADES) {
      return OrderSelect(index, selectType, pool) &&
             OrderSymbol() == Symbol() &&
             OrderMagicNumber() == ObliviousAiMagic;
}

int Orders_Count() {
      int count = 0;
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (Orders_Select(i))
          count++;
      }
      return count;
}

bool Orders_HasPosition() {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (Orders_Select(i) && OrderType() <= OP_SELL)
          return true;
      }
      return false;
}

bool Orders_SendSafe(int type, double lots, double price, double sl, double tp, string comment="") {
      RefreshRates();
      double ask = MarketInfo(Symbol(), MODE_ASK);
      double bid = MarketInfo(Symbol(), MODE_BID);
      sl = NormalizePrice(sl);
      tp = NormalizePrice(tp);
      price = NormalizePrice(price);
      int retries = 0;
      int ticket = -1;
      while (retries < 3) {
        ticket = SafeOrderSend(Symbol(), type, ClampLots(lots), price, 3, sl, tp,
                           comment, ObliviousAiMagic, 0, clrNONE);
        if (ticket >= 0)
          return true;
        int err = GetLastError();
        if (err == 130 || err == 131 || err == 133 || err == 136 ||
            err == 146) {
          retries++; Sleep(500);
          RefreshRates();
          continue;
        } else {
          LogError("Ordine fallito: err=" + IntegerToString(err));
          break;
        }
      }
      return false;
}

bool Orders_ModifySafe(int ticket, double price, double sl, double tp) {
      RefreshRates();
      price = NormalizeDouble(price, Digits);
      sl = NormalizeDouble(sl, Digits);
      tp = NormalizeDouble(tp, Digits);
      int retries = 0;
      while (retries < 3) {
        if (!OrderSelect(ticket, SELECT_BY_TICKET) || OrderSymbol() != Symbol()) {
          retries++;
          RefreshRates();
          continue;
        }
        if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) break;
        if (OrderModify(ticket, price, sl, tp, 0, clrNONE))
          return true;
        int err = GetLastError();
        if (err == 130 || err == 131 || err == 133 || err == 136 ||
            err == 146) {
          retries++;
          Sleep(500);
          RefreshRates();
          continue;
        } else {
          Print("Order modify failed: err=", err);
          break;
        }
      }
      return false;
}

bool Orders_CloseSafe(int ticket) {
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return false;
      double closePrice = OrderType() == OP_BUY ? Bid : Ask;
      closePrice = NormalizeDouble(closePrice, Digits);
      int retries = 0;
      while (retries < 3) {
        if (OrderClose(ticket, OrderLots(), closePrice, 3, clrNONE))
          return true;
        int err = GetLastError();
        if (err == 130 || err == 131 || err == 133 || err == 136 ||
            err == 146) {
          retries++;
          Sleep(500);
          RefreshRates();
        } else {
          Print("Order close failed: err=", err);
          break;
        }
      }
      return false;
}

void CloseAllTrades(int typeToClose = -1) {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          if (OrderSymbol() == Symbol() &&
              (typeToClose == -1 || OrderType() == typeToClose)) {
            double closePrice = (OrderType() == OP_BUY)
                                    ? MarketInfo(Symbol(), MODE_BID)
                                    : MarketInfo(Symbol(), MODE_ASK);
            RefreshRates();
            {
    // Global safety: only allowed from risk engine, kill-switch, or emergency
              int __ticket = OrderTicket();
              double __lots = OrderLots();
              SmartLogWrap(
                  "CLOSE",
                  StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s",
                               __ticket, __lots, OrderSymbol()));
            }
            if (!OrderClose(OrderTicket(), OrderLots(), closePrice,
                            GetAdaptiveSlippagePoints(), clrRed)) {
              {
                int __err = GetLastError();
                bool __isok = (__err == 0);
                SmartLogWrap(
                    "CLOSE",
                    StringFormat("%s | ticket=%d price=%.5f lots=%.2f err=%d",
                                 __isok ? "PostClose OK" : "PostClose FAIL",
                                 OrderTicket(), OrderClosePrice(), OrderLots(),
                                 __err));
              }
              PrintFormat("? Errore chiusura ordine %d: %d", OrderTicket(),
                          GetLastError());
            } else {
              PrintFormat("? Ordine chiuso: %d", OrderTicket());
            }
          }
        }
      }
}

void CloseAllOpenOrders() {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (Orders_Select(i)) {
          if (OrderType() <= OP_SELL) {
            Orders_CloseSafe(OrderTicket());
          } else {
            bool _wRes = OrderDelete(OrderTicket());
          }
        }
      }
}

