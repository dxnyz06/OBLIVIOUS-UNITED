// --- RGB RAINBOW ENGINE ---
#define RGB_CYCLE_SECONDS 120

color HSVtoRGB(double H, double S, double V) {
   if (H < 0) H = 0;
   if (H >= 360.0) H = MathMod(H, 360.0);
   if (S < 0) S = 0; if (S > 1) S = 1;
   if (V < 0) V = 0; if (V > 1) V = 1;
   double C = V * S;
   double X = C * (1.0 - MathAbs(MathMod(H / 60.0, 2.0) - 1.0));
   double m = V - C;
   double r = 0, g = 0, b = 0;
   int h = ((int)MathFloor(H / 60.0)) % 6;
   if (h == 0)      { r = C; g = X; b = 0; }
   else if (h == 1) { r = X; g = C; b = 0; }
   else if (h == 2) { r = 0; g = C; b = X; }
   else if (h == 3) { r = 0; g = X; b = C; }
   else if (h == 4) { r = X; g = 0; b = C; }
   else             { r = C; g = 0; b = X; }
   return MakeRGB((int)MathRound((r + m) * 255),
                  (int)MathRound((g + m) * 255),
                  (int)MathRound((b + m) * 255));
}

void Rainbow_CleanChart() {
   ChartSetInteger(0, CHART_MODE, CHART_CANDLES);
   ChartSetInteger(0, CHART_SHOW_GRID, false);
   ChartSetInteger(0, CHART_COLOR_CHART_LINE, clrBlack);
   long bg = 0;
   ChartGetInteger(0, CHART_COLOR_BACKGROUND, 0, bg);
   ChartSetInteger(0, CHART_COLOR_GRID, (color)bg);
   ChartSetInteger(0, CHART_COLOR_CANDLE_BULL, clrBlack);
   ChartSetInteger(0, CHART_COLOR_CANDLE_BEAR, clrBlack);
}

void Rainbow_UpdateColor() {
   double step = 360.0 / (double)RGB_CYCLE_SECONDS;
   g_hue += step;
   if (g_hue >= 360.0) g_hue -= 360.0;
   g_rainbowColor = HSVtoRGB(g_hue, 1.0, 1.0);
   ApplyRainbow(g_rainbowColor);
}

string Panel_GetSessionName() {
   int hh = TimeHour(TimeCurrent());
   if (hh >= 0  && hh < 7)  return "Asian";
   if (hh >= 7  && hh < 12) return "London";
   if (hh >= 12 && hh < 16) return "New York";
   if (hh >= 16 && hh < 21) return "US Late";
   return "Off Hours";
}

string Panel_MagicToStrategy(int magic) {
   if (magic == PredictedMagic) return "Predicted";
   if (magic == GridMagic)      return "Grid";
   if (magic == BreakoutMagic)  return "Breakout";
   if (magic == FVGMagic)       return "FVG";
   if (magic == SMCMagic)       return "SMC";
   if (magic == ICTMagic)       return "ICT";
   if (magic == ReverseMagic)   return "Reverse";
   return "";
}

bool Panel_IsOurMagic(int magic) {
   return (magic == PredictedMagic || magic == GridMagic || magic == BreakoutMagic ||
           magic == FVGMagic || magic == SMCMagic || magic == ICTMagic || magic == ReverseMagic);
}

