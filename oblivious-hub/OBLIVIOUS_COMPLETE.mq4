double AdjustLotForChallenge(double userLot, double stopLossPips) {
   // ModalitÃƒÃ†ÃƒÃ‚Â  per rispettare i limiti di drawdown giornaliero e totale per account di tipo prop firm.
   if (!ChallengePassage)
   return userLot; // Nessun controllo se disattivato
   double dailyDD =
   GetDailyDDLimit();
   double pnlToday =
   0;
   datetime todayStart = iTime(
   Symbol(),
   PERIOD_D1,
   0);
   for (
   int i =
   OrdersHistoryTotal() -
   1;
   i >=
   0;
   i--) {
   if (OrderSelect(
   i,
   SELECT_BY_POS,
   MODE_HISTORY)) {
   if (OrderCloseTime() >=
   todayStart) {
   pnlToday +=
   OrderProfit() +
   OrderSwap() +
   OrderCommission();
   }
   }
   }
   double floatingPnl =
   0;
   for (
   int i =
   OrdersTotal() -
   1;
   i >=
   0;
   i--) {
   if (OrderSelect(
   i,
   SELECT_BY_POS,
   MODE_TRADES)) {
   floatingPnl +=
   OrderProfit() +
   OrderSwap() +
   OrderCommission();
   }
   }
   double riskAvailable =
   dailyDD +
   (pnlToday +
   floatingPnl);
   if (riskAvailable <=
   0)
   return 0;
double maxLot = riskAvailable / (ScalePipsByATR(stopLossPips) * Point * MarketInfo(Symbol(), MODE_TICKVALUE));
return MathMin(userLot, maxLot);
}
