}

bool BlueMart_AA_AllowNextLayer(int steps){
      int n = AA_AutoN();
      double eq = AccountEquity(), bal = AccountBalance();
      double dd = (bal > 0 ? (bal - eq) / bal : 0);
      double mR, sR;
      AA_MeanStd(mR, sR, false, n);
      double atr = iATR(Symbol(), Period(), MathMax(5, (int)MathSqrt(n)), 1);
      bool vol_ok = atr <= (mR + sR);
      bool dd_ok = dd < 0.1;
      bool steps_ok = steps < MathMax(2, (int)(MathSqrt(n) / 4));
      return vol_ok && dd_ok && steps_ok;
}

bool ATRRegimeOK() {
      double atr = EATR(Symbol(), 0, 14);
      double atr_long_term = EATR(Symbol(), 0, 50);
      return (atr > 0.8 * atr_long_term);
}

double VolumeMA(int period = 20)
{
      double sum = 0;
      for (int i = 1; i <= period; i++)
        sum += (double)iVolume(Symbol(), Period(), i);
      return sum / period;
}

enum POIType { POI_NONE=0, POI_OB=1, POI_FVG=2, POI_EQ=3, POI_SWEEP=4, POI_ALL=99 };
struct POI {
   POIType type;
   double  hi;
   double  lo;
   double  zHigh;
   double  zLow;
   double  mid;
   int     tf;
   int     bar;
   bool    valid;
   bool    active;
   bool    isBull;
   string  symbol;
};
POI  g_POIs[100];
int  g_POIsCount = 0;

enum VolRegime { VOL_LOW=0, VOL_NORMAL=1, VOL_HIGH=2, VOL_EXTREME=3 };

struct AdaptState {
   int    regime;
