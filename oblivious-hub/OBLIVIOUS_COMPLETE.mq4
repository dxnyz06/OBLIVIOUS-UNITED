                                            bool FVG_Logic_Legacy() {
                                              // ===== Fair Value Gap (SMC
                                              // advanced) - full auto-adaptive
                                              // (3-candle), VI (Volume
                                              // Imbalance) come
                                              // filtro/raffinamento,
                                              double atr = iATR(NULL, 0, 14, 0);
                                              double spread =
                                                  (Ask - Bid) / _Point;
                                              double maxSpread = iStdDevOnArray(
                                                  Close, 0, 20, 0, MODE_SMA, 0);
                                              if (spread > maxSpread * 2.0) {
                                                Bridge_SendLog(
                                                    2, "FVG",
                                                    "Spread too high, "
                                                    "skipping");
                                                return false;
                                              }
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              // CE/MT (entry al 50%), IFVG
                                              // (Inversion FVG) tramite
                                              // tracking locale.
                                              // Stretch/mean-reversion context
                                              // (auto-adaptive) Guard bars
                                              // (auto-adaptive, evita lookahead
                                              // e array underflow)
                                              int n_base = Auto_ATR_Period() +
                                                           Auto_ADX_Period();
                                              int c0 = 1, c1 = 2, c2 = 3;

                                              n_base = MathMax(c2, n_base);
                                              if (Bars <= (n_base + c2 + 2))
                                                return (false);

                                              double vwapZ =
                                                  Auto_Generic_Dev() *
                                                  Auto_VolFactor() *
                                                  ModeScale();
                                              if (!VWAPDeviationTrigger(vwapZ))
                                                return (false);

                                              // Imbalance istituzionale
                                              // (auto-adaptive, senza soglie
                                              // fisse)
                                              if (!FVG_InstitutionalImbalance())
                                                return (false);

                                              // Definizione FVG su barre
                                              // chiuse: c2=3, c1=2, c0=1 (evita
                                              // repaint su barra 0)
                                              bool bullFVG =
                                                  (Low[c0] > High[c2]);
                                              bool bearFVG =
                                                  (High[c0] < Low[c2]);

                                              // Tracking per IFVG (inversione)
                                              // — locale alla strategia, no
                                              // LOGIC FOR FVG]
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              static bool tr_active = false;
                                              static bool tr_bull = true;
                                              static double tr_low = 0.0,
   tr_high = 0.0;
                                              static datetime tr_time = 0;
                                              static bool tr_filled = false;
                                              static bool tr_inverted = false;

                                              // ---- IFVG maintenance: se il
                                              // gap viene "riempito" e poi
                                              // rotto, registra inversione ----
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              if (tr_active && !tr_inverted) {
                                                double buf = POI_PipSize();
                                                if (buf <= 0.0)
                                                  buf = Point;

                                                // Full fill (mitigation) e
                                                // successiva rottura oltre il
                                                // bordo => inversione
                                                if (tr_bull) {
                                                  if (!tr_filled &&
                                                      Low[c0] <= tr_low + buf)
                                                    tr_filled = true;
                                                  if (tr_filled &&
                                                      Close[c0] <
                                                          tr_low - buf) {
                                                    // Bull FVG rotto al ribasso
                                                    // => IFVG bearish
                                                    // (breaker/inversion)
                                                    // FVG]
                                                    double _atr =
                                                        iATR(NULL, 0, 14, 0);
                                                    double _spread =
                                                        (Ask - Bid) / _Point;
                                                    double _maxSpread =
                                                        iStdDevOnArray(
   Close, 0, 20, 0,
   MODE_SMA, 0);
                                                    if (_spread >
                                                        _maxSpread * 2.0) {
                                                      Bridge_SendLog(
                                                          2, "FVG",
                                                          "Spread too high, "
                                                          "skipping");
                                                      return false;
                                                    }
                                                    if (Bridge_IsConnected()) {
                                                      string aiPayload;
                                                      if (Bridge_GetAISignals(
   Symbol(),
   Period(), Time[0],
   aiPayload)) {
                                                        if (StringFind(
   aiPayload,
   "fvg=0") >= 0) {
                                                          Bridge_SendLog(
   1, "FVG",
   "AI suggests NO "
   "TRADE");
                                                          return false;
                                                        }
                                                      }
                                                    }
                                                    RegisterPOI(POI_FVG, false,
   tr_low,
   tr_high);
                                                    int idx =
                                                        ArraySize(g_POIs) - 1;
                                                    if (idx >= 0 &&
                                                        g_POIs[idx].type == POI_FVG)



                                                      g_POIs[idx].mid =
                                                          (tr_low + tr_high) /
                                                          2.0; // CE/MT
                                                    tr_inverted = true;
                                                  }
                                                } else {
                                                  if (!tr_filled &&
                                                      High[c0] >= tr_high - buf)
                                                    tr_filled = true;
                                                  if (tr_filled &&
                                                      Close[c0] >
                                                          tr_high + buf) {
                                                    // Bear FVG rotto al rialzo
                                                    // => IFVG bullish
                                                    // FVG]
                                                    double _atr =
                                                        iATR(NULL, 0, 14, 0);
                                                    double _spread =
                                                        (Ask - Bid) / _Point;
                                                    double _maxSpread =
                                                        iStdDevOnArray(
   Close, 0, 20, 0,
   MODE_SMA, 0);
                                                    if (_spread >
                                                        _maxSpread * 2.0) {
                                                      Bridge_SendLog(
                                                          2, "FVG",
                                                          "Spread too high, "
                                                          "skipping");
                                                      return false;
                                                    }
                                                    if (Bridge_IsConnected()) {
                                                      string aiPayload;
                                                      if (Bridge_GetAISignals(
   Symbol(),
   Period(), Time[0],
   aiPayload)) {
                                                        if (StringFind(
   aiPayload,
   "fvg=0") >= 0) {
                                                          Bridge_SendLog(
   1, "FVG",
   "AI suggests NO "
   "TRADE");
                                                          return false;
                                                        }
                                                      }
                                                    }
                                                    RegisterPOI(POI_FVG, true,
   tr_low,
   tr_high);
                                                    int idx =
                                                        ArraySize(g_POIs) - 1;
                                                    if (idx >= 0 &&
                                                        g_POIs[idx].type == POI_FVG)



                                                      g_POIs[idx].mid =
                                                          (tr_low + tr_high) /
                                                          2.0; // CE/MT
                                                    tr_inverted = true;
                                                  }
                                                }
                                              }

                                              if (!(bullFVG || bearFVG))
                                                return (false);

                                              // Zona FVG (full gap)
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              double zLow = 0.0, zHigh = 0.0;
                                              bool isBull = bullFVG;

                                              if (bullFVG) {
                                                zLow = High[c2];
                                                zHigh = Low[c0];
                                              } else {
                                                zLow = High[c0];
                                                zHigh = Low[c2];
                                              }

                                              if (zHigh <= zLow)
                                                return (false);

                                              // CE / MT (Mean Threshold): 50%
                                              // della zona
                                              double ce = (zLow + zHigh) / 2.0;

                                              // VI (Volume Imbalance) —
                                              // filtro/raffinamento
                                              // autoadaptive usando mediane
                                              int n = Auto_ATR_Period() +
                                                      Auto_ADX_Period();
                                              n = MathMax(3, n);
                                              n = MathMin(n, Bars - (c2 + 2));
                                              double atr_vi =
                                                  iATR(Symbol(), PERIOD_CURRENT,
                                                       Auto_ATR_Period(), c0);
                                              if (atr_vi <= 0.0)
                                                atr_vi = iATR(
                                                    Symbol(), PERIOD_CURRENT,
                                                    Auto_ATR_Period(), 0);

                                              if (n >= 3 && atr_vi > 0.0) {
                                                double vols[];
                                                ArrayResize(vols, n);
                                                double bods[];
                                                ArrayResize(bods, n);
                                                double scs[];
                                                ArrayResize(scs, n);

                                                for (int i = 0; i < n; i++) {
                                                  int sh = c0 + i;
                                                  vols[i] = (double)iVolume(
                                                      Symbol(), PERIOD_CURRENT,
                                                      sh);
                                                  bods[i] = MathAbs(Close[sh] -
   Open[sh]);
                                                }

                                                double vmed = __Median(vols, n);
                                                double bmed = __Median(bods, n);
                                                if (vmed <= 0.0)
                                                  vmed = vols[0];
                                                if (bmed <= 0.0)
                                                  bmed = bods[0];

                                                for (int j = 0; j < n; j++) {
                                                  double vr =
                                                      (vmed > 0.0
                                                           ? vols[j] / vmed
                                                           : 1.0);
                                                  double br =
                                                      (atr_vi > 0.0 ? bods[j] / atr_vi
   : 1.0);
                                                  scs[j] = vr * br;
                                                }

                                                double sc_med =
                                                    __Median(scs, n);

                                                // score del displacement candle
                                                // (c1): dovrebbe essere outlier
                                                // positivo
                                                double v1 =
                                                    (double)iVolume(Symbol(),
   PERIOD_CURRENT, c1);
                                                double b1 = MathAbs(Close[c1] -
   Open[c1]);
                                                double vr1 =
                                                    (vmed > 0.0 ? v1 / vmed
   : 1.0);
                                                double br1 =
                                                    (atr_vi > 0.0 ? b1 / atr_vi
   : 1.0);
                                                double sc1 = vr1 * br1;

                                                bool vi_ok = (sc1 > sc_med);

                                                if (vi_ok) {
                                                  // Raffina la zona verso
                                                  // l'imbalance (corpo del
                                                  // displacement) se
                                                  // sovrapposto al gap
                                                  double bLo = MathMin(
                                                      Open[c1], Close[c1]);
                                                  double bHi = MathMax(
                                                      Open[c1], Close[c1]);

                                                  double rzLow =
                                                      MathMax(zLow, bLo);
                                                  double rzHigh =
                                                      MathMin(zHigh, bHi);

                                                  if (rzHigh > rzLow) {
                                                    zLow = rzLow;
                                                    zHigh = rzHigh;
                                                    ce = (zLow + zHigh) /
                                                         2.0; // aggiorna CE/MT
   // sul refined
                                                  }
                                                }
                                              }

                                              // Registra POI FVG (zona
                                              // raffinata o full) e forza entry
                                              // FOR FVG]
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              RegisterPOI(POI_FVG, isBull, zLow,
                                                          zHigh);
                                              int idx = ArraySize(g_POIs) - 1;
                                              if (idx >= 0 &&
                                                  g_POIs[idx].type == POI_FVG)
                                                g_POIs[idx].mid = ce;

                                              // Aggiorna tracking IFVG
                                              if (Bridge_IsConnected()) {
                                                string aiPayload;
                                                if (Bridge_GetAISignals(
                                                        Symbol(), Period(),
                                                        Time[0], aiPayload)) {
                                                  if (StringFind(aiPayload,
   "fvg=0") >=
                                                      0) {
                                                    Bridge_SendLog(
                                                        1, "FVG",
                                                        "AI suggests NO TRADE");
                                                    return false;
                                                  }
                                                }
                                              }
                                              tr_active = true;
                                              tr_bull = isBull;
                                              tr_low = zLow;
                                              tr_high = zHigh;
                                              tr_time = TimeCurrent();
                                              tr_filled = false;
                                              tr_inverted = false;

                                              return (true);
                                            }

                                          void CheckPredictedAutoMode() {
                                            if (!g_BridgeConnected) return;
                                            // tpsl AI active: computed inline via IsTPSL_AI() && ai_file_present
                                          }

                                          void CheckPredictedManualMode() {
                                            if (g_BridgeConnected) return;
                                            // Manual mode: check AI signals file via Bridge mechanism
                                          }

                                          int GetCurrentAISignal_v2(
                                              int &confidence) {
                                            // Bridge-based: read from in-memory
                                            // AI signal state
                                            confidence = (int)g_aiSignalConf;
                                            // Stale check: discard signal older
                                            // than AISignalStaleSeconds
                                            if (TimeCurrent() - g_aiSignalTime >
                                                AISignalStaleSeconds) {
                                              g_aiSignalDir = 0;
                                              g_aiSignalConf = 0;
                                              return 0;
                                            }
                                            return g_aiSignalDir;
                                          }

                                          // delta=+42chars from
                                          // Bridge-based: check kernel32 pipe
                                          // handle validity
                                          // (g_hAIPipeIn ==
                                          // INVALID_HANDLE_VALUE) {
                                          // AI_PIPE_NAME_IN,
                                          // OPEN_EXISTING,
                                          // FILE_ATTRIBUTE_NORMAL,
                                          // INVALID_HANDLE_VALUE);

bool CheckAISignals() {
   if (!Predicted) return false;
   return (g_aip_direction != 0 && g_aip_confidence >= (double)AiMinConfidence);
}

                                          string GetAISignalsJSON() {
                                            // Bridge-based AI signals
                                            // retrieval (replaces //
                                            // Bridge_* mechanism]
                                            string ai_signals = "";
                                            string payload = "";
                                            datetime lastBarTime = iTime(
                                                Symbol(), PERIOD_CURRENT, 1);

                                            if (Bridge_GetAISignals(
                                                    Symbol(), Period(),
                                                    lastBarTime, payload)) {
                                              // Parse payload: format
                                              // "key=value;key=value|..."
                                              // or simple
                                              // "symbol|type|confidence|..."
                                              if (StringLen(payload) > 0) {
                                                string signals[];
                                                int sigCount = StringSplit(
                                                    payload, '|', signals);
                                                int parsed = 0;

                                                for (int i = 0;
                                                     i < sigCount && parsed < 3;
                                                     i++) {
                                                  if (StringLen(signals[i]) == 0)



                                                    continue;

                                                  // Parse signal:
                                                  // "SYMBOL,TYPE,CONFIDENCE"
                                                  // or key=value pairs
                                                  string parts[];
                                                  int partCount = StringSplit(
                                                      signals[i], ',', parts);

                                                  if (partCount >= 3) {
                                                    if (parsed > 0)
                                                      ai_signals += ",";
                                                    ai_signals += StringFormat(
                                                        "{\"symbol\":\"%\""
                                                        "s\",\"type\":\"%\""
                                                        "s\",\""
                                                        "confidence\":\"%\""
                                                        "s\",\"time\":\"%\""
                                                        "s\"}",
                                                        parts[0], parts[1],
                                                        parts[2],
                                                        TimeToString(
   TimeCurrent(),
   TIME_MINUTES));
                                                    parsed++;
                                                  } else {
                                                    // Try key=value format
                                                    int eqPos = StringFind(
                                                        signals[i], "=");
                                                    if (eqPos > 0) {
                                                      // Simple format: just
                                                      // add as-is
                                                      if (parsed > 0)
                                                        ai_signals += ",";
                                                      ai_signals += StringFormat(
                                                          "{\"signal\":\"%\""
                                                          "s\",\"time\":\"%\""
                                                          "s\"}",
                                                          signals[i],
                                                          TimeToString(
   TimeCurrent(),
   TIME_MINUTES));
                                                      parsed++;
                                                    }
                                                  }
                                                }
                                              }
                                            }

                                            // If no AI signals, provide
                                            // default standby data
                                            if (ai_signals == "") {
                                              ai_signals = StringFormat(
                                                  "{\"symbol\":\"%s\","
                                                  "\"type\":\"STANDBY\","
                                                  "\"confidence\":\"0\","
                                                  "\"time\":\"%s\"}",
                                                  Symbol(),
                                                  TimeToString(TimeCurrent(), TIME_MINUTES));
                                            }
                                            return ai_signals;
                                          }

                                          int GetAISignal() { return 0; }

// ============================================================
// ZeroMQ transport state (R3, R4) — owns the live g_ai_* update path.
// ============================================================
Context  g_zmq_ctx("ObliviousEA");
Socket   g_zmq_req(g_zmq_ctx, ZMQ_REQ);
Socket   g_zmq_sub(g_zmq_ctx, ZMQ_SUB);
Socket   g_zmq_push(g_zmq_ctx, ZMQ_PUSH);
bool     g_zmq_initialized   = false;
bool     g_zmq_is_master     = false;
datetime g_ai_lastHeartbeat  = 0;
uint     g_zmq_lastPushMs    = 0;
string   g_ai_lastNewsCacheJson = "";
datetime g_ai_lastNewsCacheTs   = 0;
string   g_ai_lastBookmapJson   = "";
datetime g_ai_lastBookmapTs     = 0;

// ============================================================
// Orderflow state — populated by AI_HandleBookmap from the hub
// SUB topic `oblivious.bookmap`. All values are normalised numerics
// (the hub already classifies bullish/bearish/up/down to ±1).
//   g_of_*           : 16 fields per the EXE contract
//   g_of_lastTs      : last update wallclock; OF_IsFresh() uses it
//   g_of_symbol      : symbol the cached state belongs to (so a
//                       multi-chart EA only consumes its own data)
// All consumers go through OF_Refine* helpers — never read these
// globals directly from owner strategies.
// ============================================================
string   g_of_symbol            = "";
datetime g_of_lastTs            = 0;     // EA wallclock when last frame was applied
long     g_of_last_update_ts    = 0;     // hub-side ms timestamp from the frame
int      g_of_sequence          = 0;     // monotonic per-symbol sequence
bool     g_of_fresh             = false; // hub-flagged freshness
bool     g_of_symbol_match      = false; // last frame matched Symbol()
double   g_of_bias              = 0.0;   // -1..+1
double   g_of_confidence        = 0.0;   // 0..1
string   g_of_signal            = "NONE";
double   g_of_imbalance         = 0.0;   // -1..+1
double   g_of_dom_pressure      = 0.0;   // -1..+1
double   g_of_delta_shift       = 0.0;
double   g_of_delta_divergence  = 0.0;   // -1..+1
double   g_of_absorption        = 0.0;   // 0..1
double   g_of_exhaustion        = 0.0;   // 0..1
int      g_of_iceberg_side      = 0;     // -1/0/+1
double   g_of_iceberg_strength  = 0.0;   // 0..1
double   g_of_stop_activity     = 0.0;   // 0..1
int      g_of_sweep_signal      = 0;     // -1/0/+1
int      g_of_trap_signal       = 0;     // -1/0/+1
double   g_of_hold_continue     = 0.0;   // 0..1
double   g_of_cancel_signal     = 0.0;   // 0..1
double   g_of_execution_danger  = 0.0;   // 0..1 (derived by hub)

#define OF_FRESH_TTL_SEC          15

// ============================================================
// AI-query response cache — populated by Bridge_QueryAI() once
// the hub answers a synchronous REQ. The response holds a fused
// view of EA context + Bookmap + News + (optional) AI provider.
// Owners consume it through the OF_Refine* helpers (SOFT, never
// hard-veto). Stale data is discarded by AIQ_IsFresh().
// ============================================================
string   g_aiq_symbol           = "";
string   g_aiq_strategy         = "";
datetime g_aiq_lastTs           = 0;
double   g_aiq_final_bias       = 0.0;   // -1..+1
double   g_aiq_ai_confidence    = 0.0;   // 0..1
double   g_aiq_orderflow_bias   = 0.0;   // -1..+1
double   g_aiq_orderflow_conf   = 0.0;   // 0..1
double   g_aiq_hold_continue    = 0.0;   // 0..1
double   g_aiq_cancel_signal    = 0.0;   // 0..1
string   g_aiq_news_block_state = "none";
double   g_aiq_tp1              = 0.0;
double   g_aiq_tp2              = 0.0;
double   g_aiq_tp3              = 0.0;
double   g_aiq_tpmax            = 0.0;
string   g_aiq_invalidate_if    = "";
string   g_aiq_provider_used    = "";
int      g_aiq_reqSeq           = 0;
string   g_aiq_lastRequestId    = "";
bool     g_aiq_predicted_setup_valid = false;
bool     g_aiq_bookmap_fresh    = false;
bool     g_aiq_bookmap_stale    = false;
int      g_aiq_bookmap_sequence = 0;
int      g_aiq_bookmap_age_ms   = 0;

#define AIQ_FRESH_TTL_SEC         30
#define AIQ_MIN_INTERVAL_SEC      10

// ============================================================
// Order ownership registry (R7) — every order opened by a hub
// command (EXECUTE_ORDER) is recorded so subsequent CANCEL /
// INVALIDATE / REFINE_TPSL only touches what they're allowed to.
// ============================================================
struct OrderOwnership {
   int      ticket;
   int      magic;
   string   owner;        // "Predicted"/"Breakout"/...
   string   source;       // "hub_command" | "native"
   int      ocoPeerTicket; // OCO sibling for Predicted, else 0
   datetime opened_at;
   string   correlation;  // hub correlation id, optional
};
OrderOwnership g_orderOwnership[OWNERSHIP_MAX];
int            g_ownershipCount = 0;

// ============================================================
// R8 — Hub-driven HOLD state.
//
// Two layers are supported (both controlled remotely via the
// command bus from Electron / VPS / Mobile gateway):
//
//   * Global hold (`g_hold_global = true`): blocks ALL new
//     openings, both hub-driven (EXECUTE_ORDER) and owner-strategy
//     local entries. NEVER auto-closes anything; only stops new
//     position/pending creation.
//
//   * Per-owner hold (`g_hold_owner[i]`): blocks new openings for
//     a SINGLE owner-strategy. Slot per owner — bounded array.
//
// State is idempotent: re-issuing HOLD/RESUME on the same target
// is a no-op (just refreshes the reason/timestamp). State is
// purely in-memory: an EA restart clears every hold (failsafe).
//
// Owner-strategies see the hold transparently because
// NewsPolicy_CanOpen() — already the single per-strategy entry
// gate — returns false when a matching hold is active. The hub
// command path (Cmd_HandleExecute) re-checks the same flags as
// part of its own HARD GATES.
// ============================================================
#define HOLD_OWNER_MAX 16
bool     g_hold_global             = false;
datetime g_hold_global_since       = 0;
string   g_hold_global_reason      = "";
struct OwnerHold {
   string   owner;
   bool     active;
   datetime since;
   string   reason;
};
OwnerHold g_hold_owner[HOLD_OWNER_MAX];
int       g_hold_owner_count = 0;

