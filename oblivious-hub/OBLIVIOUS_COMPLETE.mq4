// AutoAdaptive.mqh already included earlier in OBLIVIOUS.mq4

// Core ICT Zone Structures
#ifndef __ICT_STRUCTS_DEFINED__

    struct ADV_FVG_ZONE {
      bool valid;
      int dir; // +1 bullish, -1 bearish
      int tf;
      int barNewer; // shift of newer candle on tf
      double top;
      double bot;
      double mid;
      datetime tForm;
    };

    struct ADV_OB_ZONE {
      bool valid;
      int dir;
      int tf;
      int bar; // shift of the OB candle
      double top;
      double bot;
      double mid;
      datetime tForm;
    };

    struct ICT_SCORE_RESULT {
      double score; // 0-100
      bool hasFVG;
      bool hasOB;
      bool hasSweep;
      bool inKillzone;
      string reasons;
      ADV_FVG_ZONE fvg;
      ADV_OB_ZONE ob;
    };

    struct RiskState {
      double equityPeakHistoric; // All-time equity high
      double equityPeakDaily;    // Today's equity high
      double dailyDDPercent;     // Current daily DD %
      double totalDDPercent;     // Current total DD %
      double peakProfit;         // Peak unrealized profit
      double currentEquity;      // AccountEquity()
      double currentBalance;     // AccountBalance()
      double currentMarginLevel; // AccountInfoDouble(ACCOUNT_MARGIN_LEVEL)
      double currentSpreadPips;  // Current spread in pips
      double currentATR;         // ATR(14) in price
      double medianATR;          // ATR(50) as baseline
      double currentADX;         // ADX(14) main line
      bool killSwitchActive;     // Emergency kill
      bool canTrade;             // Composite result
      string blockReason;        // Why trading is blocked
      int tradesToday;           // Count of trades opened g_today
      int lastResetDay;          // Day of month for daily reset
    };

    struct SymbolExposure {
      string symbol;
      double buyLots;
      double sellLots;
      double netLots;
      double totalLots;
      double unrealizedPnL;
      int buyCount;
      int sellCount;
    };

    struct TrackedPosition {
      int ticket;
      string symbol;
      int cmd;
      double lots;
      double openPrice;
      double sl;
      double tp;
      int magic;
      datetime openTime;
      double highWaterMark; // Best price seen (for trailing)
      bool beApplied;       // Breakeven already applied
      bool active;
    };

    struct VirtualLevel {
      int ticket;
      string symbol;
      int cmd; // OP_BUY or OP_SELL
      double virtualTP;
      double virtualSL;
      double trailDistance;  // Virtual trailing distance (price)
      double trailHighWater; // Best price for trailing
      bool active;
    };



    struct FVGGap {
      double upperLimit;
      double lowerLimit;
      int direction; // +1 bullish FVG, -1 bearish FVG
      int barIndex;  // When discovered
      bool filled;
      bool active;
      double ictScore; // ICT confluence score
      bool hasOB;      // Order block aligned
    };

    struct GridState {
   bool isActive;
   double seedPrice;
   double maxAdverse;
   double basketDD;
   int levelCount;
   datetime startTime;
   double rangeHigh;
   double rangeLow;
   bool invalidated;
      string symbol;
      int gridCount;      // Number of open grid levels
      int direction;      // OP_BUY or OP_SELL
      double basePrice;   // Grid origin price
      double gridSpacing; // Distance between levels
      bool active;
      bool paused;
      string pauseReason;
    };

    struct MartingaleState {
   int level;
      string symbol;
      int currentStep; // 0 = not in cycle
      int direction;   // OP_BUY or OP_SELL
      double baseLot;
      double lastEntryPrice;
      bool active;
      bool paused; // Paused by safety checks
      string pauseReason;
    };

    struct NewsCache {
      bool valid;
      datetime lastUpdate;
      int cachedBlockTrading;
      int cachedSeverity;
      int cachedMinutesToEvent;
    };

    struct OrderBlock {
      double high;
      double low;
      int direction; // +1 bullish, -1 bearish
      int age;       // Bars since formation
      bool active;
      bool mitigated;  // Has price returned to it
      double ictScore; // ICT confluence score at formation
    };

    struct ArbitrationState {
      string symbol;
      int activeStrategy;    // Currently active strategy on this symbol (-1 =
                             // none)
      int activeDirection;   // Current direction on this symbol
      int tradesOpenedToday; // Anti-overtrading counter
      int lastTradeDay;      // Day of last trade
    };

    int GMTOffset =
        0; // GMT offset (auto-detected at runtime from TimeGMT()-TimeCurrent())
