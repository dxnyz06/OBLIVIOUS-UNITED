   // Returns +1/-1/0 from generic AI bridge

// SECTION 18: EXECUTION / ORDER / POSITION MANAGEMENT


   double Get_Predicted_Signal_Strength(
   int &
   dir) {
   dir =
   0;
   if (!Predicted)
   return 0.0;
   if (g_aip_direction == 0)



   return 0.0;
   if (g_aip_impact <
   3)
   return 0.0; // require HIGH impact
   if (g_aip_confidence <=
   0.0)
   return 0.0;
   long delta =
   (long)(TimeCurrent() -
   g_aip_timestamp);
   if (delta >
   180) {
   g_aip_direction =
   0;
   return 0.0;
   } // stale > 3 min
   dir =
   g_aip_direction;
   return MathMin(
   g_aip_confidence,
   100.0);
   }

   double PredictedTrend() {
   // Multi-TF EMA alignment score: -1.0 (full bear) to +1.0 (full bull)
   double score =
   0.0;
   double maH1 = iMA(
   NULL,
   PERIOD_H1,
   50,
   0,
   MODE_EMA,
   PRICE_CLOSE,
   0);
   double maH4 = iMA(
   NULL,
   PERIOD_H4,
   50,
   0,
   MODE_EMA,
   PRICE_CLOSE,
   0);
   double maD1 = iMA(
   NULL,
   PERIOD_D1,
   50,
   0,
   MODE_EMA,
   PRICE_CLOSE,
   0);
   double clH1 = iClose(
   NULL,
   PERIOD_H1,
   1);
   double clH4 = iClose(
   NULL,
   PERIOD_H4,
   1);
   double clD1 = iClose(
   NULL,
   PERIOD_D1,
   1);
   if (clH1 >
   maH1)
   score +=
   0.33;
   else
   score -=
   0.33;
   if (clH4 >
   maH4)
   score +=
   0.33;
   else
   score -=
   0.33;
   if (clD1 >
   maD1)
   score +=
   0.34;
   else
   score -=
   0.34;
   // Slope bonus
   double maH4prev = iMA(
   NULL,
   PERIOD_H4,
   50,
   0,
   MODE_EMA,
   PRICE_CLOSE,
   1);
   if (maH4 >
   maH4prev)
   score +=
   0.1;
   else
   score -=
   0.1;
   return MathMax(
   MathMin(
   score,
   1.0),
   -1.0);
   }

   // PredictedVolatility: AI-synthetic prediction (rule-based, no external model)

   double PredictedVolatility() {
   // Volatility regime: 0.0 (low/stable) to 1.0 (high/dangerous)
   double atr14 = iATR(
   NULL,
   0,
   14,
   1);
   double atr50 = iATR(
   NULL,
   0,
   50,
   1);
   double atr200 = iATR(
   NULL,
   0,
   200,
   1);
   if (atr50 <=
   0 ||
   atr200 <=
   0)
   return 0.5;
   double ratio14_50 =
   atr14 /
   atr50;
   double ratio50_200 =
   atr50 /
   atr200;
   double vol =
   (ratio14_50 *
   0.6 +
   ratio50_200 *
   0.4 -
   1.0) *
   0.5 +
   0.5;
   return MathMax(
   MathMin(
   vol,
   1.0),
   0.0);
   }

   // PredictedReversal: AI-synthetic prediction (rule-based, no external model)

   double PredictedReversal() {
   // Reversal probability: -1.0 (strong bear reversal) to +1.0 (strong bull reversal)
   double rsi = iRSI(
   NULL,
   0,
   14,
   PRICE_CLOSE,
   1);
   double rsi2 = iRSI(
   NULL,
   0,
   14,
   PRICE_CLOSE,
   2);
   double cci = iCCI(
   NULL,
   0,
   20,
   PRICE_TYPICAL,
   1);
   double wpr = iWPR(
   NULL,
   0,
   14,
   1);
   double score =
   0.0;
   // RSI divergence proxy
   if (rsi <
   30)
   score +=
   0.4;
   else if (
   rsi >
   70)
   score -=
   0.4;
   // RSI rising from oversold
   if (rsi >
   rsi2 &&
   rsi <
   40)
   score +=
   0.3;
   if (rsi <
   rsi2 &&
   rsi >
   60)
   score -=
   0.3;
   // CCI gate
   if (cci <
   -100)
   score +=
   0.2;
   else if (
   cci >
   100)
   score -=
   0.2;
   // WPR gate
   if (wpr >
   -20)
   score -=
   0.1;
   else if (
   wpr <
   -80)
   score +=
   0.1;
   return MathMax(
   MathMin(
   score,
   1.0),
   -1.0);
   }

   // PredictedMomentum: AI-synthetic prediction (rule-based, no external model)

   double PredictedMomentum() {
   // Momentum continuation score: -1.0 to +1.0
   double macd1 = iMACD(
   NULL,
   0,
   12,
   26,
   9,
   PRICE_CLOSE,
   MODE_MAIN,
   1);
   double macd2 = iMACD(
   NULL,
   0,
   12,
   26,
   9,
   PRICE_CLOSE,
   MODE_MAIN,
   2);
   double mom14 = iMomentum(
   NULL,
   0,
   14,
   PRICE_CLOSE,
   1);
   double mom14p = iMomentum(
   NULL,
   0,
   14,
   PRICE_CLOSE,
   2);
   double ao1 = iAO(
   NULL,
   0,
   1);
   double ao2 = iAO(
   NULL,
   0,
   2);
   double score =
   0.0;
   // MACD slope
   if (macd1 >
   macd2 &&
   macd1 >
   0)
   score +=
   0.4;
   else if (
   macd1 <
   macd2 &&
   macd1 <
   0)
   score -=
   0.4;
   else if (
   macd1 >
   macd2)
   score +=
   0.2;
   else
   score -=
   0.2;
   // Momentum slope
   if (mom14 >
   100 &&
   mom14 >
   mom14p)
   score +=
   0.3;
   else if (
   mom14 <
   100 &&
   mom14 <
   mom14p)
   score -=
   0.3;
   // AO color
   if (ao1 > ao2 && ao1 > 0)
     score += 0.3;
   else if (ao1 < ao2 && ao1 < 0)
     score -= 0.3;
   return MathMax(
   MathMin(
   score,
   1.0),
   -1.0);
   }

   // PredictedSentiment: AI-synthetic prediction (rule-based, no external model)

   double PredictedSentiment() {
   // Synthetic sentiment: -1.0 (full fear/bearish) to +1.0 (full greed/bullish)
   // Composite of bullish/bearish pressure indicators
   double bulls = iBullsPower(
   NULL,
   0,
   13,
   PRICE_CLOSE,
   1);
   double bears = iBearsPower(
   NULL,
   0,
   13,
   PRICE_CLOSE,
   1);
   double mfi = iMFI(
   NULL,
   0,
   14,
   1);
   double obv1 = iOBV(
   NULL,
   0,
   PRICE_CLOSE,
   1);
   double obv5 = iOBV(
   NULL,
   0,
   PRICE_CLOSE,
   5);
   double score =
   0.0;
   // BullsPower vs BearsPower
   double totalPow =
   MathAbs(
   bulls) +
   MathAbs(
   bears);
   if (totalPow >
   0)
   score +=
   (bulls -
   MathAbs(
   bears)) /
   totalPow *
   0.4;
   // MFI
   if (mfi >
   60)
   score +=
   0.3;
   else if (
   mfi <
   40)
   score -=
   0.3;
   else
   score +=
   (mfi -
   50) /
   50.0 *
   0.3;
   // OBV slope
   if (obv1 >
   obv5)
   score +=
   0.3;
   else
   score -=
   0.3;
   return MathMax(
   MathMin(
   score,
   1.0),
   -1.0);
   }

   // PredictedSignal: aggregates all 5 Predicted scores -> int direction
   // Block on high volatility
   // Composite weighted score

   // CombinedPredictedConfidence: returns confidence 50-88 from Predicted scores

      // Wires all 3 pipelines through CombinedFilterConfidence -> ConfirmTradeEntry

