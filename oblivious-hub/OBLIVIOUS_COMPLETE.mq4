                                          int Strategy_AI_Signal(
                                              string symbol) {
                                            if (!Predicted)
                                              return 0;

                                            // Check if AI bridge has a
                                            // fresh signal
                                            if (!AIBridge_HasFreshSignal())
                                              return 0;

                                            int aiDir = AIBridge_GetDirection();
                                            double aiConf =
                                                AIBridge_GetConfidence();

                                            // Minimum confidence threshold
                                            double minConf =
                                                AiMinConfidence / 100.0;
                                            if (aiConf < minConf)
                                              return 0;

                                            double close = iClose(symbol, 0, 0);

                                            //--- Primary: OTE Band System
                                            // validation ---
                                            if (aiDir > 0) {
                                              // BUY: check OTE band touch
                                              // on LTF+HTF
                                              if (AIP2_T0_RangeTouchOK(+1))
                                                return +1;

                                              // Fallback: tick-sequential
                                              // touch
                                              if (aiConf >= 0.75 &&
                                                  AIP2_T0_TickSequentialOK(+1))
                                                return +1;
                                            } else if (aiDir < 0) {
                                              if (AIP2_T0_RangeTouchOK(-1))
                                                return -1;

                                              if (aiConf >= 0.75 &&
                                                  AIP2_T0_TickSequentialOK(-1))
                                                return -1;
                                            }

                                            //--- Secondary: ICT confluence
                                            // filter ---
                                            ICT_SCORE_RESULT
                                            ictRes;
                                            double ictScore =
                                                ICT_ComputeConfluence(aiDir, 40,
   ictRes);
                                            if (ictScore >= 60 &&
                                                aiConf >= 0.70) {
                                              // ICT confluence is high + AI
                                              // confidence OK ÃƒÃ‚Â¢— → accept
                                              int pbias = GetPatternBias(0);
                                              if (aiDir > 0 && pbias >= 0)
                                                return +1;
                                              if (aiDir < 0 && pbias <= 0)
                                                return -1;
                                            }

                                            // OTE zone check ---
                                            int lookback = 20;
                                            double hi = iHigh(
                                                symbol, 0,
                                                iHighest(symbol, 0, MODE_HIGH,
                                                         lookback, 1));
                                            double lo = iLow(
                                                symbol, 0,
                                                iLowest(symbol, 0, MODE_LOW,
                                                        lookback, 1));
                                            double range = hi - lo;
                                            if (range <= 0)
                                              return 0;

                                            double oteUpper =
                                                hi - range * 0.236;
                                            double oteLower =
                                                hi - range * 0.382;

                                            if (aiDir > 0) {
                                              if (close >= lo + range * 0.618 &&
                                                  close <= oteUpper)
                                                return 1;
                                              if (aiConf >= 0.8 &&
                                                  close <= lo + range * 0.382)
                                                return 1;
                                            } else if (aiDir < 0) {
                                              if (close >= oteLower &&
                                                  close <= hi - range * 0.618)
                                                return -1;
                                              if (aiConf >= 0.8 &&
                                                  close >= hi - range * 0.382)
                                                return -1;
                                            }

                                            // High confidence override
                                            if (aiConf >= 0.9)
                                              return aiDir;

                                            return 0;
                                          }

                                          void Strategy_AI_Manage(
                                              string symbol) {
                                            // Manage AI Predicted
                                            // positions: apply breakeven +
                                            // trailing stop
                                            int magic = PredictedMagic;
                                            for (int i = OrdersTotal() - 1;
                                                 i >= 0; i--) {
                                              if (!OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES))
                                                continue;
                                              if (OrderSymbol() != symbol)
                                                continue;
                                              if (OrderMagicNumber() != magic)
                                                continue;
                                              if (OrderType() > OP_SELL)
                                                continue;
                                              ApplyTrailingStop(OrderTicket());
                                            }
                                          }

