double GetSuperTrend(int period, double multiplier, int shift)
{
      double atr = iATR(NULL, 0, period, shift);
      double median = (iHigh(NULL, 0, shift) + iLow(NULL, 0, shift)) / 2.0;
      return median + multiplier * atr;
}

double GetDonchian(int period, int mode, int shift)
{
      if (mode == MODE_UPPER)
        return iHigh(NULL, 0, iHighest(NULL, 0, MODE_HIGH, period, shift));
      return iLow(NULL, 0, iLowest(NULL, 0, MODE_LOW, period, shift));
}

double GetKeltner(int period, int mode, int shift)
{
      double ma = iMA(NULL, 0, period, 0, MODE_SMA, PRICE_CLOSE, shift);
      double atr = iATR(NULL, 0, period, shift);
      if (mode == MODE_UPPER)
        return ma + 2 * atr;
      if (mode == MODE_LOWER)
        return ma - 2 * atr;
      return ma;
}

double GetVortex(int period, int mode, int shift)
{
      double vmp = MathAbs(iHigh(NULL, 0, shift) - iLow(NULL, 0, shift + 1));
      double vmm = MathAbs(iLow(NULL, 0, shift) - iHigh(NULL, 0, shift + 1));
      double tr = MathMax(
          iHigh(NULL, 0, shift) - iLow(NULL, 0, shift),
          MathMax(MathAbs(iHigh(NULL, 0, shift) - iClose(NULL, 0, shift + 1)),
                  MathAbs(iLow(NULL, 0, shift) - iClose(NULL, 0, shift + 1))));
      return (tr > 0 ? vmp / tr : 0.5);
}

double _SessionVWAP(string sym, ENUM_TIMEFRAMES tf, int bars=1440)
{
      // Approx VWAP using tick volume
      double sumPV = 0, sumV = 0;
      int counted = (int)MathMin(bars, Bars - 1);
      for (int i = 0; i < counted; i++) {
        double tp =
            (iHigh(sym, tf, i) + iLow(sym, tf, i) + iClose(sym, tf, i)) / 3.0;
        double v = (double)iVolume(sym, tf, i);
        sumPV += tp * v;
        sumV += v;
      }
      if (sumV <= 0)
        return iClose(sym, tf, 0);
      return sumPV / sumV;
}

