bool AA_IsNewBar(){
      datetime bt = iTime(Symbol(), Period(), 0);
      if (g_lastBarTime == 0) {
        g_lastBarTime = bt;
        return true;
      }
      if (bt != g_lastBarTime) {
        g_lastBarTime = bt;
        return true;
      }
      return false; }

void FindBestConsolidation(int &startIdx, int &length)
{
   startIdx = 0;
   length = 10;
   double minRange = 1e10;
   int lookback = (int)MathMin(200, Bars - 1);
   for (int i = 1; i < lookback; i++) {
      double rng = High[i] - Low[i];
      if (rng < minRange) { minRange = rng; startIdx = i; length = 1; }
   }
}

int AdaptiveMaxLook()
{
      // Use median run of low-range clusters as a proxy, scaled
      int si = 0, L = 0;
      FindBestConsolidation(si, L);
      int base = 5 * L; // scaled by consolidation length
      return ClampInt(base, 40, 240);
}

int AdaptiveLookbackN(int Nbase){
      if (Nbase <= 0)
        return 0;
      double atr_now = GetATRNow();
      double atr_ref = GetATRRef();
      if (atr_now <= 0 || atr_ref <= 0)
        return Nbase;
      double ratio = atr_now / atr_ref;           // >1 means higher current vol
      ratio = MathMax(0.33, MathMin(3.0, ratio)); // clamp
      double inv = 1.0 / ratio;                   // higher vol -> smaller N
      int nmin = (int)MathMax(3, MathRound(0.5 * Nbase));
      int nmax = (int)MathMin(500, MathRound(3.0 * Nbase));
      int Nadj = (int)MathRound(Nbase * inv);
      if (Nadj < nmin)
        Nadj = nmin;
      if (Nadj > nmax)
        Nadj = nmax;
      return Nadj;
}

bool AdaptiveEngulfing(bool bullish, int shift){
      double atr = _AA_ATR(Period());
      double k = (Auto_VolRegime() >= 2 ? 0.8 : 0.6);
      double body = MathAbs(Close[shift] - Open[shift]);
      if (body < k * atr)
        return false;
      if (bullish) {
        return (
            Open[shift] < Close[shift] && Open[shift + 1] > Close[shift + 1] &&
            Open[shift] <= Close[shift + 1] && Close[shift] >= Open[shift + 1]);
      } else {
        return (
            Open[shift] > Close[shift] && Open[shift + 1] < Close[shift + 1] &&
            Open[shift] >= Close[shift + 1] && Close[shift] <= Open[shift + 1]);
      }
}

bool AdaptivePinBar(bool bullish, int shift){
      double atr = _AA_ATR(Period());
      double total = High[shift] - Low[shift];
      if (total <= 0)
        return false;
      double body = MathAbs(Close[shift] - Open[shift]);
      double upper = High[shift] - MathMax(Open[shift], Close[shift]);
      double lower = MathMin(Open[shift], Close[shift]) - Low[shift];
      double min_tail_ratio = (Auto_VolRegime() >= 2 ? 0.65 : 0.55);
      double max_body_ratio = (Auto_VolRegime() >= 2 ? 0.35 : 0.40);
      if (bullish) {
        if (lower / total < min_tail_ratio)
          return false;
      } else {
        if (upper / total < min_tail_ratio)
          return false;
      }
      if (body / total > max_body_ratio)
        return false;
      return total >= 0.6 * atr;
}

void RegimeBox_Update(const int span = 10)
{
      if (Bars <= span)
        return;
      // compute extremes over the last 'span' bars (including current forming
      // bar)
      int idxHi = iHighest(NULL, 0, MODE_HIGH, span, 0);
      int idxLo = iLowest(NULL, 0, MODE_LOW, span, 0);
      double hi = High[idxHi];
      double lo = Low[idxLo];
      datetime t1 = Time[span - 1];
      datetime t2 = Time[0];
      string id = "REG_BOX";
      if (ObjectFind(0, id) < 0)
        ObjectCreate(0, id, OBJ_RECTANGLE, 0, 0, 0);
      // coordinates & style (border-only look)
      ObjectSetInteger(0, id, OBJPROP_BACK, false);
      ObjectSetInteger(0, id, OBJPROP_STYLE, STYLE_SOLID);
      ObjectSetInteger(0, id, OBJPROP_WIDTH, 1);
      ObjectSetInteger(0, id, OBJPROP_COLOR, RGB_Current());
      ObjectSetInteger(0, id, OBJPROP_TIME1, t1);
      ObjectSetDouble(0, id, OBJPROP_PRICE1, hi);
      ObjectSetInteger(0, id, OBJPROP_TIME2, t2);
      ObjectSetDouble(0, id, OBJPROP_PRICE2, lo);
}

double RegimeTrendiness01(int tf=0){
      double adx = iADX(Symbol(), tf > 0 ? tf : Period(), 14, PRICE_CLOSE, MODE_MAIN, 0);
      return MathMin(1.0, MathMax(0.0, adx / 50.0));
}

double RegimeVolatility01(int tf=0){
      double BBDev = Auto_BB_Dev();
      int    BBPeriod = Auto_BB_Period();
      double bbdev = BBDev;
      int    RegimeLookback = 50;
      double up0 = iBands(NULL, tf, BBPeriod, bbdev, Auto_BB_Period(),
                          PRICE_CLOSE, MODE_UPPER, 0);
      double lo0 = iBands(NULL, tf, BBPeriod, bbdev, Auto_BB_Period(),
                          PRICE_CLOSE, MODE_LOWER, 0);
      double mi0 = iBands(NULL, tf, BBPeriod, bbdev, Auto_BB_Period(),
                          PRICE_CLOSE, MODE_MAIN, 0);
      int look = (int)MathMin(RegimeLookback, Bars);
      if (look <= 1)
        return 0.5;
      int rank = 0;
      for (int k = 0; k < look; k++) {
        double up = iBands(NULL, tf, BBPeriod, bbdev, Auto_BB_Period(),
                           PRICE_CLOSE, MODE_UPPER, k);
        double lo = iBands(NULL, tf, BBPeriod, bbdev, Auto_BB_Period(),
                           PRICE_CLOSE, MODE_LOWER, k);
        double mi = iBands(NULL, tf, BBPeriod, bbdev, Auto_BB_Period(),
                           PRICE_CLOSE, MODE_MAIN, k);
        double bbw = (up - lo) / MathMax(Point, MathAbs(mi));
        double bbw0 = (up0 - lo0) / MathMax(Point, MathAbs(mi0));
        if (bbw <= bbw0)
          rank++;
      }
      return (double)rank / (double)look;
}

double __GetAdaptiveRetracePct(){
      int tf = Period();
      double v = __VolRatio();
      double pct;
      if (tf <= PERIOD_M5)
        pct = 30.0;
      else if (tf <= PERIOD_M15)
        pct = 25.0;
      else if (tf <= PERIOD_H1)
        pct = 20.0;
      else if (tf <= PERIOD_H4)
        pct = 18.0;
      else
        pct = 15.0;
      if (v > 2.0)
        pct += 5.0;
      else if (v > 1.5)
        pct += 2.0;
      else if (v < 0.9)
        pct -= 2.0;
      if (pct < 10.0)
        pct = 10.0;
      if (pct > 40.0)
        pct = 40.0;
      return pct;
}

int __GetAdaptiveConfirmBarsFull(){
      int tf = Period();
      double v = __VolRatio();
      double adx = __TrendADX();
      double base;
      if (tf <= PERIOD_M5)
        base = 3;
      else if (tf <= PERIOD_M15)
        base = 2.5;
      else if (tf <= PERIOD_H1)
        base = 2;
      else if (tf <= PERIOD_H4)
        base = 1.5;
      else
        base = 1;
      if (v > 2.0)
        base -= 0.7;
      else if (v > 1.5)
        base -= 0.4;
      else if (v < 0.8)
        base += 0.5;
      if (adx >= Auto_ADX_Threshold())
        base -= 0.5;
      else if (adx <= 15)
        base += 0.5;
      double atr = __ATR_(14);
      if (atr > Point * 2) {
        double spreadToATR = __SpreadPoints() / atr;
        if (spreadToATR > 0.25)
          base += 0.5;
      }
      int bars = (int)MathRound(base);
      if (bars < 1)
        bars = 1;
      if (bars > 5)
        bars = 5;
      return bars;
}

int Auto_GridStepPips(){
      double atr = iATR(Symbol(), Period(), Auto_ATR_Period(), 0);
      double pips = (atr / Point) / AA_PointsPerPip();
      VolRegime r = (VolRegime)g_adapt.regime;
      double k =
          (r == VOL_LOW
               ? 1.20
               : (r == VOL_NORMAL ? 1.00 : (r == VOL_HIGH ? 0.85 : 0.75)));
      int step = (int)MathMax(2, MathRound(pips * 0.5 * k));
      return step; }

