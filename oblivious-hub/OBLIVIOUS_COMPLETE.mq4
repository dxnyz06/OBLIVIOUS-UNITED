      CreateDashboardLabel("Dashboard_TEMA", "TEMA: ", 1430, clrWhite, 10);
      CreateDashboardButton("Button_TEMA_Toggle",
                            (UI_EnableTEMA() ? "SPENTO" : "ATTIVO"), 250, 1430);
      CreateDashboardLabel("Dashboard_TRIX", "TRIX: ", 1445, clrWhite, 10);
      CreateDashboardButton("Button_TRIX_Toggle",
                            (UI_EnableTRIX() ? "SPENTO" : "ATTIVO"), 250, 1445);
      CreateDashboardLabel("Dashboard_TrueRange", "TrueRange: ", 1460, clrWhite,
                           10);
      CreateDashboardButton("Button_TrueRange_Toggle",
                            (UI_EnableTrueRange() ? "SPENTO" : "ATTIVO"), 250,
                            1460);
      CreateDashboardLabel("Dashboard_UlcerIndex", "UlcerIndex: ", 1475,
                           clrWhite, 10);
      CreateDashboardButton("Button_UlcerIndex_Toggle",
                            (UI_EnableUlcerIndex() ? "SPENTO" : "ATTIVO"), 250,
                            1475);
      CreateDashboardLabel("Dashboard_Vortex", "Vortex: ", 1490, clrWhite, 10);
      CreateDashboardButton("Button_Vortex_Toggle",
                            (UI_EnableVortex() ? "SPENTO" : "ATTIVO"), 250,
                            1490);
      CreateDashboardLabel("Dashboard_Williams", "Williams: ", 1505, clrWhite,
                           10);
      CreateDashboardButton("Button_Williams_Toggle",
                            (UI_EnableWilliams() ? "SPENTO" : "ATTIVO"), 250,
                            1505);
      CreateDashboardLabel("Dashboard_RSI_AI_Filter", "RSI AI Filter: ", 1520,
                           clrWhite, 10);
      CreateDashboardButton("Button_RSI_AI_Filter_Toggle",
                            (UI_Enable_RSI_AI_Filter() ? "SPENTO" : "ATTIVO"),
                            250, 1520);

      // --- 7 CANONICAL STRATEGY: Labels and confidence bars ---
      int _yStart = 280; int _yStep = 15;
      string _dStrats2[7] = {"Predicted","Breakout","FVG","Grid","SMC","ICT","Reverse"};
      string _dLabels2[6] = {"Predicted: ","Breakout: ","FVG: ","Grid: ","SMC/ICT: ","Reverse: "};
      for (int _di=0; _di<6; _di++) {
         int _yPos = _yStart + _di * _yStep;
         string _id = "Dashboard_" + _dStrats2[_di];
         string _barId = _id + "_Bar";
         CreateDashboardLabel(_id, _dLabels2[_di], _yPos, clrWhite, 10);
         CreateDashboardConfidenceBar(_barId, _yPos);
      }
}

void DisplayDashboard() {
      string status = "";
      status += ";Strategie: ";
      if (UI_EnableMomentum()) {
        status += "Momentum ";
      }
      // L'RSI (Relative Strength Index) valuta condizioni di ipercomprato e
      // ipervenduto.
      if (UI_EnableRSI()) {
        status += "RSI ";
      }
      if (EnableSMC) {
        status += "SMC ";
      }
      if (UI_EnablePredicted()) {
        status += "AI_PREDICTED ";
      }
      status += " ATR: " + DoubleToStr(Auto_ATR_Period(), 0) +
                " | SLx: " + DoubleToStr(GridSLMultiplier, 1) +
                " | TPx: " + DoubleToStr(GridTPMultiplier, 1);
      if (HighImpactNewsActive()) {
        LogGate("BLOCK NEWS",
                StringFormat("Symbol=%s Time=%s (file=file pATH)", Symbol(),
                             TimeToStr(TimeCurrent(), TIME_SECONDS)));
        status += " NOTIZIE AD ALTO IMPATTO!";
      }
      Comment(status);
}

void DisplayDrawdownLimits(){
      double maxDD = Active_MaxTotalDDPercent();
      double maxDaily = Active_MaxDailyDDPercent();
      double currentDD = GetTotalDrawdownPerc();
      DrawLabel("DD_LIMITS", 10, 350,
                StringFormat("DD: %.1f%% / Max: %.1f%% | Daily Max: %.1f%%",
                             currentDD, maxDD, maxDaily),
                currentDD > maxDD * 0.8 ? clrRed : clrLime);
}

void DrawConfidenceBar(string name, double conf, int x, int y, int width) {
      int bar_width = (int)(width * conf / 100.0);
      color bar_color = GetConfidenceColor(conf);
      ObjectCreate(0, name, OBJ_RECTANGLE_LABEL, 0, 0, 0);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_BGCOLOR, bar_color);
      ObjectSetInteger(0, name, OBJPROP_XSIZE, bar_width);
      ObjectSetInteger(0, name, OBJPROP_YSIZE, 10);
}

void CreateDashboardButton(string name, string text, int x, int y)
{
      if (ObjectFind(0, name) < 0)
        ObjectCreate(0, name, OBJ_BUTTON, 0, 0, 0);
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_XSIZE, 110);
      ObjectSetInteger(0, name, OBJPROP_YSIZE, 22);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite);
      ObjectSetInteger(0, name, OBJPROP_BGCOLOR, C'30,50,100');
      ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, clrSilver);
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 8);
      ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
}

void CreateDashboardLabel(string name, string text, int y, color clr, int fontSize)
{
      if (ObjectFind(0, name) < 0)
        ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
      ObjectSetString(0, name, OBJPROP_TEXT, text);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
      ObjectSetInteger(0, name, OBJPROP_FONTSIZE, fontSize);
      ObjectSetString(0, name, OBJPROP_FONT, "Arial");
      ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
}

void CreateDashboardConfidenceBar(string name, int y)
{
      string bgName = name + "_BG";
      string fgName = name + "_FG";
      if (ObjectFind(0, bgName) < 0)
        ObjectCreate(0, bgName, OBJ_RECTANGLE_LABEL, 0, 0, 0);
      ObjectSetInteger(0, bgName, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, bgName, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, bgName, OBJPROP_XSIZE, 120);
      ObjectSetInteger(0, bgName, OBJPROP_YSIZE, 10);
      ObjectSetInteger(0, bgName, OBJPROP_BGCOLOR, C'40,40,40');
      ObjectSetInteger(0, bgName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, bgName, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, bgName, OBJPROP_HIDDEN, true);
      if (ObjectFind(0, fgName) < 0)
        ObjectCreate(0, fgName, OBJ_RECTANGLE_LABEL, 0, 0, 0);
      ObjectSetInteger(0, fgName, OBJPROP_XDISTANCE, 10);
      ObjectSetInteger(0, fgName, OBJPROP_YDISTANCE, y);
      ObjectSetInteger(0, fgName, OBJPROP_XSIZE, 0);
      ObjectSetInteger(0, fgName, OBJPROP_YSIZE, 10);
      ObjectSetInteger(0, fgName, OBJPROP_BGCOLOR, clrDodgerBlue);
      ObjectSetInteger(0, fgName, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, fgName, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, fgName, OBJPROP_HIDDEN, true);
}

void DrawNewsPreview(string prefix, int x, int y, string filename, int rows) {
      string lines[];
      int n = ReadTopN(filename, lines, rows);
      for (int i = 0; i < rows; i++) {
        string nm = prefix + "_ROW_" + IntegerToString(i);
        string tag = prefix + "_TAG_" + IntegerToString(i);
        if (i >= n || StringLen(StringTrim(lines[i])) == 0) {
          if (ObjectFind(0, nm) >= 0)
            ObjectDelete(0, nm);
          if (ObjectFind(0, tag) >= 0)
            ObjectDelete(0, tag);
          continue;
        }
        string txt, imp;
        ParseNewsLine(lines[i], txt, imp);
        if (StringLen(txt) == 0) {
          if (ObjectFind(0, nm) >= 0)
            ObjectDelete(0, nm);
        } else {
          if (ObjectFind(0, nm) < 0)
            ObjectCreate(0, nm, OBJ_LABEL, 0, 0, 0);
          ObjectSetInteger(0, nm, OBJPROP_XDISTANCE, x);
          ObjectSetInteger(0, nm, OBJPROP_YDISTANCE, y + 16 * i);
          ObjectSetInteger(0, nm, OBJPROP_FONTSIZE, 9);
          ObjectSetInteger(0, nm, OBJPROP_COLOR, clrWhite);
          ObjectSetString(0, nm, OBJPROP_TEXT, txt);
        }
        if (StringLen(imp) == 0) {
          if (ObjectFind(0, tag) >= 0)
            ObjectDelete(0, tag);
        } else {
          if (ObjectFind(0, tag) < 0)
            ObjectCreate(0, tag, OBJ_LABEL, 0, 0, 0);
          ObjectSetInteger(0, tag, OBJPROP_XDISTANCE, x + 420);
          ObjectSetInteger(0, tag, OBJPROP_YDISTANCE, y + 16 * i);
          ObjectSetInteger(0, tag, OBJPROP_FONTSIZE, 9);
          ObjectSetInteger(0, tag, OBJPROP_COLOR, ImpactColor(imp));
          ObjectSetString(0, tag, OBJPROP_TEXT, StringUpper(imp));
        }
      }
}

void DrawPnLPanel() {
      for (int k = 0; k < 120; k++) {
        string lbl = "PNL_ITEM_" + IntegerToString(k);
        if (ObjectFind(0, lbl) != -1)
          ObjectDelete(0, lbl);
      }
      int y = 0;
      for (int i = 0; i < pnl_count; i++) {
        string lbl = "PNL_ITEM_" + IntegerToString(i);
        if (ObjectFind(0, lbl) == -1)
          ObjectCreate(0, lbl, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, lbl, OBJPROP_CORNER, PNL_CORNER);
        ObjectSetInteger(0, lbl, OBJPROP_XDISTANCE, PNL_OFFSET_X);
        ObjectSetInteger(0, lbl, OBJPROP_YDISTANCE, PNL_OFFSET_Y + y);
        ObjectSetInteger(0, lbl, OBJPROP_FONTSIZE, PNL_FONTSIZE);
        ObjectSetString(0, lbl, OBJPROP_FONT, PNL_FONT);
        color pnl_col = (pnl_list[i].pnl >= 0 ? clrLime : clrRed);
        string text =
            pnl_list[i].name + "" + DoubleToString(pnl_list[i].pnl, 2);
        ObjectSetString(0, lbl, OBJPROP_TEXT, text);
        ObjectSetInteger(0, lbl, OBJPROP_COLOR, pnl_col);
        y += PNL_FONTSIZE + 4;
      }
}

void DrawSectionTitle(string name, string text, int x, int y) {
      if (ObjectFind(0, name) < 0)
