double GetAutoSL(string strategy) {
  double atr = iATR(Symbol(), 0, 14, 1);
  if (atr <= 0) atr = 10 * Point;
  return atr * 1.5;
}
double GetAutoTP(string strategy) {
  double atr = iATR(Symbol(), 0, 14, 1);
  if (atr <= 0) atr = 10 * Point;
  return atr * 2.5;
}
void AutoAdjustRisk() {
  double equity = AccountEquity();
  if (equity <= 0) return;
  double dd = (g_peakEquity > 0) ? ((g_peakEquity - equity) / g_peakEquity) : 0.0;
  if (dd > 0.10) {
    // Risk adjustment noted: ManualLot is input, use DynamicLotSize scaling instead
    SmartLogWrap("AutoAdjustRisk", "DD=" + DoubleToStr(dd * 100, 1) + "% - lot reduction active");
  }
}

                      double GetSL(string strategy) {
                        if (strategy == "FVG")                 return FVGSL;
                        if (strategy == "Breakout")            return BreakoutSL;
                        if (strategy == "Reverse")             return ReverseSL;
                        if (strategy == "SMC") return SMCSL;
                        if (strategy == "ICT") return ICTSL;
                        if (strategy == "Grid")                return GridSL;
                        if (strategy == "Predicted")           return PredictedSL;
                        return 0;
                      }

                      double GetTP(string strategy) {
                        if (strategy == "FVG")                 return FVGTP;
                        if (strategy == "Breakout")            return BreakoutTP;
                        if (strategy == "Reverse")             return ReverseTP;
                        if (strategy == "SMC") return SMCTP;
                        if (strategy == "ICT") return ICTTP;
                        if (strategy == "Grid")                return GridTP;
                        if (strategy == "Predicted")           return PredictedTP;
                        return 0;
                      }

