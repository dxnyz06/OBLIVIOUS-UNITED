bool FVG_AA_Detect(bool isBuy, int sh, double &gL, double &gH, double &ce){
      double h2 = iHigh(Symbol(), Period(), sh + 2),
             l2 = iLow(Symbol(), Period(), sh + 2);
      double h0 = iHigh(Symbol(), Period(), sh),
             l0 = iLow(Symbol(), Period(), sh);
      if (isBuy) {
        if (l0 > h2) {
          gL = h2;
          gH = l0;
          ce = (gL + gH) / 2.0;
          return true;
        }
      } else {
        if (h0 < l2) {
          gL = h0;
          gH = l2;
          ce = (gL + gH) / 2.0;
          return true;
        }
      }
      return false;
}

bool FVG_AA_DisplacementOK(int sh)  {
      return true; }

bool FVG_AA_RetestCE(bool isBuy, double gL, double gH, double ce){
      double tol = FVG_AA_Tolerance();
      double p = isBuy ? Bid : Ask;
      return (p >= ce - tol && p <= ce + tol && p >= MathMin(gL, gH) &&
              p <= MathMax(gL, gH));
}

bool FVG_AA_SessionOK()
{
      return AA_SessionOK();
}

double FVG_AA_Tolerance()  {
      return ADV_Pip() * 5; }

bool FVG_AA_StructureOK(bool isBuy)  {
      return true; }

int GetDTDB_Signal()    {
      return 0; }

bool ICT_IsInKillzone(int kzStart, int kzEnd)
{
      int gmtHour = TimeHour(TimeGMT());
      if (kzStart < kzEnd)
        return (gmtHour >= kzStart && gmtHour < kzEnd);
      else // Wraps midnight
        return (gmtHour >= kzStart || gmtHour < kzEnd);
}

bool ICT_InLondonKZ()      {
      int h = TimeHour(TimeCurrent());
      return (h >= 2 && h <= 5); }

bool ICT_InNYKZ()          {
      int h = TimeHour(TimeCurrent());
      return (h >= 7 && h <= 10); }

bool ICT_InAsianKZ()       {
      int h = TimeHour(TimeCurrent());
      return (h >= 20 || h <= 0); }

bool ICT_InOverlapKZ()     {
      return (ICT_InLondonKZ() && ICT_InNYKZ()); }

bool ICT_InAnyKillzone()
{
      return (ICT_InLondonKZ() || ICT_InNYKZ() || ICT_InAsianKZ());
}

string ICT_CurrentKillzone()
{
      if (ICT_InOverlapKZ())
        return "LDN+NY Overlap";
      if (ICT_InLondonKZ())
        return "London KZ";
      if (ICT_InNYKZ())
        return "New York KZ";
      if (ICT_InAsianKZ())
        return "Asian KZ";
      return "Off-KZ";
}

void ICT_GetSessionRange(int kzStart, int kzEnd, double &hi, double &lo, double &mid) {
      hi = -DBL_MAX; lo = DBL_MAX;
      int curH = TimeHour(TimeCurrent());
      for (int i = 1; i < MathMin(Bars, 200); i++) {
        int h = TimeHour(Time[i]);
        if (h >= kzStart && h < kzEnd) {
          double barH = iHigh(Symbol(), 0, i);
          double barL = iLow(Symbol(), 0, i);
          if (barH > hi) hi = barH;
          if (barL < lo) lo = barL;
        }
      }
      if (hi == -DBL_MAX) hi = Close[0];
      if (lo == DBL_MAX)  lo = Close[0];
      mid = (hi + lo) * 0.5;
}

void ICT_GetAsianRange(double &hi, double &lo, double &mid)
{
      ICT_GetSessionRange(ICT_ASIAN_START, ICT_ASIAN_END, hi, lo, mid);
}

void ICT_GetLondonRange(double &hi, double &lo, double &mid)
{
      ICT_GetSessionRange(ICT_LONDON_START, ICT_LONDON_END, hi, lo, mid);
}

double ICT_ComputeConfluence(int dir, int lookback, ICT_SCORE_RESULT &result)
{
      result.score = 0;
      result.hasFVG = false;
      result.hasOB = false;
      result.hasSweep = false;
      result.inKillzone = false;
      result.reasons = "";

      int tf = Period();
      double totalWeight = 0;
      double totalScore = 0;

      //--- 1. FVG (weight: 30) ---
      ADV_FVG_ZONE fvg;
      ADV_OB_ZONE obFromFVG;
      if (ADV_FindFVG_Pro(tf, dir, lookback, false, fvg, obFromFVG)) {
        result.hasFVG = true;
        result.fvg = fvg;
        double fvgScore = 1.0;

        // Bonus: price is in the FVG zone right now
        if (ADV_PriceInZone_FVG(tf, fvg))
          fvgScore += 0.5;

        // Bonus: FVG not yet filled
        if (!ADV_FVG_IsFilled(tf, fvg, 10))
          fvgScore += 0.3;

        totalScore += 30.0 * MathMin(fvgScore, 1.8) / 1.8;
        totalWeight += 30.0;
        result.reasons += "FVG ";
      } else {
        totalWeight += 30.0; // Still counts toward denominator
      }

      //--- 2. Order Block (weight: 25) ---
      ADV_OB_ZONE ob;
      if (result.hasFVG && obFromFVG.valid) {
        ob = obFromFVG;
        result.hasOB = true;
      } else if (ADV_FindOrderBlock(tf, 2, dir, ob)) {
        result.hasOB = true;
      }

      if (result.hasOB) {
        result.ob = ob;
        totalScore += 25.0;
        totalWeight += 25.0;
        result.reasons += "OB ";
      } else {
        totalWeight += 25.0;
      }

      //--- 3. Liquidity Sweep (weight: 20) ---
      double poolLevel = 0;
      int poolCount = 0;
      int sweepShift = -1;
      bool foundPool = false;

      if (dir > 0)
        foundPool = ADV_FindEqualLows(tf, lookback, poolLevel, poolCount);
      else
        foundPool = ADV_FindEqualHighs(tf, lookback, poolLevel, poolCount);

      if (foundPool &&
          ADV_HasLiquiditySweep(tf, dir, poolLevel, lookback, sweepShift)) {
        result.hasSweep = true;
        totalScore += 20.0;
        result.reasons += "SWEEP ";
      }
      totalWeight += 20.0;

      //--- 4. Killzone (weight: 15) ---
      if (ICT_InAnyKillzone()) {
        result.inKillzone = true;
        totalScore += 15.0;
        result.reasons += ICT_CurrentKillzone() + " ";
      }
      totalWeight += 15.0;

      //--- 5. Structure (weight: 10) ---
      double fracLvl = 0;
      int fracBar = -1;
      if (ADV_LastFractal(tf, dir, lookback, fracLvl, fracBar)) {
        double c = iClose(Symbol(), tf, 0);
        bool aligned = (dir > 0 ? (c > fracLvl) : (c < fracLvl));
        if (aligned) {
          totalScore += 10.0;
          result.reasons += "FRAC ";
        }
      }
      totalWeight += 10.0;

      // Final score
      result.score = (totalWeight > 0 ? (totalScore / totalWeight) * 100.0 : 0);
      return result.score;
}

bool ICT_HasValidSetup(int dir, int lookback, double minScore=60.0)
{
      ICT_SCORE_RESULT res;
      double score = ICT_ComputeConfluence(dir, lookback, res);
      return (score >= minScore && res.hasFVG);
}

double Score_Engulfing()  {
      double b0 = MathAbs(Close[1] - Open[1]), b1 = MathAbs(Close[2] - Open[2]);
      if (b1 <= 0)
        return 0;
      return clamp01(b0 / b1 - 1.0); }

double Score_Doji()  {
      double r = High[1] - Low[1];
      if (r <= 0)
        return 0;
      return clamp01(1.0 - MathAbs(Close[1] - Open[1]) / r); }

double Score_Piercing()  {
      if (Close[2] >= Open[2])
        return 0;
      double mid2 = (Open[2] + Close[2]) * 0.5;
      if (Close[1] > mid2 && Open[1] < Close[2])
        return 0.7;
      return 0; }

double Score_DarkCloud()  {
      if (Close[2] <= Open[2])
        return 0;
      double mid2 = (Open[2] + Close[2]) * 0.5;
      if (Close[1] < mid2 && Open[1] > Close[2])
        return 0.7;
      return 0; }

double Score_MorningStar()  {
      if (Bars < 4)
        return 0;
      bool d1 = Close[3] < Open[3];
      double b2 = MathAbs(Close[2] - Open[2]), r2 = High[2] - Low[2];
      bool sm = (r2 > 0 && b2 < r2 * 0.3);
      bool u3 = Close[1] > Open[1] && Close[1] > (Open[3] + Close[3]) * 0.5;
      return (d1 && sm && u3 ? 0.85 : 0); }

double Score_EveningStar()  {
      if (Bars < 4)
        return 0;
      bool u1 = Close[3] > Open[3];
      double b2 = MathAbs(Close[2] - Open[2]), r2 = High[2] - Low[2];
      bool sm = (r2 > 0 && b2 < r2 * 0.3);
      bool d3 = Close[1] < Open[1] && Close[1] < (Open[3] + Close[3]) * 0.5;
      return (u1 && sm && d3 ? 0.85 : 0); }

double Score_ThreeSoldiers()  {
      if (Bars < 4)
        return 0;
      bool ok = true;
      for (int i = 1; i <= 3; i++) {
        if (Close[i] <= Open[i])
          ok = false;
        if (i < 3 && Close[i] <= Close[i + 1])
          ok = false;
      }
      return (ok ? 0.9 : 0); }

double Score_ThreeCrows()  {
      if (Bars < 4)
        return 0;
      bool ok = true;
      for (int i = 1; i <= 3; i++) {
        if (Close[i] >= Open[i])
          ok = false;
        if (i < 3 && Close[i] >= Close[i + 1])
          ok = false;
      }
      return (ok ? 0.9 : 0); }

double Score_AbandonedBaby()  {
      if (Bars < 4)
        return 0;
      double r2 = High[2] - Low[2], b2 = MathAbs(Close[2] - Open[2]);
      bool doji = (r2 > 0 && b2 < r2 * 0.1);
      bool gap1 = (Low[2] > MathMax(Open[3], Close[3]) ||
                   High[2] < MathMin(Open[3], Close[3]));
      bool gap2 = (Low[2] > MathMax(Open[1], Close[1]) ||
                   High[2] < MathMin(Open[1], Close[1]));
      return (doji && gap1 && gap2 ? 0.95 : 0); }

double Score_Kicker()  {
      if (Bars < 3)
        return 0;
      bool bear1 = Close[2] < Open[2];
      bool gapUp = Open[1] > Open[2];
      bool bull2 = Close[1] > Open[1];
      return ((bear1 && gapUp && bull2) ? 0.9 : 0); }

double Score_ThreeMethods(){
      double s = 0;
      if (Close[4] < Open[4] && Close[3] < Open[3] && Close[2] < Open[2] &&
          Close[1] < Open[1] && Close[0] > Open[0])
        s = 1;
      return znorm(s, 0.5); }

double Score_MATHold()  {
      return 0.5; }

double Score_SpinningTop()  {
      double r = High[1] - Low[1], b = MathAbs(Close[1] - Open[1]);
      if (r <= 0)
        return 0;
      return clamp01((r > 0 && b < r * 0.3 && b > r * 0.05) ? 0.4 : 0); }

double Score_HaramiCross()  {
      double b0 = MathAbs(Close[1] - Open[1]), b1 = MathAbs(Close[2] - Open[2]),
             r0 = High[1] - Low[1];
      if (b1 <= 0 || r0 <= 0)
        return 0;
      return ((b0 < r0 * 0.1 && b0 < b1 * 0.5) ? 0.6 : 0); }

double Score_EngulfingGap(){
      double ok = 0;
      if (Close[1] < Open[1] && Close[0] > Open[0] && Open[0] > High[1] &&
          Close[0] > Open[1])
        ok = 1;
      if (Close[1] > Open[1] && Close[0] < Open[0] && Open[0] < Low[1] &&
          Close[0] < Open[1])
        ok = 1;
      return znorm(ok, 0.5); }

double Score_ThreeInsideUp()  {
      if (Bars < 4)
        return 0;
      bool bear1 = Close[3] < Open[3];
      double mid1 = (Open[3] + Close[3]) * 0.5;
      bool inside =
          Close[2] > Open[2] && Close[2] < Open[3] && Open[2] > Close[3];
      bool up = Close[1] > Open[3];
      return ((bear1 && inside && up) ? 0.75 : 0); }

double Score_ThreeInsideDown()  {
      if (Bars < 4)
        return 0;
      bool bull1 = Close[3] > Open[3];
      bool inside =
          Close[2] < Open[2] && Close[2] > Open[3] && Open[2] < Close[3];
      bool dn = Close[1] < Open[3];
      return ((bull1 && inside && dn) ? 0.75 : 0); }

double Score_ThreeOutsideUp()  {
      if (Bars < 4)
        return 0;
      bool bear1 = Close[3] < Open[3];
      bool engulf =
          Close[2] > Open[2] && Close[2] > Open[3] && Open[2] < Close[3];
      bool up = Close[1] > Close[2];
      return ((bear1 && engulf && up) ? 0.8 : 0); }

double Score_ThreeOutsideDown()  {
      if (Bars < 4)
        return 0;
      bool bull1 = Close[3] > Open[3];
      bool engulf =
          Close[2] < Open[2] && Close[2] < Open[3] && Open[2] > Close[3];
      bool dn = Close[1] < Close[2];
      return ((bull1 && engulf && dn) ? 0.8 : 0); }

double Score_DojiStar()  {
      if (Bars < 3)
        return 0;
      double r1 = High[1] - Low[1], b1 = MathAbs(Close[1] - Open[1]);
      bool doji = (r1 > 0 && b1 < r1 * 0.1);
      bool gap = (MathMin(Open[1], Close[1]) > MathMax(Open[2], Close[2]) ||
                  MathMax(Open[1], Close[1]) < MathMin(Open[2], Close[2]));
      return ((doji && gap) ? 0.7 : 0); }

double Score_SeparatingLines(){
      double ok = 0;
      if (MathAbs(Open[0] - Open[1]) <= Point * 3 &&
          ((Close[1] > Open[1] && Close[0] < Open[0]) ||
           (Close[1] < Open[1] && Close[0] > Open[0])))
        ok = 1;
      return znorm(ok, 0.5); }

double Score_SideBySideWhiteLines(){
