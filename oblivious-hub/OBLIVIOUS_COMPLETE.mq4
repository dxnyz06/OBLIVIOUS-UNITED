      int tf = NextHigherTF(Auto_TFHigher2());
      return EnsureAvailableTF(Symbol(), tf);
}

bool IsNewBar()
{
      static datetime lastBarTime = 0;
      datetime cur = iTime(Symbol(), Period(), 0);
      if (cur != lastBarTime) {
        lastBarTime = cur;
        return true;
      }
      return false;
}

int AdaptiveEMAPeriodMTF() {
      int base_tf = Use_TF();
      int htf = Use_TFHigher1();
      int base_min = TFMinutes(base_tf);
      int htf_min = TFMinutes(htf);
      // Keep approx the same time window as EMA(50) on H1
      double target_minutes = (TFMinutes(PERIOD_H1) * 50.0); // 50 hours
      int period = (int)MathRound(target_minutes / htf_min);
      if (period < 2)
        period = 2;
      if (period > 200)
        period = 200;
      return period;
}

