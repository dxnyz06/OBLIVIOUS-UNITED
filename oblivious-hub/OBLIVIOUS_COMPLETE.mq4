   double __CombinedBreakEvenPrice(
   int tk1,
   int tk2) {
   double V =
   __PointValuePerLot();
   if (V <=
   0)
   return 0;
   double
   sum_q =
   0,
   sum_qe =
   0,
   C = 0;
   int arr[2];
   arr[0] = tk1;
   arr[1] = tk2;
   for (int i = 0; i < 2; i++) {
   int tk = arr[i];
   if (tk <= 0 || !OrderSelect(tk, SELECT_BY_TICKET)) continue;
   double q = (OrderType() == OP_BUY ? +OrderLots() : -OrderLots());
   double e = OrderOpenPrice();
   sum_q += q;
   sum_qe += q * e;
   C += OrderCommission() + OrderSwap();
   }
   return (sum_q != 0.0) ? (sum_qe / sum_q) : 0.0;
}
   bool AIB_SafeOrderModifyTP(
   int ticket,
   double
   tp) {
   if (ticket <=
   0 ||
   !OrderSelect(
   ticket,
   SELECT_BY_TICKET))
   return false;
   RefreshRates();
   double sl =
   OrderStopLoss();
   double price =
   (OrderType() == OP_BUY



   ? Bid
   : Ask);
   datetime exp =
   OrderExpiration();
   return OrderModify(
   ticket,
   price,
   sl,
   tp,
   exp,
   clrNONE);
   }

