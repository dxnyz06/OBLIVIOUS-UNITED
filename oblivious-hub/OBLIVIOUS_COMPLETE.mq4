void ExecuteStrategies() {
   // === Canonical dispatcher for: Grid, Breakout, Reverse ===
   // (Predicted -> DispatchPredictedStrategy, FVG -> FVG_Logic, SMC -> Strategy_SMC_Logic, ICT -> Strategy_ICT_Logic)
   // === GATE 1: Daily risk limit ===
   if (DailyStopOpenGate()) return;
   // === GATE 2: Session hours + day-of-week ===
   if (!IsSessionValid()) return;
   // === GATE 3: Volatility/spread check ===
   if (!MarketFiltersActive()) return;
   // === GATE 4: High-impact news block ===
   // NewsPolicy: per-strategy gating (Predicted exempt from high-impact block)

   int regime = TrendRegime(Symbol(), Period()); // 0=ranging, 1=trending

   // ITER 21 (F2) — Legacy dispatcher: SupportEngines_HardGate removed
   //   for Breakout/Reverse/Grid. The Decision Engine + new-bar event
   //   loop is the primary driver; CheckXXXSignal is retained ONLY as
   //   a cheap regime probe (not as a blocker). Soft penalties applied
   //   downstream in Staging_Submit.

   // ITER 22 (P3) — LEGACY DISPATCH NEUTRALIZED.
   //   The primary dispatcher in Orchestrator_OnTick now handles
   //   Breakout/Reverse/Grid via Decision-first (OBL_OwnerDecide →
   //   OBL_DecSet → Strategy_*_Logic). The shallow CheckBreakoutSignal /
   //   CheckReverseSignal / CheckGridSignal probes and the
   //   ExecuteStrategy("Grid") MARKET path are NOT called anymore.
   //   This function body is intentionally left empty so that the
   //   legacy callsite in Orchestrator_OnTick (after the Decision-first
   //   block) is a no-op for these 3 owners, preventing double-firing.
   //   Predicted / FVG / SMC / ICT were never in this legacy path.
   return;
   // Dead-code below intentionally kept commented for archaeology:
   // if (regime == 1 && Breakout && ...) Strategy_Breakout_Logic();
   // if (Reverse && ...) Strategy_Reverse_Logic();
   // if (regime == 0 && Grid && ...) ExecuteStrategy("Grid", sigG, gConf);
}

void ExecuteStrategy(string name, int direction, double confidence) {
   // ITER 23 (FASE A + MISSING-2) — LEGACY DISABLED.
   //   Owner execution flow goes EXCLUSIVELY through the Decision-first
   //   dispatcher in Orchestrator_OnTick → Strategy_*_Logic → Staging.
   //   This market-path shortcut would bypass projected lifecycle and
   //   ladder management. Hard-removed.
   return;
   // Dead code retained as archaeology only — not executed.
   // if (!IsSafeToTrade()) return;
   // ... original body removed ...
}

// Functions: 51

void LogOrderActivity(string action, int ticket, string symbol, double lots, double price) {
      if (ticket > 0) {
        AddToSmartLog(StringFormat("?? %s: Ticket %d, %s %.2f lots @ %.5f",
                                   action, ticket, symbol, lots, price));
      } else {
        AddToSmartLog(StringFormat("? %s failed: %s %.2f lots @ %.5f", action,
                                   symbol, lots, price));
      }
}

void CloseLosingPositions() {
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
        if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
        if (OrderSymbol() == Symbol() && OrderProfit() < 0) {
          double price = (OrderType() == OP_BUY) ? Bid : Ask;
          RefreshRates();
          {
    // TPSLMode routing: Native=strategy-own TP/SL, AI=bridge-derived TP/SL
    // Confidence model: 60% strategy base + 25% indicator score + 15% pattern confidence
    // Indicators and patterns support entry confidence - they do NOT own the trade
    // Ownership stays with caller strategy regardless of mode
            int __ticket = OrderTicket();
            double __lots = OrderLots();
            SmartLogWrap(
                "CLOSE",
                StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s",
                             __ticket, __lots, OrderSymbol()));
          }
          bool _wRes = OrderClose(OrderTicket(), OrderLots(), price,
                     GetAdaptiveSlippagePoints(), clrRed);
          {
            int __err = GetLastError();
            bool __isok = (__err == 0);
            SmartLogWrap(
                "CLOSE",
                StringFormat("%s | ticket=%d price=%.5f lots=%.2f err=%d",
                             __isok ? "PostClose OK" : "PostClose FAIL",
                             OrderTicket(), OrderClosePrice(), OrderLots(),
                             __err));
          }
        }
      }
}

string TagFromOrder(int ticket){
      string tag = "";
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return tag;
      string cmt = OrderComment();
      if (StringFind(cmt, "FVG", 0) >= 0)
        tag = "[FVG]";
      else if (StringFind(cmt, "SMC", 0) >= 0 || StringFind(cmt, "ICT", 0) >= 0)
        tag = "[SMC]";
      else if (StringFind(cmt, "Cobra", 0) >= 0)
        tag = "[COBRA]";
      else if (StringFind(cmt, "Blue", 0) >= 0 ||
               StringFind(cmt, "Marti", 0) >= 0)
        tag = "[MARTI]";
      else if (StringFind(cmt, "Emperor", 0) >= 0)
        tag = "[EMPEROR]";
      else if (StringFind(cmt, "Royal", 0) >= 0)
        tag = "[ROYAL]";
      else if (StringFind(cmt, "Grid", 0) >= 0)
        tag = "[GRID]";
      else if (StringFind(cmt, "Struct", 0) >= 0)
        tag = "[STRUCT]";
      else if (StringFind(cmt, "AI", 0) >= 0)
        tag = "[AI]";
      return tag;
}

int CountOpenBySide(int magic, bool isBuy)
{
      int cnt = 0;
      for (int i = 0; i < OrdersTotal(); i++) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != magic)
          continue;
        if ((isBuy && OrderType() == OP_BUY) ||
            (!isBuy && OrderType() == OP_SELL))
          cnt++;
      }
      return cnt;
}

string MakeOrderComment(string baseName, int levelIndex)
{
      int suffix = (int)MathMax(0, levelIndex - 1);
      return baseName + " ~ " + IntegerToString(suffix);
}

      bool ADV_FindOrderBlock(int tf, int dispBar, int dir, ADV_OB_ZONE &ob) {
        ob.valid = false;
        ob.dir = dir;
        ob.tf = tf;
        ob.bar = -1;
        ob.top = 0;
        ob.bot = 0;
        ob.mid = 0;
        ob.tForm = 0;

        int bars = iBars(Symbol(), tf);
        if (bars < dispBar + 5)
          return false;

        // Search backwards from the displacement bar for the last opposite
        // candle.
        int maxBack = (int)MathMin(
            20, bars - dispBar -
                    3); // adaptive enough without hard dependence on pips
        for (int k = 1; k <= maxBack; k++) {
          int s = dispBar + k;
          double o = iOpen(Symbol(), tf, s);
          double c = iClose(Symbol(), tf, s);
          double h = iHigh(Symbol(), tf, s);
          double l = iLow(Symbol(), tf, s);

          bool isOpp = (dir > 0 ? (c < o) : (c > o));
          if (!isOpp)
            continue;

          // Basic quality: candle range should be meaningful but not absurd
          // relative to ATR.
          double atr = ADV_ATR(tf, MathMax(10, Auto_ATR_Period()), s);
          if (atr <= 0)
            atr = 10.0 * ADV_Pip();
          double rng = h - l;
          if (rng < 0.20 * atr)
            continue;
          if (rng > 3.50 * atr)
            continue;

          // OB zone: body range (more ICT-consistent than full wick)
          double top = MathMax(o, c);
          double bot = MathMin(o, c);

          ob.valid = true;
          ob.bar = s;
          ob.top = top;
          ob.bot = bot;
          ob.mid = (top + bot) * 0.5;
          ob.tForm = iTime(Symbol(), tf, s);
          return true;
        }
        return false;
      }

      // Detect an EQH/EQL pool on tf in direction context.
      // dir>0 -> we are bullish: we want EQL (lows cluster) to be swept before
      // buying. dir<0 -> bearish: we want EQH (highs cluster) to be swept
      // before selling. Returns true with poolLevel and touches count.

bool ADV_HasOpenPosition(int magic)
{
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        if (OrderMagicNumber() != magic)
          continue;
        int t = OrderType();
        if (t == OP_BUY || t == OP_SELL)
          return true;
      }
      return false;
}

        bool OpenTrade(int type, double lot, double sl, double tp) {
          // === extra confirmations: Stochastic & CCI ===
          bool __isBuy = (type == OP_BUY);
          if (!ExtraIndicatorsConfirmAll(__isBuy)) {
            Print("Extra indicator confirmation failed (Stochastic/CCI).");
            return false;
          }
          // === end extra confirmations ===
          EnsureMinPriceSLTP(type, sl, tp);
          double price = (type == OP_BUY) ? Ask : Bid;
          // Unified spread filter gate
          if (SpreadFilter_IsHardBlocked()) {
            Print("SpreadFilter: hard block (spread > MaxSpreadPoints)");
            return false;
          }
          double spread = SpreadPoints();
          if (spread > MaxAllowedSpread) {
            Print("Spread troppo alto: ", spread);
            return false;
          }
          if (!CheckVolatility()) { Print("Ordine bloccato: volatilita eccessiva"); return false; }
          if (!CheckMultiSymbolRisk()) { Print("Ordine bloccato: rischio multi-simbolo oltre limite"); return false; }
          if (UI_BlockHighImpactNews() && CheckHighImpactNews()) {
            if (!Predicted) { Print("News ad alto impatto rilevata - strategie disattivate"); return false; }
          }
          if (!CheckDailyDDLimit()) { Print("Ordine bloccato per superamento DD giornaliero."); return false; }
          // Risk clamp: enforce MaxRiskTradePercent
          lot = Risk_ClampLotToMaxRisk(Symbol(), lot, sl, price);
          if (lot <= 0) { Print("Risk_ClampLotToMaxRisk rejected trade"); return false; }
          if (IsTPSL_AI()) {
            if (!__AP_DailyDrawdownGuard() || !__AP_ProfitLockOK() || !__AP_TotalDrawdownGuard()) return false;
            int __dir = __isBuy ? 1 : -1;
            if (!__AP_ClusterOK(Symbol(), PERIOD_CURRENT, __dir)) { Print("[AP] Cluster control skip"); return false; }
          }
          int ticket = SafeOrderSend(Symbol(), type, lot, price, Slippage, sl, tp, "OpenTrade", MagicNumber, 0, clrNONE);
          if (ticket > 0) {
             TPSL_RegisterTrade(ticket, MagicNumber, "Generic", type, price, sl);
          }
          return (ticket > 0);
        }

bool OpenTrade_BuyInternal(double lot, double sl, double tp) {
                          return OpenTrade(OP_BUY, lot, sl, tp);
}

bool OpenTrade_SellInternal(double lot, double sl, double tp) {
                          return OpenTrade(OP_SELL, lot, sl, tp);
}

bool SendTradeOrder(int type, double lot, double sl, double tp) {
                          return OpenTrade(type, lot, sl, tp);
}

                      bool findOrderBlock(int idx, int dir, double &obH,
   double &obL) {
                      // Find the last bearish OB (for bullish setups) or
                      // bullish OB (for bearish setups) dir=1: looking for
                      // demand OB (last down candle before impulse up)
                      // dir=-1: looking for supply OB (last up candle before
                      // impulse down)
                      int lookback = 30;
                      obH = 0.0;
                      obL = 0.0;
                      for (int j = idx + 1; j <= idx + lookback; j++) {
                        if (dir == 1) {
                          // Demand: find last bearish candle before a bullish
                          // impulse
                          if (Close[j] < Open[j]) { // Bearish candle
                            // Check impulse up after it
                            if (j > 1 && Close[j - 1] > Open[j - 1] &&
                                (Close[j - 1] - Open[j - 1]) >
                                    (High[j] - Low[j])) {
                              obH = High[j];
                              obL = Low[j];
                              return true;
                            }
                          }
                        } else {
                          // Supply: find last bullish candle before a bearish
                          // impulse
                          if (Close[j] > Open[j]) { // Bullish candle
                            if (j > 1 && Close[j - 1] < Open[j - 1] &&
                                (Open[j - 1] - Close[j - 1]) >
                                    (High[j] - Low[j])) {
                              obH = High[j];
                              obL = Low[j];
                              return true;
                            }
                          }
                        }
                      }
                      return false;
                      }

                      bool DailyStopOpenGate() {
                        double dd = -DailyPnLPercent();
                        double gain = DailyPnLPercent();
                        // Daily profit target removed: no forced close on profit
                        if (dd >= Active_DailyMaxLoss())
                          return true;
                        if (ChallengePassage && dd >= 0.035)
                          return true;
                        return false;
                      }

                      void DailyEmergencyCloseIfNeeded() {
                        if (!ChallengePassage)
                          return;
                        double dd = -DailyPnLPercent();
                        // FASE 5 (Patch 2): dd e' FRAZIONE (DailyPnLPercent
                        // ritorna frazione, non percentuale - confronto con
                        // 0.045 era hardcoded a 4.5%). Ora usa l'input.
                        if (dd >= MaxDailyDDPercent / 100.0) {
                          for (int i = OrdersTotal() - 1; i >= 0; i--) {
                            if (!OrderSelect(i, SELECT_BY_POS))
                              continue;
                            if (OrderSymbol() != Symbol())
                              continue;
                            int t = OrderType();
                            double lots = OrderLots();
                            {
                              int __ticket = OrderTicket();
                              double __lots = OrderLots();
                              SmartLogWrap("CLOSE",
                                           StringFormat("PreClose | "
                                                        "ticket=%d lots=%.2f "
                                                        "symbol=%s",
                                                        __ticket, __lots,
                                                        OrderSymbol()));
                            }
                            if (t == OP_BUY)
                              bool _wRes = OrderClose(OrderTicket(), lots, Bid,
                                         GetAdaptiveSlippagePoints(), clrRed);
                            {
                              int __err = GetLastError();
                              bool __isok = (__err == 0);
                              SmartLogWrap("CLOSE",
                                           StringFormat("%s | ticket=%d "
                                                        "price=%.5f "
                                                        "lots=%.2f err=%d",
                                                        __isok ? "PostClose OK"
   : "PostClose "
   "FAIL",
                                                        OrderTicket(),
                                                        OrderClosePrice(),
                                                        OrderLots(), __err));
                            }
                            {
                              int __ticket = OrderTicket();
                              double __lots = OrderLots();
                              SmartLogWrap("CLOSE",
                                           StringFormat("PreClose | "
                                                        "ticket=%d lots=%.2f "
                                                        "symbol=%s",
                                                        __ticket, __lots,
                                                        OrderSymbol()));
                            }
                            if (t == OP_SELL)
                              bool _wRes = OrderClose(OrderTicket(), lots, Ask,
                                         GetAdaptiveSlippagePoints(), clrRed);
                            {
                              int __err = GetLastError();
                              bool __isok = (__err == 0);
                              SmartLogWrap("CLOSE",
                                           StringFormat("%s | ticket=%d "
                                                        "price=%.5f "
                                                        "lots=%.2f err=%d",
                                                        __isok ? "PostClose OK"
   : "PostClose "
   "FAIL",
                                                        OrderTicket(),
                                                        OrderClosePrice(),
                                                        OrderLots(), __err));
                            }
                          }
                          PrintFormat("%s [LIMIT][DAILYDD] Emergency close at %.2f%%",
                                      TimeToString(TimeCurrent(),
                                                   TIME_DATE | TIME_SECONDS),
                                      MaxDailyDDPercent);
                        }
                      }

                      string OrderManager_BuildComment(string strategyName,
                                                       int magic) {
                        return StringFormat("%s|%s|%d", OM_COMMENT_PREFIX,
                                            strategyName, magic);
                      }

                      bool OrderManager_Modify(int ticket, double sl,
                                               double tp) {
                        if (!OrderSelect(ticket, SELECT_BY_TICKET, MODE_TRADES))
                          return false;

                        int digits =
                            (int)MarketInfo(OrderSymbol(), MODE_DIGITS);
                        if (sl > 0)
                          sl = NormalizeDouble(sl, digits);
                        if (tp > 0)
                          tp = NormalizeDouble(tp, digits);

                        double currentSL =
                            NormalizeDouble(OrderStopLoss(), digits);
                        double currentTP =
                            NormalizeDouble(OrderTakeProfit(), digits);

                        // Only modify if values actually
                        // changed
                        if (MathAbs(sl - currentSL) <
                                MarketInfo(OrderSymbol(), MODE_POINT) &&
                            MathAbs(tp - currentTP) <
                                MarketInfo(OrderSymbol(), MODE_POINT))
                          return true; // Nothing to change

                        for (int attempt = 0; attempt < OM_MAX_RETRIES;
                             attempt++) {
                          RefreshRates();
                          if (OrderModify(ticket, OrderOpenPrice(), sl, tp,
                                          0)) {
                            return true;
                          }

                          int err = GetLastError();
                          if (err == ERR_NO_RESULT)
                            return true; // Already at these
                          // levels
                          if (err == ERR_INVALID_STOPS)
                            break;

                          if (attempt < OM_MAX_RETRIES - 1)
                            Sleep(OM_RETRY_DELAY_MS);
                        }

                        return false;
                      }

                      bool OrderManager_Close(int ticket, int maxSlippage =
   OM_MAX_SLIPPAGE) {
                        if (!OrderSelect(ticket, SELECT_BY_TICKET, MODE_TRADES))
                          return false;

                        double lots = OrderLots();
                        string symbol = OrderSymbol();
                        int cmd = OrderType();

                        // Only close market orders
                        if (cmd != OP_BUY && cmd != OP_SELL)
                          return OrderManager_Delete(ticket);

                        for (int attempt = 0; attempt < OM_MAX_RETRIES;
                             attempt++) {
                          RefreshRates();
                          double closePrice =
                              (cmd == OP_BUY) ? MarketInfo(symbol, MODE_BID)
                                              : MarketInfo(symbol, MODE_ASK);

                          if (OrderClose(ticket, lots, closePrice,
                                         maxSlippage)) {
                            PrintFormat("[OrderManager] CLOSED #%d "
                                        "| %s %s %.2f @ %.5f",
                                        ticket, symbol,
                                        (cmd == OP_BUY ? "BUY" : "SELL"), lots,
                                        closePrice);
                            return true;
                          }

                          int err = GetLastError();
                          if (err == ERR_INVALID_TICKET)
                            return true; // Already closed

                          if (attempt < OM_MAX_RETRIES - 1)
                            Sleep(OM_RETRY_DELAY_MS);
                        }

                        return false;
                      }

                      bool OrderManager_Delete(int ticket) {
                        if (!OrderSelect(ticket, SELECT_BY_TICKET, MODE_TRADES))
                          return false;

                        for (int attempt = 0; attempt < OM_MAX_RETRIES;
                             attempt++) {
                          if (OrderDelete(ticket)) {
                            PrintFormat("[OrderManager] "
                                        "DELETED #%d",
                                        ticket);
                            return true;
                          }

                          int err = GetLastError();
                          if (err == ERR_INVALID_TICKET)
                            return true;

                          if (attempt < OM_MAX_RETRIES - 1)
                            Sleep(OM_RETRY_DELAY_MS);
                        }

                        return false;
                      }

                      int OrderManager_CountByMagic(int magic,
                                                    string symbol = "") {
                        int count = 0;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderMagicNumber() != magic)
                            continue;
                          if (symbol != "" && OrderSymbol() != symbol)
                            continue;
                          if (OrderType() <= OP_SELL)
                            count++;
                        }
                        return count;
                      }

                      int OrderManager_CountByMagicDir(int magic, int cmd,
                                                       string symbol = "") {
                        int count = 0;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderMagicNumber() != magic)
                            continue;
                          if (OrderType() != cmd)
                            continue;
                          if (symbol != "" && OrderSymbol() != symbol)
                            continue;
                          count++;
                        }
                        return count;
                      }

                      double OrderManager_AvgEntryPrice(int magic, int cmd,
                                                        string symbol = "") {
                        double totalLots = 0;
                        double weightedPrice = 0;

                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderMagicNumber() != magic)
                            continue;
                          if (OrderType() != cmd)
                            continue;
                          if (symbol != "" && OrderSymbol() != symbol)
                            continue;

                          totalLots += OrderLots();
                          weightedPrice += OrderOpenPrice() * OrderLots();
                        }

                        if (totalLots <= 0)
                          return 0;
                        return weightedPrice / totalLots;
                      }

