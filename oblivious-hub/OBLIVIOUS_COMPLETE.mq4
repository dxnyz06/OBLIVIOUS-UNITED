        Sleep(ms);
}

void SL_TrackerDraw(string prefix, int ticket)
{
      if (ticket <= 0)
        return;
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      if (OrderSymbol() != Symbol())
        return;

      double sl = OrderStopLoss();
      double tp = OrderTakeProfit();
      double entry = OrderOpenPrice();

      if (entry > 0)
        DrawHLine_Entry(prefix, entry);
      if (sl > 0)
        DrawHLine_SL(prefix, sl);
      if (tp > 0)
        DrawHLine_TP(prefix, tp);
}

void SL_TrackerRemove(string prefix)
{
      DrawHLine_Remove(prefix + "_SL");
      DrawHLine_Remove(prefix + "_TP");
      DrawHLine_Remove(prefix + "_ENTRY");
      DrawHLine_Remove(prefix + "_BE");
}

double _HSL_HueToRGB(double p, double q, double t)
{
      if (t < 0.0)
        t += 1.0;
      if (t > 1.0)
        t -= 1.0;
      if (t < 1.0 / 6.0)
        return p + (q - p) * 6.0 * t;
      if (t < 1.0 / 2.0)
        return q;
      if (t < 2.0 / 3.0)
        return p + (q - p) * (2.0 / 3.0 - t) * 6.0;
      return p;
}

color HSLtoRGB(double h, double s, double l)
{
      double hNorm = h / 360.0;
      double r, g, b;
      if (s == 0.0) {
        r = g = b = l;
      } else {
        double q = (l < 0.5) ? l * (1.0 + s) : l + s - l * s;
        double p = 2.0 * l - q;
        r = _HSL_HueToRGB(p, q, hNorm + 1.0 / 3.0);
        g = _HSL_HueToRGB(p, q, hNorm);
        b = _HSL_HueToRGB(p, q, hNorm - 1.0 / 3.0);
      }
      return MakeRGB((int)(r * 255.0), (int)(g * 255.0), (int)(b * 255.0));
}

string SL_Name(int i)  {
      return DP + "SMARTLOG_" + IntegerToString(i); }

void   SL_ClearBuf(){
      for (int i = 0; i < SL_LINES; i++)
        SL_buf[i] = ""; }

