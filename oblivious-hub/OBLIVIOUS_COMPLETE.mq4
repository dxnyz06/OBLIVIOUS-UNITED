int NextScaleLevel(int magic, bool isBuy)
{
      int openCnt = CountOpenBySide(magic, isBuy);
      int nextLevel = openCnt + 1;
      int N = (int)MathMax(1, (int)MathFloor(Active_MaxRiskForSymbol()));
      if (nextLevel > N)
        nextLevel = N;
      return nextLevel;
}

int MaxLevelsForSymbol()
{
      int N = (int)MathFloor(Active_MaxRiskForSymbol());
      if (N < 1)
        N = 1;
      return N;
}

double LevelMultiplier(int levelIndex)
{
      if (levelIndex < 1)
        levelIndex = 1;
      return (double)levelIndex;
}

double TotalMultiplierSum(int N)
{
      return (N <= 0 ? 0.0 : (double)N * ((double)N + 1.0) / 2.0);
}

string CommentWithLevelDefault(string baseComment, int magic, int cmd)
{
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      int level = NextScaleLevel(magic, isBuy);
      int suffix = (int)MathMax(0, level - 1);
      if (StringFind(baseComment, "~") >= 0 ||
          StringFind(baseComment, " - ") >= 0 ||
          StringFind(baseComment, " x ") >= 0)
        return baseComment;
      return baseComment + " ~ " + IntegerToString(suffix);
}

string CommentWithLevelBlue(string baseComment, int magic, int cmd)
{
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      int level = NextScaleLevel(magic, isBuy);
      int suffix = (int)MathMax(0, level - 1);
      if (StringFind(baseComment, "~") >= 0 ||
          StringFind(baseComment, " - ") >= 0 ||
          StringFind(baseComment, " x ") >= 0)
        return baseComment;
      return baseComment + " x " + IntegerToString(suffix);
}

int MagicBase(int observedMagic)
{
      if (ObliviousAiMagic == 0)
        return observedMagic;
      return (observedMagic ^ ObliviousAiMagic);
}

int MagicCompose(int strategyMagic)
{
      if (ObliviousAiMagic == 0)
        return strategyMagic;
      return (strategyMagic ^ ObliviousAiMagic);
}

