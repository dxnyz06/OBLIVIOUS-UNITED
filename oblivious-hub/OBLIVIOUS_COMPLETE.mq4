                                          void Grid_DrawProjectedLevels() {
                                            // Draw projected grid levels
                                            // based on ATR spacing
                                            double atr =
                                                iATR(Symbol(), Period(), 14, 0);
                                            double base =
                                                NormalizeDouble(Bid, Digits);
                                            for (int i = -5; i <= 5; i++) {
                                              if (i == 0)
                                                continue;
                                              double level = base + i * atr;
                                              string name = "GRID_LVL_" +
   IntegerToString(i);
                                              // DrawHLineNamed expects (..., string label);
                                              // colour is set via ObjectSet at draw time. Pass
                                              // empty label to satisfy the modern signature.
                                              DrawHLineNamed(name, level, "");
                                            }
                                          }

                                          double __AP_GetChallengeBaseEquity() {
                                            static double base = -1;
                                            if (!ChallengePassage)
                                              return -1;
                                            if (base > 0)
                                              return base;

                                            if (GlobalVariableCheck(
                                                    "BASE_EQUITY")) {
                                              base = GlobalVariableGet(
                                                  "BASE_EQUITY");
                                            } else {
                                              base = AccountEquity();
                                              GlobalVariableSet(
                                                  "BASE_EQUITY", base);
                                              Print("[CP] Base equity set "
                                                    "to ",
                                                    DoubleToString(base, 2));
                                            }
                                            return base;
                                          }

                                          double __AP_ChallengeDrawdown() {
                                            double base =
                                                __AP_GetChallengeBaseEquity();
                                            if (base <= 0)
                                              return 0;
                                            return (1.0 -
                                                    AccountEquity() / base) *
                                                   100.0;
                                          }


