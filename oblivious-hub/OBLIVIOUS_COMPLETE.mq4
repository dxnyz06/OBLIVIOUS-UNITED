                      void EmergencyProfitGuard() {
                        // FASE 9 (Patch 3): DEPRECATED. Sostituita da
                        // ClusterMoney_OnTick (safety = costi+buffer
                        // auto-class, non 10% del balance per ticket).
                        return;
                        // ---- unreachable legacy body below ----
                        double minPct = MathMax(
                            0.10,
                            Active_MinEmergencyProfitPercent()); // at least 10%
                        double base = AccountBalance();
                        if (base <= 0)
                          return;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS))
                            continue;
                          if (OrderSymbol() != Symbol())
                            continue;
                          double net = OrderProfit() + OrderSwap() +
                                       OrderCommission(); // include
                          // current
                          // swap &
                          // commissions
                          double th = base * minPct; // gain above costs
                          // (net P&L) relative
                          // to balance
                          if (net >= th) {
                            int type = OrderType();
                            double lots = OrderLots();
                            bool ok = false;
                            {
                              int __ticket = OrderTicket();
                              double __lots = OrderLots();
                              SmartLogWrap("CLOSE",
                                           StringFormat("PreClose | "
                                                        "ticket=%d lots=%.2f "
                                                        "symbol=%s",
                                                        __ticket, __lots,
                                                        OrderSymbol()));
                            }
                            if (type == OP_BUY)
                              ok = OrderClose(OrderTicket(), lots, Bid,
                                              GetAdaptiveSlippagePoints(),
                                              clrGreen);
                            {
                              int __err = GetLastError();
                              bool __isok = (__err == 0);
                              SmartLogWrap("CLOSE",
                                           StringFormat("%s | ticket=%d "
                                                        "price=%.5f "
                                                        "lots=%.2f err=%d",
                                                        __isok ? "PostClose OK"
   : "PostClose "
   "FAIL",
                                                        OrderTicket(),
                                                        OrderClosePrice(),
                                                        OrderLots(), __err));
                            }
                            {
                              int __ticket = OrderTicket();
                              double __lots = OrderLots();
                              SmartLogWrap("CLOSE",
                                           StringFormat("PreClose | "
                                                        "ticket=%d lots=%.2f "
                                                        "symbol=%s",
                                                        __ticket, __lots,
                                                        OrderSymbol()));
                            }
                            if (type == OP_SELL)
                              ok = OrderClose(OrderTicket(), lots, Ask,
                                              GetAdaptiveSlippagePoints(),
                                              clrGreen);
                            {
                              int __err = GetLastError();
                              bool __isok = (__err == 0);
                              SmartLogWrap("CLOSE",
                                           StringFormat("%s | ticket=%d "
                                                        "price=%.5f "
                                                        "lots=%.2f err=%d",
                                                        __isok ? "PostClose OK"
   : "PostClose "
   "FAIL",
                                                        OrderTicket(),
                                                        OrderClosePrice(),
                                                        OrderLots(), __err));
                            }
                            if (ok) {
                              Print(TimeToString(TimeCurrent(),
                                                 TIME_DATE | TIME_SECONDS) +
                                        " [LIMIT][EMERG] "
                                        "Secured min net "
                                        "profit ",
                                    DoubleToString(minPct * 100, 1),
                                    "% (net=", DoubleToString(net, 2), ")");
                            }
                          }
                        }
                      }

                      double NetProfitPercentForEmergency() {
                        // Calcola il profitto % netto (al
                        // netto di swap + commissioni)
                        // rispetto al balance
                        double costs = 0.0;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          int type = OrderType();
                          if (type != OP_BUY && type != OP_SELL)
                            continue;
                          costs +=
                              MathAbs(OrderSwap()) + MathAbs(OrderCommission());
                        }
                        double gross = AccountEquity() - AccountBalance();
                        double net = gross - costs;
                        if (AccountBalance() <= 0)
                          return 0.0;
                        return 100.0 * (net / AccountBalance());
                      }

                      double OrderManager_ProfitByMagic(int magic,
                                                        string symbol = "") {
                        double profit = 0;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderMagicNumber() != magic)
                            continue;
                          if (symbol != "" && OrderSymbol() != symbol)
                            continue;
                          if (OrderType() <= OP_SELL)
                            profit +=
                                OrderProfit() + OrderSwap() + OrderCommission();
                        }
                        return profit;
                      }

                      
// ============================================================
// TPSL MANAGER: Progressive TP/SL Ladder
// ============================================================

double TPSL_GetATR() {
   return iATR(Symbol(), Period(), 14, 1);
}

void TPSL_ComputeLevels(int orderType, double entryPrice, string strategy,
                         double &tp1, double &tp2, double &tp3, double &tpmax) {
   double atr = TPSL_GetATR();
   if (atr <= 0) atr = 50 * Point;
   
   double m1 = 1.0, m2 = 2.0, m3 = 3.0, mMax = 4.5;
   
   if (strategy == "Predicted")             { m1 = 1.2; m2 = 2.5; m3 = 3.5; mMax = 5.0; }
   else if (strategy == "Grid")             { m1 = 0.5; m2 = 1.0; m3 = 1.5; mMax = 2.5; }
   else if (strategy == "Breakout")         { m1 = 1.5; m2 = 2.5; m3 = 3.5; mMax = 5.0; }
   else if (strategy == "FVG")              { m1 = 1.0; m2 = 2.0; m3 = 3.0; mMax = 4.0; }
   else if (strategy == "SMC") { m1 = 1.2; m2 = 2.2; m3 = 3.2; mMax = 4.5; }
   else if (strategy == "ICT") { m1 = 1.0; m2 = 2.0; m3 = 3.0; mMax = 4.0; }
   else if (strategy == "Reverse")          { m1 = 0.8; m2 = 1.5; m3 = 2.5; mMax = 3.5; }

   // ITER 26 — Adaptive TP spacing multiplier (CRYPTO/EXPANDING ladder
   //   further out, FX compressed shorter). Predicted is preserved on
   //   its own news-driven ladder (no symbol-class scaling).
   if (strategy != "Predicted") {
      double tpMul = Adaptive_TPSpacingMul();
      m1   *= tpMul;
      m2   *= tpMul;
      m3   *= tpMul;
      mMax *= tpMul;
   }
   
   // BUG FIX (FASE 1): usare il PARAMETRO entryPrice, non il globale
   // g_entryPrice che resta sempre 0.0. Con il bug originale la ladder
   // TP1/TP2/TP3/TPMax era calcolata attorno a 0 -> trigger mai validi
   // su SELL e istantanei/errati su BUY, e di conseguenza il trailing
   // SL legato a tp*Hit non scattava mai.
   double e = entryPrice;
   if (orderType == OP_BUY) {
      tp1   = e + atr * m1;
      tp2   = e + atr * m2;
      tp3   = e + atr * m3;
      tpmax = e + atr * mMax;
   } else {
      tp1   = e - atr * m1;
      tp2   = e - atr * m2;
      tp3   = e - atr * m3;
      tpmax = e - atr * mMax;
   }
}

int TPSL_FindTrack(int ticket) {
   for (int i = 0; i < g_tpsl_trackCount; i++) {
      if (g_tpsl_tracks[i].ticket == ticket) return i;
   }
   return -1;
}

void TPSL_RegisterTrade(int ticket, int magic, string strategy, int orderType,
                         double entryPrice, double initialSL,
                         bool isRecovery = false) {
   if (g_tpsl_trackCount >= TPSL_MAX_TRACKED) return;
   if (TPSL_FindTrack(ticket) >= 0) return;

   int idx = g_tpsl_trackCount;
   g_tpsl_tracks[idx].ticket = ticket;
   g_tpsl_tracks[idx].magic = magic;
   g_tpsl_tracks[idx].strategy = strategy;
   g_tpsl_tracks[idx].entryPrice = entryPrice;
   g_tpsl_tracks[idx].initialSL = initialSL;
   g_entryPrice = entryPrice;
   g_tpsl_tracks[idx].orderType = orderType;
   g_tpsl_tracks[idx].tp1Hit = false;
   g_tpsl_tracks[idx].tp2Hit = false;
   g_tpsl_tracks[idx].tp3Hit = false;
   g_tpsl_tracks[idx].liveState = LIVE_UNARMED;
   g_tpsl_tracks[idx].openedAt  = TimeCurrent();
   g_tpsl_tracks[idx].recoveredAt = 0;

   if (!isRecovery) {
      // FASE 3 + ITER 26 - SL "arming" largo per i primi N secondi.
      //   Adaptive: 1.40 ATR base × Adaptive_MinWidthAtrMul (CRYPTO/METAL
      //   widen, COMPRESSED tighten). Predicted skips the multiplier
      //   to preserve its news-driven SL ladder.
      double atr_now = iATR(Symbol(), Period(), 14, 1);
      double dist_proj = MathAbs(entryPrice - initialSL);
      double mwMulReg  = (strategy == "Predicted" ? 1.0 : Adaptive_MinWidthAtrMul());
      double dist_min  = 1.40 * atr_now * mwMulReg;
      double dist_arm  = MathMax(dist_proj, dist_min);
      double armingSL  = (orderType == OP_BUY)
                         ? entryPrice - dist_arm
                         : entryPrice + dist_arm;
      g_tpsl_tracks[idx].armingSL = armingSL;
      // ITER 35 — FULL VIRTUAL SL: do NOT push armingSL to broker for
      //   non-Predicted owners. Broker SL must stay at 0 so the engine
      //   can dynamically widen/tighten the *internal* SL on every tick
      //   without market noise stop-outs. Only Predicted (news flow)
      //   keeps a broker fail-safe.
      if (strategy == "Predicted") {
         if (OrderSelect(ticket, SELECT_BY_TICKET) && OrderCloseTime() == 0) {
            double tpDummy = OrderTakeProfit();
            bool _armRes = OrderModify(ticket, OrderOpenPrice(),
                                       NormalizeDouble(armingSL, Digits),
                                       tpDummy, 0, clrGoldenrod);
            if (!_armRes) PrintFormat("[TPSL] WARN arming OrderModify failed tkt=%d err=%d",
                                      ticket, GetLastError());
         }
      } else {
         // ITER 35 — clear any leftover broker SL/TP for non-Predicted
         //   so the trade is fully virtual from the start.
         // ITER 38 — wrap result in a single bool assignment to avoid
         //   "unused return value" compile warnings on stricter setups.
         if (OrderSelect(ticket, SELECT_BY_TICKET) && OrderCloseTime() == 0) {
            if (OrderStopLoss() != 0 || OrderTakeProfit() != 0) {
               bool _clrRes = OrderModify(ticket, OrderOpenPrice(), 0, 0, 0, clrGoldenrod);
               if (!_clrRes) PrintFormat("[TPSL] WARN clear SL/TP OrderModify failed tkt=%d err=%d",
                                         ticket, GetLastError());
            }
         }
      }
      PrintFormat("[TPSL] REGISTER tkt=%d %s entry=%.5f slProj=%.5f armSL=%.5f (UNARMED, dist_proj=%.5f dist_arm=%.5f virtual=%s)",
                  ticket, strategy, entryPrice, initialSL, armingSL,
                  dist_proj, dist_arm, (strategy == "Predicted" ? "NO" : "YES"));
   } else {
      // FASE 12 - REATTACH RECOVERY: NON sovrascrivere SL broker.
      // Marca come PROTECTED se SL gia' presente (gestione gia'
      // attiva dal trade originale), altrimenti UNARMED ma senza
      // arming forzato. recoveredAt attiva il grace warmup.
      g_tpsl_tracks[idx].armingSL = initialSL;
      g_tpsl_tracks[idx].recoveredAt = TimeCurrent();
      double brokerSL = 0;
      if (OrderSelect(ticket, SELECT_BY_TICKET)) brokerSL = OrderStopLoss();
      g_tpsl_tracks[idx].liveState = (brokerSL > 0 ? 1 : 0);
      PrintFormat("[TPSL] RECOVER tkt=%d %s entry=%.5f brokerSL=%.5f state=%s",
                  ticket, strategy, entryPrice, brokerSL,
                  (brokerSL > 0 ? "PROTECTED(recovered)" : "UNARMED(recovered)"));
   }

   TPSL_ComputeLevels(orderType, entryPrice, strategy,
      g_tpsl_tracks[idx].tp1, g_tpsl_tracks[idx].tp2,
      g_tpsl_tracks[idx].tp3, g_tpsl_tracks[idx].tpmax);

   g_tpsl_trackCount++;
}

void TPSL_RemoveTrack(int idx) {
   if (idx < 0 || idx >= g_tpsl_trackCount) return;
   for (int i = idx; i < g_tpsl_trackCount - 1; i++) {
      g_tpsl_tracks[i] = g_tpsl_tracks[i + 1];
   }
   g_tpsl_trackCount--;
}

bool TPSL_ModifySL(int ticket, double newSL) {
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) return false;
   if (MathAbs(OrderStopLoss() - newSL) < Point) return false;
   // ITER 35 — FULL VIRTUAL SL: skip broker modification for non-Predicted
   //   owners. The internal state-machine continues to track the desired SL
   //   level; OBL_Ladder_Tick + ClusterMoney_OnTick close via OrderClose
   //   when the virtual SL is crossed. Predicted keeps a broker fail-safe.
   int omg = OrderMagicNumber();
   bool isPredictedOrder = (omg == PredictedMagic);
   if (!isPredictedOrder) {
      // No-op success — caller's state machine assumes the move succeeded
      // and proceeds with LIVE_PROTECTED / LIVE_BE / LIVE_TRAIL transitions.
      return true;
   }
   return OrderModify(ticket, OrderOpenPrice(), NormalizeDouble(newSL, Digits),
                      OrderTakeProfit(), 0, clrYellow);
}

// ============================================================
// FASE 4 — CLUSTER MONEY: UNICA AUTHORITY per profit-close
// Sostituisce __AP_PTP_ManageAll (80%/40% hardcoded) e
// EmergencyProfitGuard (mai chiamata, soglia troppo aggressiva).
//
// Patch 3: il safe-close per ticket per profit/peak vive QUI e solo
// qui. __AP_DailyDrawdownGuard resta separato (daily DD globale).
// Patch 4: la safety di MinEmergencyProfitPercent NON e' "10% del
// balance" (troppo aggressiva = blocca quasi sempre). E' invece il
// modulatore di un buffer minimo coerente con la classe del simbolo
// (fx=3pip, metal=8pip, index=10pip, crypto=50pip) sopra i costi
// commission+swap, scalato sui lots.
// Patch 7: le GlobalVariable PTP_PEAK_<ticket> sono pulite on-close,
// periodicamente in OnTimer (orphan) e completamente in OnDeinit.
// ============================================================

string ClusterMoney_GVName(int ticket) {
   return StringFormat("PTP_PEAK_%d", ticket);
}

double ClusterMoney_TrackPeak(int ticket, double pnl_net) {
   string gv = ClusterMoney_GVName(ticket);
   double peak = (GlobalVariableCheck(gv) ? GlobalVariableGet(gv) : pnl_net);
   if (pnl_net > peak) { peak = pnl_net; GlobalVariableSet(gv, peak); }
   return peak;
}

void ClusterMoney_RemoveGV(int ticket) {
   string gv = ClusterMoney_GVName(ticket);
   if (GlobalVariableCheck(gv)) GlobalVariableDel(gv);
}

void ClusterMoney_CleanupOrphanGV() {
   // Pulisce GV PTP_PEAK_* di ticket non piu' presenti o gia' chiusi.
   // Chiamata da OnTimer (ogni ~60s tramite contatore interno).
   int total = GlobalVariablesTotal();
   for (int i = total - 1; i >= 0; i--) {
      string nm = GlobalVariableName(i);
      if (StringFind(nm, "PTP_PEAK_") != 0) continue;
      int t = (int)StringToInteger(StringSubstr(nm, 9));
      if (!OrderSelect(t, SELECT_BY_TICKET) || OrderCloseTime() != 0) {
         GlobalVariableDel(nm);
      }
   }
}

void ClusterMoney_CleanupAllGV() {
   // Pulisce TUTTE le GV PTP_PEAK_*. Chiamata da Orchestrator_OnDeinit
   // per non lasciare stato sporco quando l'EA viene rimosso.
   int total = GlobalVariablesTotal();
   for (int i = total - 1; i >= 0; i--) {
      string nm = GlobalVariableName(i);
      if (StringFind(nm, "PTP_PEAK_") == 0) GlobalVariableDel(nm);
   }
}

double ClusterMoney_GetMinSafetyProfit() {
   // Buffer minimo profit-safe per ticket = |swap|+|commission| + buffer_pip
   // scalato per (a) classe asset auto-detect (Hyb_SymbolClass: int via
   // HYB_SYM_*) e (b) lot size attuale. MinEmergencyProfitPercent
   // (input 447) modula il buffer: 10.0 = 1.0x base, 20.0 = 2.0x base.
   double cost = MathAbs(OrderSwap()) + MathAbs(OrderCommission());
   int    cls  = Hyb_SymbolClass();
   double bufferPips = 3.0;                          // fx default
   if      (cls == HYB_SYM_CRYPTO) bufferPips = 50.0;
   else if (cls == HYB_SYM_METAL)  bufferPips = 8.0;
   else if (cls == HYB_SYM_INDEX)  bufferPips = 10.0;
   double tickVal = MarketInfo(OrderSymbol(), MODE_TICKVALUE);
   double lotStep = MarketInfo(OrderSymbol(), MODE_LOTSTEP);
   if (lotStep <= 0) lotStep = 0.01;
   double lots = OrderLots();
   // Profit in valuta deposito per 1 pip su lots = bufferPips * tickVal * 10 * (lots/lotStep)
   // (1 pip = 10 point su simboli 5-digit; tickVal e' per 1 tick)
   double buffer_money = bufferPips * tickVal * 10.0 * (lots / lotStep);
   double scale = (MinEmergencyProfitPercent > 0 ? MinEmergencyProfitPercent / 10.0 : 1.0);
   return cost + buffer_money * scale;
}

void ClusterMoney_OnTick() {
   // FASE 5 - ClusterMoney "ultima sponda":
   // GATE 0 (NUOVO): MATURITY - trade deve essere maturo prima che
   //   il peak-retrace sia valutato. Niente chiusure su spike di
   //   profitto in trade appena nato. Min-age mode/TF aware.
   // GATE 1: SAFETY (no close sotto minSafe class-aware)
   // GATE 2: PEAK RETRACE (close su retrace X% dal peak)
   //
   // ITER 15 USER FIX: minimum hold extended to 5 candles + 300s/600s
   // so trades have time to develop the trend before any close logic
   // fires. User was seeing premature closes in loss; this lets the
   // trade breathe through normal intrabar noise.
   datetime now = TimeCurrent();
   int matureSec = (Mode == Aggressive ? 300 : (Mode == Conservative ? 900 : 600));
   int matureBars = (Period() <= 5 ? 5 : 4);
   int periodSec = Period() * 60;

   for (int i = OrdersTotal() - 1; i >= 0; i--) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if (OrderSymbol() != Symbol()) continue;
      if (OrderType() > OP_SELL) continue;            // solo market positions

      int    ticket  = OrderTicket();
      double pnl_net = OrderProfit() + OrderSwap() + OrderCommission();
      double minSafe = ClusterMoney_GetMinSafetyProfit();
      int    ageSec  = (int)(now - OrderOpenTime());

      // [GATE 0: MATURITY] trade troppo giovane -> solo tracking,
      // niente close. Lascia respirare verso TP1/TP2.
      if (ageSec < matureSec || ageSec < matureBars * periodSec) {
         ClusterMoney_TrackPeak(ticket, pnl_net);
         continue;
      }
      // [GATE 0b: RECOVERY GRACE] trade ripreso da reattach -> per
      // la finestra di recovery NON chiudere mai (warmup completo).
      int trk = TPSL_FindTrack(ticket);
      if (trk >= 0 && g_tpsl_tracks[trk].recoveredAt > 0) {
         int recGrace = (Mode == Aggressive ? 180 : (Mode == Conservative ? 600 : 360));
         if ((int)(now - g_tpsl_tracks[trk].recoveredAt) < recGrace) {
            ClusterMoney_TrackPeak(ticket, pnl_net);
            continue;
         }
      }
      // [GATE 1: SAFETY] non chiudere mai sotto la soglia auto-class.
      if (pnl_net < minSafe) {
         ClusterMoney_TrackPeak(ticket, pnl_net);
         continue;
      }
      // ITER 23 (FASE I + MISSING-8) — STRICT MIN-EMERGENCY GUARD.
      //   MinEmergencyProfitPercent (driving minSafe via
      //   ClusterMoney_GetMinSafetyProfit) must NEVER act as primary
      //   close pre-TP3. Acceptance grep: ClusterMoney_OnTick body must
      //   contain `if (g_tpsl_tracks[i].liveState < LIVE_TRAIL)` for the
      //   MinEmergencyProfit block. Log MINEMERG_BLOCKED_PRE_TP3.
      if (trk >= 0 && g_tpsl_tracks[trk].liveState < LIVE_TRAIL) {
         static datetime __minEmergLog = 0;
         if (TimeCurrent() - __minEmergLog > 120) {
            __minEmergLog = TimeCurrent();
            SmartLog_Brain("MINEMERG_BLOCKED_PRE_TP3",
               StringFormat("tkt=%d pnl=%.2f minSafe=%.2f liveState=%d (waiting LIVE_TRAIL post-TP3)",
                            ticket, pnl_net, minSafe, g_tpsl_tracks[trk].liveState),
               C'255,170,80');
         }
         ClusterMoney_TrackPeak(ticket, pnl_net);
         continue;   // hard gate: no MinEmergency-driven close pre-LIVE_TRAIL
      }

      // [GATE 2: PEAK RETRACE] chiudi se profit retrocede X% dal picco
      // (PeakProfitRetracePercent, default 20%). Il peak deve essere a
      // sua volta sopra minSafe per evitare chiusure "rumorose".
      // FASE 4 NEW: richiede anche TP1 hit (se ticket tracked dal
      // TPSL Manager). Cosi' il trade ha gia' costruito profitto
      // reale e PeakRetrace non chiude su spike intrabar normale.
      // PeakProfitLock input (default true) gate-a tutto il GATE 2.
      //
      // ITER 10 USER FIX: il PeakRetrace ora attiva SOLO DOPO TP3.
      // Motivo: il TP Ladder Ratchet sposta SL a ogni TP raggiunto
      // (TP1 hit -> SL=BE+1, TP2 hit -> SL=TP1, TP3 hit -> SL=TP2),
      // quindi fino a TP3 il profitto e' GIA' protetto. Chiudere su
      // retrace prima di TP3 mutila il trade verso TP MAX. Dopo TP3,
      // SL e' a TP2 (lots of profit locked) e il corridoio TP3->TPMAX
      // resta esposto: e' qui che ClusterMoney lavora come ultima
      // sponda anti-retrace.
      if (!PeakProfitLock) continue;
      // ITER 23 (FASE I + MISSING-8) — PEAKLOCK ARMING EXPLICIT.
      //   Peak tracking must NOT accumulate before TP1 is hit, otherwise
      //   spike intrabar profit (later retraced) would erroneously arm
      //   the peak. Reset peak to zero and skip until tp1Hit. Acceptance
      //   grep: PeakProfitLock block must contain
      //   `if (!g_tpsl_tracks[i].tp1Hit)` early reset.
      if (trk >= 0 && !g_tpsl_tracks[trk].tp1Hit) {
         ClusterMoney_RemoveGV(ticket);          // reset stored peak GV
         continue;
      }
      if (trk >= 0 && g_tpsl_tracks[trk].tp3Hit == false) {
         // PHASE 8 (ITER 20) — anti-strangle log. Trade is being kept
         // open by the TP3 gate; ClusterMoney/PeakRetrace cannot bite.
         static datetime __ec_log = 0;
         if (TimeCurrent() - __ec_log > 120) {
            __ec_log = TimeCurrent();
            SmartLog_Brain("EARLY_CLOSE_BLOCKED",
               StringFormat("tkt=%d pnl=%.2f peak guard waits TP3 (anti-strangle)",
                            ticket, pnl_net),
               C'120,200,255');
         }
         continue;   // pre-TP3: ladder owns the trade
      }
      double peak = ClusterMoney_TrackPeak(ticket, pnl_net);
      if (peak <= minSafe) continue;
      double thr = peak * (1.0 - PeakProfitRetracePercent / 100.0);
      if (pnl_net <= thr) {
         double cp = (OrderType() == OP_BUY ? Bid : Ask);
         int    slp = GetAdaptiveSlippagePoints();
         bool   ok = OrderClose(ticket, OrderLots(), cp, slp, clrYellow);
         if (ok) {
            ClusterMoney_RemoveGV(ticket);
            PrintFormat("[ClusterMoney] PeakRetrace closed ticket=%d peak=%.2f pnl=%.2f thr=%.2f minSafe=%.2f",
                        ticket, peak, pnl_net, thr, minSafe);
         } else {
            PrintFormat("[ClusterMoney] close FAILED ticket=%d err=%d",
                        ticket, GetLastError());
         }
      }
   }
}

// ============================================================
// FASE 8 - LIVE OVERLAY: TP1 / TP2 / TP3 / TPMAX / SL per ticket
// ============================================================
// Per ogni g_tpsl_tracks[] disegna HLine_RAY a destra del prezzo:
//   - SL  (rosso, DASH, label "SL")
//   - TP1 (lime, DASH, label "TP1")
//   - TP2 (aqua, DASH, label "TP2")
//   - TP3 (gold, DASH, label "TP3")
//   - TPMAX (magenta, DASH, label "TPMAX")
// Le label cambiano colore quando il TP corrispondente e' stato
// hittato (verde + "[HIT]") - il BE-move e' gia' fatto da TPSL
// Manager_OnTick e si vede dall'aggiornamento SL.
// Cleanup: oggetti con prefisso "OBL_LVL_<ticket>_" vengono
// eliminati quando il ticket non esiste piu' o e' chiuso.
// ============================================================

// ============================================================
// FASE 2 - PROFESSIONAL CHART PALETTE (no rainbow random)
// Coerente, categorica, distingue projected vs live, bull vs
// bear, entry/SL/TP/liquidity/trigger/hybrid/invalidation.
// ============================================================
// ITER 14 — INSTITUTIONAL SPEC: every level / chip / projection renders
// in pure WHITE. Colour-coded palette is OFF — the user's intent is a
// monochrome professional skin where role is distinguished by line
// STYLE (DASH for SL, DOT for TP, DASHDOT for ENTRY) rather than colour.
#define OBL_PAL_ENTRY_LIMIT      clrWhite             // entry pending limit
#define OBL_PAL_ENTRY_LIVE       clrWhite             // entry pending DEPLOYED / live
#define OBL_PAL_ADDON_LIMIT      clrWhite             // add-on pending
#define OBL_PAL_SL               clrWhite             // stop loss
#define OBL_PAL_SL_MOVED         clrWhite             // SL spostato (BE+)
#define OBL_PAL_TP1              clrWhite
#define OBL_PAL_TP2              clrWhite
#define OBL_PAL_TP3              clrWhite
#define OBL_PAL_TPMAX            clrWhite
#define OBL_PAL_TP_HIT           clrWhite
#define OBL_PAL_LIQ_BSL          clrWhite
#define OBL_PAL_LIQ_BSL_DEEP     clrWhite
#define OBL_PAL_LIQ_SSL          clrWhite
#define OBL_PAL_LIQ_SSL_DEEP     clrWhite
#define OBL_PAL_BULL_TRIGGER     clrWhite
#define OBL_PAL_BEAR_TRIGGER     clrWhite
#define OBL_PAL_HYBRID           clrWhite
#define OBL_PAL_HYBRID_ALT       clrWhite
#define OBL_PAL_INVALIDATION     clrWhite
#define OBL_PAL_PROJ_TENUE       clrWhite

color OBL_StrategyColor(string s) {
   if (s == "FVG")       return clrAqua;
   if (s == "SMC")       return clrOrange;
   if (s == "ICT")       return clrGold;
   if (s == "Reverse")   return clrViolet;
   if (s == "Breakout")  return clrTomato;
   if (s == "Grid")      return clrSilver;
   if (s == "Predicted") return clrDodgerBlue;
   return clrGray;
}

void OBL_DrawLevel(string name, double price, color clr, ENUM_LINE_STYLE st,
                   string text, int fontSize) {
   if (ObjectFind(0, name) < 0) {
      ObjectCreate(0, name, OBJ_HLINE, 0, 0, price);
      ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
      ObjectSetInteger(0, name, OBJPROP_STYLE, st);
      ObjectSetInteger(0, name, OBJPROP_WIDTH, 1);
      ObjectSetInteger(0, name, OBJPROP_BACK, true);
      ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
      ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
   }
   ObjectSetDouble (0, name, OBJPROP_PRICE, price);
   ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
   ObjectSetString (0, name, OBJPROP_TEXT, text);
}

void OBL_RemoveTicketObjects(int ticket) {
   string prefix = StringFormat("OBL_LVL_%d_", ticket);
   int total = ObjectsTotal(0, -1, -1);
   for (int i = total - 1; i >= 0; i--) {
      string nm = ObjectName(0, i);
      if (StringFind(nm, prefix) == 0) ObjectDelete(0, nm);
   }
}

// ITER 34/35/36 — ORPHAN CLEANUP: scans all OBL_LVL_<ticket>_* objects on
//   the chart and deletes those whose ticket is closed/cancelled or
//   no longer present in the broker book. Eliminates the lingering
//   SL/TP/ENTRY lines that survived position close.
//   ITER 36 — Pass 2 (OBL_STG_*) REMOVED because it was wiping new
//   setup projections before they could draw on XAUUSD chart.
//   Setup projections clean themselves via Staging_CleanupObjects()
//   when the setup transitions to a dead state.
//   Throttled at 10s. Called from Orchestrator_OnTick.
datetime g_orphan_lastSweep = 0;
void OBL_OrphanCleanup() {
   // ITER 42 — throttle reduced 5s → 3s for faster visual cleanup.
   //   Also sweeps any OBJ_ARROW left over (no arrows policy).
   // ITER 43 — throttle further reduced 3s → 1s per user spec
   //   ("aggressively remove invalidated projected setup objects /
   //   stale ladder visuals / dead staged objects"). Adds Pass 2
   //   that wipes OBL_STG_<id>_* objects for any staged setup whose
   //   in-memory state is terminal (INVALIDATED / EXPIRED / REPLACED
   //   / CANCELLED). Boot-sweep of OBJ_ARROW is preserved.
   if (TimeCurrent() - g_orphan_lastSweep < 1) return;
   g_orphan_lastSweep = TimeCurrent();
   // Pass 0 — kill any OBJ_ARROW on the chart (user contract: no arrows).
   {
      int _at = ObjectsTotal(0, -1, OBJ_ARROW);
      for (int _ai = _at - 1; _ai >= 0; _ai--) {
         string _an = ObjectName(0, _ai, -1, OBJ_ARROW);
         if (StringLen(_an) > 0) ObjectDelete(0, _an);
      }
   }
   int total = ObjectsTotal(0, -1, -1);
   int removed = 0;
   for (int i = total - 1; i >= 0; i--) {
      string nm = ObjectName(0, i);
      // Pass 1 — OBL_LVL_<ticket>_* tied to broker ticket lifecycle.
      if (StringFind(nm, "OBL_LVL_") != 0) continue;
      int p1 = 8;                            // len("OBL_LVL_")
      int p2 = StringFind(nm, "_", p1);
      if (p2 <= p1) continue;
      string sTk = StringSubstr(nm, p1, p2 - p1);
      int tk = (int)StringToInteger(sTk);
      if (tk <= 0) continue;
      bool alive = false;
      if (OrderSelect(tk, SELECT_BY_TICKET)) {
         int otype = OrderType();
         if (OrderCloseTime() == 0 && otype <= OP_SELLSTOP) alive = true;
      }
      if (!alive) {
         ObjectDelete(0, nm);
         removed++;
      }
   }
   // ITER 43 — Pass 2: OBL_STG_<stg_id>_* objects for setups whose
   //   in-memory state is terminal. Catches anything Staging_Cleanup
   //   missed (e.g. when transition was logged but draw was repeated
   //   afterwards).
   int removedStg = 0;
   for (int j = 0; j < g_staged_count; j++) {
      int st = g_staged[j].state;
      if (st != STG_INVALIDATED && st != STG_EXPIRED &&
          st != STG_REPLACED    && st != STG_CANCELLED) continue;
      string prefix = StringFormat("OBL_STG_%d_", g_staged[j].stg_id);
      int t2 = ObjectsTotal(0, -1, -1);
      for (int k = t2 - 1; k >= 0; k--) {
         string nmk = ObjectName(0, k);
         if (StringFind(nmk, prefix) == 0) {
            ObjectDelete(0, nmk);
            removedStg++;
         }
      }
   }
   if (removed > 0 || removedStg > 0) {
      PrintFormat("[OrphanCleanup] removed=%d OBL_LVL_*  stg_terminal=%d OBL_STG_*",
                  removed, removedStg);
   }
}

datetime g_lvl_overlay_lastUpdate = 0;

void TpSlOverlay_Update() {
   // throttle: ogni 3 secondi (no flicker, no overhead)
   if (TimeCurrent() - g_lvl_overlay_lastUpdate < 3) return;
   g_lvl_overlay_lastUpdate = TimeCurrent();

   // 1) refresh per ogni track attivo
   for (int t = 0; t < g_tpsl_trackCount; t++) {
      int ticket = g_tpsl_tracks[t].ticket;
      if (!OrderSelect(ticket, SELECT_BY_TICKET) || OrderCloseTime() != 0) {
         OBL_RemoveTicketObjects(ticket);
         continue;
      }
      string strat = g_tpsl_tracks[t].strategy;
      color  base  = OBL_StrategyColor(strat);

      double sl   = OrderStopLoss();
      double tp1  = g_tpsl_tracks[t].tp1;
      double tp2  = g_tpsl_tracks[t].tp2;
      double tp3  = g_tpsl_tracks[t].tp3;
      double tpM  = g_tpsl_tracks[t].tpmax;

      string p   = StringFormat("OBL_LVL_%d_", ticket);
      string lab = StringFormat("%s #%d", strat, ticket);

      // FASE 2/6 - palette professionale: SL crimson, TP1 tenue
      // -> TPMAX brillante (gradient verde), HIT diventa lime.
      // UI FIX (Iter 10): TEXT label on HLines REMOVED to avoid
      // duplicating OBL_DrawChipLabels (single source of truth for
      // strategy chip labels). Only the price lines remain as visual
      // reference. The chip system (OBL_CHIP_<ticket>_<role>) carries
      // the strategy+role text.
      if (sl  > 0) OBL_DrawLevel(p + "SL",  sl,  OBL_PAL_SL,  STYLE_DASH,
                                 "", 8);
      if (tp1 > 0) OBL_DrawLevel(p + "TP1", tp1,
                                 (g_tpsl_tracks[t].tp1Hit ? OBL_PAL_TP_HIT : OBL_PAL_TP1),
                                 STYLE_DOT,
                                 "",
                                 8);
      if (tp2 > 0) OBL_DrawLevel(p + "TP2", tp2,
                                 (g_tpsl_tracks[t].tp2Hit ? OBL_PAL_TP_HIT : OBL_PAL_TP2),
                                 STYLE_DOT,
                                 "",
                                 8);
      if (tp3 > 0) OBL_DrawLevel(p + "TP3", tp3,
                                 (g_tpsl_tracks[t].tp3Hit ? OBL_PAL_TP_HIT : OBL_PAL_TP3),
                                 STYLE_DOT,
                                 "",
                                 8);
      if (tpM > 0) OBL_DrawLevel(p + "TPMAX", tpM, OBL_PAL_TPMAX, STYLE_DOT,
                                 "", 8);
   }
}

// ============================================================
// FASE 1 NEW - LIQUIDITY POOLS INTERNAL ONLY (no drawing).
//
// La liquidita' (BSL/SSL primary + deep) viene calcolata e
// cached per uso interno (bias, target, invalidation context)
// ma NON viene piu' disegnata sul chart.
//
// Consumer interni:
//   - Liq_GetBSL1()/BSL2()/SSL1()/SSL2()  -> ritornano i livelli
//   - Liq_RemovePoolObjects()             -> cleanup difensivo
// ============================================================
datetime g_liq_overlay_lastUpdate = 0;
double   g_liq_BSL1_cached = 0, g_liq_BSL2_cached = 0;
double   g_liq_SSL1_cached = 0, g_liq_SSL2_cached = 0;
int      g_liq_BSL1_sweepN = 0, g_liq_BSL2_sweepN = 0;
int      g_liq_SSL1_sweepN = 0, g_liq_SSL2_sweepN = 0;

void Liq_RemovePoolObjects() {
   // Cleanup difensivo: rimuove eventuali OBL_LIQ_* residui
   // (es. da versioni precedenti dell'EX4) ma non ricrea nulla.
   int total = ObjectsTotal(0, -1, -1);
   for (int i = total - 1; i >= 0; i--) {
      string nm = ObjectName(0, i);
      if (StringFind(nm, "OBL_LIQ_") == 0) ObjectDelete(0, nm);
   }
   g_liq_BSL1_cached = g_liq_BSL2_cached = 0;
   g_liq_SSL1_cached = g_liq_SSL2_cached = 0;
   g_liq_BSL1_sweepN = g_liq_BSL2_sweepN = 0;
   g_liq_SSL1_sweepN = g_liq_SSL2_sweepN = 0;
}

bool Liq_NeedRefresh(double cached, double fresh, double atr) {
   if (cached <= 0) return true;
   if (atr <= 0)   return MathAbs(fresh - cached) > 50 * Point;
   return MathAbs(fresh - cached) > 0.30 * atr;
}

// API interna per consumer logici (bias / target liquidity).
double Liq_GetBSL1() { return g_liq_BSL1_cached; }
double Liq_GetBSL2() { return g_liq_BSL2_cached; }
double Liq_GetSSL1() { return g_liq_SSL1_cached; }
double Liq_GetSSL2() { return g_liq_SSL2_cached; }

void Liq_DrawPools() {
   // Nome storico mantenuto per non rompere i caller, ma il
   // comportamento e' diventato "Liq_UpdatePoolsInternal".
   if (TimeCurrent() - g_liq_overlay_lastUpdate < 10) return;
   g_liq_overlay_lastUpdate = TimeCurrent();

   int lb = Mini_GetSwingLookback("Liq");
   if (lb < 10) lb = 10;
   if (lb > Bars - 2) lb = Bars - 2;
   if (lb < 5) return;
   double h1 = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, lb, 1));
   double l1 = iLow (Symbol(), 0, iLowest (Symbol(), 0, MODE_LOW,  lb, 1));
   double h2 = iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, lb,  lb + 1));
   double l2 = iLow (Symbol(), 0, iLowest (Symbol(), 0, MODE_LOW,  lb,  lb + 1));
   double cur = (Ask + Bid) * 0.5;
   double atr = iATR(Symbol(), Period(), 14, 1);

   // ---------- BSL1 (solo cache, no draw) ----------
   if (h1 > cur) {
      g_liq_BSL1_sweepN = 0;
      if (Liq_NeedRefresh(g_liq_BSL1_cached, h1, atr)) g_liq_BSL1_cached = h1;
   } else {
      g_liq_BSL1_sweepN++;
      if (g_liq_BSL1_sweepN >= 3) g_liq_BSL1_cached = 0;
   }
   // ---------- BSL2 ----------
   bool bsl2_ok = (h2 > cur && MathAbs(h2 - h1) > 0.50 * atr);
   if (bsl2_ok) {
      g_liq_BSL2_sweepN = 0;
      if (Liq_NeedRefresh(g_liq_BSL2_cached, h2, atr)) g_liq_BSL2_cached = h2;
   } else {
      g_liq_BSL2_sweepN++;
      if (g_liq_BSL2_sweepN >= 3) g_liq_BSL2_cached = 0;
   }
   // ---------- SSL1 ----------
   if (l1 < cur) {
      g_liq_SSL1_sweepN = 0;
      if (Liq_NeedRefresh(g_liq_SSL1_cached, l1, atr)) g_liq_SSL1_cached = l1;
   } else {
      g_liq_SSL1_sweepN++;
      if (g_liq_SSL1_sweepN >= 3) g_liq_SSL1_cached = 0;
   }
   // ---------- SSL2 ----------
   bool ssl2_ok = (l2 < cur && MathAbs(l2 - l1) > 0.50 * atr);
   if (ssl2_ok) {
      g_liq_SSL2_sweepN = 0;
      if (Liq_NeedRefresh(g_liq_SSL2_cached, l2, atr)) g_liq_SSL2_cached = l2;
   } else {
      g_liq_SSL2_sweepN++;
      if (g_liq_SSL2_sweepN >= 3) g_liq_SSL2_cached = 0;
   }
}

void TPSLManager_OnTick() {
   // FASE 3+4 - state machine LIVE_UNARMED -> PROTECTED -> BE -> TRAIL.
   // min-age (mode/TF aware) e min-bars: il trade respira prima
   // di stringere SL. TP1/2/3 muovono SL solo quando il rispettivo
   // livello e' effettivamente toccato. No emergency close path.
   //
   // ITER 25 (FIX-5) — PRECISION-ENTRY BREATHING ROOM.
   //   Live management was technically correct but a bit too tight
   //   for precision-entry trades on M1/M5. We now widen armSec by
   //   1.4× on M1/M5 (and 1.2× on M15) so a wick-fade entry gets the
   //   space it needs to develop into TP1/TP2 instead of being BE-
   //   choked by intrabar noise. Higher TFs (>= H1) keep tighter arms.
   datetime now = TimeCurrent();
   int armSec_base = (Mode == Aggressive ? 25 : (Mode == Conservative ? 90 : 50));
   double armTfMul = 1.0;
   int per_arm = Period();
   if      (per_arm <= PERIOD_M1)  armTfMul = 1.40;
   else if (per_arm <= PERIOD_M5)  armTfMul = 1.40;
   else if (per_arm <= PERIOD_M15) armTfMul = 1.20;
   else if (per_arm <= PERIOD_H1)  armTfMul = 1.00;
   else                             armTfMul = 0.90;
   // ITER 26 — SymClass aware breathing: CRYPTO + METAL move violently,
   // need wider arming. INDEX impulses fast but settles; FX cleanest.
   double armSymMul = 1.0;
   int sc_arm = SymClass();
   if      (sc_arm == SYMC_CRYPTO) armSymMul = 1.30;
   else if (sc_arm == SYMC_METAL)  armSymMul = 1.20;
   else if (sc_arm == SYMC_INDEX)  armSymMul = 1.10;
   else                             armSymMul = 1.00;
   int armSec = (int)MathRound(armSec_base * armTfMul * armSymMul);
   int armBars = (Period() <= 5 ? 1 : 2);   // M5 -> 1 bar, > M5 -> 2 bar
   int periodSec = Period() * 60;

   for (int i = g_tpsl_trackCount - 1; i >= 0; i--) {
      int ticket = g_tpsl_tracks[i].ticket;
      if (!OrderSelect(ticket, SELECT_BY_TICKET)) {
         TPSL_RemoveTrack(i);
         continue;
      }
      if (OrderCloseTime() > 0) {
         TPSL_RemoveTrack(i);
         continue;
      }

      double price = (g_tpsl_tracks[i].orderType == OP_BUY) ? Bid : Ask;
      double entry = g_tpsl_tracks[i].entryPrice;
      double currentSL = OrderStopLoss();
      double spread_val = (Ask - Bid);
      // FASE 7+8 + ITER 25 (FIX-5) + ITER 26 — Adaptive BE buffer.
      //   base = spread + 2pt; structural floor 0.10×ATR; M1/M5 widen
      //   to 0.15×ATR. ITER 26: CRYPTO/METAL +0.05 (wick volatility),
      //   SHOCK/EXHAUSTION +0.05 (avoid noise BE-choke), capped at 0.30.
      double atr_be = iATR(Symbol(), Period(), 14, 1);
      double atrFloor = 0.10;
      int per_be = Period();
      if (per_be <= PERIOD_M5) atrFloor = 0.15;
      int sc_be = SymClass();
      if (sc_be == SYMC_CRYPTO || sc_be == SYMC_METAL) atrFloor += 0.05;
      int v_be = Vol5_Regime();
      if (v_be == 3 || v_be == 4) atrFloor += 0.05;
      if (atrFloor > 0.30) atrFloor = 0.30;
      double buffer = MathMax(spread_val + 2 * Point, atrFloor * atr_be);

      bool isBuy = (g_tpsl_tracks[i].orderType == OP_BUY);
      int    ageSec = (int)(now - g_tpsl_tracks[i].openedAt);
      bool   matured = (ageSec >= armSec) && (ageSec >= armBars * periodSec);
      // FASE 12 - RECOVERY GRACE: trade ripreso da reattach -> per
      // RECOVERY_GRACE_SEC il TPSL manager osserva senza toccare SL
      // ne' applicare BE. Permette al sistema di "capire" il trade.
      int RECOVERY_GRACE_SEC = (Mode == Aggressive ? 90 : (Mode == Conservative ? 240 : 150));
      if (g_tpsl_tracks[i].recoveredAt > 0 &&
          (now - g_tpsl_tracks[i].recoveredAt) < RECOVERY_GRACE_SEC) {
         continue;   // warmup: solo TP-hit detection naturale al prossimo tick
      }

      // -------- TRANSITION UNARMED -> PROTECTED --------
      // Una volta passato il periodo di arming, restringi SL a
      // initialSL (projected) MA con clamp di min-width: se la
      // distanza projected e' < 0.9 ATR -> usa max(0.9 ATR distance,
      // sl_proj) per evitare SL microscopici rumor-sensitive.
      if (g_tpsl_tracks[i].liveState == LIVE_UNARMED && matured) {
         double pSL = g_tpsl_tracks[i].initialSL;
         if (pSL > 0) {
            // FASE 3 - min-width clamp (ATR-based, structural)
            double atr_now = iATR(Symbol(), Period(), 14, 1);
            double min_dist = 0.90 * atr_now;
            double dist_proj = MathAbs(entry - pSL);
            if (dist_proj < min_dist && atr_now > 0) {
               double widened = (isBuy ? entry - min_dist : entry + min_dist);
               PrintFormat("[TPSL] tkt=%d PROTECTED clamp: dist_proj=%.5f < min_dist=%.5f -> widen to %.5f",
                           ticket, dist_proj, min_dist, widened);
               pSL = widened;
            }
            bool tighten = (isBuy ? (pSL > currentSL) : (pSL < currentSL || currentSL <= 0));
            if (tighten) {
               if (TPSL_ModifySL(ticket, pSL)) {
                  g_tpsl_tracks[i].liveState = LIVE_PROTECTED;
                  PrintFormat("[TPSL] tkt=%d UNARMED->PROTECTED slBroker=%.5f age=%ds",
                              ticket, pSL, ageSec);
               }
            } else {
               g_tpsl_tracks[i].liveState = LIVE_PROTECTED;
            }
         } else {
            g_tpsl_tracks[i].liveState = LIVE_PROTECTED;
         }
      }

      // -------- TP1/TP2/TP3/TRAIL (invariati, ma con guardia matured per BE) --------
      if (isBuy) {
         if (!g_tpsl_tracks[i].tp1Hit && price >= g_tpsl_tracks[i].tp1) {
            g_tpsl_tracks[i].tp1Hit = true;
            if (matured) {
               double newSL = entry + buffer;
               if (newSL > currentSL && TPSL_ModifySL(ticket, newSL))
                  g_tpsl_tracks[i].liveState = LIVE_BE;
            }
         }
         if (!g_tpsl_tracks[i].tp2Hit && price >= g_tpsl_tracks[i].tp2) {
            g_tpsl_tracks[i].tp2Hit = true;
            double newSL = g_tpsl_tracks[i].tp1;
            if (newSL > currentSL) TPSL_ModifySL(ticket, newSL);
         }
         if (!g_tpsl_tracks[i].tp3Hit && price >= g_tpsl_tracks[i].tp3) {
            g_tpsl_tracks[i].tp3Hit = true;
            double newSL = g_tpsl_tracks[i].tp2;
            if (newSL > currentSL && TPSL_ModifySL(ticket, newSL))
               g_tpsl_tracks[i].liveState = LIVE_TRAIL;
         }
         if (g_tpsl_tracks[i].tp3Hit) {
            double trailDist = (g_tpsl_tracks[i].tpmax - g_tpsl_tracks[i].tp3) * 0.4;
            double trailSL = price - trailDist;
            if (trailSL > currentSL && trailSL > g_tpsl_tracks[i].tp2)
               TPSL_ModifySL(ticket, trailSL);
         }
      } else {
         if (!g_tpsl_tracks[i].tp1Hit && price <= g_tpsl_tracks[i].tp1) {
            g_tpsl_tracks[i].tp1Hit = true;
            if (matured) {
               double newSL = entry - buffer;
               if ((newSL < currentSL || currentSL <= 0) && TPSL_ModifySL(ticket, newSL))
                  g_tpsl_tracks[i].liveState = LIVE_BE;
            }
         }
         if (!g_tpsl_tracks[i].tp2Hit && price <= g_tpsl_tracks[i].tp2) {
            g_tpsl_tracks[i].tp2Hit = true;
            double newSL = g_tpsl_tracks[i].tp1;
            if (newSL < currentSL || currentSL <= 0) TPSL_ModifySL(ticket, newSL);
         }
         if (!g_tpsl_tracks[i].tp3Hit && price <= g_tpsl_tracks[i].tp3) {
            g_tpsl_tracks[i].tp3Hit = true;
            double newSL = g_tpsl_tracks[i].tp2;
            if ((newSL < currentSL || currentSL <= 0) && TPSL_ModifySL(ticket, newSL))
               g_tpsl_tracks[i].liveState = LIVE_TRAIL;
         }
         if (g_tpsl_tracks[i].tp3Hit) {
            double trailDist = MathAbs(g_tpsl_tracks[i].tpmax - g_tpsl_tracks[i].tp3) * 0.4;
            double trailSL = price + trailDist;
            if ((trailSL < currentSL || currentSL <= 0) && trailSL < g_tpsl_tracks[i].tp2)
               TPSL_ModifySL(ticket, trailSL);
         }
      }
   }
}

// ============================================================
// FASE 5+8 NEW - DYNAMIC TP RECOMPUTE on NEW BAR
// I TP (tp1/tp2/tp3/tpmax) NON sono numeri congelati a vita.
// A ogni nuova candela il sistema, per ogni track ancora vivo e
// non in tp3Hit, ricalcola la ladder con ATR corrente + multipli
// strategy-specific (stessa Map di TPSL_ComputeLevels). Applica
// le modifiche solo se:
//   - il TP corrispondente NON e' gia' hit
//   - lo spostamento e' >= 0.40 ATR (no micro-aggiornamenti)
//   - non porta il TP "indietro" rispetto al prezzo corrente
//     (mai TP gia' superato dal prezzo)
//   - se trade in PROTECTED+/BE, mantieni R-multiple monotone:
//     TP1 deve sempre restare >= entry+min_step nella direzione
// Mantiene g_tpsl_tracks consistente con la realta' di mercato.
// ============================================================
void TPSL_RebalanceTPs_OnNewBar() {
   if (g_tpsl_trackCount <= 0) return;
   double atr_now = iATR(Symbol(), Period(), 14, 1);
   if (atr_now <= 0) return;
   double moveTol = 0.40 * atr_now;

   for (int i = 0; i < g_tpsl_trackCount; i++) {
      int ticket = g_tpsl_tracks[i].ticket;
      if (!OrderSelect(ticket, SELECT_BY_TICKET)) continue;
      if (OrderCloseTime() != 0)                  continue;
      if (g_tpsl_tracks[i].tp3Hit)                continue;  // trail-phase: niente reset
      // Skip recovery window: durante il warmup non toccare i TP
      if (g_tpsl_tracks[i].recoveredAt > 0) {
         datetime now = TimeCurrent();
         int recGrace = (Mode == Aggressive ? 90 :
                        (Mode == Conservative ? 240 : 150));
         if ((int)(now - g_tpsl_tracks[i].recoveredAt) < recGrace) continue;
      }

      double newTp1=0, newTp2=0, newTp3=0, newTpM=0;
      TPSL_ComputeLevels(g_tpsl_tracks[i].orderType,
                          g_tpsl_tracks[i].entryPrice,
                          g_tpsl_tracks[i].strategy,
                          newTp1, newTp2, newTp3, newTpM);

      bool   isBuy = (g_tpsl_tracks[i].orderType == OP_BUY);
      double price = (isBuy ? Bid : Ask);
      double minStep = 0.20 * atr_now;
      // Sanity per TP gia' hit: mantieni il valore esistente
      // (non rompere la ladder di trigger gia' passati).
      if (g_tpsl_tracks[i].tp1Hit) newTp1 = g_tpsl_tracks[i].tp1;
      if (g_tpsl_tracks[i].tp2Hit) newTp2 = g_tpsl_tracks[i].tp2;
      // Anti-back: TP non puo' essere riportato dietro al prezzo.
      if (isBuy) {
         if (!g_tpsl_tracks[i].tp1Hit && newTp1 <= price + minStep)
            newTp1 = price + minStep;
         if (newTp2 <= newTp1 + minStep) newTp2 = newTp1 + minStep;
         if (newTp3 <= newTp2 + minStep) newTp3 = newTp2 + minStep;
         if (newTpM <= newTp3 + minStep) newTpM = newTp3 + minStep;
      } else {
         if (!g_tpsl_tracks[i].tp1Hit && newTp1 >= price - minStep)
            newTp1 = price - minStep;
         if (newTp2 >= newTp1 - minStep) newTp2 = newTp1 - minStep;
         if (newTp3 >= newTp2 - minStep) newTp3 = newTp2 - minStep;
         if (newTpM >= newTp3 - minStep) newTpM = newTp3 - minStep;
      }
      // Apply with movement tolerance (no micro-flicker)
      bool changed = false;
      if (!g_tpsl_tracks[i].tp1Hit &&
          MathAbs(newTp1 - g_tpsl_tracks[i].tp1) >= moveTol) {
         g_tpsl_tracks[i].tp1 = newTp1; changed = true;
      }
      if (!g_tpsl_tracks[i].tp2Hit &&
          MathAbs(newTp2 - g_tpsl_tracks[i].tp2) >= moveTol) {
         g_tpsl_tracks[i].tp2 = newTp2; changed = true;
      }
      if (MathAbs(newTp3 - g_tpsl_tracks[i].tp3) >= moveTol) {
         g_tpsl_tracks[i].tp3 = newTp3; changed = true;
      }
      if (MathAbs(newTpM - g_tpsl_tracks[i].tpmax) >= moveTol) {
         g_tpsl_tracks[i].tpmax = newTpM; changed = true;
      }
      if (changed) {
         PrintFormat("[TPSL] REBAL tkt=%d %s ATR=%.5f -> TP1=%.5f TP2=%.5f TP3=%.5f TPMAX=%.5f",
                     ticket, g_tpsl_tracks[i].strategy, atr_now,
                     g_tpsl_tracks[i].tp1, g_tpsl_tracks[i].tp2,
                     g_tpsl_tracks[i].tp3, g_tpsl_tracks[i].tpmax);
      }
   }
}

void PositionManager_ApplyTrailing(int idx) {
                        if (idx < 0 || idx >= g_positionCount)
                          return;

                        string symbol = g_positions[idx].symbol;
                        int cmd = g_positions[idx].cmd;
                        double pv = PipValue(symbol);
                        double trailDist = TrailingStopPips() * pv;

                        if (trailDist <= 0)
                          return;

                        double currentPrice =
                            (cmd == OP_BUY) ? MarketInfo(symbol, MODE_BID)
                                            : MarketInfo(symbol, MODE_ASK);

                        if (cmd == OP_BUY) {
                          double newSL =
                              NormalizeDouble(currentPrice - trailDist, Digits);
                          if (newSL > g_positions[idx].openPrice) // Only trail
                          // in profit
                          {
                            if (newSL > g_positions[idx].sl +
                                            MarketInfo(symbol, MODE_POINT)) {
                              if (OrderManager_Modify(g_positions[idx].ticket,
                                                      newSL,
                                                      g_positions[idx].tp))
                                g_positions[idx].sl = newSL;
                            }
                          }
                        } else if (cmd == OP_SELL) {
                          double newSL =
                              NormalizeDouble(currentPrice + trailDist, Digits);
                          if (newSL < g_positions[idx].openPrice) // Only trail
                          // in profit
                          {
                            if (g_positions[idx].sl == 0 ||
                                newSL < g_positions[idx].sl -
                                            MarketInfo(symbol, MODE_POINT)) {
                              if (OrderManager_Modify(g_positions[idx].ticket,
                                                      newSL,
                                                      g_positions[idx].tp))
                                g_positions[idx].sl = newSL;
                            }
                          }
                        }
                      }

                      int PositionManager_AddSlot() {
                        if (g_positionCount >= PM_MAX_TRACKED) {
                          PositionManager_Compact();
                          if (g_positionCount >= PM_MAX_TRACKED)
                            return -1;
                        }
                        int idx = g_positionCount;
                        g_positionCount++;
                        return idx;
                      }

                      double ProfitToday_Realized() { return g_pnl_realized; }

                      double ProfitToday_Unrealized() {
                        double unrealized = 0;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderSymbol() != Symbol())
                            continue;
                          int t = OrderType();
                          if (t != OP_BUY && t != OP_SELL)
                            continue;
                          unrealized +=
                              OrderProfit() + OrderSwap() + OrderCommission();
                        }
                        g_pnl_unrealized = unrealized;
                        return unrealized;
                      }

                      double ProfitToday_Total() {
                        return ProfitToday_Realized() +
                               ProfitToday_Unrealized();
                      }

                      double ProfitToday_Percent() {
                        if (g_pnl_dayStartEquity <= 0)
                          return 0;
                        return (ProfitToday_Total() / g_pnl_dayStartEquity) *
                               100.0;
                      }

                      void ProfitGuards_OnTimer() {
                        // FASE 4.4 (Patch 3): __AP_PTP_ManageAll DEPRECATED.
                        // Tutto il profit-close per ticket vive ora in
                        // ClusterMoney_OnTick (chiamato da Orchestrator_OnTick
                        // ogni tick, non ogni 30s).
                        //
                        // FASE 5 (Patch 2): PnLTracker_EmergencyCheck lavora
                        // in PERCENTUALE diretta (dd in 0..100), quindi
                        // passare MaxDailyDDPercent DIRETTO (no /100.0).
                        if (ChallengePassage)
                          PnLTracker_EmergencyCheck(MaxDailyDDPercent);

                        // Patch 7: cleanup GV PTP_PEAK_* orfane ogni ~60
                        // tick di timer (timer = 1s ufficiale -> ~60s).
                        static int __cm_cleanup_cnt = 0;
                        if (++__cm_cleanup_cnt >= 60) {
                          __cm_cleanup_cnt = 0;
                          ClusterMoney_CleanupOrphanGV();
                        }
                      }

                      void ProfitGuards_CheckAll() {
                        // Per-tick profit guard: exposure
                        // check
                        if (!__AP_ExposureOK(Symbol(), MaxLots)) {
                          SmartLog("WARN", "ProfitGuard",
                                   "Max exposure reached: " +
                                       DoubleToString(
                                           __AP_TotalExposure(Symbol()), 2));
                        }
                      }

                      bool AIP2_IsLiveOnly() {
                        return !IsTesting(); // OTE system
                                             // only runs
                                             // live, not in
                                             // backtester
                      }

                      void __PTP_SetDouble(string key, double val) {
                        GlobalVariableSet(key, val);
                      }

                      double __PTP_GetDouble(string key, double defVal) {
                        if (GlobalVariableCheck(key))
                          return GlobalVariableGet(key);
                        return defVal;
                      }

                      void __PTP_SetInt(string key, int val) {
                        GlobalVariableSet(key, (double)val);
                      }

                      int __PTP_GetInt(string key, int defVal) {
                        if (GlobalVariableCheck(key))
                          return (int)GlobalVariableGet(key);
                        return defVal;
                      }

                      bool __PTP_NetOK() {
                        double net = 0;
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderSymbol() != Symbol())
                            continue;
                          net +=
                              OrderProfit() + OrderSwap() + OrderCommission();
                        }
                        return (net >= 0);
                      }

                      void __AP_PTP_ManageAll(int debounceSec, int timeoutSec) {
                        // FASE 9 (Patch 3): DEPRECATED. Sostituita da
                        // ClusterMoney_OnTick (path unico per profit-close
                        // peak-retrace per ticket). Lasciata definita per
                        // non rompere call-site indiretti; early return.
                        return;
                        // ---- unreachable legacy body below ----
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderSymbol() != Symbol())
                            continue;
                          int type = OrderType();
                          if (type != OP_BUY && type != OP_SELL)
                            continue;

                          int ticket = OrderTicket();
                          string kPeak = "PTP_PEAK_" + IntegerToString(ticket);
                          string kState =
                              "PTP_STATE_" + IntegerToString(ticket);
                          string kOsc = "PTP_OSC_" + IntegerToString(ticket);
                          string kFirst80 =
                              "PTP_F80_" + IntegerToString(ticket);
                          string kPeakTs =
                              "PTP_PEAKTS_" + IntegerToString(ticket);

                          double pnl =
                              OrderProfit() + OrderSwap() + OrderCommission();
                          double peak = __PTP_GetDouble(kPeak, pnl);

                          // Update peak
                          if (pnl > peak) {
                            peak = pnl;
                            __PTP_SetDouble(kPeak, peak);
                            __PTP_SetInt(kPeakTs, (int)TimeCurrent());
                          }

                          // Ratio computation
                          double ratio = (peak > 0 ? pnl / peak : 1.0);
                          if (peak <= 0)
                            ratio = 1.0;

                          // State tracking (0=normal,
                          // 1=warning, 2=critical)
                          int region = 0;
                          if (ratio <= PG_RATIO_EMERGENCY)
                            region = 2;
                          else if (ratio <= PG_RATIO_WARN)
                            region = 1;

                          int prevState = __PTP_GetInt(kState, 0);
                          if (region != prevState) {
                            int osc = __PTP_GetInt(kOsc, 0);
                            __PTP_SetInt(kOsc, osc + 1);
                            __PTP_SetInt(kState, region);
                          }

                          // Mark first 0.80 cross
                          if (ratio <= PG_RATIO_WARN &&
                              __PTP_GetInt(kFirst80, 0) == 0)
                            __PTP_SetInt(kFirst80, (int)TimeCurrent());

                          // Reset if recovered above 0.85
                          if (ratio >= 0.85)
                            __PTP_SetInt(kFirst80, 0);

                          // EMERGENCY CLOSE
                          if (ratio < PG_RATIO_EMERGENCY && __PTP_NetOK()) {
                            bool ok = false;
                            if (type == OP_BUY)
                              ok = OrderClose(
                                  ticket, OrderLots(),
                                  MarketInfo(Symbol(), MODE_BID),
                                  (int)MarketInfo(Symbol(), MODE_STOPLEVEL),
                                  clrNONE);
                            else
                              ok = OrderClose(
                                  ticket, OrderLots(),
                                  MarketInfo(Symbol(), MODE_ASK),
                                  (int)MarketInfo(Symbol(), MODE_STOPLEVEL),
                                  clrNONE);
                            if (ok) {
                              GlobalVariableDel(kPeak);
                              GlobalVariableDel(kState);
                              GlobalVariableDel(kOsc);
                              GlobalVariableDel(kFirst80);
                              GlobalVariableDel(kPeakTs);
                            }
                            continue;
                          }

                          // Regular close: hysteresis +
                          // debounce
                          int oscCount = __PTP_GetInt(kOsc, 0);
                          int f80 = __PTP_GetInt(kFirst80, 0);
                          bool enoughTime =
                              (f80 > 0 &&
                               (TimeCurrent() - (datetime)f80) >= debounceSec);
                          int pts = __PTP_GetInt(kPeakTs, (int)TimeCurrent());
                          bool timedExit =
                              (pts > 0 &&
                               (TimeCurrent() - (datetime)pts) >= timeoutSec);

                          if (ratio <= PG_RATIO_WARN && __PTP_NetOK() &&
                              (oscCount >= PG_OSC_THRESHOLD || enoughTime ||
                               timedExit)) {
                            bool ok = false;
                            if (type == OP_BUY)
                              ok = OrderClose(
                                  ticket, OrderLots(),
                                  MarketInfo(Symbol(), MODE_BID),
                                  (int)MarketInfo(Symbol(), MODE_STOPLEVEL),
                                  clrNONE);
                            else
                              ok = OrderClose(
                                  ticket, OrderLots(),
                                  MarketInfo(Symbol(), MODE_ASK),
                                  (int)MarketInfo(Symbol(), MODE_STOPLEVEL),
                                  clrNONE);
                            if (ok) {
                              GlobalVariableDel(kPeak);
                              GlobalVariableDel(kState);
                              GlobalVariableDel(kOsc);
                              GlobalVariableDel(kFirst80);
                              GlobalVariableDel(kPeakTs);
                            }
                          }
                        }
                      }

                      void ManageVirtualTPSL(string strategyName, double lot,
                                             double tp, double sl) {
                        double currentProfit = (OrderType() == OP_BUY)
                            ? (Bid - OrderOpenPrice()) * lot *
                                  MarketInfo(OrderSymbol(), MODE_TICKVALUE)
                            : (OrderOpenPrice() - Ask) * lot *
                                  MarketInfo(OrderSymbol(), MODE_TICKVALUE);
                                  // Peak Profit virtuale
                                  if (ApplyPeakProfit &&
                                      currentProfit >=
                                          (PeakProfitPercent / 100.0) * tp) {
                                    if (strategyName == "Grid") {
                                      static string __GRID_LAST_REASON;
                                      __GRID_LAST_REASON = "VTP";
                                    }
                                    double minProfit =
                                        (MinProfitPercent / 100.0) * tp;
                                    if (currentProfit >= minProfit) {
                                      {
                                        int __ticket = OrderTicket();
                                        double __lots = OrderLots();
                                        SmartLogWrap(
                                            "CLOSE",
                                            StringFormat("PreClose "
                                                         "| "
                                                         "ticket=%d "
                                                         "lots=%.2f "
                                                         "symbol=%s",
                                                         __ticket, __lots,
                                                         OrderSymbol()));
                                      }
                                      bool _wRes = OrderClose(OrderTicket(), OrderLots(),
                                                 (OrderType() == OP_BUY) ? Bid
   : Ask,
                                                 GetAdaptiveSlippagePoints(),
                                                 clrGreen);
                                      {
                                        int __err = GetLastError();
                                        bool __isok = (__err == 0);
                                        SmartLogWrap(
                                            "CLOSE",
                                            StringFormat("%s | "
                                                         "ticket=%d "
                                                         "price=%."
                                                         "5f "
                                                         "lots=%.2f "
                                                         "err=%d",
                                                         __isok ? "Post"
   "Clos"
   "e OK"
   : "Post"
   "Clos"
   "e "
   "FAI"
   "L",
                                                         OrderTicket(),
                                                         OrderClosePrice(),
                                                         OrderLots(), __err));
                                      }
                                    }
                                  }
                                  // Profit Lock giornaliero
                                  if (EnableProfitLock) {
                                    double dailyProfit = AccountProfit();
                                    if (dailyProfit <
                                        (ProfitLockPercent / 100.0) *
                                            AccountBalance()) {
                                      {
                                        int __ticket = OrderTicket();
                                        double __lots = OrderLots();
                                        SmartLogWrap(
                                            "CLOSE",
                                            StringFormat("PreClose "
                                                         "| "
                                                         "ticket=%d "
                                                         "lots=%.2f "
                                                         "symbol=%s",
                                                         __ticket, __lots,
                                                         OrderSymbol()));
                                      }
                                      bool _wOk = OrderClose(
                                          OrderTicket(), OrderLots(),
                                          (OrderType() == OP_BUY) ? Bid : Ask,
                                          GetAdaptiveSlippagePoints(), clrRed);
                                      {
                                        int __err = GetLastError();
