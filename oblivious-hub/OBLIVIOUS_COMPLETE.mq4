int GetAITradeSignal() {
                        int ai = GetCurrentAISignal();
                        int conf =  (int)(GetConfidenceFromAI());
                        int rsiSig = GetRSISignal();
                        int dir = 0;
                        if (conf >= 60 && ai != 0)
                          dir = ai;
                        if (dir == 0) {
                          bool eng = IsEngulfingPattern();
                          bool pin = IsPinBarPattern();
                          if (eng || pin)
                            dir = rsiSig;
                        }
                        return dir;
                      }

                      string GetNewsDataJSON() {
                        // Bridge-based news retrieval
                        // with Bridge_* mechanism]
                        string news_data = "";
                        datetime now = TimeCurrent();
                        int blockTrading = 0, severity = 0, minutesToEvent = 0;

                        if (Bridge_GetNewsStatus(now, blockTrading, severity,
                                                 minutesToEvent)) {
                          // Format news data as JSON for
                          // web dashboard Bridge returns:
                          // blockTrading (0/1), severity
                          // (0-3), minutesToEvent
                          string impact = "LOW";
                          if (severity >= 3)
                            impact = "HIGH";
                          else if (severity >= 2)
                            impact = "MEDIUM";

                          string eventDesc = "No upcoming news";
                          if (minutesToEvent > 0) {
                            eventDesc = StringFormat("News event in %d minutes",
                                                     minutesToEvent);
                          }

                          news_data = StringFormat(
                              "{\"event\":\"%s\",\"impact\":\"%s\",\"time\":\"%s\",\"blockTrading\":%d}",
                              eventDesc, impact,
                              TimeToString(now, TIME_MINUTES), blockTrading);
                        } else {
                          // Fallback: no news data
                          // available (EXE not connected or
                          // no news)
                          news_data = "{\"event\":\"No news data "
                                      "available\",\"impact\":\""
                                      "LOW\",\"time\":\"" +
                                      TimeToString(now, TIME_MINUTES) +
                                      "\",\"blockTrading\":0}";
                        }
                        return news_data;
                      }

