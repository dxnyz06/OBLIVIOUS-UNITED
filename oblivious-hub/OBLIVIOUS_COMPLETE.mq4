void   Hub_HoldGlobal_Set(bool on, string reason);
void   Hub_HoldOwner_Set(string owner, bool on, string reason);
// R8 — payload-aware field helpers (read from `payload` first, then envelope)
string Cmd_PField(string body, string scope, string key);
double Cmd_PDouble(string body, string scope, string key, double def);
int    Cmd_PInt(string body, string scope, string key, int def);
int    Ownership_Add(int ticket, int magic, string owner, string source, int ocoPeer, string correlation);
int    Ownership_FindByTicket(int ticket);
bool   Ownership_Remove(int ticket);
string Ownership_GetOwner(int ticket);
bool   Ownership_IsHubManaged(int ticket);

                                          void AIBridge_Init() {
                                            g_ai_connected = false;
                                            g_ai_enabled = true;
                                            g_ai_status = "INIT";
                                            g_ai_errorCount = 0;
                                            g_ai_successCount = 0;

                                            // Auto-disable in Strategy
                                            // Tester
                                            if (IsTesting() ||
                                                IsOptimization()) {
                                              g_ai_enabled = false;
                                              g_ai_status = "DISABLED_TESTER";
                                              Print("[AIBridge] Disabled "
                                                    "in Strategy Tester");
                                              return;
                                            }

                                            // Check if DLLs are allowed
                                            if (!IsDllsAllowed()) {
                                              g_ai_enabled = false;
                                              g_ai_status = "DISABLED_NO_DLL";
                                              Print("[AIBridge] DLL imports "
                                                    "not allowed - running "
                                                    "in local mode");
                                              return;
                                            }

                                            // Attempt initial connection
                                            AIBridge_Connect();

                                            PrintFormat(
                                                "[AIBridge] Init | "
                                                "Enabled: %s | Connected: "
                                                "%s",
                                                g_ai_enabled ? "YES" : "NO",
                                                g_ai_connected ? "YES" : "NO");
                                          }

// ============================================================
// R3: AIBridge transport — ZeroMQ implementations.
// AIBridge_Connect, AIBridge_Disconnect, AIBridge_SendRequest and
// AIBridge_Poll are thin wrappers over the ZMQ_* helpers further
// below. The legacy named-pipe code path was removed; all four
// functions now feed/read from the live g_zmq_* sockets and update
// the g_ai_* globals so AIBridge_IsConnected/GetDirection/...
// reflect transport reality (R4).
// ============================================================
                                          bool AIBridge_Connect() {
   if (!g_ai_enabled) return false;
   bool ok = ZMQ_Init();
   if (ok) {
      g_ai_connected    = true;
      g_BridgeConnected = true;
      g_ai_status       = "ZMQ_CONNECTED";
      AIBridge_SendMarketData(Symbol());
      Print("[AIBridge] ZMQ ready (REQ:5565 / SUB:5566 / PUSH:5567)");
   } else if (!g_zmq_is_master) {
      g_ai_connected    = false;
      g_BridgeConnected = false;
      g_ai_status       = "ZMQ_SLAVE_CHART";
   } else {
      g_ai_connected    = false;
      g_BridgeConnected = false;
      g_ai_status       = "ZMQ_CONNECT_FAILED";
      g_ai_errorCount++;
   }
   return ok;
                                          }

                                          void AIBridge_Disconnect() {
   ZMQ_Shutdown();
   g_ai_connected    = false;
   g_BridgeConnected = false;
   g_ai_status       = "ZMQ_DISCONNECTED";
}

bool AIBridge_SendRequest(string request) {
   // Fire-and-forget context push on PUSH socket. Used by SendMarketData
   // and Bridge_SendLog. Non-blocking; if the hub is not draining we
   // bump g_ai_errorCount and degrade the bridge state for R4.
   if (!g_ai_enabled || !g_zmq_initialized) return false;
   if (!ZMQ_PushContext(request)) {
                                              g_ai_errorCount++;
      g_ai_status = "ZMQ_PUSH_FAILED";
                                              return false;
                                            }
                                            return true;
                                          }

                                          void AIBridge_Poll() {
   // Drain SUB socket (non-blocking) to update g_ai_* + news/bookmap
   // caches + dispatch hub commands.  Also enforces the heartbeat
   // staleness check so g_ai_connected drops when the hub goes silent.
   if (!g_ai_enabled) return;
   if (!g_zmq_initialized && g_zmq_is_master) {
                                              AIBridge_Connect();
      if (!g_zmq_initialized) return;
   }
   if (!g_zmq_initialized) return;
   int n = ZMQ_DrainSubscriber();
   if (n > 0) {
                                            g_ai_lastResponse = TimeCurrent();
                                            g_ai_successCount++;
                                            g_ai_status = "ACTIVE";
   }
   datetime hbTs = OBL_GetHubHeartbeatTs();
   if (hbTs > 0 && (TimeCurrent() - hbTs) > ZMQ_HEARTBEAT_TIMEOUT_S) {
      if (g_zmq_initialized) {
         g_ai_connected    = false;
         g_BridgeConnected = false;
         g_ai_status       = "HEARTBEAT_TIMEOUT";
      }
   } else if (hbTs > 0) {
      g_ai_connected    = true;
      g_BridgeConnected = true;
      if (g_ai_status == "HEARTBEAT_TIMEOUT") g_ai_status = "ACTIVE";
   }
   DynPanel_RefreshBridgeAndNews();
}


                                          void AIBridge_ParseResponse(
                                              string response) {
                                            // Expected format:
                                            // "DIR:1|CONF:0.85|TP:1.2345|SL:1.2300|TRAIL:0.0015"
                                            // or simple: "BUY|0.85" /
                                            // "SELL|0.72" / "NONE|0.0"

                                            g_ai_direction = 0;
                                            g_ai_confidence = 0;
                                            g_ai_virtualTP = 0;
                                            g_ai_virtualSL = 0;
                                            g_ai_virtualTrail = 0;
                                            g_ai_lastSignal = response;

                                            // Try structured format first
                                            if (StringFind(response, "DIR:") >=
                                                0) {
                                              AIBridge_ParseStructured(
                                                  response);
                                              return;
                                            }

                                            // Simple format
                                            if (StringFind(response, "BUY") >=
                                                0)
                                              g_ai_direction = 1;
                                            else if (StringFind(response,
   "SELL") >= 0)
                                              g_ai_direction = -1;

                                            // Extract confidence
                                            int pipePos =
                                                StringFind(response, "|");
                                            if (pipePos > 0) {
                                              string confStr = StringSubstr(
                                                  response, pipePos + 1);
                                              g_ai_confidence =
                                                  StringToDouble(confStr);
                                            }

                                            // Validate
                                            AIBridge_ValidateSignal();
                                          }

                                          void AIBridge_ParseStructured(
                                              string response) {
                                            // DIR:1|CONF:0.85|TP:1.2345|SL:1.2300|TRAIL:0.0015
                                            string parts[];
                                            int count = AIBridge_StringSplit(
                                                response, '|', parts);

                                            for (int i = 0; i < count; i++) {
                                              int colonPos =
                                                  StringFind(parts[i], ":");
                                              if (colonPos <= 0)
                                                continue;

                                              string key = StringSubstr(
                                                  parts[i], 0, colonPos);
                                              string val = StringSubstr(
                                                  parts[i], colonPos + 1);

                                              if (key == "DIR")
                                                g_ai_direction =
                                                    (int)StringToInteger(val);
                                              else if (key == "CONF")
                                                g_ai_confidence =
                                                    StringToDouble(val);
                                              else if (key == "TP")
                                                g_ai_virtualTP =
                                                    StringToDouble(val);
                                              else if (key == "SL")
                                                g_ai_virtualSL =
                                                    StringToDouble(val);
                                              else if (key == "TRAIL")
                                                g_ai_virtualTrail =
                                                    StringToDouble(val);
                                            }

                                            AIBridge_ValidateSignal();
                                          }

                                          void AIBridge_ValidateSignal() {
                                            // Clamp direction
                                            if (g_ai_direction > 1)
                                              g_ai_direction = 1;
                                            if (g_ai_direction < -1)
                                              g_ai_direction = -1;

                                            // Clamp confidence
                                            if (g_ai_confidence < 0)
                                              g_ai_confidence = 0;
                                            if (g_ai_confidence > 1.0)
                                              g_ai_confidence = 1.0;

                                            // Validate TP/SL (must be
                                            // positive and reasonable)
                                            if (g_ai_virtualTP < 0)
                                              g_ai_virtualTP = 0;
                                            if (g_ai_virtualSL < 0)
                                              g_ai_virtualSL = 0;
                                            if (g_ai_virtualTrail < 0)
                                              g_ai_virtualTrail = 0;
                                          }

// ============================================================
// CONTEXT-PUSH ENRICHMENT — positions[] / pending[] JSON
// ------------------------------------------------------------
// AIBridge_SendMarketData publishes a JSON `context_push` over the
// ZMQ PUSH socket. Historically this carried scalar market context
// only (bid/ask/atr/rsi/...). The Hub's MobileGateway exposes
// `positions[]` + `pending[]` to paired mobile devices but until now
// the EA never emitted those arrays, so the mobile dashboard kept
// them empty. The two helpers below fix that surgically.
//
//   * Both walk the live order book.
//   * Both honour Panel_IsOurMagic so non-Oblivious manual trades
//     never leak into the Hub stream.
//   * Numeric fields are normalised to the symbol Digits.
//   * Output is a self-contained JSON array string — caller concatenates
//     it after the existing StringFormat result, NEVER inside it (to
//     avoid disturbing the StringFormat arg count).
// ============================================================
string Oblivious_BuildPositionsJson() {
   string out   = "[";
   bool   first = true;
   for (int i = OrdersTotal() - 1; i >= 0; i--) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      int t = OrderType();
      if (t != OP_BUY && t != OP_SELL) continue;
      if (!Panel_IsOurMagic(OrderMagicNumber())) continue;
      int    ticket = OrderTicket();
      string sym    = OrderSymbol();
      int    digits = (int)MarketInfo(sym, MODE_DIGITS);
      double entry  = OrderOpenPrice();
      double cur    = (t == OP_BUY) ? MarketInfo(sym, MODE_BID)
                                    : MarketInfo(sym, MODE_ASK);
      double pnl    = OrderProfit() + OrderSwap() + OrderCommission();
      double sl     = OrderStopLoss();
      double tp     = OrderTakeProfit();
      string side   = (t == OP_BUY) ? "BUY" : "SELL";
      string strat  = Panel_MagicToStrategy(OrderMagicNumber());
      if (!first) out += ",";
      first = false;
      out += "{"
           + "\"ticket\":"   + IntegerToString(ticket)
           + ",\"sym\":\""   + sym + "\""
           + ",\"side\":\""  + side + "\""
           + ",\"lots\":"    + DoubleToString(OrderLots(), 2)
           + ",\"entry\":"   + DoubleToString(entry,  digits)
           + ",\"current\":" + DoubleToString(cur,    digits)
           + ",\"pnl\":"     + DoubleToString(pnl,    2)
           + ",\"sl\":"      + DoubleToString(sl,     digits)
           + ",\"tp\":"      + DoubleToString(tp,     digits)
           + ",\"strategy\":\"" + strat + "\""
           + ",\"magic\":"   + IntegerToString(OrderMagicNumber())
           + "}";
   }
   out += "]";
   return out;
}

string Oblivious_PendingTypeName(int t) {
   if (t == OP_BUYLIMIT)  return "BUYLIMIT";
   if (t == OP_SELLLIMIT) return "SELLLIMIT";
   if (t == OP_BUYSTOP)   return "BUYSTOP";
   if (t == OP_SELLSTOP)  return "SELLSTOP";
   return "PENDING";
}

string Oblivious_BuildPendingJson() {
   string out   = "[";
   bool   first = true;
   for (int i = OrdersTotal() - 1; i >= 0; i--) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      int t = OrderType();
      // OP_BUY=0, OP_SELL=1 are market positions — skip them.
      if (t < OP_BUYLIMIT || t > OP_SELLSTOP) continue;
      if (!Panel_IsOurMagic(OrderMagicNumber())) continue;
      int    ticket = OrderTicket();
      string sym    = OrderSymbol();
      int    digits = (int)MarketInfo(sym, MODE_DIGITS);
      datetime exp  = OrderExpiration();
      string expStr = (exp > 0) ? TimeToString(exp, TIME_DATE | TIME_MINUTES) : "";
      if (!first) out += ",";
      first = false;
      out += "{"
           + "\"ticket\":"      + IntegerToString(ticket)
           + ",\"sym\":\""      + sym + "\""
           + ",\"type\":"       + IntegerToString(t)
           + ",\"type_name\":\""+ Oblivious_PendingTypeName(t) + "\""
           + ",\"lots\":"       + DoubleToString(OrderLots(),       2)
           + ",\"price\":"      + DoubleToString(OrderOpenPrice(),  digits)
           + ",\"sl\":"         + DoubleToString(OrderStopLoss(),   digits)
           + ",\"tp\":"         + DoubleToString(OrderTakeProfit(), digits)
           + ",\"expiry\":\""   + expStr + "\""
           + ",\"magic\":"      + IntegerToString(OrderMagicNumber())
           + "}";
   }
   out += "]";
   return out;
}

// AIBridge_SendMarketData → ships a JSON context_push on the PUSH
// socket (port 5557). High-frequency, non-blocking, throttled by
// ZMQ_PUSH_THROTTLE_MS so we never block the EA tick on transport.
void AIBridge_SendMarketData(string symbol) {
   if (!g_ai_enabled || !g_zmq_initialized) return;
   string payload = StringFormat(
      "{\"op\":\"context_push\",\"sym\":\"%s\",\"tf\":%d,\"bid\":%.5f,\"ask\":%.5f,"
      "\"atr\":%.5f,\"rsi\":%.2f,\"adx\":%.2f,\"trend\":%d,\"spread\":%.1f,"
      "\"news_block\":%s,\"news_impact\":%d,\"strategies\":{\"predicted\":%s,\"breakout\":%s,"
      "\"fvg\":%s,\"grid\":%s,\"reverse\":%s,\"smc\":%s,\"ict\":%s},"
      "\"tpsl_mode\":\"%s\",\"ts\":%d",
      OBL_JsonEscape(symbol), Period(),
      MarketInfo(symbol, MODE_BID), MarketInfo(symbol, MODE_ASK),
                                                iATR(symbol, 0, 14, 0),
      iRSI(symbol, 0, 14, PRICE_CLOSE, 0),
      Ind_ADX(symbol), Ind_TrendDir(symbol),
                                                RiskEngine_GetSpread(),
      g_news_blockTrading ? "true" : "false", (int)g_news_currentImpact,
      Predicted ? "true" : "false", Breakout ? "true" : "false",
      FVG ? "true" : "false", Grid ? "true" : "false",
      Reverse ? "true" : "false", SMC ? "true" : "false",
      ICT ? "true" : "false",
      IsTPSL_AI() ? "AI" : "Native",
      (int)TimeCurrent());
   // Account snapshot — campi consumati dalla UI ACCOUNT MATRIX.
   double marginUsed = AccountMargin();
   double marginLvl  = (marginUsed > 0.0) ? (AccountEquity() / marginUsed * 100.0) : 0.0;
   payload += StringFormat(
      ",\"balance\":%.2f,\"equity\":%.2f,\"margin\":%.2f,\"free_margin\":%.2f,"
      "\"margin_level\":%.2f,\"leverage\":%d,\"account_id\":%d,"
      "\"broker\":\"%s\",\"server\":\"%s\",\"currency\":\"%s\"",
      AccountBalance(), AccountEquity(), marginUsed, AccountFreeMargin(),
      marginLvl, (int)AccountLeverage(), (int)AccountNumber(),
      OBL_JsonEscape(AccountCompany()), OBL_JsonEscape(AccountServer()),
      OBL_JsonEscape(AccountCurrency()));
   // Performance metrics — campi consumati dalla UI PERFORMANCE METRICS.
   double perf_open  = 0.0;
   int    perf_oTrades = 0;
   for (int i = 0; i < OrdersTotal(); i++) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if (OrderType() == OP_BUY || OrderType() == OP_SELL) {
         perf_open += OrderProfit() + OrderSwap() + OrderCommission();
         perf_oTrades++;
      }
   }
   double perf_today = 0.0, perf_total = 0.0;
   int    perf_trades = 0, perf_wins = 0, perf_losses = 0;
   double perf_grossProfit = 0.0, perf_grossLoss = 0.0;
   double perf_maxDD = 0.0;
   datetime todayStart = StrToTime(TimeToStr(TimeCurrent(), TIME_DATE));
   for (int j = 0; j < OrdersHistoryTotal(); j++) {
      if (!OrderSelect(j, SELECT_BY_POS, MODE_HISTORY)) continue;
      if (OrderType() != OP_BUY && OrderType() != OP_SELL) continue;
      double pnl = OrderProfit() + OrderSwap() + OrderCommission();
      perf_total += pnl;
      perf_trades++;
      if (pnl >= 0) { perf_wins++;   perf_grossProfit += pnl; }
      else          { perf_losses++; perf_grossLoss   += -pnl; }
      if (OrderCloseTime() >= todayStart) perf_today += pnl;
      if (pnl < perf_maxDD) perf_maxDD = pnl;
   }
   double perf_winrate = (perf_trades > 0) ? (100.0 * perf_wins / perf_trades) : 0.0;
   double perf_pf      = (perf_grossLoss > 0.0) ? (perf_grossProfit / perf_grossLoss) : 0.0;
   double bal          = (AccountBalance() > 0.0) ? AccountBalance() : 1.0;
   double perf_today_pct = (bal > 0.0) ? MathAbs(perf_today / bal) * 100.0 : 0.0;
   double perf_open_pct  = (bal > 0.0) ? MathAbs(perf_open  / bal) * 100.0 : 0.0;
   double perf_total_pct = (bal > 0.0) ? MathAbs(perf_total / bal) * 100.0 : 0.0;
   double perf_maxdd_pct = (bal > 0.0) ? MathAbs(perf_maxDD / bal) * 100.0 : 0.0;
   payload += StringFormat(
      ",\"perf_total\":%.2f,\"perf_total_pct\":%.2f,"
      "\"perf_today\":%.2f,\"perf_today_pct\":%.2f,"
      "\"perf_open\":%.2f,\"perf_open_pct\":%.2f,"
      "\"perf_trades\":%d,\"perf_winrate\":%.2f,"
      "\"perf_max_dd\":%.2f,\"perf_maxdd_pct\":%.2f,"
      "\"perf_pf\":%.2f",
      perf_total, MathMin(100.0, perf_total_pct),
      perf_today, MathMin(100.0, perf_today_pct),
      perf_open,  MathMin(100.0, perf_open_pct),
      perf_trades, perf_winrate,
      perf_maxDD, MathMin(100.0, perf_maxdd_pct),
      perf_pf);
   payload += ",\"positions\":" + Oblivious_BuildPositionsJson();
   payload += ",\"pending\":"   + Oblivious_BuildPendingJson();
   payload += "}";
   AIBridge_SendRequest(payload);
                                          }

                                          int AIBridge_StringSplit(
                                              string str, ushort sep,
                                              string & result[]) {
                                            ArrayResize(result, 0);
                                            int count = 0;
                                            string current = "";

                                            for (int i = 0; i < StringLen(str);
                                                 i++) {
                                              ushort ch =
                                                  StringGetCharacter(str, i);
                                              if (ch == sep) {
                                                ArrayResize(result, count + 1);
                                                result[count] = current;
                                                count++;
                                                current = "";
                                              } else {
                                                current +=
                                                    CharToString((uchar)ch);
                                              }
                                            }

                                            if (StringLen(current) > 0) {
                                              ArrayResize(result, count + 1);
                                              result[count] = current;
                                              count++;
                                            }

                                            return count;
                                          }

                                          bool AIBridge_IsEnabled() {
                                            return Predicted;
                                          }

                                          // R4: real bridge state.  All seven
                                          // accessors expose the live g_ai_*
                                          // globals that are updated by the
                                          // ZeroMQ transport (REQ response,
                                          // SUB heartbeat, SUB command,
                                          // timeout/reconnect).  No stub
                                          // returns.
                                          bool AIBridge_IsConnected() {
                                            return g_ai_connected;
                                          }

                                          int AIBridge_GetDirection() {
                                            return g_ai_direction;
                                          }

                                          double AIBridge_GetConfidence() {
                                            return g_ai_confidence;
                                          }

                                          string AIBridge_GetStatus() {
                                            return g_ai_status;
                                          }

                                          string AIBridge_GetLastSignal() {
                                            return g_ai_lastSignal;
                                          }

                                          int AIBridge_GetErrorCount() {
                                            return g_ai_errorCount;
                                          }

                                          int AIBridge_GetSuccessCount() {
                                            return g_ai_successCount;
                                          }

// ============================================================
// R3 / R4 / R7 — ZMQ transport, hub-command dispatcher, and
// order ownership registry implementations.
// ============================================================

// --- Format-agnostic message helpers ---------------------------
// The hub may emit either:
//   1) legacy pipe-delimited ............ "op=EXECUTE|sym=EURUSD|..."
//   2) flat JSON (the new Electron path) . "{\"op\":\"EXECUTE\",\"sym\":\"EURUSD\",...}"
//
// We try the JSON path first (looking for the `"key":` token and
// reading either a quoted string or a bare number/bool/null), and
// fall back to the pipe parser for legacy callers. This keeps the
// 30+ existing call sites working unchanged while letting the new
// hub send native JSON.
//
// Strict JSON parsing (escapes, unicode, nested objects) is NOT
// required: every field consumed by the EA is FLAT (string / number /
// bool). Nested `of_context` objects are walked separately by
// passing the inner JSON substring (Msg_ExtractObject helper).
string OBL_JsonEscape(string s) {
   if (StringLen(s) == 0) return "";
   StringReplace(s, "\\", "\\\\");
   StringReplace(s, "\"", "\\\"");
   StringReplace(s, "\r", "\\r");
   StringReplace(s, "\n", "\\n");
   return s;
}

string Msg_GetField(string body, string key) {
   if (StringLen(body) == 0 || StringLen(key) == 0) return "";

   // ── Path A: JSON ────────────────────────────────────────────
   // Look for `"key"` then scan past whitespace + `:` + whitespace
   // to the value start.
   string jsonNeedle = "\"" + key + "\"";
   int    p = StringFind(body, jsonNeedle);
   if (p >= 0) {
      int   i = p + StringLen(jsonNeedle);
      int   n = StringLen(body);
      while (i < n) {
         ushort c = StringGetCharacter(body, i);
         if (c == ' ' || c == '\t' || c == '\r' || c == '\n') { i++; continue; }
         if (c == ':') { i++; break; }
         break;
      }
      while (i < n) {
         ushort c = StringGetCharacter(body, i);
         if (c == ' ' || c == '\t' || c == '\r' || c == '\n') { i++; continue; }
         break;
      }
      if (i < n) {
         ushort first = StringGetCharacter(body, i);
         if (first == '"') {
            int s = i + 1;
            int e = StringFind(body, "\"", s);
            if (e < 0) e = n;
            return StringSubstr(body, s, e - s);
         }
         if (first == '{' || first == '[') {
            // Caller wants a string — return the inner substring up
            // to matching delimiter (depth-1 only, no escapes).
            int depth = 1;
            int s = i + 1;
            int j = i + 1;
            ushort openC  = first;
            ushort closeC = (first == '{' ? '}' : ']');
            while (j < n && depth > 0) {
               ushort cc = StringGetCharacter(body, j);
               if (cc == openC)  depth++;
               else if (cc == closeC) depth--;
               j++;
            }
            return StringSubstr(body, s, (j - 1) - s);
         }
         // Bare number / bool / null — read until , or } or ]
         int s = i;
         int j = i;
         while (j < n) {
            ushort cc = StringGetCharacter(body, j);
            if (cc == ',' || cc == '}' || cc == ']' ||
                cc == ' ' || cc == '\t' || cc == '\r' || cc == '\n') break;
            j++;
         }
         return StringSubstr(body, s, j - s);
      }
   }

   // ── Path B: legacy pipe ─────────────────────────────────────
   string sep_needle = "|" + key + "=";
   p = StringFind(body, sep_needle);
   int valStart;
   if (p < 0) {
      string head_needle = key + "=";
      if (StringFind(body, head_needle) != 0) return "";
      valStart = StringLen(head_needle);
   } else {
      valStart = p + StringLen(sep_needle);
   }
   int valEnd = StringFind(body, "|", valStart);
   if (valEnd < 0) valEnd = StringLen(body);
   return StringSubstr(body, valStart, valEnd - valStart);
}

double Msg_GetDouble(string body, string key, double dflt) {
   string v = Msg_GetField(body, key);
   if (StringLen(v) == 0) return dflt;
   if (v == "true")  return 1.0;
   if (v == "false" || v == "null") return 0.0;
   return StringToDouble(v);
}

int Msg_GetInt(string body, string key, int dflt) {
   string v = Msg_GetField(body, key);
   if (StringLen(v) == 0) return dflt;
   if (v == "true")  return 1;
   if (v == "false" || v == "null") return 0;
   return (int)StringToInteger(v);
}

// Extract a nested JSON object as raw substring (e.g. "of_context").
// Returns "" if the key is missing or the value is not an object.
string Msg_GetObject(string body, string key) {
   string s = Msg_GetField(body, key);
   // Msg_GetField already returns the inner-substring of `{...}`
   // (without braces). We add them back so callers can keep parsing
   // it with Msg_GetField recursively.
   if (StringLen(s) == 0) return "";
   return "{" + s + "}";
}

// --- Ownership registry (R7) -----------------------------------
int Ownership_FindByTicket(int ticket) {
   for (int i = 0; i < g_ownershipCount; i++) {
      if (g_orderOwnership[i].ticket == ticket) return i;
   }
   return -1;
}

int Ownership_Add(int ticket, int magic, string owner, string source,
                  int ocoPeer, string correlation) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx >= 0) {
      g_orderOwnership[idx].magic         = magic;
      g_orderOwnership[idx].owner         = owner;
      g_orderOwnership[idx].source        = source;
      g_orderOwnership[idx].ocoPeerTicket = ocoPeer;
      g_orderOwnership[idx].correlation   = correlation;
      return idx;
   }
   if (g_ownershipCount >= OWNERSHIP_MAX) return -1;
   idx                                    = g_ownershipCount;
   g_orderOwnership[idx].ticket           = ticket;
   g_orderOwnership[idx].magic            = magic;
   g_orderOwnership[idx].owner            = owner;
   g_orderOwnership[idx].source           = source;
   g_orderOwnership[idx].ocoPeerTicket    = ocoPeer;
   g_orderOwnership[idx].correlation      = correlation;
   g_orderOwnership[idx].opened_at        = TimeCurrent();
   g_ownershipCount++;
   return idx;
}

bool Ownership_Remove(int ticket) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx < 0) return false;
   for (int i = idx; i < g_ownershipCount - 1; i++) {
      g_orderOwnership[i] = g_orderOwnership[i + 1];
   }
   g_ownershipCount--;
   return true;
}

string Ownership_GetOwner(int ticket) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx < 0) return "";
   return g_orderOwnership[idx].owner;
}

bool Ownership_IsHubManaged(int ticket) {
   int idx = Ownership_FindByTicket(ticket);
   if (idx < 0) return false;
   return (g_orderOwnership[idx].source == "hub_command");
}

// --- ZMQ transport core ----------------------------------------
bool ZMQ_ClaimMaster() {
   long myChart = ChartID();
   if (!GlobalVariableCheck(GV_ZMQ_MASTER_CHART)) {
      GlobalVariableSet(GV_ZMQ_MASTER_CHART, (double)myChart);
      return true;
   }
   long owner = (long)GlobalVariableGet(GV_ZMQ_MASTER_CHART);
   if (owner == myChart) return true;
   // Previous owner chart removed — take over.
   if (owner <= 0 || ChartSymbol((int)owner) == "") {
      GlobalVariableSet(GV_ZMQ_MASTER_CHART, (double)myChart);
      return true;
   }
   // Stale lock: owner chart alive but no hub heartbeat — reclaim so a
   // visible chart can own ZMQ after Hub restart or a stuck master.
   datetime hbTs = 0;
   if (GlobalVariableCheck(GV_HUB_LAST_HB))
      hbTs = (datetime)GlobalVariableGet(GV_HUB_LAST_HB);
   if (hbTs == 0 || (TimeCurrent() - hbTs) > ZMQ_HEARTBEAT_TIMEOUT_S) {
      GlobalVariableSet(GV_ZMQ_MASTER_CHART, (double)myChart);
      return true;
   }
   return false;
}

void ZMQ_ReleaseMaster() {
   long myChart = ChartID();
   if (GlobalVariableCheck(GV_ZMQ_MASTER_CHART) &&
       (long)GlobalVariableGet(GV_ZMQ_MASTER_CHART) == myChart) {
      GlobalVariableDel(GV_ZMQ_MASTER_CHART);
   }
}

bool ZMQ_Init() {
   if (g_zmq_initialized) return true;
   if (!ZMQ_ClaimMaster()) {
      g_zmq_is_master = false;
      Print("[ZMQ] secondary chart — bridge sockets skipped (use one chart for Hub UI)");
      return false;
   }
   g_zmq_is_master = true;
   g_zmq_req.setLinger(ZMQ_LINGER_MS);
   g_zmq_req.setSendTimeout(ZMQ_REQ_TIMEOUT_MS);
   g_zmq_req.setReceiveTimeout(ZMQ_REQ_TIMEOUT_MS);
   // ZMQ_REQ_RELAXED + ZMQ_REQ_CORRELATE rendono la state machine
   // REQ tollerante ai timeout: dopo un recv mancato il prossimo
   // send è permesso (senza queste opzioni REQ si "blocca" per
   // sempre in stato waiting-for-reply al primo timeout). CORRELATE
   // marca ogni request con un id interno per scartare reply tardive.
   g_zmq_req.setRequestRelaxed(true);
   g_zmq_req.setRequestCorrelated(true);
   if (!g_zmq_req.connect(ZMQ_REQ_ENDPOINT)) {
      Print("[ZMQ] REQ connect failed: ", ZMQ_REQ_ENDPOINT);
      return false;
   }
   g_zmq_sub.setLinger(ZMQ_LINGER_MS);
   g_zmq_sub.setReceiveHighWaterMark(10000);
   if (!g_zmq_sub.connect(ZMQ_SUB_ENDPOINT)) {
      Print("[ZMQ] SUB connect failed: ", ZMQ_SUB_ENDPOINT);
      g_zmq_req.disconnect(ZMQ_REQ_ENDPOINT);
      return false;
   }
   g_zmq_sub.subscribe(ZMQ_TOPIC_HEARTBEAT);
   g_zmq_sub.subscribe(ZMQ_TOPIC_COMMAND);
   g_zmq_sub.subscribe(ZMQ_TOPIC_NEWS);
   g_zmq_sub.subscribe(ZMQ_TOPIC_BOOKMAP);
   g_zmq_sub.subscribe(ZMQ_TOPIC_DECISION);
   g_zmq_push.setLinger(ZMQ_LINGER_MS);
   g_zmq_push.setSendHighWaterMark(10000);
   if (!g_zmq_push.connect(ZMQ_PUSH_ENDPOINT)) {
      Print("[ZMQ] PUSH connect failed: ", ZMQ_PUSH_ENDPOINT);
      g_zmq_req.disconnect(ZMQ_REQ_ENDPOINT);
      g_zmq_sub.disconnect(ZMQ_SUB_ENDPOINT);
      return false;
   }
   g_zmq_initialized  = true;
   g_ai_lastHeartbeat = 0;
   PrintFormat("[ZMQ] connected | REQ=%s SUB=%s PUSH=%s",
               ZMQ_REQ_ENDPOINT, ZMQ_SUB_ENDPOINT, ZMQ_PUSH_ENDPOINT);
   return true;
}

void ZMQ_Shutdown() {
   if (!g_zmq_initialized) {
      if (g_zmq_is_master) ZMQ_ReleaseMaster();
      g_zmq_is_master = false;
      return;
   }
   g_zmq_req.disconnect(ZMQ_REQ_ENDPOINT);
   g_zmq_sub.disconnect(ZMQ_SUB_ENDPOINT);
   g_zmq_push.disconnect(ZMQ_PUSH_ENDPOINT);
   g_zmq_initialized = false;
   ZMQ_ReleaseMaster();
   g_zmq_is_master = false;
   Print("[ZMQ] sockets disconnected");
}

bool ZMQ_SendRequest(string payload, string &reply) {
   reply = "";
   if (!g_zmq_initialized) return false;
   ZmqMsg out_msg(payload);
   static int      s_dbg_callCnt    = 0;
   static int      s_dbg_lastLogErr = 0;
   static datetime s_dbg_lastLogTs  = 0;       // ITER 32 — rate limit
   s_dbg_callCnt++;
   if (s_dbg_callCnt == 1)
      PrintFormat("[DBG] ZMQ_SendRequest FIRST call: payload_size=%d", StringLen(payload));
   if (!g_zmq_req.send(out_msg)) {
      g_ai_errorCount++;
      g_ai_status = "ZMQ_REQ_SEND_FAIL";
      // ITER 32 — rate-limited log: at most once / 30s, regardless of err count.
      datetime _nowTs = TimeCurrent();
      if (s_dbg_callCnt == 1 ||
          ((_nowTs - s_dbg_lastLogTs) >= 30 &&
           (g_ai_errorCount - s_dbg_lastLogErr) >= 10)) {
         s_dbg_lastLogErr = g_ai_errorCount;
         s_dbg_lastLogTs  = _nowTs;
         PrintFormat("[DBG] ZMQ_SendRequest SEND FAIL (call#%d err#%d)", s_dbg_callCnt, g_ai_errorCount);
      }
      return false;
   }
   ZmqMsg in_msg;
   if (!g_zmq_req.recv(in_msg)) {
      g_ai_errorCount++;
      g_ai_status = "ZMQ_REQ_TIMEOUT";
      // ITER 32 — rate-limited timeout log so a hub silence storm cannot
      //   spam the journal and confuse the operator. Owner engine is
      //   already neutral on timeout (Bridge_GetAISignals returns false →
      //   strategies skip AI penalty → no quality downgrade), this just
      //   keeps the noise floor manageable.
      datetime _nowTs = TimeCurrent();
      if (s_dbg_callCnt == 1 ||
          ((_nowTs - s_dbg_lastLogTs) >= 30 &&
           (g_ai_errorCount - s_dbg_lastLogErr) >= 10)) {
         s_dbg_lastLogErr = g_ai_errorCount;
         s_dbg_lastLogTs  = _nowTs;
         PrintFormat("[DBG] ZMQ_SendRequest RECV TIMEOUT (call#%d err#%d) — hub non risponde entro %dms — owner engine NEUTRAL fallback",
                     s_dbg_callCnt, g_ai_errorCount, ZMQ_REQ_TIMEOUT_MS);
      }
      return false;
   }
   reply             = in_msg.getData();
   g_ai_lastResponse = TimeCurrent();
   g_ai_successCount++;
   if (g_ai_successCount == 1 || (g_ai_successCount % 20) == 0)
      PrintFormat("[DBG] ZMQ_SendRequest OK #%d reply_size=%d", g_ai_successCount, StringLen(reply));
   return true;
}

bool ZMQ_PushContext(string payload) {
   if (!g_zmq_initialized) return false;
   uint nowMs = GetTickCount();
   if (g_zmq_lastPushMs > 0 &&
       (nowMs - g_zmq_lastPushMs) < ZMQ_PUSH_THROTTLE_MS) {
      return true;  // coalesced — drop within window, R3
   }
   g_zmq_lastPushMs = nowMs;
   ZmqMsg msg(payload);
   bool ok = g_zmq_push.send(msg, true);  // non-blocking
   if (!ok) {
      g_zmq_lastPushMs = 0;
      static datetime s_pushFailLog = 0;
      if (TimeCurrent() - s_pushFailLog >= 15) {
         s_pushFailLog = TimeCurrent();
         PrintFormat("[ZMQ] PUSH send failed err=%d payload_len=%d",
                     GetLastError(), StringLen(payload));
      }
   }
   // Heartbeat GV is updated only from AI_HandleHeartbeat (real PUB), not
   // from a successful PUSH — otherwise the panel shows CONNECTED while
   // SUB/news are stale and the Hub never receives context_push.
   return ok;
}

int ZMQ_DrainSubscriber() {
   if (!g_zmq_initialized) return 0;
   int processed = 0;
   for (int i = 0; i < ZMQ_SUB_DRAIN_MAX; i++) {
      ZmqMsg topic_msg;
      if (!g_zmq_sub.recv(topic_msg, true)) break;
      string topic = topic_msg.getData();
      string body  = "";
      // mql-zmq exposes the multipart-flag as ZmqMsg.more() (per-message)
      // which mirrors libzmq's zmq_msg_more().  hasMore() doesn't exist.
      if (topic_msg.more()) {
         ZmqMsg body_msg;
         if (g_zmq_sub.recv(body_msg, true)) body = body_msg.getData();
      }
      if (StringFind(topic, ZMQ_TOPIC_HEARTBEAT) == 0)      AI_HandleHeartbeat(body);
      else if (StringFind(topic, ZMQ_TOPIC_COMMAND)   == 0) AI_HandleCommand(body);
      else if (StringFind(topic, ZMQ_TOPIC_NEWS)      == 0) AI_HandleNews(body);
      else if (StringFind(topic, ZMQ_TOPIC_BOOKMAP)   == 0) AI_HandleBookmap(body);
      else if (StringFind(topic, ZMQ_TOPIC_DECISION)  == 0) AI_HandleDecision(body);
      processed++;
   }
   return processed;
}

// --- SUB topic handlers (R4, R6) -------------------------------
void AI_HandleHeartbeat(string body) {
   bool firstHb     = (g_ai_lastHeartbeat == 0);
   bool hubWasStale = (g_ai_lastHeartbeat > 0 &&
                       (TimeCurrent() - g_ai_lastHeartbeat) > ZMQ_HEARTBEAT_TIMEOUT_S);
   g_ai_lastHeartbeat = TimeCurrent();
   OBL_SyncHubHeartbeatGV();
   g_ai_connected     = true;
   g_BridgeConnected  = true;
   g_ai_status        = "ACTIVE";
   // Hub restart: re-connect PUSH only after prolonged silence (not every
   // first heartbeat) — disconnect/connect per tick leaked TCP sockets.
   static datetime s_lastPushReconnect = 0;
   if (g_zmq_initialized && hubWasStale &&
       (TimeCurrent() - s_lastPushReconnect) >= 30) {
      g_zmq_push.disconnect(ZMQ_PUSH_ENDPOINT);
      g_zmq_push.connect(ZMQ_PUSH_ENDPOINT);
      s_lastPushReconnect = TimeCurrent();
   }
   // Feed Hub ACCOUNT MATRIX / PERFORMANCE METRICS (every ~2s with hub heartbeat).
   static datetime s_lastHubCtxPush = 0;
   if (TimeCurrent() - s_lastHubCtxPush >= 2) {
      AIBridge_SendMarketData(Symbol());
      s_lastHubCtxPush = TimeCurrent();
   }
   string dir = Msg_GetField(body, "ai_dir");
   if (StringLen(dir) > 0) {
      if (dir == "BUY")       g_ai_direction = 1;
      else if (dir == "SELL") g_ai_direction = -1;
      else                    g_ai_direction = 0;
   }
   double conf = Msg_GetDouble(body, "ai_conf", -1.0);
   if (conf >= 0.0) g_ai_confidence = conf;
   string sig = Msg_GetField(body, "ai_signal");
   if (StringLen(sig) > 0) g_ai_lastSignal = sig;
   // News panel lines piggyback on heartbeat (every ~2s) — reliable even if
   // the dedicated oblivious.news frame was missed (PUB slow-joiner).
   AI_ApplyNewsPanelFromBody(body);
}

// R6: news state from hub becomes a HINT for the local NewsPolicy,
//     not a parallel block layer.  We update the news cache only;
//     NewsPolicy_CanOpen() remains the single gate.
void OBL_ParseNewsPanelPack(string pack) {
   string l0, l1, l2;
   OBL_SplitNewsPack(pack, l0, l1, l2);
   AI_ApplyNewsPanelLines(l0, l1, l2);
}

void AI_ApplyNewsPanelLines(string l0, string l1, string l2) {
   int filled = 0;
   if (StringLen(l0) > 0) filled++;
   if (StringLen(l1) > 0) filled++;
   if (StringLen(l2) > 0) filled++;
   if (filled == 0) return;

   // Full snapshot from hub (3 headlines, newest first).
   if (filled >= 3) {
      OBL_ApplyNewsPanelLines(l0, l1, l2);
      return;
   }
   if (filled == 2 && StringLen(l0) > 0 && StringLen(l1) > 0) {
      string keep = g_dynNews[2];
      if (keep == l0 || keep == l1) keep = "";
      OBL_ApplyNewsPanelLines(l0, l1, keep);
      return;
   }
   // Single fresh headline — roll stack (new on top, drop oldest).
   if (StringLen(l0) > 0 && l0 != g_dynNews[0])
      DynPanel_PushNews(l0);
   else if (StringLen(l1) > 0 && l1 != g_dynNews[0])
      DynPanel_PushNews(l1);
   else if (StringLen(l2) > 0 && l2 != g_dynNews[0])
      DynPanel_PushNews(l2);
}

void AI_ApplyNewsPanelFromBody(string body) {
   string l0 = "", l1 = "", l2 = "";
   string pack = Msg_GetField(body, "panel_pack");
   if (StringLen(pack) > 0)
      OBL_SplitNewsPack(pack, l0, l1, l2);
   else {
      l0 = Msg_GetField(body, "panel_line0");
      l1 = Msg_GetField(body, "panel_line1");
      l2 = Msg_GetField(body, "panel_line2");
   }
   if (StringLen(l0) > 0 || StringLen(l1) > 0 || StringLen(l2) > 0) {
      g_news_lastUpdate = TimeCurrent();
      AI_ApplyNewsPanelLines(l0, l1, l2);
   }
}

void AI_HandleNews(string body) {
   g_ai_lastNewsCacheJson = body;
   g_ai_lastNewsCacheTs   = TimeCurrent();
   int    block   = Msg_GetInt(body, "block", 0);
   int    impact  = Msg_GetInt(body, "impact", 0);
   string nextEv  = Msg_GetField(body, "next_event");
   int    untilTs = Msg_GetInt(body, "until_ts", 0);
   g_news_blockTrading   = (block != 0);
   g_news_currentImpact  = impact;
   g_news_highImpactNow  = (impact >= 3);
   if (StringLen(nextEv) > 0) g_news_nextEvent = nextEv;
   if (untilTs > 0) g_news_nextEventTime = (datetime)untilTs;
   g_news_lastUpdate = TimeCurrent();
   AI_ApplyNewsPanelFromBody(body);
   DynPanel_UpdateNewsRows();
}

// Fast-path orderflow stream on topic `oblivious.decision`. Compact
// frame: {symbol, of_bias, of_confidence, of_signal}. Updates the
// g_of_* cache so SOFT helpers reflect the latest orderflow view
// without waiting for the next heavy `bookmap` snapshot or `ai_query`
// roundtrip. `of_bias` here is a string ("bullish"/"bearish"/"neutral")
// that we map to the same [-1.0 .. +1.0] scale used elsewhere.
void AI_HandleDecision(string body) {
   string frameSym = Msg_GetField(body, "symbol");
   if (StringLen(frameSym) > 0 && frameSym != Symbol()) return;
   string biasStr = Msg_GetField(body, "of_bias");
   string sig     = Msg_GetField(body, "of_signal");
   double conf    = Msg_GetDouble(body, "of_confidence", 0.0);
   double bias    = 0.0;
   if (biasStr == "bullish" || biasStr == "BULLISH" || biasStr == "bull") bias =  1.0;
   else if (biasStr == "bearish" || biasStr == "BEARISH" || biasStr == "bear") bias = -1.0;
   g_of_lastTs     = TimeCurrent();
   OBL_SyncOrderflowGV();
   g_of_symbol     = (StringLen(frameSym) > 0 ? frameSym : Symbol());
   g_of_bias       = bias;
   g_of_confidence = conf / 100.0;  // normalize 0..1
   if (StringLen(sig) > 0) g_of_signal = sig;
   g_of_fresh      = true;
   DynPanel_UpdateBridgeStatus();

   // FASE 11 - EXE trigger marker: disegna freccia OF sul grafico
   // OGNI volta che arriva una decisione orderflow esterna. Cosi'
   // l'utente vede chiaramente che il trigger NON e' nativo mq4 ma
   // viene dal bridge EXE/Bookmap. Le frecce si auto-puliscono
   // dopo 200 candele per evitare clutter.
   // ITER42 — chart arrows DISABLED (user contract: no arrows on MT4 chart).
   //   The Bookmap/OF trigger info still flows through Smart Log and panel,
   //   just no longer draws an OBJ_ARROW on the chart.
   if (false /* ITER42 OF arrow draw disabled */
       && StringLen(sig) > 0 && sig != "NONE" && bias != 0.0) {
      string aname = StringFormat("OBL_OF_%d", (int)TimeCurrent());
      datetime  t  = Time[0];
      double    px = (bias > 0 ? Bid : Ask);
      int       code = (bias > 0 ? 233 : 234);   // up/down arrow
      color     clr  = (bias > 0 ? clrLime : clrTomato);
      if (ObjectCreate(0, aname, OBJ_ARROW, 0, t, px)) {
         ObjectSetInteger(0, aname, OBJPROP_ARROWCODE, code);
         ObjectSetInteger(0, aname, OBJPROP_COLOR, clr);
         ObjectSetInteger(0, aname, OBJPROP_WIDTH, 2);
         ObjectSetInteger(0, aname, OBJPROP_BACK, false);
         ObjectSetString (0, aname, OBJPROP_TEXT,
                          StringFormat("OF %s %.0f%%", sig, conf));
      }
      // garbage-collect arrow OF piu' vecchi di 200 candele
      datetime cutoff = Time[0] - 200 * PeriodSeconds();
      for (int i = ObjectsTotal(0, -1, OBJ_ARROW) - 1; i >= 0; i--) {
         string nm = ObjectName(0, i, -1, OBJ_ARROW);
         if (StringFind(nm, "OBL_OF_") != 0) continue;
         if ((datetime)ObjectGetInteger(0, nm, OBJPROP_TIME) < cutoff)
            ObjectDelete(0, nm);
      }
   }
}

void AI_HandleBookmap(string body) {
   g_ai_lastBookmapJson = body;
   g_ai_lastBookmapTs   = TimeCurrent();

   // The hub publishes a per-symbol orderflow decision frame on
   // topic `oblivious.bookmap` (and a richer one on
   // `oblivious.decision`). The frame may carry a "decisions" map
   // ({sym:{...}}) or a flat decision object. We support both.
   //
   // Strategy: figure out which symbol-keyed block (if any) covers
   // Symbol(); if missing, parse top-level fields directly. We only
   // overwrite the cache when the frame is actually about us, so a
   // multi-chart EA stays clean.
   string targetSym = Symbol();
   string scope = body;

   string decisionsBlock = Msg_GetObject(body, "decisions");
   if (StringLen(decisionsBlock) > 4) {
      string mySymBlock = Msg_GetObject(decisionsBlock, targetSym);
      if (StringLen(mySymBlock) > 4) scope = mySymBlock;
   }
   // Some frames embed the data under "decision":{...}.
   string decisionObj = Msg_GetObject(scope, "decision");
   if (StringLen(decisionObj) > 4) scope = decisionObj;

   // ── Freshness / sequence / symbol-match guard ──────────────
   // Reject:
   //   - frames with an explicit `symbol` that doesn't match us,
   //   - replayed frames whose `sequence` is <= the cached one
   //     (PUB/SUB does NOT guarantee ordering nor exclude dupes,
   //      so this is the safety net),
   //   - stale frames whose hub `last_update_ts` is older than
   //     our currently-cached one.
   string frameSym = Msg_GetField(scope, "symbol");
   bool   symMatch = (StringLen(frameSym) == 0 || frameSym == targetSym);
   g_of_symbol_match = symMatch;
   if (!symMatch) return;  // frame for another symbol — ignore

   int  seqIn   = Msg_GetInt   (scope, "sequence",       0);
   long tsHubIn = (long)Msg_GetDouble(scope, "last_update_ts", 0);
   if (tsHubIn <= 0) tsHubIn = (long)Msg_GetDouble(scope, "ts", 0);

   // Drop frames that are older than what we already have. We only
   // enforce monotonic sequence when the publisher actually emits
   // it (sequence > 0); otherwise we fall back to the timestamp.
   if (seqIn > 0 && g_of_sequence > 0 && seqIn <= g_of_sequence) return;
   if (seqIn == 0 && tsHubIn > 0 && g_of_last_update_ts > 0 &&
       tsHubIn <= g_of_last_update_ts) return;

   g_of_symbol           = (StringLen(frameSym) > 0 ? frameSym : targetSym);
   g_of_lastTs           = TimeCurrent();
   OBL_SyncOrderflowGV();
   if (seqIn   > 0) g_of_sequence       = seqIn;
   if (tsHubIn > 0) g_of_last_update_ts = tsHubIn;
   string freshTok = Msg_GetField(scope, "fresh");
   g_of_fresh = (freshTok == "true" || freshTok == "1");
   g_of_bias             = Msg_GetDouble(scope, "of_bias",             0.0);
   g_of_confidence       = Msg_GetDouble(scope, "of_confidence",       0.0);
   string sig            = Msg_GetField (scope, "of_signal");
   if (StringLen(sig) > 0) g_of_signal = sig;
   g_of_imbalance        = Msg_GetDouble(scope, "of_imbalance",        0.0);
   g_of_dom_pressure     = Msg_GetDouble(scope, "of_dom_pressure",     0.0);
   g_of_delta_shift      = Msg_GetDouble(scope, "of_delta_shift",      0.0);
   g_of_delta_divergence = Msg_GetDouble(scope, "of_delta_divergence", 0.0);
   g_of_absorption       = Msg_GetDouble(scope, "of_absorption",       0.0);
   g_of_exhaustion       = Msg_GetDouble(scope, "of_exhaustion",       0.0);
   g_of_iceberg_side     = Msg_GetInt   (scope, "of_iceberg_side",     0);
   g_of_iceberg_strength = Msg_GetDouble(scope, "of_iceberg_strength", 0.0);
   g_of_stop_activity    = Msg_GetDouble(scope, "of_stop_activity",    0.0);
   g_of_sweep_signal     = Msg_GetInt   (scope, "of_sweep_signal",     0);
   g_of_trap_signal      = Msg_GetInt   (scope, "of_trap_signal",      0);
   g_of_hold_continue    = Msg_GetDouble(scope, "of_hold_continue",    0.0);
   g_of_cancel_signal    = Msg_GetDouble(scope, "of_cancel_signal",    0.0);
   // Hub-derived danger metric (may not be present in legacy frames):
   double dangerDflt = MathMin(1.0, 0.45 * g_of_exhaustion + 0.55 * g_of_cancel_signal);
   g_of_execution_danger = Msg_GetDouble(scope, "of_execution_danger", dangerDflt);
   DynPanel_UpdateBridgeStatus();
}

// ── Command bus dedup ring (R7) ────────────────────────────────
// The hub may publish the same command twice on PUB/SUB transient
// reconnects. We keep a small ring buffer of recently-seen
// command_ids and drop duplicates instead of re-executing them.
#define CMD_DEDUP_SIZE 64
string   g_cmd_ring[CMD_DEDUP_SIZE];
int      g_cmd_ring_head = 0;
bool Cmd_AlreadySeen(string commandId) {
   if (StringLen(commandId) == 0) return false;  // empty ids cannot be deduped
   for (int i = 0; i < CMD_DEDUP_SIZE; i++) {
      if (g_cmd_ring[i] == commandId) return true;
   }
   g_cmd_ring[g_cmd_ring_head] = commandId;
   g_cmd_ring_head = (g_cmd_ring_head + 1) % CMD_DEDUP_SIZE;
   return false;
}

void AI_HandleCommand(string body) {
   // ── Envelope-level guards (R7) ──────────────────────────────
   //   1. command_id dedup (drops PUB redeliveries)
   //   2. wrong-symbol drop (multi-chart safety)
   //   3. expiry_ts honor (the hub may flag a stale command as
   //      "do not act on it after this wallclock") — skip silently
   string commandId    = Msg_GetField(body, "command_id");
   string envSym       = Msg_GetField(body, "symbol");
   long   expiryTs     = (long)Msg_GetDouble(body, "expiry_ts", 0);

   if (Cmd_AlreadySeen(commandId)) return;
   if (StringLen(envSym) > 0 && envSym != Symbol()) {
      // Allow per-symbol commands targeted at OTHER charts to pass
      // through silently. (Multi-chart EAs share the SUB topic.)
      return;
   }
   if (expiryTs > 0 && expiryTs < (long)TimeCurrent() * 1000) {
      PrintFormat("[Hub Cmd] dropped expired command_id=%s expiry_ts=%I64d",
                  commandId, expiryTs);
      return;
   }

   // ── Verb routing ────────────────────────────────────────────
   // The new spec uses `decision` (EXECUTE_ORDER/HOLD/CANCEL/...)
   // at the envelope level. We also accept legacy `op` for back
   // compat with older publishers.
   string verb = Msg_GetField(body, "decision");
   if (StringLen(verb) == 0) verb = Msg_GetField(body, "op");

   // ── R8: full verb table (legacy + explicit + mobile-friendly) ──
   //   EXECUTE_ORDER  → opens market/limit/stop (HARD GATES + Risk_Preflight)
   //   HOLD           → per-owner hold ON (envelope `owner`/`strategy_name`,
   //                    if missing fallback to HOLD_GLOBAL for safety)
   //   CANCEL         → legacy dispatcher: pending → CANCEL_PENDING,
   //                    market → CLOSE_POSITION (back-compat path)
   //   CANCEL_PENDING → cancel ONLY pending tickets (errors on market)
   //   CLOSE_POSITION → close ONLY market tickets (errors on pending)
   //   HOLD_GLOBAL    → freeze ALL new openings (no auto-close)
   //   RESUME_GLOBAL  → lift global hold + every per-owner hold
   //   INVALIDATE     → mark setup invalid + cancel pending if ticket given
   //   REFINE_TPSL    → adjust SL/TP{1..max} on a live ticket
   //   CLOSE_ALL_BY_OWNER          → bulk close (market) per owner
   //   CANCEL_ALL_PENDING_BY_OWNER → bulk cancel pendings per owner
   if      (verb == "EXECUTE_ORDER")               Cmd_HandleExecute(body);
   else if (verb == "HOLD")                        Cmd_HandleHold(body);
   else if (verb == "HOLD_GLOBAL")                 Cmd_HandleHoldGlobal(body);
   else if (verb == "RESUME_GLOBAL" ||
            verb == "RESUME")                      Cmd_HandleResumeGlobal(body);
   else if (verb == "CANCEL")                      Cmd_HandleCancel(body);
   else if (verb == "CANCEL_PENDING")              Cmd_HandleCancelPending(body);
   else if (verb == "CLOSE_POSITION")              Cmd_HandleClosePosition(body);
   else if (verb == "CLOSE_ALL_BY_OWNER")          Cmd_HandleCloseAllByOwner(body);
   else if (verb == "CANCEL_ALL_PENDING_BY_OWNER") Cmd_HandleCancelAllPendingByOwner(body);
   else if (verb == "INVALIDATE")                  Cmd_HandleInvalidate(body);
   else if (verb == "REFINE_TPSL")                 Cmd_HandleRefineTPSL(body);
   else PrintFormat("[Hub Cmd] unknown decision=%s body=%s", verb, body);
}

// --- Hub command handlers (R7) ---------------------------------
// All handlers preserve owner strategy / magic / comment / TP ladder
// / OCO Predicted / pending cancel / invalidation state through the
// ownership registry. Lots routed via Risk_Preflight (Phase 4).
void Cmd_HandleExecute(string body) {
   // The new spec puts the actual order parameters under
   // `payload`:{...}. We accept both layouts (envelope-flat for
   // legacy callers, nested for the new bus) by extracting the
   // payload object and reading from it first, with envelope-level
   // fallback. Direction is `direction:1|-1` in the new spec, or
   // `side:"BUY"|"SELL"` in the legacy spec.
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);

   string sym       = Msg_GetField(body,  "symbol");      // envelope
   if (StringLen(sym) == 0) sym = Msg_GetField(body, "sym");
   string ownerEnv  = Msg_GetField(body,  "strategy_name");
   if (StringLen(ownerEnv) == 0) ownerEnv = Msg_GetField(body, "owner");
   string corr      = Msg_GetField(body,  "correlation_id");
   if (StringLen(corr) == 0) corr = Msg_GetField(body, "corr");
   string commandId = Msg_GetField(body,  "command_id");

   int    direction = Msg_GetInt   (scope, "direction", 0);
   string side      = Msg_GetField (scope, "side");
   if (StringLen(side) == 0) {
      if      (direction ==  1) side = "BUY";
      else if (direction == -1) side = "SELL";
   }
   string entryType = Msg_GetField (scope, "entry_type");
   if (StringLen(entryType) == 0) entryType = Msg_GetField(scope, "ord_type");
   string ordType   = StringLen(entryType) > 0 ? entryType : "MARKET";
   StringToUpper(ordType);

   double price       = Msg_GetDouble(scope, "entry_price", 0.0);
   if (price <= 0.0) price = Msg_GetDouble(scope, "price", 0.0);
   double tp1         = Msg_GetDouble(scope, "tp1",      0.0);
   double tp2         = Msg_GetDouble(scope, "tp2",      0.0);
   double tp3         = Msg_GetDouble(scope, "tp3",      0.0);
   double tpMax       = Msg_GetDouble(scope, "tpmax",    0.0);
   if (tpMax <= 0.0)   tpMax = Msg_GetDouble(scope, "tp_max", 0.0);
   double sl          = Msg_GetDouble(scope, "sl",       0.0);
   double slPips      = Msg_GetDouble(scope, "sl_pips",  0.0);
   double riskPct     = Msg_GetDouble(scope, "risk_pct", 0.0);
   double explicitLot = Msg_GetDouble(scope, "lot",      0.0);
   string comment     = Msg_GetField (scope, "comment");
   if (StringLen(comment) == 0) comment = StringFormat("hub:%s", commandId);
   int    magic       = Msg_GetInt   (scope, "magic",    0);
   if (magic == 0)    magic = Strategy_NameToMagic(ownerEnv);
   int    ocoPeer     = Msg_GetInt   (scope, "oco_peer", 0);
   if (ocoPeer == 0)  ocoPeer = (int)Msg_GetDouble(scope, "oco_peer", 0.0);

   string owner = ownerEnv;
   if (StringLen(sym) == 0) sym = Symbol();

   // ── HARD GATES (the EA always has the final word) ──────────
   // The hub may propose a trade, but the local EA enforces every
   // hard rule independently — license, schedule, session, news,
   // spread, daily-DD, margin. The hub CAN suggest entries; it
   // CANNOT bypass these checks.
   string hg_reason = "";
   // R8: hold layers are evaluated FIRST so an operator can
   // freeze the EA without waiting for a news/DD gate to align.
   if      (Hub_HoldGlobal_IsActive())          hg_reason = "hold_global";
   else if (StringLen(owner) > 0 &&
            Hub_HoldOwner_IsActive(owner))      hg_reason = "hold_owner";
   else if (IsMaxTotalDDExceeded())             hg_reason = "max_total_dd";
   else if (DailyStopOpenGate())                hg_reason = "daily_stop";
   else if (!IsMarginLevelSufficient(50))       hg_reason = "low_margin";
   else if (!IsSessionValid())                  hg_reason = "session_closed";
   else if (!MarketFiltersActive())             hg_reason = "market_filter";
   else if (StringLen(owner) > 0 &&
            !NewsPolicy_CanOpen(owner))         hg_reason = "news_block";
   else if (g_news_blockTrading &&
            owner != "Predicted")               hg_reason = "high_impact_news";
   if (StringLen(hg_reason) > 0) {
      PrintFormat("[Hub Cmd] EXECUTE blocked by EA hard-gate sym=%s owner=%s reason=%s",
                  sym, owner, hg_reason);
      return;
   }

   // R5: every hub-driven order routes through Risk_Preflight, the
   // single point that clamps to MaxRiskTradePercent + broker step
   // + Grid basket budget + EA gates. Lot precedence:
   //   explicit hub `lot` > local `ManualLot` > computed from risk%.
   double desired;
   if      (explicitLot > 0)   desired = explicitLot;
   else if (ManualLot   > 0)   desired = ManualLot;
   else                        desired = RiskEngine_ComputeLots(sym, riskPct, slPips);
   string risk_reason;
   int    side_dir = (side == "BUY") ? 1 : -1;
   double lots = Risk_Preflight(sym, owner, desired, slPips, side_dir, risk_reason);
   if (lots <= 0.0) {
      PrintFormat("[Hub Cmd] EXECUTE blocked sym=%s owner=%s reason=%s",
                  sym, owner, risk_reason);
      return;
   }
   int cmd;
   if (ordType == "MARKET") {
      cmd = (side == "BUY") ? OP_BUY : OP_SELL;
      double execPrice = (cmd == OP_BUY) ? MarketInfo(sym, MODE_ASK)
                                         : MarketInfo(sym, MODE_BID);
      int ticket = SafeOrderSend(sym, cmd, lots, execPrice, 10, sl,
                             (tp1 > 0 ? tp1 : tpMax), comment, magic, 0, clrNONE);
      if (ticket > 0) {
         Ownership_Add(ticket, magic, owner, "hub_command", ocoPeer, corr);
         PrintFormat("[Hub Cmd] EXECUTE %s %s lots=%.2f ticket=%d owner=%s",
                     side, sym, lots, ticket, owner);
      } else {
         PrintFormat("[Hub Cmd] EXECUTE failed err=%d owner=%s", GetLastError(), owner);
      }
      return;
   }
   if (ordType == "LIMIT" || ordType == "STOP") {
      if (ordType == "LIMIT") cmd = (side == "BUY") ? OP_BUYLIMIT : OP_SELLLIMIT;
      else                    cmd = (side == "BUY") ? OP_BUYSTOP  : OP_SELLSTOP;
      int ticket = SafeOrderSend(sym, cmd, lots, price, 10, sl,
                             (tp1 > 0 ? tp1 : tpMax), comment, magic, 0, clrNONE);
      if (ticket > 0) {
         Ownership_Add(ticket, magic, owner, "hub_command", ocoPeer, corr);
         PrintFormat("[Hub Cmd] EXECUTE %s %s pending lots=%.2f ticket=%d owner=%s",
                     ordType, sym, lots, ticket, owner);
      } else {
         PrintFormat("[Hub Cmd] EXECUTE pending failed err=%d owner=%s",
                     GetLastError(), owner);
      }
   }
}

// ============================================================
// R8 — Cmd_HandleHold
//
// Hub-driven HOLD. Two modes:
//   * envelope has `owner` (or `strategy_name`): activate the
//     per-owner hold ONLY. The named owner-strategy stops opening
//     new entries; every other owner keeps trading.
//   * envelope has no owner: degrade to HOLD_GLOBAL as a safety
//     fallback. The reason is logged so the operator can audit.
//
// Idempotent — re-issuing HOLD on an already-held owner refreshes
// reason/timestamp. Never closes anything that is already open.
// ============================================================
void Cmd_HandleHold(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   string owner   = Cmd_PField (body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");
   string reason  = Cmd_PField (body, scope, "reason");
   if (StringLen(reason) == 0) reason = "hub_request";

   if (StringLen(owner) == 0) {
      Hub_HoldGlobal_Set(true, reason);
      PrintFormat("[Hub Cmd] HOLD (no owner → HOLD_GLOBAL) reason=%s", reason);
      return;
   }
   Hub_HoldOwner_Set(owner, true, reason);
   PrintFormat("[Hub Cmd] HOLD owner=%s reason=%s", owner, reason);
}

// ============================================================
// R8 — Cmd_HandleCancel  (legacy dispatcher kept for back-compat)
//
// Older publishers issue a single `CANCEL` verb for both pending
// and market tickets. We keep that behaviour but route INTERNALLY
// to the explicit handlers so the actual close/cancel path is one
// and the same regardless of how it was triggered.
//
// If `ticket` is missing/0, the dispatch falls back to:
//   - `CANCEL_ALL_PENDING_BY_OWNER` when `owner` is present
//   - drop otherwise (we never close blindly)
// ============================================================
void Cmd_HandleCancel(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   int    ticket  = Cmd_PInt   (body, scope, "ticket", 0);
   string owner   = Cmd_PField (body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");

   if (ticket <= 0) {
      if (StringLen(owner) > 0) {
         Cmd_HandleCancelAllPendingByOwner(body);
         return;
      }
      Print("[Hub Cmd] CANCEL dropped: missing ticket AND owner");
      return;
   }
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) {
      PrintFormat("[Hub Cmd] CANCEL ticket=%d not found", ticket);
      return;
   }
   int otype = OrderType();
   if (otype == OP_BUYLIMIT || otype == OP_SELLLIMIT ||
       otype == OP_BUYSTOP  || otype == OP_SELLSTOP) {
      Cmd_HandleCancelPending(body);
   } else if (otype == OP_BUY || otype == OP_SELL) {
      Cmd_HandleClosePosition(body);
   } else {
      PrintFormat("[Hub Cmd] CANCEL ticket=%d unknown order type=%d", ticket, otype);
   }
}

// ============================================================
// R8 — Cmd_HandleInvalidate
//
// Mark a setup as invalidated. If a ticket is provided AND it is
// a pending order, we cancel it (the setup is gone). If it is a
// live market position we DO NOT auto-close — invalidation of a
// running trade is the operator's call via CLOSE_POSITION, not
// an automatic side-effect.
//
// Symbol / owner / dedup guards are inherited from AI_HandleCommand;
// here we add a final ownership-mismatch guard so a hub bug can't
// invalidate someone else's setup.
// ============================================================
void Cmd_HandleInvalidate(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   int    ticket  = Cmd_PInt   (body, scope, "ticket", 0);
   string owner   = Cmd_PField (body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");
   string reason  = Cmd_PField (body, scope, "reason");

   PrintFormat("[Hub Cmd] INVALIDATE ticket=%d owner=%s reason=%s",
               ticket, owner, reason);
   if (ticket <= 0) return;
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) {
      PrintFormat("[Hub Cmd] INVALIDATE ticket=%d not found", ticket);
      return;
   }
   if (StringLen(owner) > 0) {
      string registered = Ownership_GetOwner(ticket);
      if (StringLen(registered) > 0 && registered != owner) {
         PrintFormat("[Hub Cmd] INVALIDATE owner mismatch ticket=%d expected=%s actual=%s",
                     ticket, owner, registered);
         return;
      }
   }
   int otype = OrderType();
   if (otype == OP_BUYLIMIT || otype == OP_SELLLIMIT ||
       otype == OP_BUYSTOP  || otype == OP_SELLSTOP) {
      // setup pending → cancel
      Cmd_HandleCancelPending(body);
   } else {
      // live ticket: just log invalidation; operator must CLOSE_POSITION
      // explicitly. Refusing to auto-close protects against hub bugs that
      // could otherwise flatten a profitable trade.
      PrintFormat("[Hub Cmd] INVALIDATE on live ticket=%d → operator must close explicitly", ticket);
   }
}

// ============================================================
// R8 — Cmd_HandleRefineTPSL
//
// Payload-aware refinement of SL / TP1..TPMAX on a live ticket.
// Accepts both envelope-flat (legacy) and nested `payload` (new).
//
// Only `sl` and `tp1` are applied to the broker (OrderModify takes
// a single SL + single TP). The richer ladder fields (tp2/tp3/tpmax)
// are reserved for the local TPSLEngine: we log them so the operator
// has full transparency, but we do not push them to the broker — the
// TP ladder is owned by the EA's TPSLManager, not by the hub.
// ============================================================
void Cmd_HandleRefineTPSL(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   int    ticket  = Cmd_PInt   (body, scope, "ticket", 0);
   string owner   = Cmd_PField (body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");
   double sl      = Cmd_PDouble(body, scope, "sl",    0.0);
   double tp1     = Cmd_PDouble(body, scope, "tp1",   0.0);
   if (tp1 <= 0.0) tp1 = Cmd_PDouble(body, scope, "tp", 0.0);  // alias
   double tp2     = Cmd_PDouble(body, scope, "tp2",   0.0);
   double tp3     = Cmd_PDouble(body, scope, "tp3",   0.0);
   double tpMax   = Cmd_PDouble(body, scope, "tpmax", 0.0);
   if (tpMax <= 0.0) tpMax = Cmd_PDouble(body, scope, "tp_max", 0.0);

   if (ticket <= 0) {
      Print("[Hub Cmd] REFINE_TPSL dropped: missing ticket");
      return;
   }
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) {
      PrintFormat("[Hub Cmd] REFINE_TPSL ticket=%d not found", ticket);
      return;
   }
   // ITER 40 — CROSS-SYMBOL GUARD: refuse REFINE_TPSL if the ticket
   //   belongs to a different chart symbol. Each chart instance must
   //   only manage its own symbol's tickets — otherwise the SL/TP
   //   computed for one symbol can pollute another (BTC SL on XAU).
   if (OrderSymbol() != Symbol()) {
      static datetime __rt_csLog = 0;
      if (TimeCurrent() - __rt_csLog >= 60) {
         __rt_csLog = TimeCurrent();
         PrintFormat("[Hub Cmd] REFINE_TPSL CROSS_SYMBOL_SKIP ticket=%d orderSym=%s chartSym=%s",
                     ticket, OrderSymbol(), Symbol());
      }
      return;
   }
   // Owner-mismatch guard: only block when the ticket IS registered
   // in the ownership table AND the registered owner ≠ envelope owner.
   // A ticket missing from the registry (native trade) is allowed
   // through — operator can refine non-hub tickets too.
   if (StringLen(owner) > 0) {
      string registered = Ownership_GetOwner(ticket);
      if (StringLen(registered) > 0 && registered != owner) {
         PrintFormat("[Hub Cmd] REFINE_TPSL owner mismatch ticket=%d expected=%s actual=%s",
                     ticket, owner, registered);
         return;
      }
   }
   double useSL = (sl  > 0.0) ? sl  : OrderStopLoss();
   double useTP = (tp1 > 0.0) ? tp1 : OrderTakeProfit();
   bool ok = OrderModify(ticket, OrderOpenPrice(), useSL, useTP, 0, clrNONE);
   PrintFormat("[Hub Cmd] REFINE_TPSL ticket=%d sl=%.5f tp1=%.5f tp2=%.5f tp3=%.5f tpmax=%.5f ok=%s err=%d",
               ticket, useSL, useTP, tp2, tp3, tpMax,
               ok ? "Y" : "N", ok ? 0 : GetLastError());
}

// ============================================================
// R8 — Payload-aware field helpers.
//
// Convention: every modern hub command may wrap its data inside
// a `payload` object. Envelope-level fields (symbol, command_id,
// correlation_id, expiry_ts, strategy_name) stay at the top; data
// fields (ticket, lot, sl, tp, ...) live inside `payload`.
//
// These helpers read from `scope` first (payload when present,
// envelope otherwise) and fall back to the envelope body so legacy
// flat publishers keep working without changes.
// ============================================================
string Cmd_PField(string body, string scope, string key) {
   string v = Msg_GetField(scope, key);
   if (StringLen(v) > 0) return v;
   if (scope != body)    return Msg_GetField(body, key);
   return "";
}
double Cmd_PDouble(string body, string scope, string key, double def) {
   double v = Msg_GetDouble(scope, key, def);
   if (v != def)         return v;
   if (scope != body)    return Msg_GetDouble(body, key, def);
   return def;
}
int Cmd_PInt(string body, string scope, string key, int def) {
   int v = Msg_GetInt(scope, key, def);
   if (v != def)         return v;
   if (scope != body)    return Msg_GetInt(body, key, def);
   return def;
}

// ============================================================
// R8 — Hub_Hold* state API
// ============================================================
bool Hub_HoldGlobal_IsActive() { return g_hold_global; }

void Hub_HoldGlobal_Set(bool on, string reason) {
   if (on == g_hold_global) {
      // idempotent: refresh reason/since only if reason supplied
      if (on && StringLen(reason) > 0) {
         g_hold_global_reason = reason;
         g_hold_global_since  = TimeCurrent();
      }
      return;
   }
   g_hold_global        = on;
   g_hold_global_since  = TimeCurrent();
   g_hold_global_reason = on ? reason : "";
}

int Hub_HoldOwner_Find(string owner) {
   for (int i = 0; i < g_hold_owner_count; i++) {
      if (g_hold_owner[i].owner == owner) return i;
   }
   return -1;
}

bool Hub_HoldOwner_IsActive(string owner) {
   if (StringLen(owner) == 0) return false;
   int idx = Hub_HoldOwner_Find(owner);
   if (idx < 0) return false;
   return g_hold_owner[idx].active;
}

void Hub_HoldOwner_Set(string owner, bool on, string reason) {
   if (StringLen(owner) == 0) return;
   int idx = Hub_HoldOwner_Find(owner);
   if (idx < 0) {
      if (!on) return;  // nothing to clear
      if (g_hold_owner_count >= HOLD_OWNER_MAX) {
         PrintFormat("[Hub Cmd] HOLD owner slot table full (max=%d) — dropping %s",
                     HOLD_OWNER_MAX, owner);
         return;
      }
      idx = g_hold_owner_count++;
      g_hold_owner[idx].owner = owner;
   }
   if (g_hold_owner[idx].active == on) {
      if (on && StringLen(reason) > 0) {
         g_hold_owner[idx].reason = reason;
         g_hold_owner[idx].since  = TimeCurrent();
      }
      return;
   }
   g_hold_owner[idx].active = on;
   g_hold_owner[idx].since  = TimeCurrent();
   g_hold_owner[idx].reason = on ? reason : "";
}

// ============================================================
// R8 — Cmd_HandleHoldGlobal / Cmd_HandleResumeGlobal
//
// HOLD_GLOBAL freezes ALL new openings (hub-driven AND owner-
// strategies, because NewsPolicy_CanOpen — the central per-strategy
// entry gate — now consults Hub_HoldGlobal_IsActive()).
//
// RESUME_GLOBAL releases the global hold AND every per-owner hold.
// Operator can re-issue per-owner HOLDs afterwards if needed.
// Neither verb ever touches open trades.
// ============================================================
void Cmd_HandleHoldGlobal(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   string reason  = Cmd_PField(body, scope, "reason");
   if (StringLen(reason) == 0) reason = "mobile_operator";
   Hub_HoldGlobal_Set(true, reason);
   PrintFormat("[Hub Cmd] HOLD_GLOBAL enabled reason=%s", reason);
}

void Cmd_HandleResumeGlobal(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   string reason  = Cmd_PField(body, scope, "reason");
   Hub_HoldGlobal_Set(false, "");
   // Lift every per-owner hold too, so the system fully resumes.
   for (int i = 0; i < g_hold_owner_count; i++) {
      g_hold_owner[i].active = false;
      g_hold_owner[i].since  = TimeCurrent();
      g_hold_owner[i].reason = "";
   }
   PrintFormat("[Hub Cmd] RESUME_GLOBAL enabled reason=%s",
               StringLen(reason) > 0 ? reason : "(none)");
}

// ============================================================
// R8 — Cmd_HandleClosePosition
//
// Close exactly ONE market position. Refuses pending tickets so
// the operator cannot mistakenly use the wrong verb.
//
// Guards (in order):
//   - ticket present and > 0
//   - OrderSelect succeeds
//   - order type is OP_BUY or OP_SELL (refuse pendings)
//   - symbol match: if envelope supplies `symbol`, must equal
//     the broker's OrderSymbol() of the ticket
//   - owner match: if supplied, must match Ownership_GetOwner()
//
// On success: OrderClose + Ownership_Remove + cleared OCO peer
// (best-effort: peer cancel is fire-and-forget so a missing peer
// never blocks our own close).
// ============================================================
void Cmd_HandleClosePosition(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   int    ticket  = Cmd_PInt   (body, scope, "ticket", 0);
   string owner   = Cmd_PField (body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");
   string envSym  = Cmd_PField (body, scope, "symbol");
   if (StringLen(envSym) == 0) envSym = Cmd_PField(body, scope, "sym");

   if (ticket <= 0) {
      Print("[Hub Cmd] CLOSE_POSITION dropped: missing ticket");
      return;
   }
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) {
      PrintFormat("[Hub Cmd] CLOSE_POSITION ticket=%d not found", ticket);
      return;
   }
   int otype = OrderType();
   if (otype != OP_BUY && otype != OP_SELL) {
      PrintFormat("[Hub Cmd] CLOSE_POSITION ticket=%d not a market position (type=%d) — use CANCEL_PENDING",
                  ticket, otype);
      return;
   }
   if (StringLen(envSym) > 0 && OrderSymbol() != envSym) {
      PrintFormat("[Hub Cmd] CLOSE_POSITION ticket=%d symbol mismatch broker=%s envelope=%s",
                  ticket, OrderSymbol(), envSym);
      return;
   }
   if (StringLen(owner) > 0) {
      string registered = Ownership_GetOwner(ticket);
      if (StringLen(registered) > 0 && registered != owner) {
         PrintFormat("[Hub Cmd] CLOSE_POSITION owner mismatch ticket=%d expected=%s actual=%s",
                     ticket, owner, registered);
         return;
      }
   }
   double price = (otype == OP_BUY) ? MarketInfo(OrderSymbol(), MODE_BID)
                                    : MarketInfo(OrderSymbol(), MODE_ASK);
   double lots  = OrderLots();
   bool ok = OrderClose(ticket, lots, price, 10, clrNONE);
   if (ok) {
      // Best-effort OCO peer cleanup (Predicted limit/stop pairs).
      int peer = 0;
      int regIdx = Ownership_FindByTicket(ticket);
      if (regIdx >= 0) peer = g_orderOwnership[regIdx].ocoPeerTicket;
      Ownership_Remove(ticket);
      if (peer > 0 && OrderSelect(peer, SELECT_BY_TICKET)) {
         int peerType = OrderType();
         if (peerType > OP_SELL) {
            // Best-effort OCO peer delete — failures are non-fatal
            // (the main ticket is already closed; broker will clean
            // up the pending eventually if our delete races a fill).
            if (!OrderDelete(peer)) {
               PrintFormat("[Hub Cmd] CLOSE_POSITION OCO peer=%d delete err=%d (non-fatal)",
                           peer, GetLastError());
            }
            Ownership_Remove(peer);
         }
      }
   }
   PrintFormat("[Hub Cmd] CLOSE_POSITION ticket=%d owner=%s lots=%.2f ok=%s err=%d",
               ticket, owner, lots, ok ? "Y" : "N", ok ? 0 : GetLastError());
}

// ============================================================
// R8 — Cmd_HandleCancelPending
//
// Cancel exactly ONE pending order. Refuses market tickets so
// the operator cannot accidentally close a live trade.
//
// Same guards as CLOSE_POSITION (ticket/select/symbol/owner) but
// the type check is inverted (must be one of the 4 pending types).
// ============================================================
void Cmd_HandleCancelPending(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   int    ticket  = Cmd_PInt   (body, scope, "ticket", 0);
   string owner   = Cmd_PField (body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");
   string envSym  = Cmd_PField (body, scope, "symbol");
   if (StringLen(envSym) == 0) envSym = Cmd_PField(body, scope, "sym");

   if (ticket <= 0) {
      Print("[Hub Cmd] CANCEL_PENDING dropped: missing ticket");
      return;
   }
   if (!OrderSelect(ticket, SELECT_BY_TICKET)) {
      PrintFormat("[Hub Cmd] CANCEL_PENDING ticket=%d not found", ticket);
      return;
   }
   int otype = OrderType();
   bool isPending = (otype == OP_BUYLIMIT || otype == OP_SELLLIMIT ||
                     otype == OP_BUYSTOP  || otype == OP_SELLSTOP);
   if (!isPending) {
      PrintFormat("[Hub Cmd] CANCEL_PENDING ticket=%d not a pending (type=%d) — use CLOSE_POSITION",
                  ticket, otype);
      return;
   }
   if (StringLen(envSym) > 0 && OrderSymbol() != envSym) {
      PrintFormat("[Hub Cmd] CANCEL_PENDING ticket=%d symbol mismatch broker=%s envelope=%s",
                  ticket, OrderSymbol(), envSym);
      return;
   }
   if (StringLen(owner) > 0) {
      string registered = Ownership_GetOwner(ticket);
      if (StringLen(registered) > 0 && registered != owner) {
         PrintFormat("[Hub Cmd] CANCEL_PENDING owner mismatch ticket=%d expected=%s actual=%s",
                     ticket, owner, registered);
         return;
      }
   }
   bool ok = OrderDelete(ticket);
   if (ok) Ownership_Remove(ticket);
   PrintFormat("[Hub Cmd] CANCEL_PENDING ticket=%d owner=%s ok=%s err=%d",
               ticket, owner, ok ? "Y" : "N", ok ? 0 : GetLastError());
}

// ============================================================
// R8 — Cmd_HandleCloseAllByOwner
//
// Bulk close every market position whose ownership registry
// matches `owner`. Iterates the live order book to also catch
// market positions opened natively (registry-source != hub) when
// the operator explicitly targets that owner from the mobile UI.
//
// Skips pending orders (use CANCEL_ALL_PENDING_BY_OWNER for those).
// ============================================================
void Cmd_HandleCloseAllByOwner(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   string owner   = Cmd_PField(body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");
   if (StringLen(owner) == 0) {
      Print("[Hub Cmd] CLOSE_ALL_BY_OWNER dropped: missing owner");
      return;
   }
   int targetMagic = Strategy_NameToMagic(owner);
   int closed = 0, failed = 0;
   for (int i = OrdersTotal() - 1; i >= 0; i--) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      int otype = OrderType();
      if (otype != OP_BUY && otype != OP_SELL) continue;
      // Snapshot every field we need BEFORE OrderClose — MQL4 may
      // invalidate the order context once the close succeeds.
      int    tk      = OrderTicket();
      string osym    = OrderSymbol();
      double olots   = OrderLots();
      int    omagic  = OrderMagicNumber();
      // ownership precedence: registry first, magic fallback
      string regOwner = Ownership_GetOwner(tk);
      bool match = (StringLen(regOwner) > 0)
                     ? (regOwner == owner)
                     : (omagic == targetMagic);
      if (!match) continue;
      double price = (otype == OP_BUY) ? MarketInfo(osym, MODE_BID)
                                       : MarketInfo(osym, MODE_ASK);
      if (OrderClose(tk, olots, price, 10, clrNONE)) {
         Ownership_Remove(tk);
         closed++;
      } else {
         PrintFormat("[Hub Cmd] CLOSE_ALL_BY_OWNER ticket=%d err=%d",
                     tk, GetLastError());
         failed++;
      }
   }
   PrintFormat("[Hub Cmd] CLOSE_ALL_BY_OWNER owner=%s closed=%d failed=%d",
               owner, closed, failed);
}

// ============================================================
// R8 — Cmd_HandleCancelAllPendingByOwner
//
// Bulk delete every pending whose ownership registry matches
// `owner` (or whose magic equals the per-strategy magic, when
// the registry doesn't track that ticket).
// ============================================================
void Cmd_HandleCancelAllPendingByOwner(string body) {
   string payload = Msg_GetObject(body, "payload");
   string scope   = (StringLen(payload) > 4 ? payload : body);
   string owner   = Cmd_PField(body, scope, "owner");
   if (StringLen(owner) == 0) owner = Cmd_PField(body, scope, "strategy_name");
   if (StringLen(owner) == 0) {
      Print("[Hub Cmd] CANCEL_ALL_PENDING_BY_OWNER dropped: missing owner");
      return;
   }
   int targetMagic = Strategy_NameToMagic(owner);
   int cancelled = 0, failed = 0;
   for (int i = OrdersTotal() - 1; i >= 0; i--) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      int otype = OrderType();
      bool isPending = (otype == OP_BUYLIMIT || otype == OP_SELLLIMIT ||
                        otype == OP_BUYSTOP  || otype == OP_SELLSTOP);
      if (!isPending) continue;
      // Snapshot before OrderDelete invalidates the context.
      int    tk     = OrderTicket();
      int    omagic = OrderMagicNumber();
      string regOwner = Ownership_GetOwner(tk);
      bool match = (StringLen(regOwner) > 0)
                     ? (regOwner == owner)
                     : (omagic == targetMagic);
      if (!match) continue;
      if (OrderDelete(tk)) {
         Ownership_Remove(tk);
         cancelled++;
      } else {
         PrintFormat("[Hub Cmd] CANCEL_ALL_PENDING_BY_OWNER ticket=%d err=%d",
                     tk, GetLastError());
         failed++;
      }
   }
   PrintFormat("[Hub Cmd] CANCEL_ALL_PENDING_BY_OWNER owner=%s cancelled=%d failed=%d",
               owner, cancelled, failed);
}

                                          bool AIBridge_HasFreshSignal() {
                                            if (!g_ai_enabled ||
                                                g_ai_direction == 0)
                                              return false;
                                            if (TimeCurrent() -
                                                    g_ai_lastResponse >
                                                AI_TIMEOUT_MS / 1000)
                                              return false;
                                            return true;
                                          }

                                          void AIBridge_Deinit() {
                                            AIBridge_Disconnect();
                                            PrintFormat("[AIBridge] Deinit "
                                                        "| Successes: %d | "
                                                        "Errors: %d",
                                                        g_ai_successCount,
                                                        g_ai_errorCount);
                                          }

                                          void AIBridge_OnTimer() {
                                            // 1. Poll base bridge for
                                            // signals
                                            AIBridge_Poll();

                                            // 2. AIBC CoPilot TP loop —
                                            // GATED OFF (R3).  The pulse
                                            // loop used to open the named
                                            // pipe \\.\pipe\OBLIVIOUS_AI_COPILOT
                                            // every 60s.  After the ZMQ
                                            // migration that transport is
                                            // gone; AI-driven TP refinement
                                            // is now handled by the hub via
                                            // REFINE_TPSL commands on
                                            // oblivious.command.  We keep
                                            // the AIBC_* helpers compiled
                                            // (they have no other live
                                            // callers, so they're inert) in
                                            // case a future revival wires
                                            // them onto ZMQ instead.
                                            // if (!IsTesting() && !IsOptimization())
                                            //   AIB_TP_CoPilot_Timer_Logic();
                                          }

                                          void AIBridge_OnTick(string symbol) {
                                            if (!g_ai_enabled)
                                              return;

                                            // Send market data: ogni 3s
                                            // (UI ACCOUNT MATRIX / PERFORMANCE
                                            // METRICS si aggiornano live)
                                            // + sempre alla nuova candela.
                                            static datetime lastSendBar = 0;
                                            static uint     lastSendMs  = 0;
                                            datetime curBar =
                                                iTime(symbol, 0, 0);
                                            uint     nowMs  = GetTickCount();
                                            bool newBar  = (curBar != lastSendBar);
                                            bool dueTime = (nowMs - lastSendMs) >= 3000;
                                            if (newBar || dueTime) {
                                              AIBridge_SendMarketData(symbol);
                                              lastSendBar = curBar;
                                              lastSendMs  = nowMs;
                                            }
                                          }

                                          void Bridge_Init() {
                                            AIBridge_Init();
                                          }

                                          void Bridge_Shutdown() {
                                            ZMQ_Shutdown();
                                            g_BridgeConnected = false;
                                          }

                                          bool Bridge_IsConnected() {
                                            return AIBridge_IsConnected();
                                          }

                                          bool Bridge_GetAISignals(
                                              string symbol, int timeframe,
                                              datetime lastBarTime,
                                              string &outPayload) {
                                            if (TimeCurrent() -
                                                    lastAISignalCheck <
                                                15) {
                                              outPayload = lastAISignalPayload;
                                              return true;
                                            }
                                            string req =
                                                "GET_AI|" + symbol + "|" +
                                                IntegerToString(timeframe) +
                                                "|" +
                                                IntegerToString(
                                                    (int)lastBarTime);
                                            string resp;
                                            if (!Bridge_SendRequest(req, resp))
                                              return false;
                                            outPayload = resp;
                                            lastAISignalPayload = resp;
                                            lastAISignalCheck = TimeCurrent();
                                            return true;
                                          }

// R6: Bridge_GetNewsStatus reads the SUB-fed cache (oblivious.news
// topic). The hub continuously pushes news state; the EA only ever
// uses the cached value here. NewsPolicy_CanOpen() remains the sole
// local gate, fed by the same cache.
bool Bridge_GetNewsStatus(datetime now, int &blockTrading,
                          int &severity, int &minutesToEvent) {
   if (g_ai_lastNewsCacheTs > 0 &&
       (TimeCurrent() - g_ai_lastNewsCacheTs) < g_NewsUpdateIntervalSec) {
      blockTrading   = g_news_blockTrading ? 1 : 0;
      severity       = (int)g_news_currentImpact;
      minutesToEvent = (g_news_nextEventTime > TimeCurrent()
                          ? (int)((g_news_nextEventTime - TimeCurrent()) / 60)
                          : 0);
      // Mirror to legacy g_NewsCache for backward compat
      g_NewsCache.lastUpdate            = TimeCurrent();
      g_NewsCache.cachedBlockTrading    = blockTrading;
      g_NewsCache.cachedSeverity        = severity;
      g_NewsCache.cachedMinutesToEvent  = minutesToEvent;
      g_NewsCache.valid                 = true;
      g_LastNewsUpdate                  = TimeCurrent();
                                              return true;
                                            }
   // R2 fallback: hub silent — keep last cached value within TTL,
   // then degrade conservatively (do NOT block, let local NewsPolicy
   // decide based on its own forex factory feed).
   if (g_NewsCache.valid &&
       (TimeCurrent() - g_NewsCache.lastUpdate) < g_NewsUpdateIntervalSec * 4) {
      blockTrading   = g_NewsCache.cachedBlockTrading;
      severity       = g_NewsCache.cachedSeverity;
      minutesToEvent = g_NewsCache.cachedMinutesToEvent;
                                              return true;
                                            }
   blockTrading   = 0;
   severity       = 0;
                                            minutesToEvent = 0;
                                            return false;
                                          }

                                          bool Bridge_HasNewsData() {
                                            return (AIBridge_IsConnected() &&
                                                    AIBridge_GetStatus() !=
                                                        "INIT");
                                          }

                                          void Bridge_SendLog(int level,
   string module,
   string msg) {
                                            string prefix = "INFO";
                                            if (level == 0)
                                              prefix = "DEBUG";
                                            else if (level == 1)
                                              prefix = "INFO";
                                            else if (level >= 2)
                                              prefix = "WARN";

                                            SmartLog(prefix, module, msg);

                                            // Also send to AI bridge if
                                            // connected
                                            if (AIBridge_IsConnected()) {
                                              string req = StringFormat(
                                                  "LOG|%s|%s|%s", prefix,
                                                  module, msg);
                                              AIBridge_SendRequest(req);
                                            }
                                          }

// R3: Bridge_SendRequest now performs a synchronous REQ/REP roundtrip
// over ZeroMQ (port 5555) instead of writing to a named pipe.  All
// previous callers (Bridge_GetAISignals, Bridge_SendLog, etc.)
// continue to work unchanged.
bool Bridge_SendRequest(string request, string &response) {
   return ZMQ_SendRequest(request, response);
}

// Map a strategy owner name to its magic input. Used by the hub
// command bus (Cmd_HandleExecute) so a command sent with only
// `strategy_name` can still route to the correct magic without
// the hub having to know the EA-side input values.
int Strategy_NameToMagic(string ownerName) {
   if (ownerName == "Predicted") return PredictedMagic;
   if (ownerName == "Breakout")  return BreakoutMagic;
   if (ownerName == "FVG")       return FVGMagic;
   if (ownerName == "Grid")      return GridMagic;
   if (ownerName == "SMC")       return SMCMagic;
   if (ownerName == "ICT")       return ICTMagic;
   if (ownerName == "Reverse")   return ReverseMagic;
   return MagicNumber;  // fallback to default magic
}

// Helpers for Bridge_QueryAI payload construction.
int Bridge_CountOpen(string sym) {
   int n = 0;
   for (int i = 0; i < OrdersTotal(); i++) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if (OrderSymbol() != sym) continue;
      if (OrderType() <= OP_SELL) n++;
   }
   return n;
}
int Bridge_CountPending(string sym) {
   int n = 0;
   for (int i = 0; i < OrdersTotal(); i++) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if (OrderSymbol() != sym) continue;
      if (OrderType() > OP_SELL) n++;
   }
   return n;
}

// ============================================================
// Bridge_QueryAI — synchronous JSON `ai_query` REQ/REP roundtrip.
//
// Builds a structured context from the live engine globals (Pattern,
// Indicator, Filter, Hybrid) + setup probes (FVG/BOS/MSS) + risk +
// news state, sends it to the hub on the REQ socket (port 5555),
// and parses the response into the g_aiq_* cache.
//
// SOFT semantics: a failed query (hub down, timeout, parse error)
// leaves the cache untouched and returns false. Owner strategies
// only consult the cache via the OF_* / AIQ_* helpers, so a missing
// hub never produces a hard veto.
//
// Throttle: the hub is polled at most once per AIQ_MIN_INTERVAL_SEC
// per (symbol, strategy). The EA Hybrid Engine + the SUB-fed
// orderflow cache stay live in between.
//
// Returns true if the response updated the cache.
// ============================================================
bool Bridge_QueryAI(string symbol, string strategyName) {
   if (!g_ai_enabled || !g_zmq_initialized) return false;
   if (StringLen(symbol) == 0)        symbol       = Symbol();
   if (StringLen(strategyName) == 0)  strategyName = "Native";

   // Throttle per (symbol,strategy).
   if (g_aiq_lastTs > 0 &&
       g_aiq_symbol   == symbol &&
       g_aiq_strategy == strategyName &&
       (TimeCurrent() - g_aiq_lastTs) < AIQ_MIN_INTERVAL_SEC) {
      return true;
   }

   // Build a request_id the hub will echo back in its ai_response.
   // Format: req_<symPrefix>_<tf>_<unix>_<seqMod>
   g_aiq_reqSeq++;
   string symPrefix = (StringLen(symbol) >= 3 ? StringSubstr(symbol, 0, 3) : symbol);
   string requestId = StringFormat("req_%s_%d_%d_%d",
                                   symPrefix, Period(), (int)TimeCurrent(),
                                   g_aiq_reqSeq);
   g_aiq_lastRequestId = requestId;

   // Setup / entry-intent context — the hub uses these to
   // route the strategy-aware bias fusion and to attach the
   // returned ai_response to the right setup on its UI.
   string setupClass = Hyb_ClassName(g_hyb_model_class);
   string setupId    = StringFormat("%s_%s_%d_%s",
                                    StringSubstr(strategyName, 0, 3),
                                    symPrefix, Period(), setupClass);
   bool   isAddon    = (Bridge_CountOpen(symbol) > 0);
   string entryIntent = isAddon ? "addon" : "main_entry";

   double bid       = MarketInfo(symbol, MODE_BID);
   double ask       = MarketInfo(symbol, MODE_ASK);
   double spread    = (ask - bid) / MarketInfo(symbol, MODE_POINT);
   double marginFr  = AccountFreeMargin();
   double maxRiskSym = MaxRiskTradePercent * 2.0;  // soft per-symbol budget hint
   bool   hasOpen   = (Bridge_CountOpen(symbol)    > 0);
   bool   hasPending= (Bridge_CountPending(symbol) > 0);

   // Liquidity / freshness scores already derived by the Hybrid
   // Engine (0..100). Reused here so we don't recompute structure.
   double liqTargetN = g_hyb_liquidity_target_score / 100.0;
   double freshN     = g_hyb_freshness_score        / 100.0;

   string newsCool = (g_news_blockTrading ? "high"
                     : (g_news_currentImpact >= 2 ? "medium" : "none"));

   // Full setup context — the hub uses this to decide. We send:
   //   - identity (symbol/tf/strategy/tpsl_mode/mode)
   //   - market state (price/spread/account/trade_state)
   //   - 4 engine consensus values
   //   - structural setup (FVG/BOS/MSS/retracement/entry_zone)
   //   - hybrid model class+id+name (so the hub knows WHICH model)
   //   - risk policy (max_risk_pct, manual_lot)
   //   - news state
   //   - the current g_of_* fresh snapshot embedded so the hub can
   //     act on the same orderflow view the EA has, even if the
   //     hub's own cache for this symbol is briefly behind.
   // Build the JSON in three chunks because StringFormat in MQL4
   // tops out around ~32 args per call. We concatenate the
   // chunks before sending — wire-shape is identical to the spec.
   string p_head = StringFormat(
      "{\"op\":\"ai_query\","
      "\"request_id\":\"%s\","
      "\"symbol\":\"%s\","
      "\"timeframe\":%d,"
      "\"strategy_name\":\"%s\","
      "\"setup_id\":\"%s\","
      "\"setup_class\":\"%s\","
      "\"entry_intent\":\"%s\","
      "\"tpsl_mode\":\"%s\","
      "\"mode\":\"%s\","
      "\"direction_context\":%d,"
      "\"market\":{\"bid\":%.5f,\"ask\":%.5f,\"spread_points\":%.1f},"
      "\"account\":{\"balance\":%.2f,\"equity\":%.2f,\"margin_free\":%.2f},",
      requestId,
      symbol, Period(), strategyName,
      setupId, setupClass, entryIntent,
      (IsTPSL_AI() ? "AI" : "Native"),
      "Moderate",
      (int)(g_hyb_bias),
      bid, ask, spread,
      AccountBalance(), AccountEquity(), marginFr);

   string p_eng_setup = StringFormat(
      "\"engines\":{"
        "\"pattern_consensus\":%.3f,"
        "\"indicator_consensus\":%.3f,"
        "\"filter_confidence\":%.3f,"
        "\"hybrid_confidence\":%.3f"
      "},"
      "\"setup\":{"
        "\"fvg_valid\":%s,"
        "\"bos_detected\":%s,"
        "\"mss_detected\":%s,"
        "\"retracement_quality\":%.3f,"
        "\"entry_zone_score\":%.3f,"
        "\"liquidity_target_score\":%.3f,"
        "\"freshness_score\":%.3f,"
        "\"hybrid_model_id\":%d,"
        "\"hybrid_model_class\":%d,"
        "\"hybrid_model_name\":\"%s\","
        "\"hybrid_quality\":%.3f,"
        "\"hybrid_penalty\":%.3f"
      "},",
      (CalculatePatternConfidence() / 100.0),
      (MathAbs(g_ind_consensus) / 100.0),
      (g_filter_confidence / 100.0),
      (g_hyb_confidence / 100.0),
      (g_hyb_model_id != HYB_MODEL_NONE ? "true" : "false"),
      (g_hyb_bos_detected ? "true" : "false"),
      (g_hyb_mss_detected ? "true" : "false"),
      g_hyb_retracement_quality / 100.0,
      g_hyb_entry_zone_score    / 100.0,
      liqTargetN, freshN,
      g_hyb_model_id, g_hyb_model_class, g_hyb_model_name,
      g_hyb_quality_score / 100.0,
      g_hyb_penalty_score / 100.0);

   string p_state = StringFormat(
      "\"trade_state\":{\"has_open_trade\":%s,\"has_pending\":%s,\"is_addon\":%s,\"open_count\":%d,\"pending_count\":%d},"
      "\"risk_state\":{\"manual_lot\":%.2f,\"max_risk_trade_percent\":%.3f,\"max_risk_for_symbol\":%.3f},"
      "\"news_state\":{\"high_impact_block\":%s,\"impact\":%d,\"cooldown_state\":\"%s\"},",
      (hasOpen    ? "true" : "false"),
      (hasPending ? "true" : "false"),
      (isAddon    ? "true" : "false"),
      Bridge_CountOpen(symbol), Bridge_CountPending(symbol),
      ManualLot, MaxRiskTradePercent, maxRiskSym,
      (g_news_blockTrading ? "true" : "false"),
      (int)g_news_currentImpact,
      newsCool);

   string p_of_a = StringFormat(
      "\"orderflow_hint\":{"
        "\"fresh\":%s,"
        "\"sequence\":%d,"
        "\"timestamp\":%d,"
        "\"age_sec\":%d,"
        "\"of_bias\":%.3f,"
        "\"of_confidence\":%.3f,"
        "\"of_absorption\":%.3f,"
        "\"of_exhaustion\":%.3f,"
        "\"of_delta_shift\":%.3f,"
        "\"of_delta_divergence\":%.3f,"
        "\"of_imbalance\":%.3f,"
        "\"of_dom_pressure\":%.3f,",
      (OF_IsFresh() ? "true" : "false"),
      g_of_sequence,
      (int)g_of_last_update_ts,
      (g_of_lastTs > 0 ? (int)(TimeCurrent() - g_of_lastTs) : -1),
      g_of_bias, g_of_confidence, g_of_absorption, g_of_exhaustion,
      g_of_delta_shift, g_of_delta_divergence, g_of_imbalance, g_of_dom_pressure);

   string p_of_b = StringFormat(
        "\"of_iceberg_side\":%d,"
        "\"of_iceberg_strength\":%.3f,"
        "\"of_stop_activity\":%.3f,"
        "\"of_sweep_signal\":%d,"
        "\"of_trap_signal\":%d,"
        "\"of_hold_continue\":%.3f,"
        "\"of_cancel_signal\":%.3f,"
        "\"of_execution_danger\":%.3f"
      "},"
      "\"ts\":%d}",
      g_of_iceberg_side, g_of_iceberg_strength, g_of_stop_activity,
      g_of_sweep_signal, g_of_trap_signal,
      g_of_hold_continue, g_of_cancel_signal, g_of_execution_danger,
      (int)TimeCurrent());

   string payload = p_head + p_eng_setup + p_state + p_of_a + p_of_b;

   string resp;
   if (!Bridge_SendRequest(payload, resp)) return false;
   if (StringLen(resp) == 0)               return false;

   // Hub returned `{"ok":false,"reason":"..."}` → keep last cache,
   // do not overwrite.
   string okFlag = Msg_GetField(resp, "ok");
   if (okFlag == "false" || okFlag == "0") return false;

   // Sanity: the hub MUST echo our request_id. If the echo is
   // missing or mismatched the response is from a stale/crossed
   // roundtrip and we discard it.
   string echoReqId = Msg_GetField(resp, "request_id");
   if (StringLen(echoReqId) > 0 && echoReqId != requestId) {
      PrintFormat("[ai_query] discarding mismatched response: sent=%s got=%s",
                  requestId, echoReqId);
      return false;
   }

   g_aiq_symbol           = symbol;
   g_aiq_strategy         = strategyName;
   g_aiq_lastTs           = TimeCurrent();
   g_aiq_final_bias       = Msg_GetDouble(resp, "final_bias",          0.0);
   g_aiq_ai_confidence    = Msg_GetDouble(resp, "ai_confidence",       0.0);
   g_aiq_orderflow_bias   = Msg_GetDouble(resp, "orderflow_bias",      0.0);
   g_aiq_orderflow_conf   = Msg_GetDouble(resp, "orderflow_confidence",0.0);
   g_aiq_hold_continue    = Msg_GetDouble(resp, "hold_continue",       0.0);
   g_aiq_cancel_signal    = Msg_GetDouble(resp, "cancel_signal",       0.0);
   g_aiq_news_block_state = Msg_GetField (resp, "news_block_state");
   g_aiq_tp1              = Msg_GetDouble(resp, "tp1",                 0.0);
   g_aiq_tp2              = Msg_GetDouble(resp, "tp2",                 0.0);
   g_aiq_tp3              = Msg_GetDouble(resp, "tp3",                 0.0);
   g_aiq_tpmax            = Msg_GetDouble(resp, "tpmax",               0.0);
   g_aiq_invalidate_if    = Msg_GetField (resp, "invalidate_if");
   g_aiq_provider_used    = Msg_GetField (resp, "provider_used");
   g_aiq_predicted_setup_valid = (Msg_GetInt(resp, "predicted_setup_valid", 0) != 0);
   g_aiq_bookmap_fresh    = (Msg_GetInt(resp, "bookmap_fresh", 0) != 0);
   g_aiq_bookmap_stale    = (Msg_GetInt(resp, "bookmap_stale", 0) != 0);
   g_aiq_bookmap_sequence = Msg_GetInt(resp, "bookmap_sequence", 0);
   g_aiq_bookmap_age_ms   = Msg_GetInt(resp, "bookmap_age_ms",   0);

   // The response also carries the inner of_context object — if
   // present, refresh the orderflow cache directly so SOFT helpers
   // see consistent data even when the SUB topic is briefly stale.
   string ofCtx = Msg_GetObject(resp, "of_context");
   if (StringLen(ofCtx) > 4) {
      g_of_lastTs           = TimeCurrent();
      g_of_symbol           = symbol;
      g_of_bias             = Msg_GetDouble(ofCtx, "of_bias",             g_of_bias);
      g_of_confidence       = Msg_GetDouble(ofCtx, "of_confidence",       g_of_confidence);
      string sig            = Msg_GetField (ofCtx, "of_signal");
      if (StringLen(sig) > 0) g_of_signal = sig;
      g_of_imbalance        = Msg_GetDouble(ofCtx, "of_imbalance",        g_of_imbalance);
      g_of_dom_pressure     = Msg_GetDouble(ofCtx, "of_dom_pressure",     g_of_dom_pressure);
      g_of_delta_shift      = Msg_GetDouble(ofCtx, "of_delta_shift",      g_of_delta_shift);
      g_of_delta_divergence = Msg_GetDouble(ofCtx, "of_delta_divergence", g_of_delta_divergence);
      g_of_absorption       = Msg_GetDouble(ofCtx, "of_absorption",       g_of_absorption);
      g_of_exhaustion       = Msg_GetDouble(ofCtx, "of_exhaustion",       g_of_exhaustion);
      g_of_iceberg_side     = Msg_GetInt   (ofCtx, "of_iceberg_side",     g_of_iceberg_side);
      g_of_iceberg_strength = Msg_GetDouble(ofCtx, "of_iceberg_strength", g_of_iceberg_strength);
      g_of_stop_activity    = Msg_GetDouble(ofCtx, "of_stop_activity",    g_of_stop_activity);
      g_of_sweep_signal     = Msg_GetInt   (ofCtx, "of_sweep_signal",     g_of_sweep_signal);
      g_of_trap_signal      = Msg_GetInt   (ofCtx, "of_trap_signal",      g_of_trap_signal);
      g_of_hold_continue    = Msg_GetDouble(ofCtx, "of_hold_continue",    g_of_hold_continue);
      g_of_cancel_signal    = Msg_GetDouble(ofCtx, "of_cancel_signal",    g_of_cancel_signal);
      g_of_execution_danger = Msg_GetDouble(ofCtx, "of_execution_danger", g_of_execution_danger);
   }
   return true;
}

// ============================================================
// Orderflow / AI-query SOFT refinement helpers.
//
// Mirror the philosophy of the Hybrid Engine refiners: never bring
// confidence outside [0..100], never flip a non-zero bias unless the
// counter-evidence is overwhelming, never act as a hard gate. Hard
// gates (spread, news, license, lot, schedule, invalidation) are
// untouched.
// ============================================================
bool OF_IsFresh()  {
   // Three-way freshness guard:
   //   1. EA wallclock TTL — even if hub flagged fresh=true, if our
   //      drain hasn't received an update within OF_FRESH_TTL_SEC
   //      we treat the cache as stale (PUB/SUB has no replay).
   //   2. Symbol match — only consume frames for Symbol() of this
   //      chart (multi-chart safety).
   //   3. Hub-side fresh flag — when present, must be true.
   if (g_of_lastTs <= 0) return false;
   if ((TimeCurrent() - g_of_lastTs) > OF_FRESH_TTL_SEC) return false;
   if (g_of_symbol != "" && g_of_symbol != Symbol())     return false;
   // Some frames omit `fresh`; only veto when it's explicitly false.
   // We rely on the wallclock TTL as the primary freshness signal.
   return true;
}
bool AIQ_IsFresh() {
   return (g_aiq_lastTs > 0 &&
           (TimeCurrent() - g_aiq_lastTs) <= AIQ_FRESH_TTL_SEC &&
           g_aiq_symbol == Symbol());
}

// Precedence rules used by the SOFT helpers below:
//   • g_aiq_* (REP response from the hub) is the OFFICIAL fused
//     decision and outranks g_of_* (live SUB stream which is just
//     normalised state). When both are fresh, the ai_query verdict
//     drives bias/confidence first, with the orderflow stream
//     contributing only a smaller residual nudge.
//   • When ai_query is stale but the SUB stream is fresh, the EA
//     falls back to g_of_* alone (still SOFT — never hard veto).
//   • When both are stale, helpers act as no-ops and the strategy
//     keeps its native value.
double OF_RefineConfidence(double base_conf, string strat) {
   // R8 guard: Predicted MUST stay on the hub-driven path
   // (command bus + Bridge_QueryAI). Soft helpers are reserved
   // for the 6 owner-strategies. The legacy "Predicted" branch
   // further below is kept as documented dead code only.
   if (strat == "Predicted") return base_conf;
   double out = base_conf;
   bool   ofFresh  = OF_IsFresh();
   bool   aiqFresh = AIQ_IsFresh();
   if (!ofFresh && !aiqFresh) return out;

   // Step 1 — apply ai_query first (authoritative, higher weight).
   if (aiqFresh) {
      double weight_aiq = 0.0;
      if      (strat == "FVG")      weight_aiq = 0.30;
      else if (strat == "SMC")      weight_aiq = 0.30;
      else if (strat == "ICT")      weight_aiq = 0.30;
      else if (strat == "Reverse")  weight_aiq = 0.25;
      else if (strat == "Breakout") weight_aiq = 0.25;
      else if (strat == "Grid")     weight_aiq = 0.10;   // refine-only
      else if (strat == "Predicted")weight_aiq = 0.35;   // most AI-driven
      else                          weight_aiq = 0.20;
      double aiq_conf_pct = g_aiq_ai_confidence * 100.0;
      out = (1.0 - weight_aiq) * out + weight_aiq * aiq_conf_pct;
      if (g_aiq_cancel_signal > 0.70) out -= 8.0;
   }

   // Step 2 — orderflow stream as a SECONDARY nudge. Reduced weight
   // when ai_query already moved the value (we don't want to count
   // the same evidence twice — the hub already saw the orderflow).
   if (ofFresh) {
      double weight_of = 0.0;
      if      (strat == "FVG")      weight_of = (aiqFresh ? 0.10 : 0.25);
      else if (strat == "SMC")      weight_of = (aiqFresh ? 0.10 : 0.25);
      else if (strat == "ICT")      weight_of = (aiqFresh ? 0.10 : 0.25);
      else if (strat == "Reverse")  weight_of = (aiqFresh ? 0.10 : 0.25);
      else if (strat == "Breakout") weight_of = (aiqFresh ? 0.08 : 0.20);
      else if (strat == "Grid")     weight_of = (aiqFresh ? 0.05 : 0.10);
      else if (strat == "Predicted")weight_of = (aiqFresh ? 0.10 : 0.30);
      else                          weight_of = (aiqFresh ? 0.08 : 0.20);
      double of_conf_pct = g_of_confidence * 100.0;
      out = (1.0 - weight_of) * out + weight_of * of_conf_pct;
      if      (g_of_execution_danger > 0.70) out -= 8.0;
      else if (g_of_cancel_signal    > 0.60) out -= 5.0;
   }

   if (out < 0.0)   out = 0.0;
   if (out > 100.0) out = 100.0;
   return out;
}

int OF_RefineBias(int base_bias, string strat) {
   // R8 guard: Predicted is hub-driven only — never soft-refined.
   if (strat == "Predicted") return base_bias;
   bool ofFresh  = OF_IsFresh();
   bool aiqFresh = AIQ_IsFresh();
   if (!ofFresh && !aiqFresh) return base_bias;

   // Vote 1 — ai_query (PRIMARY, weight 2 when strong).
   int aiqVote = 0;
   int aiqWeight = 0;
   if (aiqFresh && g_aiq_ai_confidence >= 0.55) {
      if      (g_aiq_final_bias >  0.15) { aiqVote =  1; aiqWeight = 2; }
      else if (g_aiq_final_bias < -0.15) { aiqVote = -1; aiqWeight = 2; }
   }
   // Vote 2 — orderflow stream (SECONDARY, weight 1).
   int ofVote = 0;
   int ofWeight = 0;
   if (ofFresh && g_of_confidence >= 0.55) {
      if      (g_of_bias >  0.15) { ofVote =  1; ofWeight = 1; }
      else if (g_of_bias < -0.15) { ofVote = -1; ofWeight = 1; }
   }
   int sum = aiqVote * aiqWeight + ofVote * ofWeight;

   if (base_bias == 0) {
      if (sum >=  2) return  1;
      if (sum <= -2) return -1;
      return 0;
   }
   if (sum == 0) return base_bias;            // no opinion → keep
   if (sum * base_bias > 0) return base_bias; // confirm

   // Conflict — only flip if ai_query strongly disagrees AND the
   // orderflow stream is consistent with ai_query AND execution
   // danger isn't elevated. ai_query alone (weight 2) is enough
   // when extremely confident; otherwise we need both.
   double execDanger = ofFresh ? g_of_execution_danger : 0.0;
   if (aiqFresh && g_aiq_ai_confidence >= 0.85 && execDanger < 0.5 &&
       aiqVote != 0 && aiqVote != base_bias) {
      // ai_query alone is enough at extreme confidence
      if (ofVote == 0 || ofVote == aiqVote) return aiqVote;
   }
   if (aiqFresh && ofFresh && aiqVote == ofVote && aiqVote != 0 &&
       aiqVote != base_bias && execDanger < 0.5 &&
       (g_aiq_ai_confidence + g_of_confidence) >= 1.5) {
      return aiqVote;
   }
   return base_bias;
}

bool OF_ShouldDiscourage(string strat) {
   // FASE 2B - support engine, NON hard blocker default:
   // ritorna true SOLO per:
   //   - cancel_signal molto estremo (>= 0.90) confermato
   //   - news high_impact block ufficiale (gia' un hard gate)
   // Le altre soglie producono SOLO un log soft: la
   // qualita' viene downgrade da OF_RefineConfidence e
   // filtrata a valle da Mode_QualityFloor.
   if (strat == "Predicted") return false;
   if (AIQ_IsFresh()) {
      if (g_aiq_cancel_signal       >= 0.90) return true;
      if (g_aiq_news_block_state == "high_impact_block" &&
          strat != "Predicted")               return true;
      if (g_aiq_cancel_signal >= 0.80) {
         static datetime __of_lastLog1 = 0;
         if (TimeCurrent() - __of_lastLog1 > 30) {
            __of_lastLog1 = TimeCurrent();
            PrintFormat("[OF/AIQ] %s soft-penalty (cancel=%.2f) - quality downgrade only",
                        strat, g_aiq_cancel_signal);
         }
      }
   }
   if (OF_IsFresh()) {
      if (g_of_execution_danger >= 0.90) return true;
      if (g_of_cancel_signal    >= 0.90) return true;
      if (g_of_execution_danger >= 0.75 || g_of_cancel_signal >= 0.75) {
         static datetime __of_lastLog2 = 0;
         if (TimeCurrent() - __of_lastLog2 > 30) {
            __of_lastLog2 = TimeCurrent();
            PrintFormat("[OF] %s soft-penalty (danger=%.2f cancel=%.2f) - quality downgrade only",
                        strat, g_of_execution_danger, g_of_cancel_signal);
         }
      }
   }
   return false;
}


                                          void NewsBridge_Init() {
                                            g_news_enabled = false;
                                            g_news_highImpactNow = false;
                                            g_news_blockTrading = false;
                                            g_news_currentImpact =
                                                NEWS_IMPACT_NONE;
                                            g_news_nextEvent = "";
                                            g_news_nextEventTime = 0;
                                            g_news_lastUpdate = 0;

                                            if (!g_ai_enabled) {
                                              Print("[NewsBridge] Disabled "
                                                    "- AI bridge off (DLL?)");
                                              return;
                                            }

                                            g_news_enabled = true;
                                            g_news_preMinutes =
                                                NewsCooldownMinutes;
                                            g_news_postMinutes =
                                                NewsHighImpactCooldownMinutes;

                                            Print("[NewsBridge] Initialized");
                                          }

                                          void NewsBridge_Update() {
                                            if (!g_news_enabled)
                                              return;
                                            if (!g_zmq_initialized)
                                              return;

                                            // Poll hub news every 15s via REQ
                                            // (panel lines + block state).
                                            if (TimeCurrent() - g_news_lastUpdate < 15)
                                              return;
                                            if (!Hub_IsConnectedTruthful())
                                              return;

                                            string reply = "";
                                            if (!ZMQ_SendRequest("{\"op\":\"news_query\"}", reply))
                                              return;
                                            g_news_lastUpdate = TimeCurrent();
                                            if (StringLen(reply) > 0) {
                                              AI_HandleNews(reply);
                                              AI_ApplyNewsPanelFromBody(reply);
                                            }
                                            NewsBridge_CheckBlocking();
                                          }

                                          void NewsBridge_ProcessResponse(
                                              string response) {
                                            // Expected format:
                                            // "IMPACT:3|EVENT:NFP|TIME:2026.02.23
                                            // 13:30"

                                            if (StringFind(response,
                                                           "IMPACT:") < 0)
                                              return;

                                            string parts[];
                                            int count = AIBridge_StringSplit(
                                                response, '|', parts);

                                            for (int i = 0; i < count; i++) {
                                              int colonPos =
                                                  StringFind(parts[i], ":");
                                              if (colonPos <= 0)
                                                continue;

                                              string key = StringSubstr(
                                                  parts[i], 0, colonPos);
                                              string val = StringSubstr(
                                                  parts[i], colonPos + 1);

                                              if (key == "IMPACT")
                                                g_news_currentImpact =
                                                    (int)StringToInteger(val);
                                              else if (key == "EVENT")
                                                g_news_nextEvent = val;
                                              else if (key == "TIME")
                                                g_news_nextEventTime =
                                                    StringToTime(val);
                                            }

                                            g_news_highImpactNow =
                                                (g_news_currentImpact >=
                                                 NEWS_IMPACT_HIGH);
                                            NewsBridge_CheckBlocking();
                                          }

                                          void NewsBridge_CheckBlocking() {
                                            g_news_blockTrading = false;

                                            if (!g_news_enabled || !NewsFilter)
                                              return;
                                            if (g_news_nextEventTime == 0)
                                              return;

                                            datetime now = TimeCurrent();
                                            int minutesBefore =
                                                (int)((g_news_nextEventTime -
                                                       now) /
                                                      60);
                                            int minutesAfter =
                                                (int)((now -
                                                       g_news_nextEventTime) /
                                                      60);

                                            // Block if within pre/post
                                            // window of high-impact event
                                            if (g_news_currentImpact >=
                                                NEWS_IMPACT_HIGH) {
                                              if (minutesBefore >= 0 &&
                                                  minutesBefore <=
                                                      g_news_preMinutes) {
                                                g_news_blockTrading = true;
                                                return;
                                              }
                                              if (minutesAfter >= 0 &&
                                                  minutesAfter <=
                                                      g_news_postMinutes) {
                                                g_news_blockTrading = true;
                                                return;
                                              }
                                            }
                                          }

                                          bool NewsBridge_ShouldBlock() {
                                            return g_news_blockTrading;
                                          }

                                          int NewsBridge_GetImpact() {
                                            return g_news_currentImpact;
                                          }

                                          string NewsBridge_GetNextEvent() {
                                            return g_news_nextEvent;
                                          }

                                          datetime NewsBridge_GetNextEventTime() {
                                            return g_news_nextEventTime;
                                          }

                                          bool NewsBridge_IsHighImpact() {
                                            return g_news_highImpactNow;
                                          }

