                                          }
                                          string ids[3];
                                          ids[0] = "LBL_NEWS1"; ids[1] = "LBL_NEWS2"; ids[2] = "LBL_NEWS3";
                                          string vals[3];
                                          vals[0] = n1; vals[1] = n2; vals[2] = n3;
                                          for (int i = 0; i < 3; i++) {
                                            string id = ids[i];
                                            if (ObjectFind(0, id) < 0) {
                                              ObjectCreate(0, id, OBJ_LABEL, 0,
                                                           0, 0);
