                                              bool AIBC_ParseTPs(string line2,
   int &tp1, int &tp2,
   int &tp3) {
                                            tp1 = tp2 = tp3 = 0;
                                            string parts[];
                                            int n =
                                                StringSplit(line2, ';', parts);
                                            if (n < 3)
                                              return false;
                                            for (int i = 0; i < n; i++) {
                                              string kv[];
                                              if (StringSplit(parts[i], '=',
   kv) == 2) {
                                                if (kv[0] == "tp1")
                                                  tp1 = (int)StringToInteger(
                                                      kv[1]);
                                                if (kv[0] == "tp2")
                                                  tp2 = (int)StringToInteger(
                                                      kv[1]);
                                                if (kv[0] == "tp3")
                                                  tp3 = (int)StringToInteger(
                                                      kv[1]);
                                              }
                                            }
                                            return (tp1 > 0 && tp2 > 0 &&
                                                    tp3 > 0);
                                          }

