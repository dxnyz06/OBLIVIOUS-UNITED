double TrueRange(int shift)
{
      double h = iHigh(Symbol(), Period(), shift);
      double l = iLow(Symbol(), Period(), shift);
      double c1 = iClose(Symbol(), Period(), shift + 1);
      return MathMax(h - l, MathMax(MathAbs(h - c1), MathAbs(l - c1)));
}

double TRavg(int n, int startShift=0)
{
      if (n <= 0)
        n = 14;
      double sum = 0.0;
      for (int i = startShift; i < startShift + n; i++)
        sum += TrueRange(i);
      return sum / n;
}

double MedianRange(string sym, int tf, int n)
{
      if (n <= 0)
        n = 20;
      double buf[];
      ArrayResize(buf, n);
      for (int i = 0; i < n; i++)
        buf[i] = iHigh(sym, tf, i + 1) - iLow(sym, tf, i + 1);
      return __Median(buf, n);
}

double RangeAt(int shift)
{
      return iHigh(Symbol(), Period(), shift) - iLow(Symbol(), Period(), shift);
}

bool PivotHigh(int leftBars, int rightBars, int shift)
{
      double h = iHigh(Symbol(), Period(), shift);
      for (int i = 1; i <= leftBars; i++)
        if (iHigh(Symbol(), Period(), shift + i) >= h)
          return false;
      for (int i = 1; i <= rightBars; i++)
        if (iHigh(Symbol(), Period(), shift - i) >= h)
          return false;
      return true;
}

bool PivotLow(int leftBars, int rightBars, int shift)
{
      double l = iLow(Symbol(), Period(), shift);
      for (int i = 1; i <= leftBars; i++)
        if (iLow(Symbol(), Period(), shift + i) <= l)
          return false;
      for (int i = 1; i <= rightBars; i++)
        if (iLow(Symbol(), Period(), shift - i) <= l)
          return false;
      return true;
}

bool __looks_negative_number(const string txt)
{
      if (StringLen(txt) < 2)
        return false;
      if (StringGetCharacter(txt, 0) != '-')
        return false;
      for (int i = 1; i < StringLen(txt); i++) {
        int c = StringGetCharacter(txt, i);
        if (c != '.' && (c < '0' || c > '9'))
          return false;
      }
      return true;
}

double __map_vs_threshold(double val01, double thr01)
{
      if (thr01 <= 0.0)
        return val01;
      return clamp01((val01 - thr01) / (1.0 - thr01 + 1e-9));
}

double ADV_Pip()
{
      return Point * (Digits == 3 || Digits == 5 ? 10 : 1);
}

int CurrentSpreadPoints(string sym=NULL){
      if (sym == NULL || sym == "")
        sym = Symbol();
      double spr = MarketInfo(sym, MODE_SPREAD);
      if (spr <= 0)
        spr = (MarketInfo(sym, MODE_ASK) - MarketInfo(sym, MODE_BID)) /
              MarketInfo(sym, MODE_POINT);
      return (int)MathRound(spr);
}

double __SpreadPoints()    {
      return SpreadPoints(); }

double __atr_pts_internal(int p)
{
      double v = iATR(Symbol(), Period(), p, 0);
      return (v > 0 ? v / Point : 0);
}

double ATRPoints(int p=14){
      int tf = 0;
#ifdef __MQL4__
      tf = Period();
#endif
      // If we have Use_TF(), prefer it
      return (iATR(Symbol(), (int)((bool)0 ? 0 : ((int)((int)0))), p, 0)); 
}

double ATRv(int p=14)
{
      return iATR(Symbol(), Period(), p, 0);
}

double NormalizedATR(int period=14)
{
      double atr = iATR(Symbol(), Period(), period, 0);
      double pip = ADV_Pip();
      return (pip > 0 ? atr / pip : 0);
}

double ATRScaledPoints(int period, double mult)
{
      return __atr_pts_internal(period) * mult;
}

double ModeScale() {
      // Scale parameters by trading mode
      if (Mode == 0)
        return 0.90; // Conservative: reduce
      if (Mode == 2)
        return 1.15; // Aggressive: increase
      return 1.00;   // Moderate: baseline
}

double ScalePipsByATR(double pips)
{
      int pts = (int)MathMax(1, MathRound(pips * AA_PointsPerPip()));
      int pts_dyn = ScalePointsByATR(pts);
      return ((double)pts_dyn) / AA_PointsPerPip();
}

double ADV_ATR(int tf, int period, int shift)
{
      return iATR(Symbol(), tf, period, shift);
}

void ADV_RangeHL(int tf, int lookback, double &hi, double &lo)
{
      hi = -DBL_MAX;
      lo = DBL_MAX;
      int bars = iBars(Symbol(), tf);
      if (bars < 5) {
        hi = iHigh(Symbol(), tf, 1);
        lo = iLow(Symbol(), tf, 1);
        return;
      }
      int maxShift = (int)MathMin(lookback, bars - 2);
      for (int s = 1; s <= maxShift; s++) {
        double h = iHigh(Symbol(), tf, s);
        double l = iLow(Symbol(), tf, s);
        if (h > hi)
          hi = h;
        if (l < lo)
          lo = l;
      }
      if (hi <= -DBL_MAX)
        hi = iHigh(Symbol(), tf, 1);
      if (lo >= DBL_MAX)
        lo = iLow(Symbol(), tf, 1);
}

void ADV_DealingRange(int tf, int lookback, double &hi, double &lo)
{
      hi = -DBL_MAX;
      lo = DBL_MAX;

      int shH = -1, shL = -1;
      double fh = 0.0, fl = 0.0;
      bool okH = ADV_LastFractal(tf, +1, lookback, fh, shH);
      bool okL = ADV_LastFractal(tf, -1, lookback, fl, shL);

      if (okH && okL) {
        hi = fh;
        lo = fl;
        if (hi < lo) {
          double tmp = hi;
          hi = lo;
          lo = tmp;
        }
        return;
      }

      int bars = iBars(Symbol(), tf);
      int n = (int)MathMin(lookback, bars - 2);
      for (int i = 1; i <= n; i++) {
        double h = iHigh(Symbol(), tf, i);
        double l = iLow(Symbol(), tf, i);
        if (h > hi)
          hi = h;
        if (l < lo)
          lo = l;
      }
      if (hi <= -DBL_MAX)
        hi = iHigh(Symbol(), tf, 1);
      if (lo >= DBL_MAX)
        lo = iLow(Symbol(), tf, 1);
}

int TFMinutes(int tf)
{
      switch (tf) {
      case PERIOD_M1:
        return 1;
      case PERIOD_M5:
        return 5;
      case PERIOD_M15:
        return 15;
      case PERIOD_M30:
        return 30;
      case PERIOD_H1:
        return 60;
      case PERIOD_H4:
        return 240;
      case PERIOD_D1:
        return 1440;
      case PERIOD_W1:
        return 10080;
      case PERIOD_MN1:
        return 43200;
      default:
        return 60;
      }
}

int PeriodSeconds_Custom(int tf = 0)
{
      // Map current chart Period() to seconds (MT4-safe)
      if (tf <= 0) tf = Period();
      if (tf == PERIOD_M1)
        return 60;
      if (tf == PERIOD_M5)
        return 5 * 60;
      if (tf == PERIOD_M15)
        return 15 * 60;
      if (tf == PERIOD_M30)
        return 30 * 60;
      if (tf == PERIOD_H1)
        return 60 * 60;
      if (tf == PERIOD_H4)
        return 4 * 60 * 60;
      if (tf == PERIOD_D1)
        return 24 * 60 * 60;
      if (tf == PERIOD_W1)
        return 7 * 24 * 60 * 60;
      if (tf == PERIOD_MN1)
        return 30 * 24 * 60 * 60;
      // fallback
      return 60 * Period();
}

int NextHigherTF(int tf)
{
      if (tf <= PERIOD_M1)
        return PERIOD_M5;
      if (tf <= PERIOD_M5)
        return PERIOD_M15;
      if (tf <= PERIOD_M15)
        return PERIOD_H1;
      if (tf <= PERIOD_M30)
        return PERIOD_H1;
      if (tf <= PERIOD_H1)
        return PERIOD_H4;
      if (tf <= PERIOD_H4)
        return PERIOD_D1;
      if (tf <= PERIOD_D1)
        return PERIOD_W1;
      if (tf <= PERIOD_W1)
        return PERIOD_MN1;
      return PERIOD_MN1;
}

bool HasDataTF(string sym, int tf)
{
      return (iBars(sym, tf) > 0);
}

int Use_TF()          {
      return Auto_TF(); }

int Use_TFHigher1()   {
      return Auto_TFHigher1(); }

int Use_TFHigher2()   {
      return Auto_TFHigher2(); }

int Use_TFHigher3()   {
      return Auto_TFHigher3(); }

datetime BarEndTime(int shift=0)
{
      datetime barTime = iTime(Symbol(), Period(), shift);
      int seconds = PeriodSeconds_Custom(Period());
      return barTime + seconds;
}

int ExtendSec(int base)
{
      return base * PeriodSeconds_Custom(Period()) / 60;
}

int CurrentSession()
{
      int hour = TimeHour(TimeCurrent());
      if (hour >= 0 && hour < 8)
        return SESSION_ASIA;
      if (hour >= 8 && hour < 16)
        return SESSION_LONDON;
      if (hour >= 13 && hour < 22)
        return SESSION_NEWYORK;
      return SESSION_OTHER;
}

int DetectSession()         {
      return CurrentSession(); }

int GetCurrentSession()     {
      return CurrentSession(); }

double GetSessionWeight(int session)
{
      if (session == SESSION_LONDON || session == SESSION_NEWYORK)
        return 1.2;
      if (session == SESSION_ASIA)
        return 0.8;
      return 1.0;
}

bool __ParseHHMM(string hhmm, int &hour, int &minute)
{
      int pos = StringFind(hhmm, ":");
      if (pos < 0)
        return false;
      hour = (int)StringToInteger(StringSubstr(hhmm, 0, pos));
      minute = (int)StringToInteger(StringSubstr(hhmm, pos + 1));
      return true;
}

bool __WithinStartEnd(string startStr, string endStr)
{
      int sh = 0, sm = 0, eh = 0, em = 0;
      if (!__ParseHHMM(startStr, sh, sm))
        return true;
      if (!__ParseHHMM(endStr, eh, em))
        return true;

      int now = TimeHour(TimeCurrent()) * 60 + TimeMinute(TimeCurrent());
      int startMin = sh * 60 + sm;
      int endMin = eh * 60 + em;

      if (startMin <= endMin)
        return (now >= startMin && now <= endMin);
      else // overnight
        return (now >= startMin || now <= endMin);
}

bool InTradingWindowNow(){
      datetime now = TimeCurrent();
      int wd = TimeDayOfWeek(now); // 0=Sunday..6=Saturday
      bool day_on = true;
      if (wd == 1)
        day_on = Monday;
      else if (wd == 2)
        day_on = Tuesday;
      else if (wd == 3)
        day_on = Wednesday;
      else if (wd == 4)
        day_on = Thursday;
      else if (wd == 5)
        day_on = Friday;
      else if (wd == 6)
        day_on = Saturday;
      else
        day_on = Sunday; // wd==0
      if (!day_on)
        return false;
      return __WithinStartEnd(TradeStart, TradeEnd);
}

datetime __ParseDateTime(string s){
      // Try formats: "YYYY-MM-DD HH:MM", "YYYY/MM/DD HH:MM", "DD/MM/YYYY HH:MM"
      int y, m, d, hh, mm;
      // YYYY-MM-DD HH:MM
      if (StringLen(s) >= 16 && IsDigit(StringGetChar(s, 0))) {
        string yS = StringSubstr(s, 0, 4);
        string mS = StringSubstr(s, 5, 2);
        string dS = StringSubstr(s, 8, 2);
        string hS = StringSubstr(s, 11, 2);
        string nS = StringSubstr(s, 14, 2);
        y = StrToInteger(yS);
        m = StrToInteger(mS);
        d = StrToInteger(dS);
        hh = StrToInteger(hS);
        mm = StrToInteger(nS);
        if (y > 2000 && m >= 1 && m <= 12 && d >= 1 && d <= 31)
          return StrToTime(
              StringFormat("%04d.%02d.%02d %02d:%02d", y, m, d, hh, mm));
      }
      return 0;
}

string GenerateHardwareID()
{
      // Build a deterministic fingerprint from terminal + account info
      string raw = "";
      raw += IntegerToString(AccountNumber());
      raw += "|";
      raw += AccountCompany();
      raw += "|";
      raw += AccountServer();
      raw += "|";
      raw += TerminalName();
      raw += "|";
      raw += TerminalCompany();

      // Simple hash: sum of char codes with rotation
      uint hash1 = 0x811C9DC5; // FNV offset basis
      uint hash2 = 0;
      for (int i = 0; i < StringLen(raw); i++) {
        ushort ch = StringGetCharacter(raw, i);
        hash1 ^= ch;
        hash1 *= 0x01000193; // FNV prime
        hash2 += ch * (i + 1);
      }

      string hwid = StringFormat("%08X-%08X", hash1, hash2);
      return hwid;
}

bool RestoreDoubleArray(string category, double &values[], int &count, string suffix="")
{
      string fn = __PersistFilename(category, suffix);
      string fullPath =
          TerminalInfoString(TERMINAL_COMMONDATA_PATH) + "\\Files" + fn;
      if (GetFileAttributesA(fullPath) == K32_INVALID_FILE_ATTR)
        return false;

      int h = CreateFileA(fullPath, K32_GENERIC_READ, K32_FILE_SHARE_READ, 0,
                          K32_OPEN_EXISTING, K32_FILE_ATTR_NORMAL, 0);
      if (h == K32_INVALID_HANDLE)
        return false;

      // Read entire file
      int fileSize = GetFileSize(h, 0);
      if (fileSize < 4) {
        CloseHandle(h);
        return false;
      }
      uchar buf[];
      ArrayResize(buf, fileSize + 1);
      int bytesRead = 0;
      ReadFile(h, buf, fileSize, bytesRead, 0);
      CloseHandle(h);
      if (bytesRead < 4)
        return false;
      buf[bytesRead] = 0;

      // Parse text: version\ncount\nval1\nval2\n...
      string content = CharArrayToString(buf, 0, bytesRead, CP_ACP);
      string lines[];
      int n = StringSplit(content, '\n', lines);
      if (n < 2)
        return false;

      int version = (int)StringToInteger(lines[0]);
      if (version != PERSIST_VERSION) {
        SmartLog("WARN", "PERSIST",
                 "Version mismatch in " + fn + " (got " +
                     IntegerToString(version) + ", expected " +
                     IntegerToString(PERSIST_VERSION) + ")");
        return false;
      }

      count = (int)StringToInteger(lines[1]);
      if (n < 2 + count)
        return false;
      ArrayResize(values, count);
      for (int i = 0; i < count; i++)
        values[i] = StringToDouble(lines[2 + i]);

      return true;
}

bool RestoreAdaptiveContext()
{
      double vals[];
      int count = 0;
      if (!RestoreDoubleArray("ADAPT", vals, count))
        return false;
      if (count < 9)
        return false;
      g_adapt.regime = (int)vals[0];
      g_adapt.vol_factor = vals[1];
      g_adapt.rsi_period = (int)vals[2];
      g_adapt.ema_fast = (int)vals[3];
      g_adapt.ema_slow = (int)vals[4];
      g_adapt.cci_period = (int)vals[5];
      g_adapt.bb_period = (int)vals[6];
      g_adapt.bb_dev = vals[7];
      g_adapt.mom_period = (int)vals[8];
      return true;
}

bool SaveStringToFile(string category, string content)
{
      string fn = __PersistFilename(category) + ".txt";
      string fullPath =
          TerminalInfoString(TERMINAL_COMMONDATA_PATH) + "\\Files" + fn;
      int h = CreateFileA(fullPath, K32_GENERIC_WRITE, 0, 0, K32_CREATE_ALWAYS,
                          K32_FILE_ATTR_NORMAL, 0);
      if (h == K32_INVALID_HANDLE)
        return false;
      uchar buf[];
      StringToCharArray(content, buf, 0, WHOLE_ARRAY, CP_ACP);
      int written = 0;
      WriteFile(h, buf, ArraySize(buf) - 1, written, 0);
      CloseHandle(h);
      return true;
}

string LoadStringFromFile(string category, string defaultVal="")
{
      string fn = __PersistFilename(category) + ".txt";
      string fullPath =
          TerminalInfoString(TERMINAL_COMMONDATA_PATH) + "\\Files" + fn;
      if (GetFileAttributesA(fullPath) == K32_INVALID_FILE_ATTR)
        return defaultVal;
      int h = CreateFileA(fullPath, K32_GENERIC_READ, K32_FILE_SHARE_READ, 0,
                          K32_OPEN_EXISTING, K32_FILE_ATTR_NORMAL, 0);
      if (h == K32_INVALID_HANDLE)
        return defaultVal;
      uchar buf[];
      ArrayResize(buf, 4096);
      int bytesRead = 0;
      ReadFile(h, buf, 4095, bytesRead, 0);
      CloseHandle(h);
      if (bytesRead <= 0)
        return defaultVal;
      buf[bytesRead] = 0;
      return CharArrayToString(buf, 0, bytesRead, CP_ACP);
}

void PerformanceOptimizer_Init()
{
      ArrayInitialize(g_perf_lastBar, 0);
      g_perf_symbolCount = 0;
      g_perf_lastTickMs = GetTickCount();
      g_perf_lastDashMs = GetTickCount();
      g_perf_tickCount = 0;

      // Register current symbol
      PerformanceOptimizer_RegisterSymbol(Symbol());

      Print("[PerfOpt] Initialized");
}

void PerformanceOptimizer_RegisterSymbol(string symbol)
{
      // Check if already registered
      for (int i = 0; i < g_perf_symbolCount; i++) {
        if (g_perf_symbols[i] == symbol)
          return;
      }

      if (g_perf_symbolCount < PERF_MAX_SYMBOLS) {
        g_perf_symbols[g_perf_symbolCount] = symbol;
        g_perf_lastBar[g_perf_symbolCount] = 0;
        g_perf_symbolCount++;
      }
}

void PerformanceOptimizer_OnTick()
{
      g_perf_tickCount++;
      g_perf_lastTickMs = GetTickCount();

      // Check new bar for current symbol
      g_perf_newBarFlag = PerformanceOptimizer_IsNewBar(Symbol(), Period());
}

bool PerformanceOptimizer_ShouldRunHeavy()
{
      // Only run heavy computations on new bars
      return g_perf_newBarFlag;
}

int PerformanceOptimizer_FindSymbol(string symbol)
{
      for (int i = 0; i < g_perf_symbolCount; i++) {
        if (g_perf_symbols[i] == symbol)
          return i;
      }
      return -1;
}

double PriceToPips(string symbol, double priceDelta)
{
      double pv = PipValue(symbol);
      if (pv <= 0)
        return 0;
      return MathAbs(priceDelta) / pv;
}

int Toggle_Register(string key, string displayLabel, bool initialState)
{
      if (g_toggle_count >= TGL_MAX)
        return -1;
      int idx = g_toggle_count;
      g_toggles[idx].name = key;
      g_toggles[idx].label = displayLabel;
      g_toggles[idx].state = initialState;
      g_toggles[idx].objTrack = "TGL_TRK_" + key;
      g_toggles[idx].objKnob = "TGL_KNB_" + key;
      g_toggles[idx].objLabel = "TGL_LBL_" + key;
      g_toggles[idx].x = 0;
      g_toggles[idx].y = 0;
      g_toggles[idx].created = false;
      g_toggle_count++;
      return idx;
}

void Toggle_UpdateColors(int idx)
{
      if (idx < 0 || idx >= g_toggle_count)
        return;
      if (!g_toggles[idx].created)
        return;

      string trk = g_toggles[idx].objTrack;
      string knb = g_toggles[idx].objKnob;
      string lbl = g_toggles[idx].objLabel;
      bool on = g_toggles[idx].state;
      int x = g_toggles[idx].x;
      int y = g_toggles[idx].y;

      // Track color: ON = rainbow, OFF = red
      color trackClr = on ? RainbowNow() : clrFireBrick;
      ObjectSetInteger(0, trk, OBJPROP_BGCOLOR, trackClr);

      // Knob position: ON = right side, OFF = left side
      int knobX = on ? (x + TGL_TRACK_W - TGL_KNOB_SZ - TGL_KNOB_PAD)
                     : (x + TGL_KNOB_PAD);
      int knobY = y + TGL_KNOB_PAD;
      ObjectSetInteger(0, knb, OBJPROP_XDISTANCE, knobX);
      ObjectSetInteger(0, knb, OBJPROP_YDISTANCE, knobY);
      ObjectSetInteger(0, knb, OBJPROP_BGCOLOR, clrWhite);

      // Label color: ON = rainbow, OFF = dimgray
      ObjectSetInteger(0, lbl, OBJPROP_COLOR, on ? RainbowNow() : clrDimGray);
}

void Toggle_UpdateAllColors()
{
      for (int i = 0; i < g_toggle_count; i++)
        Toggle_UpdateColors(i);
}

int Toggle_FindByName(string key)
{
      for (int i = 0; i < g_toggle_count; i++)
        if (g_toggles[i].name == key)
          return i;
      return -1;
}

bool Toggle_OnClick(string objName)
{
      int idx = Toggle_FindByObject(objName);
      if (idx < 0)
        return false;

      g_toggles[idx].state = !g_toggles[idx].state;
      Toggle_UpdateColors(idx);
      return true;
}

void ApplyChartStyle()
{
      // SPEC: institutional white-only candles. Legacy CandleBull/Bear
      // inputs are ignored — the user mandate is monochrome white.
      long chart = 0;
      ChartSetInteger(chart, CHART_MODE, CHART_CANDLES);
      // BMP background removed per user request — fullscreen scaling on MT4
      // is unreliable and produced black borders / cropped tiles. We
      // explicitly clear any stale BMP that might be carried over by templates.
      // NOTE: CHART_BMP_FILE is MT5-only and does NOT exist in MT4. The
      // original line is preserved below as a comment for reference.
      // ChartSetString (chart, CHART_BMP_FILE, "");
      ChartSetInteger(chart, CHART_COLOR_BACKGROUND, clrBlack);
      ChartSetInteger(chart, CHART_COLOR_FOREGROUND, clrWhite);
      ChartSetInteger(chart, CHART_SHOW_GRID, false);
      ChartSetInteger(chart, CHART_SHOW_VOLUMES, false);
      ChartSetInteger(chart, CHART_SHOW_OHLC, false);
      ChartSetInteger(chart, CHART_SHOW_PERIOD_SEP, false);
      ChartSetInteger(chart, CHART_COLOR_CANDLE_BULL, clrBlack);  // hollow body
      ChartSetInteger(chart, CHART_COLOR_CANDLE_BEAR, clrBlack);
      ChartSetInteger(chart, CHART_COLOR_CHART_UP,   clrWhite);   // outline up
      ChartSetInteger(chart, CHART_COLOR_CHART_DOWN, clrWhite);   // outline down
      ChartSetInteger(chart, CHART_COLOR_CHART_LINE, clrWhite);
      ChartSetInteger(chart, CHART_COLOR_GRID,       clrBlack);
      ChartSetInteger(chart, CHART_COLOR_VOLUME,     clrWhite);
      ChartSetInteger(chart, CHART_COLOR_BID,        clrWhite);
      ChartSetInteger(chart, CHART_COLOR_ASK,        clrWhite);
      ChartSetInteger(chart, CHART_COLOR_LAST,       clrWhite);
      ChartSetInteger(chart, CHART_COLOR_STOP_LEVEL, clrWhite);
      ChartRedraw();
}

void CreateTopBar()
{
      int chartW = (int)ChartGetInteger(0, CHART_WIDTH_IN_PIXELS, 0);
      int totalW = TB_TotalWidth();
      int x = (int)MathMax(0, (chartW - totalW) / 2);
      int y = 8;
      for (int i = 0; i < 12; i++) {
        string id = "TB_NAME_" + IntegerToString(i);
        if (ObjectFind(0, id) < 0)
          ObjectCreate(0, id, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, id, OBJPROP_CORNER, CORNER_LEFT_UPPER);
        ObjectSetInteger(0, id, OBJPROP_XDISTANCE, x);
        ObjectSetInteger(0, id, OBJPROP_YDISTANCE, y);
        ObjectSetInteger(0, id, OBJPROP_COLOR,
                         TB_ShowTrig[i] ? TB_OnCol() : TB_OffCol());
        ObjectSetString(0, id, OBJPROP_FONT, "Arial");
        ObjectSetInteger(0, id, OBJPROP_FONTSIZE, TB_FontSize);
        ObjectSetString(0, id, OBJPROP_TEXT, TB_StrategyNames[i]);
        ObjectSetInteger(0, id, OBJPROP_SELECTABLE, true);
        ObjectSetInteger(0, id, OBJPROP_HIDDEN, false);
        int tw = TextWidthPxPrecise("TB_TMP", TB_StrategyNames[i], TB_FontSize);
        x += (tw + TB_Spacing);
      }
}

void UpdateTopBar()
{
      int chartW = (int)ChartGetInteger(0, CHART_WIDTH_IN_PIXELS, 0);
      int totalW = TB_TotalWidth();
      int x = (int)MathMax(0, (chartW - totalW) / 2);
      int y = 8;
      for (int i = 0; i < 12; i++) {
        string id = "TB_NAME_" + IntegerToString(i);
        if (ObjectFind(0, id) < 0)
          continue;
        ObjectSetInteger(0, id, OBJPROP_XDISTANCE, x);
        ObjectSetInteger(0, id, OBJPROP_YDISTANCE, y);
        ObjectSetInteger(0, id, OBJPROP_COLOR,
                         TB_ShowTrig[i] ? TB_OnCol() : TB_OffCol());
        ObjectSetString(0, id, OBJPROP_FONT, "Arial");
        ObjectSetInteger(0, id, OBJPROP_FONTSIZE, TB_FontSize);
        int tw = TextWidthPxPrecise("TB_TMP", TB_StrategyNames[i], TB_FontSize);
        x += (tw + TB_Spacing);
      }
}

