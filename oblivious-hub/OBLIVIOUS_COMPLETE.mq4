                                            "CLOSE",
                                            StringFormat("%s | "
                                                         "ticket=%d "
                                                         "price=%."
                                                         "5f "
                                                         "lots=%.2f "
                                                         "err=%d",
                                                         __isok ? "Post"
   "Clos"
   "e OK"
   : "Post"
   "Clos"
   "e "
   "FAI"
   "L",
                                                         OrderTicket(),
                                                         OrderClosePrice(),
                                                         OrderLots(), __err));
                                      }
                                    }
                                  }
                                  // SL Virtuale
                                  if (currentProfit <= -sl) {
                                    if (strategyName == "Grid") {
                                      static string __GRID_LAST_REASON;
                                      __GRID_LAST_REASON = "VSL";
                                    }
                                    {
                                      int __ticket = OrderTicket();
                                      double __lots = OrderLots();
                                      SmartLogWrap("CLOSE",
                                                   StringFormat("PreClose | "
   "ticket=%d "
   "lots=%.2f "
   "symbol=%s",
   __ticket,
   __lots,
   OrderSymbol()));
                                    }
                                    bool _wOk = OrderClose(
                                        OrderTicket(), OrderLots(),
                                        (OrderType() == OP_BUY) ? Bid : Ask,
                                        GetAdaptiveSlippagePoints(), clrRed);
                                    {
                                      int __err = GetLastError();
                                      bool __isok = (__err == 0);
                                      SmartLogWrap(
                                          "CLOSE",
                                          StringFormat("%s | "
                                                       "ticket=%d "
                                                       "price=%.5f "
                                                       "lots=%.2f "
                                                       "err=%d",
                                                       __isok ? "PostCl"
   "ose OK"
   : "PostCl"
   "ose "
   "FAIL",
                                                       OrderTicket(),
                                                       OrderClosePrice(),
                                                       OrderLots(), __err));
                                    }
                                  }
