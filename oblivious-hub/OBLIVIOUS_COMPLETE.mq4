double PeakProfitOscRatio(){ // 0..1 oscillation proxy
      int N = 20;
      double atr = iATR(Symbol(), PERIOD_CURRENT, Auto_ATR_Period(), 0);
      if (atr <= 0)
        return 0.0;
      double maxp = -1e9, minp = 1e9;
      for (int i = 0; i < N; i++) {
        double c = iClose(Symbol(), PERIOD_CURRENT, i);
        if (c > maxp)
          maxp = c;
        if (c < minp)
          minp = c;
      }
      double osc = (maxp - minp);
      double pip = MarketInfo(Symbol(), MODE_POINT);
      if (Digits == 3 || Digits == 5)
        pip *= 10;
      double atr_pips = (pip > 0 ? atr / pip : 0);
      double osc_pips = (pip > 0 ? osc / pip : 0);
      if (atr_pips <= 0)
        return 0.0;
      return MathMin(1.0, MathMax(0.0, osc_pips / atr_pips));
}

double ProfitLockOscRatio(){ // 0..1 current profit vs peak in session
      static double peak = 0.0;
      double cur = AccountEquity() - AccountBalance();
      if (cur > peak)
        peak = cur;
      if (peak <= 0)
        return 0.0;
      double pct = cur / peak;
      if (pct < 0)
        pct = 0;
      if (pct > 1)
        pct = 1;
      return pct;
}

