void IsDrawdownAcceptable() { /* prototype resolved */ }
bool IsDrawdownAcceptableBool() { return !DrawdownTooHigh(); }

bool CalcLiquidityLevels(int lb, double &erlHi, double &erlLo, double &irlHi, double &irlLo) {
   if (Bars < lb + 2) return false;
   int hiIdx  = iHighest(NULL, 0, MODE_HIGH, lb, 1);
   int loIdx  = iLowest(NULL, 0, MODE_LOW,  lb, 1);
   erlHi = High[hiIdx];
   erlLo = Low[loIdx];
   // IRL: inner half-range pivots (second significant swing)
   int lb2 = (int)MathMax(5, lb / 2);
   irlHi = High[iHighest(NULL, 0, MODE_HIGH, lb2, 1)];
   irlLo = Low[iLowest(NULL, 0, MODE_LOW,   lb2, 1)];
   // Avoid duplicates
   if (MathAbs(irlHi - erlHi) < Point * 5) irlHi = 0.0;
   if (MathAbs(irlLo - erlLo) < Point * 5) irlLo = 0.0;
   return (erlHi > 0.0 && erlLo > 0.0);
}


