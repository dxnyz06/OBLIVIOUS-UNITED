void GetMarketRegime(double &volFactor, double &trendADX, double &tfFactor, double &sessionFactor)
{
      // Volatility factor via ATR in pips normalized (higher vol -> tighter
      // confirmations)
      double atr = iATR(Symbol(), PERIOD_CURRENT, Auto_ATR_Period(), 0);
      double pip = Point;
      double atrPips = SpreadPoints();
      volFactor =
          MathMin(3.0, MathMax(0.5, atrPips / 50.0)); // ~1 at 50 pips ATR
                                                      // Trend strength via ADX
   trendADX = iADX(NULL, PERIOD_CURRENT, Auto_ADX_Period(), PRICE_CLOSE, MODE_MAIN, 0);
   // Timeframe factor (higher Use_TF() -> stricter): M1..MN1
   int tf = Period();
   if (tf <= PERIOD_M5)
     tfFactor = 0.8;
   else if (tf <= PERIOD_M15)
     tfFactor = 1.0;
   else if (tf <= PERIOD_M30)
     tfFactor = 1.1;
   else if (tf <= PERIOD_H1)
     tfFactor = 1.2;
   else if (tf <= PERIOD_H4)
     tfFactor = 1.35;
   else
     tfFactor = 1.5;
   // Session factor (active hours ~ 7-20 server time)
   int hr = TimeHour(TimeCurrent());
   sessionFactor = (hr >= 7 && hr <= 20) ? 1.0 : 0.9;
}

