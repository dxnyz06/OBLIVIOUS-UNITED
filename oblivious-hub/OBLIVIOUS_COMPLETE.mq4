        return 0;
      int dc = 0;
      for (int i = 1; i <= 3; i++) {
        double ri = High[i] - Low[i], bi = MathAbs(Close[i] - Open[i]);
        if (ri > 0 && bi < ri * 0.1)
          dc++;
      }
      return (dc >= 3 ? 0.8 : 0); }

double Score_ConcealingBabySwallow(){
