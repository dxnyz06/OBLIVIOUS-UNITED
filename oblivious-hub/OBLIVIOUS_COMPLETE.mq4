                                          bool AIP2_GetBands_10tips_50(
                                              int side, double &lo1,
                                              double &hi1, double &lo2,
                                              double &hi2) {
                                            int tf = AIP2_LTF();
                                            int N = 10;
                                            int idxH = iHighest(
                                                Symbol(), tf, MODE_HIGH, N, 0);
                                            int idxL = iLowest(Symbol(), tf,
   MODE_LOW, N, 0);
                                            double HH =
                                                iHigh(Symbol(), tf, idxH);
                                            double LL =
                                                iLow(Symbol(), tf, idxL);
                                            double tr[];
                                            ArrayResize(tr, N);
                                            for (int i = 0; i < N; i++) {
                                              double h = iHigh(Symbol(), tf, i),
                                                     l = iLow(Symbol(), tf, i),
                                                     pc = iClose(Symbol(), tf,
   i + 1);
                                              tr[i] = MathMax(
                                                  h - l,
                                                  MathMax(MathAbs(h - pc),
                                                          MathAbs(l - pc)));
                                            }
                                            double med = AIP2_Median(tr, N);
                                            for (int j = 0; j < N; j++)
                                              tr[j] = MathAbs(tr[j] - med);
                                            double w = AIP2_Median(tr, N);
                                            double spr =
                                                MarketInfo(Symbol(),
                                                           MODE_SPREAD) *
                                                Point;
                                            double stp =
                                                MarketInfo(Symbol(),
                                                           MODE_STOPLEVEL) *
                                                Point;
                                            double width =
                                                MathMax(w, MathMax(spr, stp));
                                            if (side > 0) {
                                              lo1 = LL;
                                              hi1 = LL + width;
                                            } else {
                                              lo1 = HH - width;
                                              hi1 = HH;
                                            }
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt == AIP2_b2_time &&
                                                AIP2_b2_side == side) {
                                              lo2 = AIP2_b2_lo;
                                              hi2 = AIP2_b2_hi;
                                              return true;
                                            }
                                            if (side > 0) {
                                              lo2 = LL + width;
                                              hi2 = LL + 1.5 * width;
                                            } else {
                                              lo2 = HH - 1.5 * width;
                                              hi2 = HH - width;
                                            }
                                            AIP2_b2_time = bt;
                                            AIP2_b2_side = side;
                                            AIP2_b2_lo = lo2;
                                            AIP2_b2_hi = hi2;
                                            return true;
                                          }

                                          bool AIP2_T0_TickSequentialOK_G10(
                                              int side) {
                                            int tfL = AIP2_LTF();
                                            datetime bt =
                                                iTime(Symbol(), tfL, 0);
                                            if (bt != AIP2_g10_bar ||
                                                AIP2_g10_side != side)
                                              AIP2_G10_Reset(side);
                                            double lo1 = 0, hi1 = 0, lo2 = 0,
                                                   hi2 = 0, minD = 0, maxD = 0;
                                            if (!AIP2_GetBand1_LTF_10tips(
                                                    side, lo1, hi1))
                                              return false;
                                            if (!AIP2_GetBand2_HTF_far(
                                                    side, lo2, hi2, minD, maxD))
                                              return false;
                                            if (!AIP2_BandsDistanceOK_dyn(
                                                    lo1, hi1, lo2, hi2, minD,
                                                    maxD))
                                              return false;
                                            double olo1 = 0, ohi1 = 0;
                                            AIP2_GetBand1_LTF_10tips(
                                                -side, olo1, ohi1);
                                            double px = AIP2_TickMid();
                                            if (px >= MathMin(olo1, ohi1) &&
                                                px <= MathMax(olo1, ohi1))
                                              return false;
                                            if (!AIP2_g10_hit1) {
                                              if (px >= MathMin(lo1, hi1) &&
                                                  px <= MathMax(lo1, hi1))
                                                AIP2_g10_hit1 = true;
                                            } else if (!AIP2_g10_hit2) {
                                              if (px >= MathMin(lo2, hi2) &&
                                                  px <= MathMax(lo2, hi2))
                                                AIP2_g10_hit2 = true;
                                            }
                                            if (!AIP2_OTESeparationOK())
                                              return false;
                                            if (!AIP2_TouchedBothOTE_LTF())
                                              return false;
                                            return AIP2_g10_hit1 &&
                                                   AIP2_g10_hit2;
                                          }

                                          bool AIP2_T0_TickSequentialOK_B50(
                                              int side) {
                                            int tf = AIP2_LTF();
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt != AIP2_b50_bar ||
                                                AIP2_b50_side != side)
                                              AIP2_B50_Reset(side);
                                            double lo1 = 0, hi1 = 0, lo2 = 0,
                                                   hi2 = 0;
                                            if (!AIP2_GetBands_10tips_50(
                                                    side, lo1, hi1, lo2, hi2))
                                              return false;
                                            double opo_lo1 = 0, opo_hi1 = 0;
                                            AIP2_GetBands_10tips_50(
                                                -side, opo_lo1, opo_hi1, lo2,
                                                hi2);
                                            double px = AIP2_Mid();
                                            if (px >=
                                                    MathMin(opo_lo1, opo_hi1) &&
                                                px <= MathMax(opo_lo1, opo_hi1))
                                              return false;
                                            if (!AIP2_b50_hit1) {
                                              if (px >= MathMin(lo1, hi1) &&
                                                  px <= MathMax(lo1, hi1))
                                                AIP2_b50_hit1 = true;
                                            } else if (!AIP2_b50_hit2) {
                                              if (px >= MathMin(lo2, hi2) &&
                                                  px <= MathMax(lo2, hi2))
                                                AIP2_b50_hit2 = true;
                                            }
                                            if (!AIP2_OTESeparationOK())
                                              return false;
                                            if (!AIP2_TouchedBothOTE_LTF())
                                              return false;
                                            return AIP2_b50_hit1 &&
                                                   AIP2_b50_hit2;
                                          }

                                          bool AIP2_EnsurePendingForSide(
                                              int side, double b2_lo,
                                              double b2_hi, double volume) {
                                            int type = (side > 0 ? OP_BUYSTOP
   : OP_SELLSTOP);
                                            double price =
                                                (side > 0
                                                     ? b2_hi
                                                     : b2_lo); // trigger on
                                            // the band2
                                            // edge
                                            price =
                                                NormalizeDouble(price, Digits);
                                            int slippage = Slippage;
                                            // find existing pending of this
                                            // magic+type
                                            for (int i = 0; i < OrdersTotal();
                                                 i++) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    OrderMagicNumber() == PredictedMagic &&



                                                    OrderType() == type) {
                                                  // modify price if drifted
                                                  if (MathAbs(OrderOpenPrice() -
   price) >
                                                      MarketInfo(Symbol(),
   MODE_POINT) *
                                                          2) {
                                                    return OrderModify(
                                                        OrderTicket(), price,
                                                        OrderStopLoss(),
                                                        OrderTakeProfit(), 0);
                                                  }
                                                  return true;
                                                }
                                              }
                                            }
                                            // send new
                                            int tk = SafeOrderSend(
                                                Symbol(), type, volume, price,
                                                slippage, 0, 0, "AIP2-BAND50",
                                                PredictedMagic, 0, clrNONE);
                                            return (tk > 0);
                                          }

                                          bool AIP2_EnsurePendingAtEdge(
                                              int side, double b2_lo,
                                              double b2_hi, double volume) {
                                            int type = (side > 0 ? OP_BUYSTOP
   : OP_SELLSTOP);
                                            double price =
                                                (side > 0 ? b2_hi : b2_lo);
                                            price =
                                                NormalizeDouble(price, Digits);
                                            int slip = (int)MarketInfo(
                                                Symbol(), MODE_SPREAD);
                                            int found = -1;
                                            double pprev = 0;
                                            for (int i = 0; i < OrdersTotal();
                                                 i++) {
                                              if (OrderSelect(i, SELECT_BY_POS,
   MODE_TRADES)) {
                                                if (OrderSymbol() == Symbol() &&
                                                    OrderMagicNumber() == PredictedMagic &&



                                                    OrderType() == type) {
                                                  found = OrderTicket();
                                                  pprev = OrderOpenPrice();
                                                  break;
                                                }
                                              }
                                            }
                                            if (found < 0) {
                                              int tk = SafeOrderSend(
                                                  Symbol(), type, volume, price,
                                                  slip, 0, 0, "AIP2-DYNB2",
                                                  PredictedMagic, 0, clrNONE);
                                              return (tk > 0);
                                            } else {
                                              double diff =
                                                  MathAbs(pprev - price);
                                              if (diff >
                                                  2 * MarketInfo(Symbol(),
   MODE_POINT)) {
                                                return OrderModify(
                                                    found, price,
                                                    OrderStopLoss(),
                                                    OrderTakeProfit(), 0);
                                              }
                                              return true;
                                            }
                                          }

                                          bool AIP2_PreRangeBreakLive(
                                              int side, int tf, int lookback) {
                                            int s = lookback;
                                            double preHi = iHigh(
                                                Symbol(), tf,
                                                iHighest(Symbol(), tf,
                                                         MODE_HIGH, s, 1));
                                            double preLo =
                                                iLow(Symbol(), tf,
                                                     iLowest(Symbol(), tf,
   MODE_LOW, s, 1));
                                            double H = iHigh(Symbol(), tf, 0),
                                                   L = iLow(Symbol(), tf, 0);
                                            return (side > 0 ? (H > preHi)
   : (L < preLo));
                                          }

                                          void AIP2_ManageDualSides_T0() {
                                            int tf = AIP2_LTF();
                                            datetime bt =
                                                iTime(Symbol(), tf, 0);
                                            if (bt != AIP2_ns_bar)
                                              AIP2_ResetNewsState();
                                            // Structural guards
                                            if (!AIP2_IsImpulseLive())
                                              return;
                                            if (!AIP2_OTESeparationOK())
                                              return;
                                            if (!AIP2_TouchedBothOTE_LTF())
                                              return;
                                            double vol = NormalizeDouble(
                                                MarketInfo(Symbol(),
                                                           MODE_MINLOT),
                                                2);
                                            double px = AIP2_TickMid();
                                            // ---- SELL side ----
                                            if (AIP2_BreakPreRangeLive(-1)) {
                                              double s1_lo, s1_hi, s2_lo, s2_hi;
                                              AIP2_GetBands10_50_dynamic(
                                                  -1, s1_lo, s1_hi, s2_lo,
                                                  s2_hi);
                                              // step 1: touch band1
                                              if (!AIP2_hit1_sell &&
                                                  px >= MathMin(s1_lo, s1_hi) &&
                                                  px <= MathMax(s1_lo, s1_hi))
                                                AIP2_hit1_sell = true;
                                              // step 2: once step1 true ->
                                              // arm band2 pending and
                                              // detect touch
                                              if (AIP2_hit1_sell) {
                                                if (!AIP2_armed_sell) {
                                                  if (AIP2_EnsurePendingForSide(
                                                          -1, s2_lo, s2_hi,
                                                          vol))
                                                    AIP2_armed_sell = true;
                                                }
                                                if (px <= MathMin(s2_lo, s2_hi))
                                                  AIP2_hit2_sell =
                                                      true; // touched band2
                                                // edge
                                              }
                                            }
                                            // ---- BUY side ----
                                            if (AIP2_BreakPreRangeLive(+1)) {
                                              double b1_lo, b1_hi, b2_lo, b2_hi;
                                              AIP2_GetBands10_50_dynamic(
                                                  +1, b1_lo, b1_hi, b2_lo,
                                                  b2_hi);
                                              if (!AIP2_hit1_buy &&
                                                  px >= MathMin(b1_lo, b1_hi) &&
                                                  px <= MathMax(b1_lo, b1_hi))
                                                AIP2_hit1_buy = true;
                                              if (AIP2_hit1_buy) {
                                                if (!AIP2_armed_buy) {
                                                  if (AIP2_EnsurePendingForSide(
                                                          +1, b2_lo, b2_hi,
                                                          vol))
                                                    AIP2_armed_buy = true;
                                                }
                                                if (px >= MathMax(b2_lo, b2_hi))
                                                  AIP2_hit2_buy = true;
                                              }
                                            }
                                          }

                                          bool Mode_FVG() {
                                            if (!GlobalStrategyGuards())
                                              return (false);
                                            double rsiVal = iRSI(Symbol(), 0, 14, PRICE_CLOSE, 0);
                                            double adxVal = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0);
                                            return (IsFVG() && rsiVal > Auto_RSI_High() && adxVal > 20);
                                          }

