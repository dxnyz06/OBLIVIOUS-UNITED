int Check_Aroon(string sym, int tf, double &confidence)
{
      int period = 25;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      int highIdx = iHighest(sym, tf, MODE_HIGH, period, 0);
      int lowIdx = iLowest(sym, tf, MODE_LOW, period, 0);
      double aroonUp = 100.0 * (period - highIdx) / period;
      double aroonDown = 100.0 * (period - lowIdx) / period;
      double osc = aroonUp - aroonDown;
      confidence = MathAbs(osc);
      if (aroonUp > 70 && aroonDown < 30)
        return +1;
      if (aroonDown > 70 && aroonUp < 30)
        return -1;
      return 0;
}

int Check_AVWAP(string sym, int tf, double &confidence)
{
      int lookback = 20;
      if (iBars(sym, tf) < lookback + 2) {
        confidence = 0;
        return 0;
      }
      double sumPV = 0, sumV = 0;
      for (int i = 0; i < lookback; i++) {
        double vol = (double)iVolume(sym, tf, i);
        double tp =
            (iHigh(sym, tf, i) + iLow(sym, tf, i) + iClose(sym, tf, i)) / 3.0;
        sumPV += tp * vol;
        sumV += vol;
      }
      double vwap = (sumV > 0) ? sumPV / sumV : iClose(sym, tf, 0);
      double price = iClose(sym, tf, 0);
      double atr = iATR(sym, tf, 14, 0);
      double dist = (atr > 0) ? (price - vwap) / atr : 0;
      confidence = MathMin(100, MathAbs(dist) * 30);
      if (price > vwap)
        return +1;
      if (price < vwap)
        return -1;
      return 0;
}

int Check_ChandelierExit(string sym, int tf, double &confidence)
{
      int period = 22;
      double mult = 3.0;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      double atr = iATR(sym, tf, period, 0);
      int highIdx = iHighest(sym, tf, MODE_HIGH, period, 0);
      int lowIdx = iLowest(sym, tf, MODE_LOW, period, 0);
      double highestHigh = iHigh(sym, tf, highIdx);
      double lowestLow = iLow(sym, tf, lowIdx);
      double longStop = highestHigh - mult * atr; // exit long below this
      double shortStop = lowestLow + mult * atr;  // exit short above this
      double price = iClose(sym, tf, 0);
      confidence =
          MathMin(100, (atr > 0 ? MathAbs(price - longStop) / atr * 25 : 0));
      if (price > longStop && price > shortStop)
        return +1; // bullish
      if (price < shortStop && price < longStop)
        return -1; // bearish
      return 0;
}

int Check_CMF(string sym, int tf, double &confidence)
{
      int period = 20;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      double sumMFV = 0, sumVol = 0;
      for (int i = 0; i < period; i++) {
        double high = iHigh(sym, tf, i);
        double low = iLow(sym, tf, i);
        double close = iClose(sym, tf, i);
        double vol = (double)iVolume(sym, tf, i);
        double range = high - low;
        double mfm = (range > 0) ? ((close - low) - (high - close)) / range : 0;
        sumMFV += mfm * vol;
        sumVol += vol;
      }
      double cmf = (sumVol > 0) ? sumMFV / sumVol : 0;
      confidence = MathMin(100, MathAbs(cmf) * 200);
      if (cmf > 0.05)
        return +1; // accumulation
      if (cmf < -0.05)
        return -1; // distribution
      return 0;
}

int Check_DeMarker(string sym, int tf, double &confidence)
{
      double dm = iDeMarker(sym, tf, 14, 0);
      confidence = MathMin(100, MathAbs(dm - 0.5) * 200);
      if (dm > 0.7)
        return -1; // overbought ? bearish
      if (dm < 0.3)
        return +1; // oversold ? bullish
      if (dm > 0.5)
        return +1; // mild bullish
      return -1;   // mild bearish
}

int Check_Donchian(string sym, int tf, double &confidence)
{
      int period = 20;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      int highIdx = iHighest(sym, tf, MODE_HIGH, period, 1);
      int lowIdx = iLowest(sym, tf, MODE_LOW, period, 1);
      double upper = iHigh(sym, tf, highIdx);
      double lower = iLow(sym, tf, lowIdx);
      double mid = (upper + lower) / 2.0;
      double price = iClose(sym, tf, 0);
      double range = upper - lower;
      confidence =
          (range > 0) ? MathMin(100, MathAbs(price - mid) / range * 200) : 0;
      if (price > upper)
        return +1; // breakout up
      if (price < lower)
        return -1; // breakout down
      if (price > mid)
        return +1;
      return -1;
}

int Check_EfficiencyRatio(string sym, int tf, double &confidence)
{
      int period = 10;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      double direction = MathAbs(iClose(sym, tf, 0) - iClose(sym, tf, period));
      double volatility = 0;
      for (int i = 0; i < period; i++)
        volatility += MathAbs(iClose(sym, tf, i) - iClose(sym, tf, i + 1));
      double er = (volatility > 0) ? direction / volatility : 0;
      confidence = er * 100;
      // ER > 0.6 = trending (pass), ER < 0.3 = choppy (fail)
      if (er > 0.6)
        return +1; // trending
      if (er < 0.3)
        return -1; // choppy ÃƒÃ‚Â¯ÃƒÃ‚Â¿ÃƒÃ‚Â½ avoid
      return 0;
}

int Check_ElderRay(string sym, int tf, double &confidence)
{
      int period = 13;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      double ema = iMA(sym, tf, period, 0, MODE_EMA, PRICE_CLOSE, 0);
      double bullPower = iHigh(sym, tf, 0) - ema;
      double bearPower = iLow(sym, tf, 0) - ema;
      confidence = MathMin(100, (MathAbs(bullPower) + MathAbs(bearPower)) /
                                    (iATR(sym, tf, 14, 0) + 0.00001) * 25);
      if (bullPower > 0 && bearPower > 0)
        return +1; // strong bull
      if (bullPower < 0 && bearPower < 0)
        return -1; // strong bear
      if (bullPower > 0)
        return +1; // mild bull
      return -1;
}

int Check_Fibo(string sym, int tf, double &confidence)
{
      int lookback = 50;
      if (iBars(sym, tf) < lookback + 2) {
        confidence = 0;
        return 0;
      }
      int highIdx = iHighest(sym, tf, MODE_HIGH, lookback, 0);
      int lowIdx = iLowest(sym, tf, MODE_LOW, lookback, 0);
      double swingH = iHigh(sym, tf, highIdx);
      double swingL = iLow(sym, tf, lowIdx);
      double range = swingH - swingL;
      if (range <= 0) {
        confidence = 0;
        return 0;
      }
      double price = iClose(sym, tf, 0);
      // Key fib levels from swing low
      double fib382 = swingL + range * 0.382;
      double fib500 = swingL + range * 0.500;
      double fib618 = swingL + range * 0.618;
      // Distance to nearest fib level
      double d382 = MathAbs(price - fib382);
      double d500 = MathAbs(price - fib500);
      double d618 = MathAbs(price - fib618);
      double minDist = MathMin(d382, MathMin(d500, d618));
      double atr = iATR(sym, tf, 14, 0);
      bool nearFib = (atr > 0 && minDist < atr * 0.5);
      confidence =
          nearFib ? MathMin(100, (1.0 - minDist / (atr + 0.00001)) * 80) : 20;
      // Above 61.8 = bullish bias, below 38.2 = bearish bias
      if (price > fib618)
        return +1;
      if (price < fib382)
        return -1;
      return 0; // in consolidation zone
}

int Check_ForceIndex(string sym, int tf, double &confidence)
{
      double fi = iForce(sym, tf, 13, MODE_EMA, PRICE_CLOSE, 0);
      double fiPrev = iForce(sym, tf, 13, MODE_EMA, PRICE_CLOSE, 1);
      double atr = iATR(sym, tf, 14, 0);
      confidence = MathMin(
          100, MathAbs(fi) /
                   (atr * (double)iVolume(sym, tf, 0) / 10000.0 + 0.00001) *
                   50);
      if (fi > 0 && fi > fiPrev)
        return +1; // bullish pressure rising
      if (fi < 0 && fi < fiPrev)
        return -1; // bearish pressure rising
      return 0;
}

int Check_GannHiLo(string sym, int tf, double &confidence)
{
      int period = 13;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      // SMA of highs and SMA of lows (shifted)
      double smaHigh = 0, smaLow = 0;
      for (int i = 1; i <= period; i++) {
        smaHigh += iHigh(sym, tf, i);
        smaLow += iLow(sym, tf, i);
      }
      smaHigh /= period;
      smaLow /= period;
      double price = iClose(sym, tf, 0);
      double atr = iATR(sym, tf, 14, 0);
      confidence = MathMin(100, MathAbs(price - (smaHigh + smaLow) / 2.0) /
                                    (atr + 0.00001) * 30);
      if (price > smaHigh)
        return +1; // bullish
      if (price < smaLow)
        return -1; // bearish
      return 0;
}

int Check_HeikenAshi(string sym, int tf, double &confidence)
{
      if (iBars(sym, tf) < 3) {
        confidence = 0;
        return 0;
      }
      // Current bar HA values
      double haClose = (iOpen(sym, tf, 0) + iHigh(sym, tf, 0) +
                        iLow(sym, tf, 0) + iClose(sym, tf, 0)) /
                       4.0;
      double prevHaOpen = (iOpen(sym, tf, 1) + iClose(sym, tf, 1)) / 2.0;
      double haOpen = (prevHaOpen + (iOpen(sym, tf, 0) + iHigh(sym, tf, 0) +
                                     iLow(sym, tf, 0) + iClose(sym, tf, 0)) /
                                        4.0) /
                      2.0;
      double haHigh = MathMax(iHigh(sym, tf, 0), MathMax(haOpen, haClose));
      double haLow = MathMin(iLow(sym, tf, 0), MathMin(haOpen, haClose));
      bool bull = (haClose > haOpen);
      double body = MathAbs(haClose - haOpen);
      double range = haHigh - haLow;
      confidence = (range > 0) ? MathMin(100, body / range * 100) : 0;
      // No lower wick on bull candle = strong bull
      if (bull && MathMin(haOpen, haClose) == haLow)
        confidence = MathMin(100, confidence + 20);
      if (!bull && MathMax(haOpen, haClose) == haHigh)
        confidence = MathMin(100, confidence + 20);
      return bull ? +1 : -1;
}

int Check_KAMA(string sym, int tf, double &confidence)
{
      int erPeriod = 10;
      double fastSC = 2.0 / (2 + 1);  // fast constant
      double slowSC = 2.0 / (30 + 1); // slow constant
      if (iBars(sym, tf) < erPeriod + 32) {
        confidence = 0;
        return 0;
      }
      // Efficiency Ratio
      double direction =
          MathAbs(iClose(sym, tf, 0) - iClose(sym, tf, erPeriod));
      double volatility = 0;
      for (int i = 0; i < erPeriod; i++)
        volatility += MathAbs(iClose(sym, tf, i) - iClose(sym, tf, i + 1));
      double er = (volatility > 0) ? direction / volatility : 0;
      double sc = er * (fastSC - slowSC) + slowSC;
      sc = sc * sc; // squared
      // Approximate KAMA ÃƒÃ‚Â¯ÃƒÃ‚Â¿ÃƒÃ‚Â½ use EMA as seed
      double kama = iMA(sym, tf, erPeriod, 0, MODE_EMA, PRICE_CLOSE, 0);
      // Simple approximation: blend EMA with speed
      double sma = iMA(sym, tf, 30, 0, MODE_SMA, PRICE_CLOSE, 0);
      kama = sma + sc * (iClose(sym, tf, 0) - sma);
      double price = iClose(sym, tf, 0);
      double atr = iATR(sym, tf, 14, 0);
      confidence = MathMin(100, MathAbs(price - kama) / (atr + 0.00001) * 40);
      if (price > kama)
        return +1;
      if (price < kama)
        return -1;
      return 0;
}

int Check_LaguerreRSI(string sym, int tf, double &confidence)
{
      // Laguerre filter applied to RSI concept
      double gamma = 0.7; // damping factor
      if (iBars(sym, tf) < 10) {
        confidence = 0;
        return 0;
      }
      // Simplified Laguerre RSI using 4-element filter
      double L0 = 0, L1 = 0, L2 = 0, L3 = 0;
      double L0_1 = 0, L1_1 = 0, L2_1 = 0, L3_1 = 0;
      // Compute over last 8 bars (reverse)
      for (int i = 7; i >= 0; i--) {
        double price = iClose(sym, tf, i);
        L0_1 = L0;
        L1_1 = L1;
        L2_1 = L2;
        L3_1 = L3;
        L0 = (1.0 - gamma) * price + gamma * L0_1;
        L1 = -gamma * L0 + L0_1 + gamma * L1_1;
        L2 = -gamma * L1 + L1_1 + gamma * L2_1;
        L3 = -gamma * L2 + L2_1 + gamma * L3_1;
      }
      double cu = 0, cd = 0;
      if (L0 >= L1)
        cu += (L0 - L1);
      else
        cd += (L1 - L0);
      if (L1 >= L2)
        cu += (L1 - L2);
      else
        cd += (L2 - L1);
      if (L2 >= L3)
        cu += (L2 - L3);
      else
        cd += (L3 - L2);
      double lrsi = (cu + cd > 0) ? cu / (cu + cd) : 0.5;
      confidence = MathMin(100, MathAbs(lrsi - 0.5) * 200);
      if (lrsi > 0.8)
        return -1; // overbought
      if (lrsi < 0.2)
        return +1; // oversold
      if (lrsi > 0.5)
        return +1;
      return -1;
}

int Check_LinReg(string sym, int tf, double &confidence)
{
      int period = 14;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      // Calculate linear regression slope
      double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
      for (int i = 0; i < period; i++) {
        double x = (double)i;
        double y = iClose(sym, tf, period - 1 - i); // oldest first
        sumX += x;
        sumY += y;
        sumXY += x * y;
        sumX2 += x * x;
      }
      double n = (double)period;
      double denom = (n * sumX2 - sumX * sumX);
      if (MathAbs(denom) < 0.0000001) {
        confidence = 0;
        return 0;
      }
      double slope = (n * sumXY - sumX * sumY) / denom;
      double atr = iATR(sym, tf, 14, 0);
      double normSlope = (atr > 0) ? slope / atr : 0;
      confidence = MathMin(100, MathAbs(normSlope) * 100);
      if (slope > 0)
        return +1; // rising trend
      if (slope < 0)
        return -1; // falling trend
      return 0;
}

int Check_MFI(string sym, int tf, double &confidence)
{
      int period = 14;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      // Calculate MFI manually
      double posFlow = 0, negFlow = 0;
      for (int i = 0; i < period; i++) {
        double tp_curr =
            (iHigh(sym, tf, i) + iLow(sym, tf, i) + iClose(sym, tf, i)) / 3.0;
        double tp_prev = (iHigh(sym, tf, i + 1) + iLow(sym, tf, i + 1) +
                          iClose(sym, tf, i + 1)) /
                         3.0;
        double rawMF = tp_curr * (double)iVolume(sym, tf, i);
        if (tp_curr > tp_prev)
          posFlow += rawMF;
        else
          negFlow += rawMF;
      }
      double mfi =
          (negFlow > 0) ? 100.0 - 100.0 / (1.0 + posFlow / negFlow) : 100.0;
      confidence = MathMin(100, MathAbs(mfi - 50) * 2);
      if (mfi > 80)
        return -1; // overbought
      if (mfi < 20)
        return +1; // oversold
      if (mfi > 50)
        return +1;
      return -1;
}

int Check_MultiTFTrend(string sym, int tf, double &confidence)
{
      // Check EMA20 vs EMA50 on M15, H1, H4
      int tfs[] = {PERIOD_M15, PERIOD_H1, PERIOD_H4};
      int bullCount = 0, bearCount = 0;
      for (int i = 0; i < 3; i++) {
        if (iBars(sym, tfs[i]) < 52)
          continue;
        double ema20 = iMA(sym, tfs[i], 20, 0, MODE_EMA, PRICE_CLOSE, 0);
        double ema50 = iMA(sym, tfs[i], 50, 0, MODE_EMA, PRICE_CLOSE, 0);
        if (ema20 > ema50)
          bullCount++;
        else
          bearCount++;
      }
      confidence = MathMax(bullCount, bearCount) / 3.0 * 100;
      if (bullCount == 3)
        return +1; // all bullish
      if (bearCount == 3)
        return -1; // all bearish
      return 0;    // mixed
}

int Check_OBV(string sym, int tf, double &confidence)
{
      if (iBars(sym, tf) < 22) {
        confidence = 0;
        return 0;
      }
      double obv0 = iOBV(sym, tf, PRICE_CLOSE, 0);
      double obv1 = iOBV(sym, tf, PRICE_CLOSE, 1);
      double obv5 = iOBV(sym, tf, PRICE_CLOSE, 5);
      // OBV slope (short vs medium)
      bool rising = (obv0 > obv1 && obv1 > obv5);
      bool falling = (obv0 < obv1 && obv1 < obv5);
      // Also check price/obv divergence
      double price0 = iClose(sym, tf, 0);
      double price5 = iClose(sym, tf, 5);
      bool bullDiv = (price0 < price5 && obv0 > obv5); // price down, OBV up
      bool bearDiv = (price0 > price5 && obv0 < obv5); // price up, OBV down
      confidence = (rising || falling) ? 70 : (bullDiv || bearDiv ? 60 : 30);
      if (rising || bullDiv)
        return +1;
      if (falling || bearDiv)
        return -1;
      return 0;
}

int Check_PriceAction(string sym, int tf, double &confidence)
{
      if (iBars(sym, tf) < 4) {
        confidence = 0;
        return 0;
      }
      int score = 0;
      int dir = 0;
      // Bullish Engulfing
      if (iClose(sym, tf, 1) > iOpen(sym, tf, 1) &&
          iClose(sym, tf, 2) < iOpen(sym, tf, 2) &&
          iClose(sym, tf, 1) > iOpen(sym, tf, 2) &&
          iOpen(sym, tf, 1) < iClose(sym, tf, 2)) {
        score += 2;
        dir += 1;
      }
      // Bearish Engulfing
      if (iClose(sym, tf, 1) < iOpen(sym, tf, 1) &&
          iClose(sym, tf, 2) > iOpen(sym, tf, 2) &&
          iClose(sym, tf, 1) < iOpen(sym, tf, 2) &&
          iOpen(sym, tf, 1) > iClose(sym, tf, 2)) {
        score += 2;
        dir -= 1;
      }
      // Pinbar (hammer/shooting star)
      double range1 = iHigh(sym, tf, 1) - iLow(sym, tf, 1);
      if (range1 > 0) {
        double body1 = MathAbs(iClose(sym, tf, 1) - iOpen(sym, tf, 1));
        double lowerW =
            MathMin(iOpen(sym, tf, 1), iClose(sym, tf, 1)) - iLow(sym, tf, 1);
        double upperW =
            iHigh(sym, tf, 1) - MathMax(iOpen(sym, tf, 1), iClose(sym, tf, 1));
        if (body1 < range1 * 0.35 && lowerW > body1 * 2.0 &&
            upperW < body1 * 0.5) {
          score += 1;
          dir += 1;
        } // hammer
        if (body1 < range1 * 0.35 && upperW > body1 * 2.0 &&
            lowerW < body1 * 0.5) {
          score += 1;
          dir -= 1;
        } // shooting star
      }
      // Doji
      if (range1 > 0 &&
          MathAbs(iClose(sym, tf, 1) - iOpen(sym, tf, 1)) < range1 * 0.1) {
        score += 1;
      } // neutral ÃƒÃ‚Â¯ÃƒÃ‚Â¿ÃƒÃ‚Â½ no dir change
      confidence = MathMin(100, score * 25);
      if (dir > 0)
        return +1;
      if (dir < 0)
        return -1;
      return 0;
}

int Check_QQE(string sym, int tf, double &confidence)
{
      int rsiPeriod = 14;
      int sfPeriod = 5; // smoothing factor
      if (iBars(sym, tf) < rsiPeriod + sfPeriod + 5) {
        confidence = 0;
        return 0;
      }
      // Smoothed RSI via EMA
      double rsi0 = iRSI(sym, tf, rsiPeriod, PRICE_CLOSE, 0);
      double rsi1 = iRSI(sym, tf, rsiPeriod, PRICE_CLOSE, 1);
      double rsi2 = iRSI(sym, tf, rsiPeriod, PRICE_CLOSE, 2);
      // Simple 3-bar EMA approximation of RSI
      double k = 2.0 / (sfPeriod + 1);
      double smoothRSI =
          rsi0 * k + rsi1 * k * (1 - k) + rsi2 * (1 - k) * (1 - k);
      // QQE trailing line: RSI ÃƒÃ‚Â¯ÃƒÃ‚Â¿ÃƒÃ‚Â½ ATR-of-RSI
      double rsiATR = MathAbs(rsi0 - rsi1);
      double qqeLine = smoothRSI - 4.236 * rsiATR;
      confidence = MathMin(100, MathAbs(smoothRSI - 50) * 2);
      if (smoothRSI > 50 && rsi0 > rsi1)
        return +1;
      if (smoothRSI < 50 && rsi0 < rsi1)
        return -1;
      return 0;
}

int Check_Reflex(string sym, int tf, double &confidence)
{
      int period = 20;
      if (iBars(sym, tf) < period + 5) {
        confidence = 0;
        return 0;
      }
      // Simplified Reflex: difference between current close and SMA with slope
      double sma = iMA(sym, tf, period, 0, MODE_SMA, PRICE_CLOSE, 0);
      double smaPrev = iMA(sym, tf, period, 0, MODE_SMA, PRICE_CLOSE, 1);
      double price = iClose(sym, tf, 0);
      double priceMid = iClose(sym, tf, period / 2);
      // Reflex = normalized difference
      double atr = iATR(sym, tf, 14, 0);
      double reflex =
          (atr > 0) ? (price - 2.0 * priceMid + iClose(sym, tf, period)) / atr
                    : 0;
      confidence = MathMin(100, MathAbs(reflex) * 50);
      if (reflex > 0.1)
        return +1; // bullish reflex
      if (reflex < -0.1)
        return -1; // bearish reflex
      return 0;
}

int Check_ROC(string sym, int tf, double &confidence)
{
      int period = 12;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      double price0 = iClose(sym, tf, 0);
      double priceN = iClose(sym, tf, period);
      double roc = (priceN > 0) ? ((price0 - priceN) / priceN) * 100.0 : 0;
      confidence = MathMin(100, MathAbs(roc) * 10);
      if (roc > 0.5)
        return +1; // positive momentum
      if (roc < -0.5)
        return -1; // negative momentum
      return 0;
}

int Check_SchaffTrendCycle(string sym, int tf, double &confidence)
{
      // STC = double-smoothed Stochastic of MACD
      if (iBars(sym, tf) < 50) {
        confidence = 0;
        return 0;
      }
      double macd0 = iMACD(sym, tf, 23, 50, 1, PRICE_CLOSE, MODE_MAIN, 0);
      // Stochastic of MACD over 10 bars
      double macdHigh = macd0, macdLow = macd0;
      for (int i = 1; i < 10; i++) {
        double m = iMACD(sym, tf, 23, 50, 1, PRICE_CLOSE, MODE_MAIN, i);
        if (m > macdHigh)
          macdHigh = m;
        if (m < macdLow)
          macdLow = m;
      }
      double range = macdHigh - macdLow;
      double stc = (range > 0) ? (macd0 - macdLow) / range * 100.0 : 50.0;
      confidence = MathMin(100, MathAbs(stc - 50) * 2);
      if (stc > 75)
        return +1; // bullish trend confirmed
      if (stc < 25)
        return -1; // bearish trend confirmed
      return 0;
}

int Check_StdDev(string sym, int tf, double &confidence)
{
      double sd = iStdDev(sym, tf, 20, 0, MODE_SMA, PRICE_CLOSE, 0);
      double sdPrev = iStdDev(sym, tf, 20, 0, MODE_SMA, PRICE_CLOSE, 1);
      double atr = iATR(sym, tf, 14, 0);
      // Normalize: high volatility = stronger trend
      double ratio = (atr > 0) ? sd / atr : 0;
      confidence = MathMin(100, ratio * 60);
      if (sd > sdPrev && ratio > 0.8)
        return +1; // expanding volatility = trend
      if (sd < sdPrev && ratio < 0.5)
        return -1; // contracting = ranging
      return 0;
}

int Check_TEMA(string sym, int tf, double &confidence)
{
      int period = 20;
      if (iBars(sym, tf) < period * 3 + 5) {
        confidence = 0;
        return 0;
      }
      // TEMA = 3*EMA1 - 3*EMA2 + EMA3
      double ema1 = iMA(sym, tf, period, 0, MODE_EMA, PRICE_CLOSE, 0);
      // EMA of EMA (approximation using array)
      double ema2 = 0;
      {
        double sum = 0;
        for (int i = 0; i < period; i++)
          sum += iMA(sym, tf, period, 0, MODE_EMA, PRICE_CLOSE, i);
        ema2 = sum / period;
      }
      // EMA of EMA of EMA (further smoothing)
      double ema3 = (ema1 + ema2) / 2.0; // simplified triple smooth
      double tema = 3.0 * ema1 - 3.0 * ema2 + ema3;
      double price = iClose(sym, tf, 0);
      double atr = iATR(sym, tf, 14, 0);
      confidence = MathMin(100, MathAbs(price - tema) / (atr + 0.00001) * 40);
      if (price > tema)
        return +1;
      if (price < tema)
        return -1;
      return 0;
}

int Check_TRIX(string sym, int tf, double &confidence)
{
      int period = 15;
      if (iBars(sym, tf) < period * 3 + 5) {
        confidence = 0;
        return 0;
      }
      // Approximate TRIX: ROC of triple EMA
      double tema0 = iMA(sym, tf, period, 0, MODE_EMA, PRICE_CLOSE, 0);
      double tema1 = iMA(sym, tf, period, 0, MODE_EMA, PRICE_CLOSE, 1);
      // Use 2nd EMA layer
      double ema2_0 =
          (tema0 + iMA(sym, tf, period * 2, 0, MODE_EMA, PRICE_CLOSE, 0)) / 2.0;
      double ema2_1 =
          (tema1 + iMA(sym, tf, period * 2, 0, MODE_EMA, PRICE_CLOSE, 1)) / 2.0;
      double trix = (ema2_1 > 0) ? (ema2_0 - ema2_1) / ema2_1 * 10000 : 0;
      confidence = MathMin(100, MathAbs(trix) * 20);
      if (trix > 0)
        return +1;
      if (trix < 0)
        return -1;
      return 0;
}

int Check_UlcerIndex(string sym, int tf, double &confidence)
{
      int period = 14;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      // Find highest close in period, then compute % drawdowns
      int highIdx = iHighest(sym, tf, MODE_CLOSE, period, 0);
      double highestClose = iClose(sym, tf, highIdx);
      double sumSq = 0;
      for (int i = 0; i < period; i++) {
        double pctDD =
            (highestClose > 0)
                ? (iClose(sym, tf, i) - highestClose) / highestClose * 100.0
                : 0;
        sumSq += pctDD * pctDD;
      }
      double ui = MathSqrt(sumSq / period);
      confidence = MathMin(100, MathMax(0, 100 - ui * 15));
      if (ui < 3)
        return +1; // low risk, safe to trade
      if (ui > 8)
        return -1; // high downside risk, block
      return 0;
}

int Check_Vortex(string sym, int tf, double &confidence)
{
      int period = 14;
      if (iBars(sym, tf) < period + 2) {
        confidence = 0;
        return 0;
      }
      double sumVMplus = 0, sumVMminus = 0, sumTR = 0;
      for (int i = 0; i < period; i++) {
        double high0 = iHigh(sym, tf, i);
        double low0 = iLow(sym, tf, i);
        double high1 = iHigh(sym, tf, i + 1);
        double low1 = iLow(sym, tf, i + 1);
        double close1 = iClose(sym, tf, i + 1);
        sumVMplus += MathAbs(high0 - low1);
        sumVMminus += MathAbs(low0 - high1);
        double tr = MathMax(high0 - low0, MathMax(MathAbs(high0 - close1),
                                                  MathAbs(low0 - close1)));
        sumTR += tr;
      }
      double viPlus = (sumTR > 0) ? sumVMplus / sumTR : 0;
      double viMinus = (sumTR > 0) ? sumVMminus / sumTR : 0;
      confidence = MathMin(100, MathAbs(viPlus - viMinus) * 100);
      if (viPlus > viMinus && viPlus > 1.0)
        return +1; // bullish
      if (viMinus > viPlus && viMinus > 1.0)
        return -1; // bearish
      if (viPlus > viMinus)
        return +1;
      return -1;
}

double ADV_Tol_ICT(int tf, int shift)
{
      double pip = ADV_Pip();
      double atr = ADV_ATR(tf, MathMax(10, Auto_ATR_Period()), shift);
      if (atr <= 0.0)
        atr = 10.0 * pip;
      double spr = MarketInfo(Symbol(), MODE_SPREAD) * pip;
      double tol = MathMax(0.10 * atr, 2.0 * spr);
      tol = MathMax(tol, 1.5 * pip);
      tol = MathMin(tol, 0.60 * atr);
      return tol;
}

bool ADV_PriceInZone_FVG(int tf, const ADV_FVG_ZONE &z)
{
      double h = iHigh(Symbol(), tf, 0);
      double l = iLow(Symbol(), tf, 0);
      if (h == 0.0 || l == 0.0)
        return false;
      if (h < z.bot)
        return false;
      if (l > z.top)
        return false;
      return true;
}

int ADV_MAGIC_FVG()   {
      return FVGMagic; }

int    ADV_MAGIC_SMC() {
      return (MagicNumberBase + 620);

      // ADVANCED ICT HELPERS: EQH/EQL liquidity pools, liquidity sweeps, order
      // blocks (Auto-adaptive via ATR/spread; no external files)

}
      double ADV_Tol(int tf, int shift) {
        double pip = ADV_Pip();
        double atr = ADV_ATR(tf, MathMax(10, Auto_ATR_Period()), shift);
        if (atr <= 0.0)
          atr = 10.0 * pip;
        double spr = MarketInfo(Symbol(), MODE_SPREAD) * pip;

        // Adaptive: wider tolerance in higher vol and higher spread conditions.
        // Uses ATR scale; clamp to avoid pathological tiny/huge.
        double tol = MathMax(0.10 * atr, 2.0 * spr);
        tol = MathMax(tol, 1.5 * pip);
        tol = MathMin(tol, 0.60 * atr);
        return tol;
      }

      // Find a simple but robust Order Block aligned with a displacement bar.
      // For dir>0: last bearish candle prior to the displacement move; dir<0:
      // last bullish candle.

      bool ADV_FindEQPool(int tf, int dir, int lookback, double &poolLevel,
                          int &touches) {
        poolLevel = 0.0;
        touches = 0;
        int bars = iBars(Symbol(), tf);
        if (bars < 20)
          return false;

        int maxShift = (int)MathMin(lookback, bars - 10);
        double tol0 = ADV_Tol(tf, 1);

        // Volatility regime: if ATR is small relative to recent range, require
        // more touches.
        double atr = ADV_ATR(tf, MathMax(10, Auto_ATR_Period()), 1);
        if (atr <= 0)
          atr = 10.0 * ADV_Pip();
        double rrHi, rrLo;
        ADV_RangeHL(tf, MathMin(maxShift, 200), rrHi, rrLo);
        double rr = MathMax(atr, rrHi - rrLo);
        double tightness = atr / rr; // smaller -> range-heavy
        int minTouches = (tightness < 0.25 ? 3 : 2);

        // Use fractals for candidate levels; cluster within tolerance.
        // Iterate recent shifts; build best cluster with max touches and
        // closest-to-price relevance.
        double bestLevel = 0.0;
        int bestTouches = 0;
        double bestScore = -1e9;

        for (int s = 5; s <= maxShift; s++) {
          double cand = 0.0;
          if (dir > 0) {
            // EQL from fractal lows
            double f = iFractals(Symbol(), tf, MODE_LOWER, s);
            if (f == 0.0)
              continue;
            cand = f;
          } else {
            // EQH from fractal highs
            double f = iFractals(Symbol(), tf, MODE_UPPER, s);
            if (f == 0.0)
              continue;
            cand = f;
          }

          // Count touches around this level.
          int cnt = 0;
          double tol = MathMax(tol0, ADV_Tol(tf, s));
          for (int j = s; j <= maxShift; j++) {
            double v =
                (dir > 0 ? iLow(Symbol(), tf, j) : iHigh(Symbol(), tf, j));
            if (MathAbs(v - cand) <= tol)
              cnt++;
          }
          if (cnt < minTouches)
            continue;

          // Score: prefer more touches and more recent.
          double rec = 1.0 / (1.0 + 0.02 * s);
          double score = (double)cnt + 0.5 * rec;
          if (score > bestScore) {
            bestScore = score;
            bestLevel = cand;
            bestTouches = cnt;
          }
        }

        if (bestTouches < minTouches)
          return false;
        poolLevel = bestLevel;
        touches = bestTouches;
        return true;
      }

      // True if there is a liquidity sweep (raid) of the pool on tf.
      // For buy (dir>0): wick below pool and close back above.
      // For sell (dir<0): wick above pool and close back below.
      // Also returns sweepShift (bar shift where sweep happened).

      // Find the first (most recent) zone touch shift on tf within a window.

      // Professional FVG finder with POI scoring and optional OB requirement.
      // - Displacement is adaptive via ATR regime.
      // - OB alignment can be required (ICT) or preferred (standalone FVG).

      bool ADV_FindFVG_Pro(int tf, int dir, int lookback, bool requireOB,
                           ADV_FVG_ZONE &z, ADV_OB_ZONE &obOut) {
        z.valid = false;
        z.dir = 0;
        z.tf = tf;
        obOut.valid = false;

        double pip = ADV_Pip();
        int bars = iBars(Symbol(), tf);
        if (bars < 30)
          return false;

        int maxShift = (int)MathMin(lookback, bars - 6);
        int atrP = (int)MathMax(10, Auto_ATR_Period());

        double bestScore = -1e18;
        ADV_FVG_ZONE bestZ;
        bestZ.valid = false;
        ADV_OB_ZONE bestOB;
        bestOB.valid = false;

        for (int i = 2; i <= maxShift; i++) {
          int newer = i;
          int middle = i + 1;
          int older = i + 2;

          double oMid = iOpen(Symbol(), tf, middle);
          double cMid = iClose(Symbol(), tf, middle);
          double hMid = iHigh(Symbol(), tf, middle);
          double lMid = iLow(Symbol(), tf, middle);

          double atr = ADV_ATR(tf, atrP, middle);
          if (atr <= 0)
            atr = 10.0 * pip;

          // Adaptive displacement threshold:
          // - if market is choppy (small body vs range), require larger
          // displacement
          double body = MathAbs(cMid - oMid);
          double rng = MathMax(1e-9, hMid - lMid);
          double bodyFrac = body / rng;
          double disp = MathMax(body, rng);

          double dispMult =
              (0.85 +
               0.60 * (1.0 - bodyFrac)); // more strict when bodyFrac small
          double dispThr = dispMult * atr;
          if (disp < dispThr)
            continue;

          // Identify FVG bounds
          if (Bridge_IsConnected()) {
            string aiPayload;
            if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
              if (StringFind(aiPayload, "fvg=0") >= 0) {
                Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
                return false;
              }
            }
          }
          double top = 0.0, bot = 0.0;
          if (dir > 0) {
            double hOld = iHigh(Symbol(), tf, older);
            double lNew = iLow(Symbol(), tf, newer);
            if (hOld >= lNew)
              continue;
            bot = hOld;
            top = lNew;
          } else {
            double lOld = iLow(Symbol(), tf, older);
            double hNew = iHigh(Symbol(), tf, newer);
            if (lOld <= hNew)
              continue;
            bot = hNew;
            top = lOld;
          }

          double gap = top - bot;
          // Adaptive min gap: fraction of ATR, but never below 1 pip-ish.
          double minGap = MathMax(0.12 * atr, 1.2 * pip);
          if (gap < minGap)
            continue;

          // Candidate zone
          ADV_FVG_ZONE cz;
          cz.valid = true;
          cz.dir = dir;
          cz.tf = tf;
          cz.barNewer = newer;
          cz.top = top;
          cz.bot = bot;
          cz.mid = (top + bot) * 0.5;
          cz.tForm = iTime(Symbol(), tf, newer);

          // Order block alignment (optional)
          ADV_OB_ZONE ob;
          bool hasOB = ADV_FindOrderBlock(tf, middle, dir, ob);
          if (requireOB && !hasOB)
            continue;

          // Score: prefer larger gap (normalized), fresher, OB presence, and
          // clean displacement.
          double fres = 1.0 / (1.0 + 0.03 * newer);
          double gapN = gap / atr;
          double dispN = disp / atr;
          double obBonus = (hasOB ? 0.8 : 0.0); // preferred if present
          double score = 2.0 * gapN + 1.0 * dispN + obBonus + 0.5 * fres;

          // Extra: if OB exists, prefer OB overlapping the FVG mid vicinity
          // (alignment)
          if (Bridge_IsConnected()) {
            string aiPayload;
            if (Bridge_GetAISignals(Symbol(), Period(), Time[0], aiPayload)) {
              if (StringFind(aiPayload, "fvg=0") >= 0) {
                Bridge_SendLog(1, "FVG", "AI suggests NO TRADE");
                return false;
              }
            }
          }
          if (hasOB) {
            double dist = MathAbs(ob.mid - cz.mid) / atr;
            score += MathMax(0.0, 0.6 - dist);
          }

          if (score > bestScore) {
            bestScore = score;
            bestZ = cz;
            bestOB = ob;
          }
        }

        if (!bestZ.valid)
          return false;
        z = bestZ;
        obOut = bestOB;
        return true;
      }

      // ICT-specific wrapper: OB required.

      bool ADV_FindFVG_ICT(int tf, int dir, int lookback, ADV_FVG_ZONE &z,
                           ADV_OB_ZONE &ob) {
        return ADV_FindFVG_Pro(tf, dir, lookback, true, z, ob);
      }

int ADV_MAGIC_EB()    {
      return 101200; }

bool ADV_LastFractal(int tf, int dir, int lookback, double &level, int &barShift)
{
      level = 0.0;
      barShift = -1;
      lookback = MathMax(10, lookback);
      for (int i = 2; i < lookback; i++) {
        double v = (dir > 0 ? iFractals(Symbol(), tf, MODE_UPPER, i)
                            : iFractals(Symbol(), tf, MODE_LOWER, i));
        if (v == 0.0)
          continue;
        level = v;
        barShift = i;
        return true;
      }
      return false;
}

int ADV_FirstZoneTouchShift(int tf, const ADV_FVG_ZONE &z, int maxLookback)
{
      int bars = iBars(Symbol(), tf);
      if (bars < 5)
        return -1;
      int maxShift = (int)MathMin(maxLookback, bars - 2);
      for (int s = 1; s <= maxShift; s++) {
        double h = iHigh(Symbol(), tf, s);
        double l = iLow(Symbol(), tf, s);
        if (h == 0.0 && l == 0.0)
          continue;
        if (h < z.bot)
          continue;
        if (l > z.top)
          continue;
        return s;
      }
      return -1;
}

bool ADV_FindFVG(int tf, int dir, int lookback, ADV_FVG_ZONE &z)
{
      z.valid = false;
      z.dir = 0;
      z.tf = tf;
      double pip = ADV_Pip();
      int bars = iBars(Symbol(), tf);
      if (bars < 10)
        return false;

      int maxShift = (int)MathMin(lookback, bars - 4);
      int atrP = (int)MathMax(10, Auto_ATR_Period());
      double minGap = MathMax(0.12 * ADV_ATR(tf, atrP, 2), 1.2 * pip);

      for (int i = 2; i <= maxShift; i++) {
        int newer = i;
        int middle = i + 1;
        int older = i + 2;

        double oMid = iOpen(Symbol(), tf, middle);
        double cMid = iClose(Symbol(), tf, middle);
        double hMid = iHigh(Symbol(), tf, middle);
        double lMid = iLow(Symbol(), tf, middle);

        double atr = ADV_ATR(tf, atrP, middle);
        if (atr <= 0.0)
          atr = 10.0 * pip;

        double disp = MathMax(MathAbs(cMid - oMid), (hMid - lMid));
        if (disp < (ADV_FVG_DISP_ATR_MULT * atr))
          continue;

        double top = 0.0, bot = 0.0;
        if (dir > 0) {
          double hOld = iHigh(Symbol(), tf, older);
          double lNew = iLow(Symbol(), tf, newer);
          if (hOld >= lNew)
            continue;
          bot = hOld;
          top = lNew;
        } else {
          double lOld = iLow(Symbol(), tf, older);
          double hNew = iHigh(Symbol(), tf, newer);
          if (lOld <= hNew)
            continue;
          bot = hNew;
          top = lOld;
        }

        if ((top - bot) < minGap)
          continue;

        z.valid = true;
        z.dir = dir;
        z.tf = tf;
        z.barNewer = newer;
        z.top = top;
        z.bot = bot;
        z.mid = (top + bot) * 0.5;
        z.tForm = iTime(Symbol(), tf, newer);
        return true;
      }
      return false;
}

bool ADV_FVG_IsFilled(int tf, const ADV_FVG_ZONE &z, int maxLookback)
{
      if (!z.valid)
        return true;
      int bars = iBars(Symbol(), tf);
      int maxShift = (int)MathMin(maxLookback, bars - 2);
      for (int s = 0; s <= maxShift; s++) {
        if (z.dir > 0 && iLow(Symbol(), tf, s) <= z.bot)
          return true;
        if (z.dir < 0 && iHigh(Symbol(), tf, s) >= z.top)
          return true;
      }
      return false;
}

bool ADV_FindEqualHighs(int tf, int lookback, double &level, int &count, double tolFactor=1.5)
{
      level = 0;
      count = 0;
      int bars = iBars(Symbol(), tf);
      if (bars < lookback)
        return false;

      double tol = ADV_Tol_ICT(tf, 1) * tolFactor;

      // Collect swing highs
      double highs[];
      int hShifts[];
      int nHighs = 0;

      for (int i = 2; i < lookback - 1; i++) {
        double h = iHigh(Symbol(), tf, i);
        double prev = iHigh(Symbol(), tf, i + 1);
        double next = iHigh(Symbol(), tf, i - 1);
        if (h > prev && h > next) {
          ArrayResize(highs, nHighs + 1);
          ArrayResize(hShifts, nHighs + 1);
          highs[nHighs] = h;
          hShifts[nHighs] = i;
          nHighs++;
        }
      }

      // Find clusters of equal highs
      int bestCount = 0;
      double bestLevel = 0;
      for (int i = 0; i < nHighs; i++) {
        int clusterCount = 1;
        double sum = highs[i];
        for (int j = i + 1; j < nHighs; j++) {
          if (MathAbs(highs[j] - highs[i]) <= tol) {
            clusterCount++;
            sum += highs[j];
          }
        }
        if (clusterCount > bestCount) {
          bestCount = clusterCount;
          bestLevel = sum / clusterCount;
        }
      }

      if (bestCount >= 2) {
        level = bestLevel;
        count = bestCount;
        return true;
      }
      return false;
}

bool ADV_FindEqualLows(int tf, int lookback, double &level, int &count, double tolFactor=1.5)
{
      level = 0;
      count = 0;
      int bars = iBars(Symbol(), tf);
      if (bars < lookback)
        return false;

      double tol = ADV_Tol_ICT(tf, 1) * tolFactor;

      double lows[];
      int nLows = 0;

      for (int i = 2; i < lookback - 1; i++) {
        double l = iLow(Symbol(), tf, i);
        double prev = iLow(Symbol(), tf, i + 1);
        double next = iLow(Symbol(), tf, i - 1);
        if (l < prev && l < next) {
          ArrayResize(lows, nLows + 1);
          lows[nLows] = l;
          nLows++;
        }
      }

      int bestCount = 0;
      double bestLevel = 0;
      for (int i = 0; i < nLows; i++) {
        int clusterCount = 1;
        double sum = lows[i];
        for (int j = i + 1; j < nLows; j++) {
          if (MathAbs(lows[j] - lows[i]) <= tol) {
            clusterCount++;
            sum += lows[j];
          }
        }
        if (clusterCount > bestCount) {
          bestCount = clusterCount;
          bestLevel = sum / clusterCount;
        }
      }

      if (bestCount >= 2) {
        level = bestLevel;
        count = bestCount;
        return true;
      }
      return false;
}

bool ADV_OB_StillValid(int tf, const ADV_OB_ZONE &ob, int maxLookback)
{
      if (!ob.valid)
        return false;
      int bars = iBars(Symbol(), tf);
      int maxShift = (int)MathMin(maxLookback, bars - 2);

      // Check if price has fully traversed the OB (mitigation)
      for (int s = 1; s <= maxShift; s++) {
        double h = iHigh(Symbol(), tf, s);
        double l = iLow(Symbol(), tf, s);
        bool fullCross = (ob.dir > 0 ? (l < ob.bot && h > ob.top)
                                     : (h > ob.top && l < ob.bot));
        if (fullCross)
          return false; // Mitigated
      }
      return true;
}

bool ADV_FindOB_MTF(int dir, ADV_OB_ZONE &ob)
{
      // Try current TF first, then higher TF
      int tf = Period();
      if (ADV_FindOrderBlock(tf, 2, dir, ob))
        return true;

      // Try higher TF
      int htf = tf * 4;
      if (htf > PERIOD_MN1)
        htf = PERIOD_MN1;
      return ADV_FindOrderBlock(htf, 2, dir, ob);
}

int TrendRegime(string sym, int tf) {
      double adx = iADX(sym, tf, 14, PRICE_CLOSE, MODE_MAIN, 0);
      return (adx > 30) ? 1 : 0; // 1=trending, 0=ranging
}

double TRavg_CS(int n)  {
      if (n <= 0)
        n = 14;
      double s = 0;
      for (int i = 1; i <= n; i++)
        s += TrueRange(i);
      return s / n; }

bool _HasFVG(int shift=1){
      if (shift + 3 >= Bars)
        return false;
      bool bull = (Low[shift] > High[shift + 2]);
      bool bear = (High[shift] < Low[shift + 2]);
      return (bull || bear);
}

bool CheckGhostCandle() {
      double open = iOpen(Symbol(), 0, 1);
      double close = iClose(Symbol(), 0, 1);
      return (NormalizeDouble(open - close, Digits) == 0);
}

bool DetectFVG() {
      double gap = High[2] - Low[1];
      bullishFVG_present = gap > 0 && Close[0] > High[2];
      gap = High[1] - Low[2];
      bearishFVG_present = gap > 0 && Close[0] < Low[2];
   return false;
}

bool DetectSupplyDemandZone(bool isDemandZone) {
      double atr = iATR(Symbol(), PERIOD_H1, Auto_ATR_Period(), 1);
      double runSize = High[2] - Low[2];
      if (runSize < 2 * atr)
        return false; // Non ÃƒÃ†ÃƒÃ‚Â¨ un run istituzionale
      // Controllo base consolidamento (2-5 barre)
      bool baseQuiet = true;
      for (int i = 3; i <= 7; i++) {
        if ((High[i] - Low[i]) > atr) {
          baseQuiet = false;
          break;
        }
      }
      if (!baseQuiet)
        return false;
      if (isDemandZone)
        return (Ask <= Low[2]); // prezzo vicino zona demand
      else
        return (Bid >= High[2]); // prezzo vicino zona supply
}

bool CheckSpinningTop(int i)
{
      double r = High[i] - Low[i];
      return (r > 0 && MathAbs(Open[i] - Close[i]) > 0.1 * r &&
              MathAbs(Open[i] - Close[i]) <= 0.3 * r);
}

bool CheckMarubozu(int shift) {
      double body = MathAbs(Open[shift] - Close[shift]),
             range = High[shift] - Low[shift];
      return (range > 0 && body >= 0.8 * range); }

bool CheckHammer(int shift) {
      double body = MathAbs(Open[shift] - Close[shift]),
             lowerShadow = MathMin(Open[shift], Close[shift]) - Low[shift],
             upperShadow = High[shift] - MathMax(Open[shift], Close[shift]);
      return (lowerShadow > 2 * body && upperShadow < 0.5 * body); }

bool CheckHangingMan(int i)         {
      double r = High[1] - Low[1], b = MathAbs(Close[1] - Open[1]);
      if (r <= 0)
        return false;
      double lw = MathMin(Open[1], Close[1]) - Low[1];
      return (b < r * 0.3 && lw > r * 0.6 && Close[2] > Open[2]); }

bool CheckInvertedHammer(int i)
{
      double b = MathAbs(Open[i] - Close[i]);
      double us = High[i] - MathMax(Open[i], Close[i]);
      double ls = MathMin(Open[i], Close[i]) - Low[i];
      return (us > 2 * b && ls < 0.5 * b);
}

bool CheckShootingStar(int shift) {
      return CheckInvertedHammer(shift); }

bool CheckHighWaveCandle(int i)
{
      double r = High[i] - Low[i];
      double b = MathAbs(Open[i] - Close[i]);
      return (r > 0 && b <= 0.25 * r &&
              (High[i] - MathMax(Open[i], Close[i])) > 0.3 * r &&
              (MathMin(Open[i], Close[i]) - Low[i]) > 0.3 * r);
}

bool CheckHaramiBullish(int shift) {
      return (Close[shift + 1] < Open[shift + 1] &&
              Close[shift] > Open[shift] && Open[shift] > Close[shift + 1] &&
              Close[shift] < Open[shift + 1]); }

bool CheckHaramiBearish(int shift) {
      return (Close[shift + 1] > Open[shift + 1] &&
              Close[shift] < Open[shift] && Open[shift] < Close[shift + 1] &&
              Close[shift] > Open[shift + 1]); }

bool CheckDarkCloudCover(int i)
{
      double mid = (Open[i + 1] + Close[i + 1]) * 0.5;
      return (Close[i + 1] > Open[i + 1] && Close[i] < Open[i] &&
              Open[i] > Close[i + 1] && Close[i] < mid &&
              Close[i] > Open[i + 1]);
}

bool CheckTweezerTop(int i)
{
      double tol = 2 * Point;
      return (MathAbs(High[i] - High[i + 1]) < tol && Close[i] < Open[i] &&
              Close[i + 1] > Open[i + 1]);
}

bool CheckTweezerBottom(int i)
{
      double tol = 2 * Point;
      return (MathAbs(Low[i] - Low[i + 1]) < tol && Close[i] > Open[i] &&
              Close[i + 1] < Open[i + 1]);
}

bool CheckRisingWindow(int i)       {
      if (Bars < 3)
        return false;
      return (Low[1] > High[2]); }

bool CheckFallingWindow(int i)      {
      if (Bars < 3)
        return false;
      return (High[1] < Low[2]); }

bool CheckBeltHold(int i)
{
      double tol = 2 * Point;
      return ((Close[i] > Open[i] && MathAbs(Open[i] - Low[i]) < tol) ||
              (Close[i] < Open[i] && MathAbs(Open[i] - High[i]) < tol));
}

bool CheckKicking(int i)
{
      return (CheckMarubozu(i + 1) && CheckMarubozu(i) &&
              ((Close[i + 1] > Open[i + 1] && Close[i] < Open[i]) ||
               (Close[i + 1] < Open[i + 1] && Close[i] > Open[i])));
}

bool CheckCounterattackLines(int i)
{
      double tol = 2 * Point;
      return (MathAbs(Close[i] - Close[i + 1]) < tol &&
              ((Close[i + 1] < Open[i + 1] && Close[i] > Open[i]) ||
               (Close[i + 1] > Open[i + 1] && Close[i] < Open[i])));
}

bool CheckMorningStar(int shift) {
      return (Close[shift + 2] < Open[shift + 2] &&
              MathAbs(Open[shift + 1] - Close[shift + 1]) <=
                  (High[shift + 1] - Low[shift + 1]) * 0.3 &&
              Close[shift] > Open[shift]); }

bool CheckEveningStar(int shift) {
      return (Close[shift + 2] > Open[shift + 2] &&
              MathAbs(Open[shift + 1] - Close[shift + 1]) <=
                  (High[shift + 1] - Low[shift + 1]) * 0.3 &&
              Close[shift] < Open[shift]); }

bool CheckThreeWhiteSoldiers(int i) {
      return (Close[i + 2] > Open[i + 2] && Close[i + 1] > Open[i + 1] &&
              Close[i] > Open[i] && Close[i + 1] > Close[i + 2] &&
              Close[i] > Close[i + 1]); }

bool CheckThreeBlackCrows(int i) {
      return (Close[i + 2] < Open[i + 2] && Close[i + 1] < Open[i + 1] &&
              Close[i] < Open[i] && Close[i + 1] < Close[i + 2] &&
              Close[i] < Close[i + 1]); }

bool CheckAbandonedBaby(int i)
{
      return (Close[i + 2] < Open[i + 2] &&
              MathAbs(Open[i + 1] - Close[i + 1]) <=
                  (High[i + 1] - Low[i + 1]) * 0.1 &&
              Close[i] > Open[i]);
}

bool CheckThreeInsideUp(int i)
{
      return (Close[i + 2] < Open[i + 2] && Close[i + 1] > Open[i + 1] &&
              High[i + 1] < High[i + 2] && Low[i + 1] > Low[i + 2] &&
              Close[i] > Open[i + 1]);
}

bool CheckThreeInsideDown(int i)
{
      return (Close[i + 2] > Open[i + 2] && Close[i + 1] < Open[i + 1] &&
              High[i + 1] < High[i + 2] && Low[i + 1] > Low[i + 2] &&
              Close[i] < Open[i + 1]);
}

bool CheckThreeOutsideUp(int i)
{
      return (Close[i + 2] < Open[i + 2] && Close[i + 1] > Open[i + 1] &&
              Open[i + 1] <= Close[i + 2] && Close[i + 1] >= Open[i + 2] &&
              Close[i] > High[i + 1]);
}

bool CheckThreeOutsideDown(int i)
{
      return (Close[i + 2] > Open[i + 2] && Close[i + 1] < Open[i + 1] &&
              Open[i + 1] >= Close[i + 2] && Close[i + 1] <= Open[i + 2] &&
              Close[i] < Low[i + 1]);
}

bool CheckTriStar(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      double r0 = _Range(i), r1 = _Range(i + 1), r2 = _Range(i + 2);
      if (r0 <= 0 || r1 <= 0 || r2 <= 0)
        return false;
      bool d0 = _Body(i) / r0 <= 0.10;
      bool d1 = _Body(i + 1) / r1 <= 0.10;
      bool d2 = _Body(i + 2) / r2 <= 0.10;
      return (d0 && d1 && d2);
}

bool CheckRisingThreeMethods(int i)
{
      if (!(Close[i + 4] > Open[i + 4]))
        return false;
      for (int k = i + 1; k <= i + 3; k++)
        if (Close[k] >= Open[k])
          return false;
      return (Close[i] > Open[i] && Close[i] > High[i + 4]);
}

bool CheckFallingThreeMethods(int i)
{
      if (!(Close[i + 4] < Open[i + 4]))
        return false;
      for (int k = i + 1; k <= i + 3; k++)
        if (Close[k] <= Open[k])
          return false;
      return (Close[i] < Open[i] && Close[i] < Low[i + 4]);
}

bool CheckSeparatingLines(int i){
      if (i < 1 || !_HasBars(i, 1))
        return false;
      double tol = 3 * Point;
      bool bull =
          (_IsBull(i + 1) && _IsBear(i) && _Near(Open[i], Open[i + 1], tol));
      bool bear =
          (_IsBear(i + 1) && _IsBull(i) && _Near(Open[i], Open[i + 1], tol));
      return (bull || bear);
}

bool CheckSideBySideWhiteLines(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      if (!_IsBull(i + 2) || !_IsBull(i + 1) || !_IsBull(i))
        return false;
      double tol = 5 * Point;
      return (_Near(Open[i + 1], Open[i], tol) &&
              _Near(Close[i + 1], Close[i], tol));
}

bool CheckTasukiGap(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      // Up: gap up between i+2 and i+1, third candle bearish that closes into
      // gap but not fill
      bool up = (_IsBull(i + 2) && _IsBull(i + 1) && Low[i + 1] > High[i + 2] &&
                 _IsBear(i) && Close[i] > High[i + 2] && Close[i] < Low[i + 1]);
      // Down: gap down, third bullish closes into gap but not fill
      bool dn = (_IsBear(i + 2) && _IsBear(i + 1) && High[i + 1] < Low[i + 2] &&
                 _IsBull(i) && Close[i] < Low[i + 2] && Close[i] > High[i + 1]);
      return (up || dn);
}

bool CheckUpsideGapThreeMethods(int i){
      if (i < 3 || !_HasBars(i, 3))
        return false;
      bool gap = (Low[i + 2] > High[i + 3]); // gap up
      bool small = (_Body(i + 1) < _Body(i + 2) && _Body(i) < _Body(i + 2));
      bool cont = (_IsBull(i + 2) && _IsBull(i) && Close[i] > Close[i + 2]);
      return (gap && small && cont);
}

bool CheckDownsideGapThreeMethods(int i){
      if (i < 3 || !_HasBars(i, 3))
        return false;
      bool gap = (High[i + 2] < Low[i + 3]); // gap down
      bool small = (_Body(i + 1) < _Body(i + 2) && _Body(i) < _Body(i + 2));
      bool cont = (_IsBear(i + 2) && _IsBear(i) && Close[i] < Close[i + 2]);
      return (gap && small && cont);
}

bool CheckDeliberation(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      if (!_IsBull(i + 2) || !_IsBull(i + 1) || !_IsBull(i))
        return false;
      double b2 = _Body(i + 2), b1 = _Body(i + 1), b0 = _Body(i);
      return (b2 > b1 && b1 > b0 && Close[i] > Close[i + 1]);
}

bool CheckExhaustionGap(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      bool gapUp = (Low[i + 1] > High[i + 2]);
      bool gapDn = (High[i + 1] < Low[i + 2]);
      bool revUp = (gapUp && _IsBear(i) && Close[i] < Open[i]);
      bool revDn = (gapDn && _IsBull(i) && Close[i] > Open[i]);
      return (revUp || revDn);
}

bool CheckConcealingBabySwallow(int i){
      if (i < 3 || !_HasBars(i, 3))
        return false;
      // 1&2: long bearish
      double r3 = _Range(i + 3);
      if (r3 <= 0)
        return false;
      double r2 = _Range(i + 2);
      if (r2 <= 0)
        return false;
      bool b1 = (_IsBear(i + 3) && _Body(i + 3) / r3 >= 0.60);
      bool b2 = (_IsBear(i + 2) && _Body(i + 2) / r2 >= 0.60);
      // 3: bearish with long lower shadow
      bool b3 = (_IsBear(i + 1) && _LowerWick(i + 1) >= 2.0 * _Body(i + 1));
      // 4: bearish engulfing 3rd (range)
      bool b4 = (_IsBear(i) && High[i] > High[i + 1] && Low[i] < Low[i + 1]);
      return (b1 && b2 && b3 && b4);
}

bool CheckThreeStarsInTheSouth(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      if (!_IsBear(i + 2) || !_IsBear(i + 1) || !_IsBear(i))
        return false;
      double b2 = _Body(i + 2), b1 = _Body(i + 1), b0 = _Body(i);
      return (b2 > b1 && b1 > b0);
}

bool CheckLadderBottom(int i){
      if (i < 4 || !_HasBars(i, 4))
        return false;
      bool down = (_IsBear(i + 4) && _IsBear(i + 3) && _IsBear(i + 2));
      bool small = (_Body(i + 1) < _Body(i + 2));
      bool up = (_IsBull(i) && Close[i] > Open[i + 2]);
      return (down && small && up);
}

bool CheckUniqueThreeRiverBottom(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      bool c1 = (_IsBear(i + 2) && _Body(i + 2) / _Range(i + 2) >= 0.60);
      bool c2 = (_IsBear(i + 1) && Low[i + 1] < Low[i + 2] &&
                 Close[i + 1] > Close[i + 2]);
      bool c3 = (_IsBull(i) && Close[i] > Close[i + 1]);
      return (c1 && c2 && c3);
}

bool CheckStickSandwich(int i){
      if (i < 2 || !_HasBars(i, 2))
        return false;
      double tol = 3 * Point;
      bool c1 = _IsBear(i + 2);
      bool c2 = _IsBull(i + 1);
      bool c3 = _IsBear(i);
      bool closeMatch = _Near(Close[i], Close[i + 2], tol);
      return (c1 && c2 && c3 && closeMatch);
}

bool CheckMatchingLow(int i)          {
      if (Bars < 3)
        return false;
      return (MathAbs(Low[1] - Low[2]) < Point * 3); }

bool CheckMatchingHigh(int i)         {
      if (Bars < 3)
        return false;
      return (MathAbs(High[1] - High[2]) < Point * 3); }

bool CheckBreakaway(int i){
      if (i < 4 || !_HasBars(i, 4))
        return false;
      bool bull = (_IsBear(i + 4) && _IsBear(i + 3) && _IsBear(i + 2) &&
                   _IsBear(i + 1) && _IsBull(i) && Close[i] > Open[i + 4]);
      bool bear = (_IsBull(i + 4) && _IsBull(i + 3) && _IsBull(i + 2) &&
                   _IsBull(i + 1) && _IsBear(i) && Close[i] < Open[i + 4]);
      return (bull || bear);
}

bool CheckHaramiCross(int i){
      if (i < 1 || !_HasBars(i, 1))
        return false;
      double r = _Range(i);
      if (r <= 0)
        return false;
      bool doji = (_Body(i) <= 0.10 * r);
      bool inside = (High[i] <= High[i + 1] && Low[i] >= Low[i + 1]);
      return (doji && inside);
}

bool CheckHarami(int shift=0) {
return ((Close[shift+1] > Open[shift+1] && Close[shift] < Open[shift] && Open[shift] < Close[shift+1] && Close[shift] > Open[shift+1]) ||
       (Close[shift+1] < Open[shift+1] && Close[shift] > Open[shift] && Open[shift] > Close[shift+1] && Close[shift] < Open[shift+1]));
}

bool IsMomentumCandle(int shift = 0)
{
      double atr = iATR(Symbol(), 0, 14, shift);
      if (atr <= 0)
        return false;
      double body = MathAbs(Open[shift] - Close[shift]);
      return (body >= atr * 0.8);
}

bool IsReversalZone(int dir, int shift = 0)
{
      // Check pattern bias
      int bias = GetPatternBias(shift);
      if (dir > 0 && bias <= 0)
        return false;
      if (dir < 0 && bias >= 0)
        return false;

      // Check for rejection at extreme
      double atr = iATR(Symbol(), 0, 14, shift);
      if (atr <= 0)
        return false;

      int lookback = 20;
      double HH =
          iHigh(Symbol(), 0, iHighest(Symbol(), 0, MODE_HIGH, lookback, 1));
      double LL =
          iLow(Symbol(), 0, iLowest(Symbol(), 0, MODE_LOW, lookback, 1));
      double range = HH - LL;
      if (range <= atr * 0.5)
        return false;

      double close = Close[shift];
      if (dir > 0 && close > LL + range * 0.3)
        return false; // Not near support
      if (dir < 0 && close < HH - range * 0.3)
        return false; // Not near resistance

      return true;
}

bool IsADX_Trend()  {
      return (iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0) > 25); }

bool IsAO_Bullish()  {
      return (iAO(Symbol(), 0, 0) > 0); }

bool IsAroon_Bullish(){
      int p = 14;
      int upBars = p, dnBars = p;
      double hh = High[iHighest(NULL, 0, MODE_HIGH, p, 1)],
             ll = Low[iLowest(NULL, 0, MODE_LOW, p, 1)];
      for (int i = 1; i <= p; i++) {
        if (High[i] == hh) {
          upBars = i;
          break;
        }
      }
      for (int j = 1; j <= p; j++) {
        if (Low[j] == ll) {
          dnBars = j;
          break;
        }
      }
      return (100.0 * (p - upBars) / p > 100.0 * (p - dnBars) / p);
}

bool IsATR_Volatility()  {
      return (iATR(Symbol(), 0, 14, 0) > MinATRPips * ADV_Pip()); }

bool IsVIDYA_Signal(int shift){
      if (!VIDYA)
        return false;
      double v0 = CalculateVIDYA(14, shift);
      double v1 = CalculateVIDYA(14, shift + 1);
      double p0 = iClose(NULL, 0, shift);
      double p1 = iClose(NULL, 0, shift + 1);
      if (p1 <= v1 && p0 > v0)
        return true;
      return false;
}

void IsSwingHigh() {
      int p = 5;
      double h0 = High[0];
      for (int i = 1; i <= p; i++) {
        if (High[i] >= h0)
          return;
        return;
      }

}

        void Reversal() {
          if (!GlobalStrategyGuards())
            return;
        }
        // Strategia basata sulle strutture di mercato per sfruttare al meglio i
        // livelli chiave.
        // Il SuperTrend identifica il trend corrente basandosi sulla
        // volatilitÃƒÃ†ÃƒÃ‚Â  e sui prezzi.

color GetConfidenceColor(double confidence) {
                          if (confidence < 45)
                            return clrRed;
                          if (confidence < 75)
                            return clrOrange;
                          return clrLime;
}
// === Funzioni Reversal Signal e SMC dinamico ===

bool DynamicReversalSignal() {
                          if (!GlobalStrategyGuards())
                            return (false);
                          // Controllo avanzato per inversione prezzo

                          double prevClose = iClose(Symbol(), Period(), 1);
                          double currentClose = iClose(Symbol(), Period(), 0);
                          double rsi = iRSI(Symbol(), Period(), Auto_RSI_Period(), PRICE_CLOSE, 1);
                          bool candleReversal = (currentClose > prevClose &&
                                                 rsi < Auto_RSI_Low()) ||
                                                (currentClose < prevClose &&
                                                 rsi > Auto_RSI_High());
                          return candleReversal;
}

double DynamicSMCLookbackBar() {
                          double atr = EATR(Symbol(), Period(), 14);
                          if (atr > 500 * Point)
                            return 50; // alta volatilitÃƒÃ†ÃƒÃ‚Â 
                          return 30;   // bassa volatilitÃƒÃ†ÃƒÃ‚Â 
}

double DynamicSMCFVGDepthPips() {
                          double atr = EATR(Symbol(), Period(), 14);
                          return atr / Point; // profonditÃƒÃ†ÃƒÃ‚Â  dinamica in pips
}

void CheckTimeBasedExit() {
                          if (MaxHoldTimeMinutes <= 0)
                            return;
                          for (int i = OrdersTotal() - 1; i >= 0; i--) {
                            if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
         if (!OwnerRegistry_IsOwner(OrderTicket(), OrderMagicNumber())) continue;
                              double orderProfit = OrderProfit() + OrderSwap() +
                                                   OrderCommission();
                              if (TimeCurrent() - OrderOpenTime() >
                                  MaxHoldTimeMinutes * 60) {
                                if (orderProfit >= 0) {
                                  {
                                    int __ticket = OrderTicket();
                                    double __lots = OrderLots();
                                    SmartLogWrap(
                                        "CLOSE",
                                        StringFormat("PreClose | ticket=%d "
                                                     "lots=%.2f symbol=%s",
                                                     __ticket, __lots,
                                                     OrderSymbol()));
                                  }
                                  bool closed = OrderClose(
                                      OrderTicket(), OrderLots(),
                                      OrderClosePrice(),
                                      GetAdaptiveSlippagePoints(), clrNONE);
                                  {
                                    int __err = GetLastError();
                                    bool __isok = (__err == 0);
                                    SmartLogWrap(
                                        "CLOSE",
                                        StringFormat(
                                            "%s | ticket=%d price=%.5f "
                                            "lots=%.2f err=%d",
                                            __isok ? "PostClose OK"
                                                   : "PostClose FAIL",
                                            OrderTicket(), OrderClosePrice(),
                                            OrderLots(), __err));
                                  }
                                  if (closed)
                                    Print("Time-Based Exit: ordine ",
                                          OrderTicket(), " chiuso dopo ",
                                          MaxHoldTimeMinutes, " minuti.");
                                }
                              }
                            }
                          }
}

