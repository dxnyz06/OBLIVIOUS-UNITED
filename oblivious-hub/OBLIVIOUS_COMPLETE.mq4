bool IsUlcerIndex() {
      int n = 14;
      if (Bars < n + 1)
        return false;
      double maxC = iClose(NULL, 0, n);
      double sumSq = 0;
      for (int i = n - 1; i >= 0; i--) {
        double c = iClose(NULL, 0, i);
        if (c > maxC)
          maxC = c;
        double dd = (maxC > 0) ? (maxC - c) / maxC * 100.0 : 0;
        sumSq += dd * dd;
      }
      double ui = MathSqrt(sumSq / n);
      return (ui < 5);
}

