   NULL,
   0,
   1);
   double body = MathAbs(
   C -
   O);
   double rng =
   H -
   L;
   double lWick =
   MathMin(
   O,
   C) -
   L;
   double uWick =
   H -
   MathMax(
   O,
   C);
   int dir =
   0;
