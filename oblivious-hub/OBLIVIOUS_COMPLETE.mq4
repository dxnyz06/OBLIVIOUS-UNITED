                      bool AIP2_PreRangeBreakLive_OTE(int side) {
                        int tf = AIP2_LTF();
                        int W = (int)MathMax(20, AIP2_BarsWin());
                        double HH =
                            iHigh(Symbol(), tf,
                                  iHighest(Symbol(), tf, MODE_HIGH, W, 1));
                        double LL = iLow(Symbol(), tf,
                                         iLowest(Symbol(), tf, MODE_LOW, W, 1));
                        double R = HH - LL;
                        if (R <= 0)
                          return false;

                        double buf = AIP2_InnerBufLive();
                        double px = AIP2_TickMid();

                        if (side > 0)
                          return (px > HH - buf * 2.0 &&
                                  px < HH + buf); // Near high but
                        // not broken
                        else
                          return (px < LL + buf * 2.0 &&
                                  px > LL - buf); // Near low but
                                                  // not broken
                      }

                      bool AIP2_EnsurePending(int side, int magic,
                                              double volume) {
                        // Check if pending already exists
                        // for this magic
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderSymbol() != Symbol())
                            continue;
                          if (OrderMagicNumber() != magic)
                            continue;
                          int t = OrderType();
                          if (t >= OP_BUYLIMIT && t <= OP_SELLSTOP)
                            return true; // Already has
                          // pending
                        }

                        // No pending: place one at OTE band
                        // edge
                        double b1_lo, b1_hi, b2_lo, b2_hi;
                        if (!AIP2_GetBands10_50_dynamic(side, b1_lo, b1_hi,
                                                        b2_lo, b2_hi))
                          return false;

                        double price = (side > 0 ? b1_lo : b1_hi); // Entry at
                        // band edge
                        int type = (side > 0 ? OP_BUYLIMIT : OP_SELLLIMIT);
                        double sl =
                            (side > 0 ? b1_lo - AIP2_InnerBufLive() * 3.0
                                      : b1_hi + AIP2_InnerBufLive() * 3.0);
                        double tp = (side > 0 ? b2_hi : b2_lo); // TP at band 2

                        int digits = (int)MarketInfo(Symbol(), MODE_DIGITS);
                        price = NormalizeDouble(price, digits);
                        sl = NormalizeDouble(sl, digits);
                        tp = NormalizeDouble(tp, digits);

                        int slippage =
                            (int)MarketInfo(Symbol(), MODE_STOPLEVEL);
                        datetime expiry = TimeCurrent() + 3600; // 1 hour expiry
                        int ticket = SafeOrderSend(Symbol(), type, volume, price,
                                               slippage, sl, tp, "AIP2-OTE",
                                               magic, expiry, clrNONE);
                        return (ticket > 0);
                      }

                      void AIP2_CancelOppositeIfFilled(int filledType) {
                        int opp = (filledType == OP_BUYSTOP ? OP_SELLSTOP
   : OP_BUYSTOP);
                        for (int i = 0; i < OrdersTotal(); i++) {
                          if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
                            if (OrderSymbol() == Symbol() &&
                                OrderMagicNumber() == PredictedMagic &&
                                OrderType() == opp) {
                              bool _wRes = OrderDelete(OrderTicket());
                            }
                          }
                        }
                      }

                      void AIP2_TickHandler(int magic, double volume) {
                        if (AIP2_IsLiveOnly() && IsTesting())
                          return;

                        AIP2_ResetBarState();
                        AIP2_CancelOppositeIfFilled(magic);

                        // Check both sides for sequential
                        // touches
                        for (int side = -1; side <= 1; side += 2) {
                          if (AIP2_T0_TickSequentialOK(side)) {
                            if (!AIP2_PreRangeBreakLive_OTE(side)) {
                              AIP2_EnsurePending(side, magic, volume);
                            }
                          }
                        }
                      }

                      void AIP2_TimerHandler(int magic) {
                        if (AIP2_IsLiveOnly() && IsTesting())
                          return;

                        // Cleanup expired pendings
                        for (int i = OrdersTotal() - 1; i >= 0; i--) {
                          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
                            continue;
                          if (OrderSymbol() != Symbol())
                            continue;
                          if (OrderMagicNumber() != magic)
                            continue;
                          int t = OrderType();
                          if (t < OP_BUYLIMIT)
                            continue; // Only process
                          // pending orders
                          // Check if expired (MT4 handles
                          // this, but clean up stale ones)
                          if (OrderExpiration() > 0 &&
                              OrderExpiration() < TimeCurrent()) {
                            bool _wRes = OrderDelete(OrderTicket());
                          }
                        }
                      }

                      bool __AP_DailyDDExceeded(double maxDDPercent) {
                        static double dayStartEquity = -1;
                        static int lastDay = -1;
                        int today = TimeDay(TimeCurrent());

                        if (today != lastDay) {
                          dayStartEquity = AccountEquity();
                          lastDay = today;
                        }

                        if (dayStartEquity <= 0)
                          return false;
                        double dd =
                            (1.0 - AccountEquity() / dayStartEquity) * 100.0;
                        return (dd >= maxDDPercent);
                      }

