string TagFromStrategy(string strat)
{
      if (StringFind(strat, "Blue") >= 0)
        return "[BLUE]";
      if (StringFind(strat, "Cobra") >= 0)
        return "[COBRA]";
      if (StringFind(strat, "SMC") >= 0)
        return "[SMC]";
      if (StringFind(strat, "Structure") >= 0)
        return "[STRUCT]";
      if (StringFind(strat, "Emperor") >= 0)
        return "[EMPEROR]";
      if (StringFind(strat, "Grid") >= 0)
        return "[GRID]";
      if (StringFind(strat, "FVG") >= 0)
        return "[FVG]";
      if (StringFind(strat, "Royal") >= 0)
        return "[ROYAL]";
      if (StringFind(strat, "Ai") >= 0)
        return "[AI]";
      if (StringFind(strat, "Oblivious") >= 0)
        return "[OBL]";
      return "[???]";
}

double RR_AA_Round(double rr){
      return MathRound(rr * 2.0) / 2.0;
}

string GetStrategyFullName(string comment) {
      // Map order comment fragments to canonical 6-strategy owner names
      if (comment == "Predicted" || StringFind(comment, "AI") >= 0 || StringFind(comment, "Pred") >= 0)
        return "Predicted";
      if (comment == "Pattern" || StringFind(comment, "Pattern") >= 0)
        return "Pattern";
      if (comment == "Breakout" || comment == "Cobra" ||
          StringFind(comment, "Break") >= 0)
        return "Breakout";
      if (comment == "FVG" || StringFind(comment, "FVG") >= 0 ||
          StringFind(comment, "Fair") >= 0)
        return "FVG";
      if (comment == "Grid" || StringFind(comment, "Grid") >= 0)
        return "Grid";
      if (comment == "SMC" || comment == "ICT" || comment == "Institutional" ||
          StringFind(comment, "SMC") >= 0 || StringFind(comment, "ICT") >= 0)
        return "SMC"; // legacy mapping
      if (comment == "Reverse" || comment == "Royal" ||
          StringFind(comment, "Revers") >= 0 || StringFind(comment, "Royal") >= 0)
        return "Reverse";
      return comment;
}

void UpdatePnL() {
      ResetPnLIfNewDay();
      bool activeFlags[];
      ArrayResize(activeFlags, pnl_count);
      for (int j = 0; j < pnl_count; j++)
        activeFlags[j] = false;
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) {
          string strat = GetStrategyFullName(OrderComment());
          double profit = OrderProfit() + OrderSwap() + OrderCommission();
          int idx = -1;
          for (int j = 0; j < pnl_count; j++) {
            if (pnl_list[j].name == strat) {
              idx = j;
              break;
            }
          }
          if (idx >= 0) {
            pnl_list[idx].pnl = profit;
            activeFlags[idx] = true;
          } else {
            ArrayResize(pnl_list, pnl_count + 1);
            for (int k = pnl_count; k > 0; k--)
              pnl_list[k] = pnl_list[k - 1];
            pnl_list[0].name = strat;
            pnl_list[0].pnl = profit;
            pnl_list[0].lastOpen = TimeCurrent();
            pnl_count++;
            ArrayResize(activeFlags, pnl_count);
            activeFlags[0] = true;
          }
        }
      }
      for (int j = pnl_count - 1; j >= 0; j--)
        if (!activeFlags[j]) {
          for (int k = j; k < pnl_count - 1; k++)
            pnl_list[k] = pnl_list[k + 1];
          pnl_count--;
          ArrayResize(pnl_list, pnl_count);
        }
}

datetime _StartOfDay()
{
      datetime now = TimeCurrent();
      MqlDateTime dt;
      TimeToStruct(now, dt);
      dt.hour = 0;
      dt.min = 0;
      dt.sec = 0;
      return StructToTime(dt);
}

datetime _StartOfWeek()
{
      datetime now = TimeCurrent();
      MqlDateTime dt;
      TimeToStruct(now, dt);
      int dow = dt.day_of_week;
      if (dow == 0)
        dow = 7; // Sunday=7
      datetime monday = now - (dow - 1) * 86400;
      TimeToStruct(monday, dt);
      dt.hour = 0;
      dt.min = 0;
      dt.sec = 0;
      return StructToTime(dt);
}

datetime _StartOfMonth()
{
      datetime now = TimeCurrent();
      MqlDateTime dt;
      TimeToStruct(now, dt);
      dt.day = 1;
      dt.hour = 0;
      dt.min = 0;
      dt.sec = 0;
      return StructToTime(dt);
}

string _DetectSession()
{
      int h = TimeHour(TimeCurrent());
      if (h >= 0 && h < 8)
        return "Tokyo";
      if (h >= 8 && h < 12)
        return "London";
      if (h >= 12 && h < 17)
        return "New York";
      if (h >= 17 && h < 21)
        return "London Close";
      return "Off-Hours";
}

bool _GetStrategyBool(string key)
{
      if (key == "Predicted")        return Predicted;
      if (key == "Breakout")         return Breakout;
      if (key == "FVG")              return FVG;
      if (key == "Grid")             return Grid;
      if (key == "SMC") return SMC;
      if (key == "ICT") return ICT;

      if (key == "Reverse")          return Reverse;
      return false;
}

