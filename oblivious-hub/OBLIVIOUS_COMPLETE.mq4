};
AdaptState g_adapt;

void _DetectRegime(bool &isTrend, bool &isHighVol){
      double mTR14 = _MedianTrueRangeN(14);
      double mTR64 = _MedianTrueRangeN(64);
      double volRatio = (mTR64 > 0 ? mTR14 / mTR64 : 1.0);
      isHighVol = (volRatio >= 1.15); // current > long median
      double tscore = _TrendScore(30);
      isTrend = (tscore >= 0.28); // threshold for persistent direction
}

bool TryAutoAdaptivePOIEntry(int baseMagic, string strategyName, POIType filterType)
  {
      CleanupPOIs();

      string sym = Symbol();
      int tf =
          PERIOD_CURRENT; // MQL4 uses int for timeframes, not ENUM_TIMEFRAMES
      double bid = Bid;
      double ask = Ask;
      double pip = POI_PipSize();
      double atr = POI_AutoATR();

      if (ArraySize(g_POIs) <= 0)
        return (false);

      for (int i = 0; i < ArraySize(g_POIs); i++) {
        // MQL4 doesn't support references - use direct array access
        if (!g_POIs[i].active)
          continue;
        if (g_POIs[i].symbol != sym || g_POIs[i].tf != tf)
          continue;
        if (g_POIs[i].type != filterType)
          continue;

        double price = g_POIs[i].isBull ? bid : ask;

        // controllo: prezzo dentro la zona o molto vicino al mid
        double tol = MathMax(pip, atr * 0.2); // tolleranza dinamica
        bool inZone =
            (price >= g_POIs[i].zLow - tol && price <= g_POIs[i].zHigh + tol);

        if (!inZone)
          continue;

        // SL/TP autoadaptive: legati a struttura (ampiezza zona + ATR), NON
        // numeri fissi
        double width = MathAbs(g_POIs[i].zHigh - g_POIs[i].zLow);
        if (width < pip)
          width = atr;
        if (width < pip)
          continue;

        double slDist = width + atr * 0.5;
        if (slDist <= 0.0)
          slDist = width;

        // R:R dinamico: minimo 1:1.5, puÃƒÃ†ÃƒÃ‚Â² estendersi oltre in base al rapporto
        // ATR/ampiezza zona
        double rr = 1.5;
        if (width > 0.0 && atr > 0.0) {
          double dynRR = atr / width;
          if (dynRR > rr)
            rr = dynRR;
        }
        double tpDist = slDist * rr;

        double entryPrice = g_POIs[i].mid;

        double slPrice, tpPrice;

        if (g_POIs[i].isBull) {
          slPrice = entryPrice - slDist;
          tpPrice = entryPrice + tpDist;
        } else {
          slPrice = entryPrice + slDist;
          tpPrice = entryPrice - tpDist;
        }

        double lots = CalculateLotSize();
        int magic = MagicCompose(baseMagic);
        string cmt = strategyName + " POI";

        // Usa il motore EB per piazzare BUYLIMIT/SELLLIMIT a scaletta nella
        // zona [zLow, zHigh]
        double zLo = MathMin(g_POIs[i].zLow, g_POIs[i].zHigh);
        double zHi = MathMax(g_POIs[i].zLow, g_POIs[i].zHigh);
        bool isLong = g_POIs[i].isBull;

        bool sent = EB_PlaceEdgeBiasedLimits(sym, magic, isLong, zHi, zLo,
                                             slPrice, tpPrice, lots);

        if (sent) {
          g_POIs[i].active = false; // POI consumato
          return (true);
        }
      }

      return (false);
  }

void AutoAdaptiveEBEntry()
{
      TryAutoAdaptivePOIEntry(Magic, currentStrategy, POI_ALL);
}

double __VolRatio()
{
      double atr = iATR(Symbol(), Period(), 14, 0);
      double atrMA = 0;
      for (int i = 1; i <= 20; i++)
        atrMA += iATR(Symbol(), Period(), 14, i);
      atrMA /= 20.0;
      if (atrMA <= 0)
        return 1.0;
      return atr / atrMA;
}

double __volK()
{
      double vr = __VolRatio();
      if (vr < 0.5)
        return 0.7;
      if (vr < 0.8)
        return 0.85;
      if (vr < 1.2)
        return 1.0;
      if (vr < 2.0)
        return 1.15;
      return 1.3;
}

double ModeSigmaK()
{
      if (Mode == 0)
        return 2.0; // Conservative: require 2ÃƒÃ‚ÃƒÃ¢
      if (Mode == 2)
        return 1.0; // Aggressive: 1ÃƒÃ‚ÃƒÃ¢
      return 1.5;
}

int ModeWindow()
{
      if (Mode == 0)
        return AA_AutoN() + 20;
      if (Mode == 2)
        return MathMax(10, AA_AutoN() - 10);
      return AA_AutoN();
}

