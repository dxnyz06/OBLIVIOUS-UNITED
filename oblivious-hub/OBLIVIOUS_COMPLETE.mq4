bool IsGannHiLo() {
      double smaHigh = iMA(NULL, 0, 10, 0, MODE_SMA, PRICE_HIGH, 0);
      double smaLow = iMA(NULL, 0, 10, 0, MODE_SMA, PRICE_LOW, 0);
      double gannLine = (iClose(NULL, 0, 1) > smaHigh) ? smaLow : smaHigh;
      return (gannLine < iClose(NULL, 0, 0));
}

bool IsHeikenAshi() {
      double haClose = (iOpen(NULL, 0, 0) + iHigh(NULL, 0, 0) +
                        iLow(NULL, 0, 0) + iClose(NULL, 0, 0)) /
                       4.0;
      double haOpen = (iOpen(NULL, 0, 1) + iClose(NULL, 0, 1)) / 2.0;
      return (haClose > haOpen); // bullish HA candle
}

