}

void Strategy_ADX_Logic()       { if (!AllowStrategyToTrade()) return; double adx = iADX(Symbol(),0,14,PRICE_CLOSE,MODE_MAIN,1); double di_p = iADX(Symbol(),0,14,PRICE_CLOSE,MODE_PLUSDI,1); double di_m = iADX(Symbol(),0,14,PRICE_CLOSE,MODE_MINUSDI,1); if (adx < GetAdaptive_ADX_Trend()) return; int dir = (di_p > di_m) ? 1 : -1; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_Alligator_Logic() { if (!AllowStrategyToTrade()) return; double jaw = iAlligator(Symbol(),0,13,8,8,5,5,3,MODE_SMMA,PRICE_MEDIAN,MODE_GATORJAW,1); double lip = iAlligator(Symbol(),0,13,8,8,5,5,3,MODE_SMMA,PRICE_MEDIAN,MODE_GATORLIPS,1); int dir = (lip > jaw) ? 1 : -1; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_AC_Logic()        { if (!AllowStrategyToTrade()) return; double ac0=iAC(Symbol(),0,0),ac1=iAC(Symbol(),0,1); int dir=(ac0>ac1)?1:-1; if (MathAbs(ac0)<0.0001*Point) return; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_AD_Logic()        { if (!AllowStrategyToTrade()) return; double ad0=iAD(Symbol(),0,0),ad1=iAD(Symbol(),0,1); int dir=(ad0>ad1)?1:-1; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_BearsPower_Logic() { double bp=iBearsPower(Symbol(),0,13,PRICE_CLOSE,1); if(bp>=0) return; g_ind_bear_count++; g_ind_osc_score-=8.0; }
void Strategy_BullsPower_Logic() { double bp=iBullsPower(Symbol(),0,13,PRICE_CLOSE,1); if(bp<=0) return; g_ind_bull_count++; g_ind_osc_score+=8.0; }
// Strategy_Bollinger_Logic: full implementation at L38241 (pr/lo/up context version removed as duplicate)
void Strategy_Gator_Logic()     { if (!AllowStrategyToTrade()) return; double gu=iGator(Symbol(),0,13,8,8,5,5,3,MODE_SMMA,PRICE_MEDIAN,MODE_UPPER,1); double gl=iGator(Symbol(),0,13,8,8,5,5,3,MODE_SMMA,PRICE_MEDIAN,MODE_LOWER,1); int dir=(gu>MathAbs(gl))?1:-1; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_BWMFI_Logic()     { if (!AllowStrategyToTrade()) return; double m0=iMFI(Symbol(),0,14,0),m1=iMFI(Symbol(),0,14,1); int dir=(m0>m1)?1:-1; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_OsMA_Logic()      { if (!AllowStrategyToTrade()) return; double o0=iOsMA(Symbol(),0,12,26,9,PRICE_CLOSE,0),o1=iOsMA(Symbol(),0,12,26,9,PRICE_CLOSE,1); int dir=(o0>0&&o0>o1)?1:(o0<0&&o0<o1)?-1:0; if(dir==0)return; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_RVI_Logic()       { if (!AllowStrategyToTrade()) return; double r0=iRVI(Symbol(),0,10,MODE_MAIN,0),r1=iRVI(Symbol(),0,10,MODE_SIGNAL,0); int dir=(r0>r1)?1:-1; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_AO_Logic()        { if (!AllowStrategyToTrade()) return; double ao0=iAO(Symbol(),0,0),ao1=iAO(Symbol(),0,1),ao2=iAO(Symbol(),0,2); int dir=0; if(ao1>ao2&&ao0>ao1&&ao0>0)dir=1; if(ao1<ao2&&ao0<ao1&&ao0<0)dir=-1; if(dir==0)return; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
void Strategy_TradeEntry_Logic(){ if (!AllowStrategyToTrade()) return; int dir=GetTradeEntryDirection(); if(dir==0)return; if(dir>0)g_ind_bull_count++; else g_ind_bear_count++; g_ind_osc_score+=(dir>0)?8.0:-8.0; }
