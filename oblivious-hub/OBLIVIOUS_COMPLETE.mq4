bool GetADX_Signal(int s=0)          {
      double main = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MAIN, 0),
             pdi = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_PLUSDI, 0),
             mdi = iADX(Symbol(), 0, 14, PRICE_CLOSE, MODE_MINUSDI, 0);
      return (main > 20 &&
              ((s > 0 && pdi > mdi) || (s < 0 && mdi > pdi) || (s == 0 && pdi != mdi))); }

bool GetAO_Signal(int s=0)           {
      double ao0 = iAO(Symbol(), 0, 0), ao1 = iAO(Symbol(), 0, 1);
      return ((s > 0 && ao0 > 0 && ao0 > ao1) ||
              (s < 0 && ao0 < 0 && ao0 < ao1) ||
              (s == 0 && ao0 != ao1)); }

