double Score_InvertedHammer(int i=0)            {
      double r = High[1] - Low[1], b = MathAbs(Close[1] - Open[1]);
      if (r <= 0)
        return 0;
      double uw = High[1] - MathMax(Open[1], Close[1]);
      return ((b < r * 0.3 && uw > r * 0.6) ? 0.6 : 0); }

double Score_ShootingStar(int i=0)              {
