}

// ============================================================
// R5 — Risk_Preflight: the SINGLE point of truth for any lot that
// is about to leave the EA towards OrderSend.  Every placement
// path (Strategy_ComputeLots, Cmd_HandleExecute, Grid level,
// add-on / scale-in) MUST route through here.  ManualLot can no
// longer bypass MaxRiskTradePercent.
// ============================================================
double Risk_GridBasketRiskPct(string sym) {
   double eq = AccountEquity();
   if (eq <= 0.0) return 0.0;
   double totalPct = 0.0;
   int total = OrdersTotal();
   for (int i = 0; i < total; i++) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if (OrderSymbol() != sym) continue;
      if (MagicBase(OrderMagicNumber()) != GridMagic) continue;
      double slp = OrderStopLoss();
      if (slp <= 0.0) continue;
      double entry  = OrderOpenPrice();
      double slDist = MathAbs(entry - slp);
      double tv     = MarketInfo(sym, MODE_TICKVALUE);
      double ts     = MarketInfo(sym, MODE_TICKSIZE);
      if (tv <= 0.0 || ts <= 0.0) continue;
      double riskMoney = (slDist / ts) * tv * OrderLots();
      totalPct += (riskMoney / eq) * 100.0;
   }
   return totalPct;
}

double Risk_Preflight(string sym, string owner, double desiredLots,
                      double slPips, int direction, string &outReason) {
   if (desiredLots <= 0.0) { outReason = "zero_desired"; return 0.0; }
   if (!EA_IsTradeAllowed()) { outReason = "ea_blocked"; return 0.0; }
   if (!SpreadOk())          { outReason = "spread_wide"; return 0.0; }

   double clamped = desiredLots;
   if (slPips > 0.0 && (direction == 1 || direction == -1)) {
      int    digits = (int)MarketInfo(sym, MODE_DIGITS);
      double pipPts = (digits == 3 || digits == 5) ? 10.0 : 1.0;
      double sl_pts = slPips * pipPts;
      clamped = Risk_ApplyClampToLots(sym, clamped, sl_pts, direction);
      if (clamped < 0.0) { outReason = "below_min_after_risk_clamp"; return 0.0; }
   }

   clamped = NormalizeLots(sym, clamped);
   if (clamped <= 0.0) { outReason = "broker_normalize_zero"; return 0.0; }

   if (owner == "Grid") {
      // Cap aggregate Grid basket at 4x single-trade budget.
      double basketPct = Risk_GridBasketRiskPct(sym);
      if (basketPct >= MaxRiskTradePercent * 4.0) {
         outReason = "grid_basket_full";
         return 0.0;
      }
   }

   outReason = "ok";
   return clamped;
}

double Strategy_ComputeLots(string symbol, double riskPercent, double slPips)
{
   // FASE 5 NEW - Risk inputs con ruoli CHIARI:
   //   ManualLot   = manual TARGET size (override)
   //   RiskPercent = risk-based sizing vero (equity * pct / sl)
   //   MaxRiskTradePercent = clamp finale hard (Risk_Preflight)
   //
   // Policy: se ENTRAMBI > 0  ->  desired = min(manual, risk_based)
   //         se solo ManualLot> 0 -> desired = ManualLot
   //         se solo RiskPercent > 0 -> desired = risk_based
   // Cosi' nessun input "viene bypassato silently": il piu'
   // conservativo dei due vince, poi clamp Risk_Preflight.
   double risk_based = 0.0;
   if (riskPercent > 0)
      risk_based = RiskEngine_ComputeLots(symbol, riskPercent, slPips);
   double desired = 0.0;
   if (ManualLot > 0 && risk_based > 0) {
      desired = MathMin(ManualLot, risk_based);
   } else if (ManualLot > 0) {
      desired = ManualLot;
   } else {
      desired = risk_based;
   }
   string reason;
   double finalLots = Risk_Preflight(symbol, "Strategy", desired, slPips, 1, reason);
   if (finalLots <= 0.0) {
      PrintFormat("[Risk] Strategy_ComputeLots blocked sym=%s manual=%.2f risk=%.2f desired=%.2f reason=%s",
                  symbol, ManualLot, risk_based, desired, reason);
   }
   return finalLots;
}

