        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (DeMarker) {
        sig = Check_DeMarker(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (Donchian) {
        sig = Check_Donchian(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (EfficiencyRatio) {
        sig = Check_EfficiencyRatio(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (ElderRay) {
        sig = Check_ElderRay(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (Fibo) {
        sig = Check_Fibo(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (ForceIndex) {
        sig = Check_ForceIndex(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (GannHiLo) {
        sig = Check_GannHiLo(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (HeikenAshi) {
        sig = Check_HeikenAshi(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (KAMA) {
        sig = Check_KAMA(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (LaguerreRSI) {
        sig = Check_LaguerreRSI(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (LinReg) {
        sig = Check_LinReg(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (MFI) {
        sig = Check_MFI(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (MultiTFTrend) {
        sig = Check_MultiTFTrend(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (OBV) {
        sig = Check_OBV(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (PeakProfitLock) {
        sig = Check_PeakProfitLock(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      // FASE 7 (Patch 5): PivotPoints variabile sostituita da
      // GetAdaptive_PivotsEnabled() (intraday-only).
      if (GetAdaptive_PivotsEnabled()) {
        sig = Check_PivotPoints(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (PriceAction) {
        sig = Check_PriceAction(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (QQE) {
        sig = Check_QQE(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (Reflex) {
        sig = Check_Reflex(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (ROC) {
        sig = Check_ROC(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (SchaffTrendCycle) {
        sig = Check_SchaffTrendCycle(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (StdDev) {
        sig = Check_StdDev(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (TEMA) {
        sig = Check_TEMA(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (TRIX) {
        sig = Check_TRIX(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (UlcerIndex) {
        sig = Check_UlcerIndex(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }
      if (Vortex) {
        sig = Check_Vortex(sym, tf, conf);
        signalSum += sig;
        confSum += conf;
        enabledCount++;
      }

      if (enabledCount > 0)
        totalConfidence = confSum / enabledCount;
      else
        totalConfidence = 0;

      // Return consensus direction
      if (signalSum > 0)
        return +1;
      if (signalSum < 0)
        return -1;
      return 0;
}

                      double CalculateStrategyConfidence() {
                        // Incrementa la confidence se i
                        // pattern candlestick confermano
                        double confidence = 0.0;
                        double PatternWeight = 0.1;
                        if (IsBullishEngulfing(1) || IsHammer(1)) confidence += PatternWeight;
                        if (IsBearishEngulfing(1)) confidence += PatternWeight;
                        if (IsMorningStar(Symbol(), PERIOD_H1, 2) || IsPiercingLine(Symbol(), PERIOD_H1, 1)) confidence += PatternWeight;
                        if (IsEveningStar(Symbol(), PERIOD_H1, 2) || IsDarkCloudCover(Symbol(), PERIOD_H1, 1)) confidence += PatternWeight;
                        if (IsThreeWhiteSoldiers(Symbol(), PERIOD_H1) || IsThreeBlackCrows(Symbol(), PERIOD_H1)) confidence += PatternWeight;
                        if (IsBullishHarami(Symbol(), PERIOD_H1, 1) || IsBearishHarami(Symbol(), PERIOD_H1, 1)) confidence += PatternWeight;
                        if (IsInsideBar(Symbol(), PERIOD_H1, 1) || IsPinbar(Symbol(), PERIOD_H1, 1)) confidence += PatternWeight;
                        double conf = 0.0;
                        // ADX ==================== L'ADX
                        // (Average Directional Index)
                        // misura la forza del trend. ADX

                        // ADX ==================== L'ADX
                        // (Average Directional Index)
                        // misura la forza del trend.
                        if (false) {
                          conf += 0.5;
                        } else // ====================
                          // INDICATORE ADX
                          // L'ADX (Average Directional
                          // Index) misura la forza del
                          // trend.
                          if (Ind_ADX(Symbol()) > Auto_ADX_Threshold()) {
                            conf += 0.4;
                          }
                        // RSI ==================== L'RSI
                        // (Relative Strength Index) valuta
                        // condizioni di ipercomprato e
                        // ipervenduto. RSI

                        // RSI ==================== L'RSI
                        // (Relative Strength Index) valuta
                        // condizioni di ipercomprato e
                        // ipervenduto.
                        if (false) {
                          conf += 0.3;
                        }
                        // SUPERTREND ====================
                        // Il SuperTrend identifica il trend
                        // corrente basandosi sulla
                        // volatilitÃƒÃ†ÃƒÃ‚Â  e sui prezzi.
                        // Supertrend (supponiamo che
                        // SupertrendConfirm sia una
                        // variabile globale)
                        // SUPERTREND ====================
                        // Il SuperTrend identifica il trend
                        // corrente basandosi sulla
                        // volatilitÃƒÃ†ÃƒÃ‚Â  e sui prezzi.
                        if (SuperTrendSignal() != 0) {
                          conf += 0.3;
                        }
                        // Generic Pattern Engine context boost: when the AI
                        // bridge is connected and explicitly votes against a
                        // trade for the current bar, abort the confidence
                        // computation early. No named pattern hook here.
                        if (Bridge_IsConnected()) {
                          string aiPayload;
                          if (Bridge_GetAISignals(Symbol(), Period(), Time[0],
                                                  aiPayload)) {
                            if (StringFind(aiPayload, "no_trade=1") >= 0) {
                              Bridge_SendLog(1, "Pattern",
                                             "AI suggests NO TRADE");
                              return 0.0;
                            }
                          }
                        }
                        // Strategia basata su pattern
                        // personalizzati per alta
                        // attendibilitÃƒÃ†ÃƒÃ‚Â .
                        // Generic structure / continuation confluence boost:
                        // strong candle profile + volume spike combined with
                        // an FVG-advanced or Reverse-advanced context gives
                        // a small confidence increment. No named module.
                        if (SmartCandleProfiling(0, 2.0, 1.5) &&
                            PatternVolumeSpike(20, 2.0, 1.2) &&
                            (IsFVGAdvanced() || IsReverseAdvanced())) {
                          conf += 0.2;
                        }
                        // Volume sopra media
double volumeMA = VolumeMA(GetVolumeMAPeriod());
// L'EMA (Exponential Moving Average) calcola la media mobile esponenziale per identificare trend.
if (Volume[0] > volumeMA) {
                          conf += 0.2;
}
return MathMin(conf, 1.0);
                      }

                      double CalculateStrategyScore(string strategy) {
                        return ComputeStrategyConfidence(strategy);
                      }

                      double GetDynamicATR() {
                        return iATR(Symbol(), Period(), (int)(14 * ModeScale()),
                                    0);
                      }

                      int GetDynamicATRPeriod() {
switch(Period()) {
                        case PERIOD_M5:
                          return 14;
                        case PERIOD_M15:
                          return 10;
                        case PERIOD_M30:
                          return 7;
                        case PERIOD_H1:
                          return 5;
                        default:
                          return 14;
}
                      }

