}

bool RiskEngine_CorrelationOK(string sym, int maxCorrelated)
{
      // Count open positions on correlated pairs
      string base = StringSubstr(sym, 0, 3);
      string quote = StringSubstr(sym, 3, 3);
      int correlated = 0;

      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        string osym = OrderSymbol();
        if (osym == sym)
          continue;
        if (StringFind(osym, base) >= 0 || StringFind(osym, quote) >= 0)
          correlated++;
      }
      return (correlated < maxCorrelated);
}

double RiskEngine_SessionRiskMultiplier()
{
      int hour = TimeHour(TimeGMT());
      // London session (7-16 GMT): full risk
      if (hour >= 7 && hour < 16)
        return 1.0;
      // NY session (12-21 GMT): full risk (overlap boost)
      if (hour >= 12 && hour < 21)
        return 1.0;
      // Asian session (23-7 GMT): reduced risk
      if (hour >= 23 || hour < 7)
        return 0.70;
      // Transition: moderate
      return 0.85;
}

double RiskEngine_CompositeRiskScore()
{
      double score = 0;

      // DD component (0-40)
      score += MathMin(40.0, g_risk.dailyDDPercent * 8.0);

      // Spread component (0-20)
      double spreadRatio =
          g_risk.currentSpreadPips / MathMax(1.0, g_risk.currentATR * 10);
      score += MathMin(20.0, spreadRatio * 100.0);

      // Margin component (0-20)
      if (g_risk.currentMarginLevel < 500)
        score += MathMin(20.0, (500.0 - g_risk.currentMarginLevel) / 15.0);

      // Session component (0-10)
      double sessMult = RiskEngine_SessionRiskMultiplier();
      score += (1.0 - sessMult) * 10.0;

      // Trades today component (0-10)
      score += MathMin(10.0, g_risk.tradesToday * 1.0);

      return MathMin(100.0, score);
}

double __AP_ComputeLots(double stopPips){
      // Use Manual Lot size
      double manualLot = Active_ManualLot();
      // Try to detect common flags
      // Heuristic: use risk model
      double balance = AccountBalance();
      double risk = __AP_RiskPerTrade();
      double tickValue = MarketInfo(Symbol(), MODE_TICKVALUE);
      if (stopPips <= 0)
        stopPips = 50; // fallback
      double lot =
          (balance * risk) / MathMax(1e-6, (stopPips * Point * tickValue));
      // clamp to broker limits
      double minLot = MarketInfo(Symbol(), MODE_MINLOT);
      double maxLot = MarketInfo(Symbol(), MODE_MAXLOT);
      double lotStep = MarketInfo(Symbol(), MODE_LOTSTEP);
      lot =
          MathMax(minLot, MathMin(maxLot, MathFloor(lot / lotStep) * lotStep));
      return lot;
}

double GetCalculatedLotSize()   {
      return Lot_Compute(); }

bool WillExceedRiskCapForCmd(int cmd, int magic){
      bool isBuy = (cmd == OP_BUY || cmd == OP_BUYLIMIT || cmd == OP_BUYSTOP);
      // number of already open levels for this side
      int openCnt = CountOpenBySide(magic, isBuy);
      int N = (int)MathMax(1, (int)MathFloor(Active_MaxRiskForSymbol()));
      // next level would be openCnt+1; if that exceeds N, then we'd exceed risk
      // budget
      return (openCnt + 1 > N);
}

void ExposureManager_Init()
{
      g_exposureCount = 0;
      g_totalAccountLots = 0;
      g_totalUnrealizedPnL = 0;
      Print("[ExposureManager] Initialized");
}

void ExposureManager_Update()
{
      // Reset all
      for (int i = 0; i < g_exposureCount; i++) {
        g_exposure[i].buyLots = 0;
        g_exposure[i].sellLots = 0;
        g_exposure[i].netLots = 0;
        g_exposure[i].totalLots = 0;
        g_exposure[i].unrealizedPnL = 0;
        g_exposure[i].buyCount = 0;
        g_exposure[i].sellCount = 0;
      }
      g_totalAccountLots = 0;
      g_totalUnrealizedPnL = 0;

      // Scan all open orders
      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;

        string sym = OrderSymbol();
        int idx = ExposureManager_FindOrAdd(sym);
        if (idx < 0)
          continue;

        double lots = OrderLots();
        double pnl = OrderProfit() + OrderSwap() + OrderCommission();

        if (OrderType() == OP_BUY) {
          g_exposure[idx].buyLots += lots;
          g_exposure[idx].buyCount++;
        } else if (OrderType() == OP_SELL) {
          g_exposure[idx].sellLots += lots;
          g_exposure[idx].sellCount++;
        }

        g_exposure[idx].unrealizedPnL += pnl;
        g_totalUnrealizedPnL += pnl;
      }

      // Compute net and total
      for (int i = 0; i < g_exposureCount; i++) {
        g_exposure[i].netLots = g_exposure[i].buyLots - g_exposure[i].sellLots;
        g_exposure[i].totalLots =
            g_exposure[i].buyLots + g_exposure[i].sellLots;
        g_totalAccountLots += g_exposure[i].totalLots;
      }
}

bool ExposureManager_CanAddExposure(string symbol, double lots, int direction)
{
      int idx = ExposureManager_FindOrAdd(symbol);
      if (idx < 0)
        return false;

      // ITER 31 — `MaxRiskForSymbol` is no longer a per-symbol total
      //   lot cap.  It now means "max split entries per setup ladder".
      //   The dead-code lot-cap branch that compared `(currentTotal +
      //   lots) > MaxRiskForSymbol` would have wrongly blocked a 4th
      //   pending on a symbol carrying 3 lots, exactly the kind of
      //   conflated meaning the user explicitly forbade.  Removed.
      //   If a real symbol-wide LOT envelope is needed in the future,
      //   it must be a separate input (e.g. `MaxLotsPerSymbolHard`).
      // (no per-symbol lot cap here — anti-runaway lives in
      //  Mode_SymbolDeploymentSafetyCap on count, plus
      //  Risk_ClampLotToMaxRisk on per-trade lot size)

      // Check opposing exposure if conflict blocking is needed
      if (direction == OP_BUY && g_exposure[idx].sellLots > 0) {
        // Allow hedging only if explicitly enabled
        // By default, block opposing positions on same symbol
      }
      if (direction == OP_SELL && g_exposure[idx].buyLots > 0) {
        // Same check
      }

      return true;
}

double ExposureManager_GetSymbolLots(string symbol)
