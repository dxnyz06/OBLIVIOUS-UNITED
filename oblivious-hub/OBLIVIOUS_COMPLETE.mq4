int SL_FindTracked2(int tk){
      for (int i = 0; i < SL_trackCount2 && i < 512; i++)
        if (SL_trackedTickets2[i] == tk)
          return i;
      return -1;
}

int SL_FindTracked_EA1(int ticket){
      for (int i = 0; i < SL_trackCount_EA1 && i < 512; i++)
        if (SL_trackedTickets_EA1[i] == ticket)
          return i;
      return -1;
}

bool SL_IsNoted(int ticket){
      for (int i = 0; i < SL_notedCount && i < 256; i++)
        if (SL_notedTickets[i] == ticket)
          return true;
      return false;
}

bool SL_IsNoted2(int ticket){
      for (int i = 0; i < SL_notedCount2 && i < 256; i++)
        if (SL_notedTickets2[i] == ticket)
          return true;
      return false;
}

void SL_MarkNoted(int ticket){
      if (ticket <= 0)
        return;
      if (SL_IsNoted(ticket))
        return;
      if (SL_notedCount < 256) {
        SL_notedTickets[SL_notedCount] = ticket;
        SL_notedCount++;
      } else {
        for (int i = 1; i < 256; i++)
          SL_notedTickets[i - 1] = SL_notedTickets[i];
        SL_notedTickets[255] = ticket;
      }
}

void SL_MarkNoted2(int ticket){
      if (ticket <= 0)
        return;
      if (SL_IsNoted2(ticket))
        return;
      if (SL_notedCount2 < 256) {
        SL_notedTickets2[SL_notedCount2++] = ticket;
      } else {
        for (int i = 1; i < 256; i++)
          SL_notedTickets2[i - 1] = SL_notedTickets2[i];
        SL_notedTickets2[255] = ticket;
      }
}

void SL_OnOrderOpen(int ticket){
      if (!OrderSelect(ticket, SELECT_BY_TICKET))
        return;
      string tag = TagFromOrder(ticket);
      string side = (OrderType() == OP_BUY ? "BUY" : "SELL");
      SL_AddMessage(StringFormat("%s [ORDER] Open %s ticket=%d @%.5f SL=%.5f TP=%.5f",
                          tag, side, ticket, OrderOpenPrice(), OrderStopLoss(),
                          OrderTakeProfit()));
}

void SL_TrackEnsure2(int tk){
      int idx = SL_FindTracked2(tk);
      if (idx >= 0)
        return;
      if (SL_trackCount2 < 512) {
        idx = SL_trackCount2++;
      } else {
        for (int i = 1; i < 512; i++) {
          SL_trackedTickets2[i - 1] = SL_trackedTickets2[i];
          SL_trackedSL2[i - 1] = SL_trackedSL2[i];
          SL_trackedTP2[i - 1] = SL_trackedTP2[i];
          SL_trackedOpen2[i - 1] = SL_trackedOpen2[i];
        }
        idx = 511;
      }
      if (OrderSelect(tk, SELECT_BY_TICKET)) {
        SL_trackedTickets2[idx] = tk;
        SL_trackedSL2[idx] = OrderStopLoss();
        SL_trackedTP2[idx] = OrderTakeProfit();
        SL_trackedOpen2[idx] = true;
      }
}

void SL_TrackEnsure_EA1(int ticket){
      int idx = SL_FindTracked_EA1(ticket);
      if (idx >= 0)
        return;
      if (SL_trackCount_EA1 < 512) {
        idx = SL_trackCount_EA1++;
      } else {
        for (int i = 1; i < 512; i++) {
          SL_trackedTickets_EA1[i - 1] = SL_trackedTickets_EA1[i];
          SL_trackedSL_EA1[i - 1] = SL_trackedSL_EA1[i];
          SL_trackedTP_EA1[i - 1] = SL_trackedTP_EA1[i];
          SL_trackedOpen_EA1[i - 1] = SL_trackedOpen_EA1[i];
        }
        idx = 511;
      }
      if (OrderSelect(ticket, SELECT_BY_TICKET)) {
        SL_trackedTickets_EA1[idx] = ticket;
        SL_trackedSL_EA1[idx] = OrderStopLoss();
        SL_trackedTP_EA1[idx] = OrderTakeProfit();
        SL_trackedOpen_EA1[idx] = true;
      }
}

