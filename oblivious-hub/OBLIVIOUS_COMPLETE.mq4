          Close[0] < Open[0] && Close[0] > High[2] && Close[0] < Low[1])
        ok = 1;
      if (High[1] < Low[2] && Close[2] < Open[2] && Close[1] < Open[1] &&
          Close[0] > Open[0] && Close[0] < Low[2] && Close[0] > High[1])
