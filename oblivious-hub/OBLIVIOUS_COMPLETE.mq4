void ShowState(string prefix, bool active, int y_offset) {
   string objName = "STATE_" + prefix;
   string text    = prefix + ": " + (active ? "ON" : "OFF");
   color  clr     = active ? clrLime : clrGray;
   if (ObjectFind(0, objName) < 0)
      ObjectCreate(0, objName, OBJ_LABEL, 0, 0, 0);
   ObjectSetString (0, objName, OBJPROP_TEXT,      text);
   ObjectSetInteger(0, objName, OBJPROP_COLOR,     clr);
   ObjectSetInteger(0, objName, OBJPROP_FONTSIZE,  9);
   ObjectSetString (0, objName, OBJPROP_FONT,      "Arial");
   ObjectSetInteger(0, objName, OBJPROP_CORNER,    CORNER_LEFT_UPPER);
   ObjectSetInteger(0, objName, OBJPROP_XDISTANCE, 10);
   ObjectSetInteger(0, objName, OBJPROP_YDISTANCE, y_offset);
}
void StateManager_Update(double dailyDDPercent, double totalDDPercent) {
   if (dailyDDPercent >= MaxDailyDDPercent && MaxDailyDDPercent > 0)
      g_systemState = STATE_PAUSED_DAILY_DD;
   else if (totalDDPercent >= MaxTotalDDPercent && MaxTotalDDPercent > 0)
      g_systemState = STATE_LOCKED_TOTAL_DD;
   else if (g_systemState == STATE_PAUSED_DAILY_DD)
      g_systemState = STATE_TRADING_ENABLED;
}
