   double __get_IndicatorsConfidence() {
   double t =
   0.5;
   t = IndicatorsConfidence;
   if (t >
   1.0)
   t = clamp01(
   t /
   100.0);
   return clamp01(
   t);
   }

   double __get_IndicatorsScore01() {
   // Score indicatori 0..100 ? [0..1]
   string why =
   "";
   int dir =
   0; // neutro; se necessario, la logica di direzione puÃƒÃ†ÃƒÃ‚Â² essere inserita qui
   int sc = (int)Indicators_GetScore0_100(
   Symbol(),
   PERIOD_CURRENT,
   GetPendingSignalDir(),
   why);
   return __norm01(
   (double)
   sc);
   }

