void DisplayStrategyStatus(){
      // 6 canonical owner strategies (Pattern is always-active engine, not shown here)
      string strategies[] = {"Predicted", "Grid", "Breakout",
                             "FVG",       "SMC", "ICT", "Reverse"};
      bool enabled[6];
      enabled[0] = EnablePredicted;
      enabled[1] = Grid;
      enabled[2] = EnableBreakout;
      enabled[3] = EnableFVG;
      enabled[4] = EnableSMC;
      enabled[5] = Reverse;
      for (int i = 0; i < 6; i++) {
        DrawLabel("STRAT_S_" + strategies[i], 10, 370 + i * 15,
                  strategies[i] + ": " + (enabled[i] ? "ON" : "OFF"),
                  enabled[i] ? clrLime : clrGray);
      }
}

void ShowStrategyWithConfidence(string name, bool state, double conf, int y) {
      string label = name + ": " + (state ? "ATTIVA" : "SPENTA") + " (" +
                     DoubleToString(conf, 1) + "%)";
      ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
ObjectSetText(name, label, 10, "Arial", GetStateColor(state));
ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
DrawConfidenceBar(name + "_ConfBar", conf, 150, y, 100);
}

string _hdr_GetAccountDisplayName(){
      string nm = AccountName();
      if (StringLen(nm) <= 0)
        nm = AccountCompany();
      int sp = StringFind(nm, " ", 0);
      if (sp > 0) {
        string first = StringSubstr(nm, 0, sp);
        string last = StringSubstr(nm, sp + 1);
        int sp2 = StringFind(last, " ", 0);
        if (sp2 > 0)
          last = StringSubstr(last, 0, sp2);
        return first + " " + last;
      }
      return nm;
}

void ActiveStrategiesPanel_Update(){
      ActiveStrategiesPanel_Update_RT(); }

void ActiveStrategiesPanel_Update_Legacy(){
      ActiveStrategiesPanel_Update_RT(); }

void ActiveStrategiesPanel_Update_RT()
{
      int corner = 3; // bottom-right
      int x0 = 12, y0 = 10;
      int dy = 18;
      int nameWidth = 170;

      // Title
      string titleId = "AS_Title";
      if (ObjectFind(0, titleId) < 0)
        ObjectCreate(0, titleId, OBJ_LABEL, 0, 0, 0);
      ObjectSetInteger(0, titleId, OBJPROP_CORNER, corner);
      ObjectSetInteger(0, titleId, OBJPROP_XDISTANCE, x0);
      ObjectSetInteger(0, titleId, OBJPROP_YDISTANCE, y0);
      ObjectSetInteger(0, titleId, OBJPROP_FONTSIZE, 10);
      ObjectSetString(0, titleId, OBJPROP_FONT, "Arial");
      ObjectSetInteger(0, titleId, OBJPROP_COLOR, clrWhite);
      ObjectSetString(0, titleId, OBJPROP_TEXT, "Active Strategies");

      // 7 canonical strategy names and magic numbers
      string names[7] = {
          "Predicted", "Grid",    "Breakout",
          "FVG",       "SMC", "ICT", "Reverse"};
      int magics[AS_MAX_STRATS];
      magics[0] = PredictedMagic;        // Predicted
      magics[1] = GridMagic;             // Grid
      magics[2] = BreakoutMagic;         // Breakout
      magics[3] = FVGMagic;     // FVG
      magics[4] = SMCMagic; // SMC
      magics[5] = ICTMagic; // ICT
      magics[6] = ReverseMagic;          // Reverse

      // Compute PnL and open count per strategy
      double pnl[AS_MAX_STRATS];
      ArrayInitialize(pnl, 0.0);
      int openCount[AS_MAX_STRATS];
      ArrayInitialize(openCount, 0);
      datetime latest[AS_MAX_STRATS];
      ArrayInitialize(latest, 0);

      for (int i = OrdersTotal() - 1; i >= 0; i--) {
        if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
          continue;
        if (OrderSymbol() != Symbol())
          continue;
        int m = OrderMagicNumber();
        for (int k = 0; k < AS_MAX_STRATS; k++) {
          if (m == magics[k]) {
            openCount[k]++;
            pnl[k] += OrderProfit() + OrderSwap() + OrderCommission();
            datetime ot = (datetime)OrderOpenTime();
            if (ot > latest[k])
              latest[k] = ot;
            break;
          }
        }
      }

      // Sort by latest open time (most recent first)
      int idx[AS_MAX_STRATS]; ArrayInitialize(idx, 0);
      for (int k = 0; k < AS_MAX_STRATS; k++)
        idx[k] = k;
      for (int a = 0; a < AS_MAX_STRATS; a++) {
        int best = a;
        for (int b = a + 1; b < AS_MAX_STRATS; b++)
          if (latest[idx[b]] > latest[idx[best]])
            best = b;
        if (best != a) {
          int tmp = idx[a];
          idx[a] = idx[best];
          idx[best] = tmp;
        }
      }

      // Render rows
      int row = 1;
      for (int n = 0; n < AS_MAX_STRATS; n++) {
        int k = idx[n];
        if (openCount[k] <= 0)
          continue;

        string idName = "AS_Row_Name_" + IntegerToString(row);
        string idPnl = "AS_Row_Pnl_" + IntegerToString(row);

        // Name label
        if (ObjectFind(0, idName) < 0)
          ObjectCreate(0, idName, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, idName, OBJPROP_CORNER, corner);
        ObjectSetInteger(0, idName, OBJPROP_XDISTANCE, x0);
        ObjectSetInteger(0, idName, OBJPROP_YDISTANCE, y0 + row * dy);
        ObjectSetInteger(0, idName, OBJPROP_FONTSIZE, 9);
        ObjectSetString(0, idName, OBJPROP_FONT, "Arial");
        ObjectSetInteger(0, idName, OBJPROP_COLOR, clrWhite);
        ObjectSetString(0, idName, OBJPROP_TEXT, names[k]);

        // PnL label
        double v = pnl[k];
        string vtxt = StringFormat("%s%.2f", (v >= 0 ? "+" : ""), v);
        if (ObjectFind(0, idPnl) < 0)
          ObjectCreate(0, idPnl, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, idPnl, OBJPROP_CORNER, corner);
        ObjectSetInteger(0, idPnl, OBJPROP_XDISTANCE, x0 + nameWidth);
        ObjectSetInteger(0, idPnl, OBJPROP_YDISTANCE, y0 + row * dy);
        ObjectSetInteger(0, idPnl, OBJPROP_FONTSIZE, 9);
        ObjectSetString(0, idPnl, OBJPROP_FONT, "Arial");
        color col = (v > 0 ? RGB_Current() : (v < 0 ? clrRed : clrWhite));
        ObjectSetInteger(0, idPnl, OBJPROP_COLOR, col);
        ObjectSetString(0, idPnl, OBJPROP_TEXT, vtxt);
        row++;
      }

      // Cleanup unused rows
      for (int z = row; z < 40; z++) {
        string idName = "AS_Row_Name_" + IntegerToString(z);
        string idPnl = "AS_Row_Pnl_" + IntegerToString(z);
        if (ObjectFind(0, idName) >= 0)
          ObjectDelete(0, idName);
        if (ObjectFind(0, idPnl) >= 0)
          ObjectDelete(0, idPnl);
      }
}

void TriggerOverlay_OnNewBar()
{
      if (Bars < 6)
        return;
      datetime tbar = Time[1];
      if (tbar == gLastTrigBarTime)
        return;
      gLastTrigBarTime = tbar;
      string sym = Symbol();
      int tf = Period();
      double atr = iATR(sym, tf, Auto_ATR_Period(), 1);
      if (atr <= 0)
        atr = Point * 100;
      color bg = ColorBG();
      color base = AccentColor();
      color boxClr = BlendToBG(base, bg, 0.60);
      datetime tL = Time[5];
      datetime tR = BarEndTime(0);
      int hiIdx = iHighest(sym, tf, MODE_HIGH, 6, 0);
      int loIdx = iLowest(sym, tf, MODE_LOW, 6, 0);
      double hi6 = High[hiIdx];
      double lo6 = Low[loIdx];
#define MAKE_BOX(_id, _top, _bot, _clr)                                        \
  if (ObjectFind(0, _id) < 0)                                                  \
   ObjectCreate(0, _id, OBJ_RECTANGLE, 0, tL, _top, tR, _bot);                 \
  ObjectSetInteger(0, _id, OBJPROP_COLOR, _clr);                               \
  ObjectSetInteger(0, _id, OBJPROP_STYLE, STYLE_SOLID);                        \
  ObjectSetInteger(0, _id, OBJPROP_WIDTH, 1);                                  \
  ObjectSetInteger(0, _id, OBJPROP_BACK, true);                                \
  ObjectSetInteger(0, _id, OBJPROP_TIME, 0, tL);                               \
  ObjectSetInteger(0, _id, OBJPROP_TIME, 1, tR);                               \
  ObjectSetDouble(0, _id, OBJPROP_PRICE, 0, _top);                             \
  ObjectSetDouble(0, _id, OBJPROP_PRICE, 1, _bot);
      bool sweepOK = false;
      // FASE 7 (Patch 5): Pattern variabile sostituita da
      // GetAdaptive_PatternEnabled() (asset-class + volatility aware).
      if (Reverse || FVG || SMC || ICT ||
          GetAdaptive_PatternEnabled()) {
        sweepOK = LH_SweepValid(sym, tf, 1);
      }
      if (Reverse) {
        string idb = "TRIG_ROYAL_BOX_" + IntegerToString((int)tbar);
        string idm = "TRIG_ROYAL_MAIN_" + IntegerToString((int)tbar);
        string idh = "TRIG_ROYAL_HI_" + IntegerToString((int)tbar);
        string idl = "TRIG_ROYAL_LO_" + IntegerToString((int)tbar);
        MAKE_BOX(idb, hi6, lo6, boxClr);
        int __reg = TrendRegime(sym, tf);
        string __r = (__reg == 1 ? "TRD" : __reg == 0 ? "RNG" : "NEU");
        double _lo = 0, _hi = 0, _tol = 0;
        bool _okOTE = OTEBandFromHistory(true, tf, 15, _lo, _hi, _tol);
        int _iH = iHighest(sym, tf, MODE_HIGH, 30, 1);
        int _iL = iLowest(sym, tf, MODE_LOW, 30, 1);
        double _H = iHigh(sym, tf, _iH);
        double _L = iLow(sym, tf, _iL);
        double _leg = MathMax(_H - _L, Point * 10);
        double _fu = (_H - Close[1]) / _leg;
        double _fd = (Close[1] - _L) / _leg;
        bool _OTE = _okOTE && ((_fu >= _lo - _tol && _fu <= _hi + _tol) ||
                               (_fd >= _lo - _tol && _fd <= _hi + _tol));
        int __regL = TrendRegime(sym, tf);
        string __rL = (__regL == 1 ? "TRD" : __regL == 0 ? "RNG" : "NEU");
        string __lbl = _OTE ? "LH OTE " + __rL : "LH " + __rL;
        DrawShortHLine(idm, Time[1], BarEndTime(1), Close[1], base, __lbl,
                       true);
      }
      if (FVG) {
        string idb = "TRIG_FVG_BOX_" + IntegerToString((int)tbar);
        string idm = "TRIG_FVG_MAIN_" + IntegerToString((int)tbar);
        string idh = "TRIG_FVG_HI_" + IntegerToString((int)tbar);
        string idl = "TRIG_FVG_LO_" + IntegerToString((int)tbar);
        MAKE_BOX(idb, hi6, lo6, boxClr);
        int __reg = TrendRegime(sym, tf);
        string __r = (__reg == 1 ? "TRD" : __reg == 0 ? "RNG" : "NEU");
        double _lo = 0, _hi = 0, _tol = 0;
        bool _okOTE = OTEBandFromHistory(true, tf, 15, _lo, _hi, _tol);
        int _iH = iHighest(sym, tf, MODE_HIGH, 30, 1);
        int _iL = iLowest(sym, tf, MODE_LOW, 30, 1);
        double _H = iHigh(sym, tf, _iH);
        double _L = iLow(sym, tf, _iL);
        double _leg = MathMax(_H - _L, Point * 10);
        double _fu = (_H - Close[1]) / _leg;
        double _fd = (Close[1] - _L) / _leg;
        bool _OTE = _okOTE && ((_fu >= _lo - _tol && _fu <= _hi + _tol) ||
                               (_fd >= _lo - _tol && _fd <= _hi + _tol));
        int __regL = TrendRegime(sym, tf);
        string __rL = (__regL == 1 ? "TRD" : __regL == 0 ? "RNG" : "NEU");
        string __lbl = _OTE ? "LH OTE " + __rL : "LH " + __rL;
        DrawShortHLine(idm, Time[1], BarEndTime(1), Close[1], base, __lbl,
                       true);
      }
      if (SMC || ICT) {
        string idb = "TRIG_SMC_BOX_" + IntegerToString((int)tbar);
        string idm = "TRIG_SMC_MAIN_" + IntegerToString((int)tbar);
        string idh = "TRIG_SMC_HI_" + IntegerToString((int)tbar);
        string idl = "TRIG_SMC_LO_" + IntegerToString((int)tbar);
        MAKE_BOX(idb, hi6, lo6, boxClr);
        int __reg = TrendRegime(sym, tf);
        string __r = (__reg == 1 ? "TRD" : __reg == 0 ? "RNG" : "NEU");
        double _lo = 0, _hi = 0, _tol = 0;
        bool _okOTE = OTEBandFromHistory(true, tf, 15, _lo, _hi, _tol);
        int _iH = iHighest(sym, tf, MODE_HIGH, 30, 1);
        int _iL = iLowest(sym, tf, MODE_LOW, 30, 1);
        double _H = iHigh(sym, tf, _iH);
        double _L = iLow(sym, tf, _iL);
        double _leg = MathMax(_H - _L, Point * 10);
        double _fu = (_H - Close[1]) / _leg;
        double _fd = (Close[1] - _L) / _leg;
        bool _OTE = _okOTE && ((_fu >= _lo - _tol && _fu <= _hi + _tol) ||
                               (_fd >= _lo - _tol && _fd <= _hi + _tol));
        int __regL = TrendRegime(sym, tf);
        string __rL = (__regL == 1 ? "TRD" : __regL == 0 ? "RNG" : "NEU");
        string __lbl = _OTE ? "LH OTE " + __rL : "LH " + __rL;
        DrawShortHLine(idm, Time[1], BarEndTime(1), Close[1], base, __lbl,
                       true);
      }
      if (Breakout) {
        int regime = TrendRegime(sym, tf);
        string idb = "TRIG_COBRA_BOX_" + IntegerToString((int)tbar);
        MAKE_BOX(idb, hi6, lo6, boxClr);
        DrawShortHLine("TRIG_COBRA_MAIN_" + IntegerToString((int)tbar), Time[1],
                       BarEndTime(1), Close[1], base,
                       (regime == 1   ? "TRD"
                        : regime == 0 ? "RNG"
                                      : "NEU"),
                       true);
      }
      int maxObj = 1200;
      int total = ObjectsTotal(0, -1, -1);
      if (total > maxObj) {
        int toRemove = total / 10;
        for (int i = 0; i < toRemove; i++) {
          string nm = ObjectName(0, i);
          if (StringFind(nm, "TRIG_", 0) == 0)
            ObjectDelete(0, nm);
        }
      }
      ChartRedraw();
}

void TriggerOverlay_OnTick_Update()
{
      /*COBRA_AID*/ if (Breakout && FIL_TGL_ATR && HasBars(10)) {
        // Recompute consolidation box
        int consLB = 15;
        int shift = 1;
        double boxHigh = 0, boxLow = 0;
        int span = 0;
        ConsolidationBox(boxHigh, boxLow, span);
        static int __lastSpan = -1;
        if (__lastSpan != span) {
          SL("cobra", "box",
             StringFormat("span=%d | %.5f..%.5f", span, boxLow, boxHigh));
          __lastSpan = span;
        }
        datetime tL = Time[span];
        datetime tR = BarEndTime(0);
        // Compute NR4/NR7 and ATR condition
        bool nr4 = true, nr7 = true;
        double refRange = High[1] - Low[1];
        for (int i = 1; i <= 4 && i < Bars; i++)
          if ((High[i] - Low[i]) <= refRange && i != 1)
            ;
          else
            nr4 = false;
        for (int i = 1; i <= 7 && i < Bars; i++)
          if ((High[i] - Low[i]) <= refRange && i != 1)
            ;
          else
            nr7 = false;
        double atr = iATR(Symbol(), Period(), Auto_ATR_Period(), 0);
        // median of last 20 ranges
        double med = refRange;
        int w = 20, cnt = 0;
        double arr[64];
        ArrayInitialize(arr, 0.0);
        for (int k = 1; k <= w && k < Bars && k < 64; k++) {
          arr[cnt++] = High[k] - Low[k];
        }
        for (int i = 0; i < cnt; i++)
          for (int j = i + 1; j < cnt; j++)
            if (arr[j] < arr[i]) {
              double tmp = arr[i];
              arr[i] = arr[j];
              arr[j] = tmp;
            }
        if (cnt > 0)
          med = arr[cnt / 2];
        bool atr_ok = (atr <= 0.8 * med);
        // Draw helper tags at box edges (dashed RGB with centered names)
        if (nr4)
          DrawShortHLine("Trig_cobra_aid_nr4_hi_" +
                             IntegerToString(iBars(NULL, 0)),
                         tL, tR, boxHigh, 0, "NR4", true);
        if (nr7)
          DrawShortHLine("Trig_cobra_aid_nr7_lo_" +
                             IntegerToString(iBars(NULL, 0)),
                         tL, tR, boxLow, 0, "NR7", true);
        if (atr_ok)
          DrawShortHLine("Trig_cobra_aid_atr_mid_" +
                             IntegerToString(iBars(NULL, 0)),
                         tL, tR, (boxHigh + boxLow) / 2, 0, "ATR OK", true);
      }
      SMC_Overlay_Extras();
      FVG_Overlay_Draw();
      SMC_Overlay_Draw();
      /*BARGUARD_ONTICK*/ if (!HasBars(21)) {
        return;
      }
      // Keep forming OTE (Predicted) moving in real time and refresh grid
      // lines forward
      int tbar = iBars(NULL, 0);
      color boxClr = RGB_Current();
      // --- Predicted forming OTE2 at extremities (upper/lower), live update
      // ---
      if (Predicted && HasBars(21)) {
        double loB = 0, hiB = 0, tol = 0;
        bool okOTE = OTEBandFromHistory(true, Period(), 20, loB, hiB, tol);
        if (okOTE) {
          double addH = 0.2 * (hiB - loB);
          datetime tL = Time[20];
          datetime tR = BarEndTime(0);
          // Upper OTE2
          string id2u =
              "Trig_ai_box_ote2_hi_" + IntegerToString((int)iBars(NULL, 0));
          if (ObjectFind(0, id2u) < 0)
            ObjectCreate(0, id2u, OBJ_RECTANGLE, 0, tL, hiB + addH, tR, hiB);
          ObjectSetInteger(0, id2u, OBJPROP_COLOR, RGB_Current());
          ObjectSetInteger(0, id2u, OBJPROP_BACK, true);
          ObjectSetInteger(0, id2u, OBJPROP_TIME, 0, tL);
          ObjectSetInteger(0, id2u, OBJPROP_TIME, 1, tR);
          ObjectSetDouble(0, id2u, OBJPROP_PRICE, 0, hiB + addH);
          ObjectSetDouble(0, id2u, OBJPROP_PRICE, 1, hiB);
          // Lower OTE2
          string id2d =
              "Trig_ai_box_ote2_lo_" + IntegerToString((int)iBars(NULL, 0));
          if (ObjectFind(0, id2d) < 0)
            ObjectCreate(0, id2d, OBJ_RECTANGLE, 0, tL, loB, tR, loB - addH);
          ObjectSetInteger(0, id2d, OBJPROP_COLOR, RGB_Current());
          ObjectSetInteger(0, id2d, OBJPROP_BACK, true);
          ObjectSetInteger(0, id2d, OBJPROP_TIME, 0, tL);
          ObjectSetInteger(0, id2d, OBJPROP_TIME, 1, tR);
          ObjectSetDouble(0, id2d, OBJPROP_PRICE, 0, loB);
          ObjectSetDouble(0, id2d, OBJPROP_PRICE, 1, loB - addH);
        }
      }
}

int CountActiveStrategies() {
    int count = 0;
    if (Predicted)        count++;
    if (Breakout)         count++;
    if (FVG)     count++;
    if (Grid)             count++;
    if (SMC) count++;
    if (ICT) count++;
    if (Reverse)          count++;
    return count; } // Pattern Engine is always active (not counted as owner strategy)

