void Auto_PA_Thresholds(double &bodyRatioMin, double &wickMaxFrac, double &impulseATRMin){
      double sens = Auto_PA_Sensitivity();
      bodyRatioMin = 0.55;
      if (sens < 1.0)
        bodyRatioMin += 0.05 * (1.0 - sens);
      else
        bodyRatioMin -= 0.04 * (sens - 1.0);
      wickMaxFrac = 0.35;
      if (sens < 1.0)
        wickMaxFrac -= 0.08 * (1.0 - sens);
      else
        wickMaxFrac += 0.06 * (sens - 1.0);
      impulseATRMin = 0.60;
      if (sens < 1.0)
        impulseATRMin += 0.15 * (1.0 - sens);
      else
        impulseATRMin -= 0.15 * (sens - 1.0);
      // Clamp
      if (bodyRatioMin < 0.45)
        bodyRatioMin = 0.45;
      if (bodyRatioMin > 0.70)
        bodyRatioMin = 0.70;
      if (wickMaxFrac < 0.15)
        wickMaxFrac = 0.15;
      if (wickMaxFrac > 0.50)
        wickMaxFrac = 0.50;
      if (impulseATRMin < 0.35)
        impulseATRMin = 0.35;
      if (impulseATRMin > 0.90)
        impulseATRMin = 0.90;
}

double Auto_SAR_Step(){
