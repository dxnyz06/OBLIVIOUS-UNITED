// --- TPSLManager State ---
#define TPSL_MAX_TRACKED 64

// LIVE trade state machine — named constants (replaces 0/1/2/3 literals).
// Sequence: UNARMED → PROTECTED → BE → TRAIL.
// Read by ManageBreakEven, ClusterMoney_OnTick, Smart Panel, chart overlay.
#ifndef LIVE_UNARMED
#define LIVE_UNARMED    0   // arming window: broker SL wide, trade breathes
#define LIVE_PROTECTED  1   // broker SL = projected initialSL (post-arming)
#define LIVE_BE         2   // SL moved to entry + ATR buffer (post-TP1)
#define LIVE_TRAIL      3   // ATR-trail engaged (post-TP3)
#endif

struct TPSLTrackInfo {
   int ticket;
   int magic;
   string strategy;
   double entryPrice;
   double initialSL;
   double tp1;
   double tp2;
   double tp3;
   double tpmax;
   bool tp1Hit;
   bool tp2Hit;
   bool tp3Hit;
   int orderType; // OP_BUY or OP_SELL
   // FASE 3 - LIVE state machine:
   //   0=UNARMED (SL broker LARGO arming, lascia respirare)
   //   1=PROTECTED (SL broker = initialSL projected)
   //   2=BE (SL spostato a entry+buffer dopo TP1)
   //   3=TRAIL (trailing post-TP3)
   int      liveState;
   datetime openedAt;        // wall time del fill (per arming guard)
   double   armingSL;        // SL "largo" usato in UNARMED
   // FASE 12 - REATTACH RECOVERY:
   //   recoveredAt > 0 -> trade ripreso da EA reattach.
   //   Durante recovery_grace il TPSL manager NON tocca SL broker
   //   ne' applica BE per ulteriori N secondi (warmup).
   datetime recoveredAt;
};
TPSLTrackInfo g_tpsl_tracks[TPSL_MAX_TRACKED];
int g_tpsl_trackCount = 0;

