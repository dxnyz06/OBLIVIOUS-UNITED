//| 27. cleanup / helper finali / compatibilitÃƒÃ‚Â¯ÃƒÃ‚Â¿ÃƒÃ‚Â½ minima

void GV_Cleanup(int maxAgeSec)
{
      int total = GlobalVariablesTotal();
      datetime now = TimeCurrent();
      for (int i = total - 1; i >= 0; i--) {
        string name = GlobalVariableName(i);
        if (StringFind(name, GV_PREFIX) != 0)
          continue;
        datetime lastAccess = GlobalVariableTime(name);
        if (lastAccess > 0 && (now - lastAccess) > maxAgeSec)
          GlobalVariableDel(name);
      }
}

void ActiveStrategiesPanel_Cleanup()
{
      if (ObjectFind(0, "AS_Title") >= 0)
        ObjectDelete(0, "AS_Title");
      for (int z = 0; z < 40; z++) {
        string idName = "AS_Row_Name_" + IntegerToString(z);
        string idPnl = "AS_Row_Pnl_" + IntegerToString(z);
        if (ObjectFind(0, idName) >= 0)
          ObjectDelete(0, idName);
        if (ObjectFind(0, idPnl) >= 0)
          ObjectDelete(0, idPnl);
      }
}

   void CleanupPOIs() {
   DeleteTrigByPrefix(
   "POI_");
   }

