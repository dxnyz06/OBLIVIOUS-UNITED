// ============================================================
// PREDICTED STRATEGY v2: Event-Driven OTE2 with Impulse Detection
// ============================================================

bool Predicted_DetectImpulse() {
   if (g_aip_impact < 3) return false;
   if (g_aip_direction == 0) return false;
   
   datetime eventTime = g_aip_timestamp;
   if (eventTime <= 0) eventTime = g_np_nextHighEventTime;
   if (eventTime <= 0) return false;
   
   int barsFromEvent = iBarShift(Symbol(), Period(), eventTime, false);
   if (barsFromEvent < 0 || barsFromEvent > 30) return false;
   
   double atr = iATR(Symbol(), Period(), 14, 1);
   if (atr <= 0) return false;
   
   double impulseHi = -999999;
   double impulseLo = 999999;
   int lookback = (int)MathMin(barsFromEvent + 1, 20);
   int i;
   
   for (i = 0; i < lookback; i++) {
      double h = iHigh(Symbol(), Period(), i);
      double l = iLow(Symbol(), Period(), i);
      if (h > impulseHi) impulseHi = h;
      if (l < impulseLo) impulseLo = l;
   }
   
   double impulseRange = impulseHi - impulseLo;
   if (impulseRange < atr * 0.5) return false;
   
   bool foundImpulsiveBar = false;
   for (i = 0; i < lookback; i++) {
      double o = iOpen(Symbol(), Period(), i);
      double c = iClose(Symbol(), Period(), i);
      double hh = iHigh(Symbol(), Period(), i);
      double ll = iLow(Symbol(), Period(), i);
      double body = MathAbs(c - o);
      double rng = hh - ll;
      if (rng > 0 && body / rng > 0.65 && rng > atr * 1.2) {
         foundImpulsiveBar = true;
         break;
      }
   }
   if (!foundImpulsiveBar) return false;
   
   double closeNow = Close[0];
   double midImpulse = (impulseHi + impulseLo) / 2.0;
   int impulseDir = 0;
   if (closeNow > midImpulse + atr * 0.3) impulseDir = +1;
   else if (closeNow < midImpulse - atr * 0.3) impulseDir = -1;
   
   if (g_aip_direction != 0 && impulseDir != 0 && g_aip_direction != impulseDir)
      return false;
   if (impulseDir == 0) impulseDir = g_aip_direction;
   if (impulseDir == 0) return false;
   
   g_pred_impulseHigh = impulseHi;
   g_pred_impulseLow = impulseLo;
   g_pred_impulseDir = impulseDir;
   g_pred_impulseValid = true;
   g_pred_impulseStartTime = eventTime;
   g_pred_barsFromImpulse = barsFromEvent;
   
   return true;
}

bool Predicted_BuildOTE2() {
   if (!g_pred_impulseValid) return false;
   
   double hi = g_pred_impulseHigh;
   double lo = g_pred_impulseLow;
   double rng = hi - lo;
   double atr = iATR(Symbol(), Period(), 14, 1);
   
   if (rng > atr * 6.0) {
      double mid = (hi + lo) / 2.0;
      hi = mid + atr * 3.0;
      lo = mid - atr * 3.0;
      rng = hi - lo;
   }
   
   if (g_pred_impulseDir > 0) {
      g_pred_ote2High = hi - rng * 0.618;
      g_pred_ote2Low = hi - rng * 0.786;
   } else {
      g_pred_ote2Low = lo + rng * 0.618;
      g_pred_ote2High = lo + rng * 0.786;
   }
   
   double ote2Width = MathAbs(g_pred_ote2High - g_pred_ote2Low);
   if (ote2Width < atr * 0.1 || ote2Width > atr * 3.0) return false;
   
   g_pred_ote2Active = true;
   return true;
}

bool Predicted_AntiLateFilter() {
   if (g_pred_impulseStartTime <= 0) return false;
   
   int minutesSinceEvent = (int)((TimeCurrent() - g_pred_impulseStartTime) / 60);
   int maxMinutes = Period() * 15;
   if (minutesSinceEvent > maxMinutes) return false;
   if (g_pred_barsFromImpulse > 20) return false;
   
   double atr = iATR(Symbol(), Period(), 14, 1);
   double currentExtension = MathAbs(Close[0] - (g_pred_impulseHigh + g_pred_impulseLow) / 2.0);
   if (currentExtension > atr * 4.0) return false;
   
   return true;
}

bool Predicted_AntiChaosFilter() {
   if (SpreadFilter_IsHardBlocked()) return false;
   if (SpreadFilter_GetAnomalyScore() > 70) return false;
   if (!g_pred_impulseValid) return false;
   
   double ote2Width = MathAbs(g_pred_ote2High - g_pred_ote2Low);
   double atr = iATR(Symbol(), Period(), 14, 1);
   if (ote2Width < atr * 0.05 || ote2Width > atr * 5.0) return false;
   
   if (g_aip_confidence > 0 && g_aip_confidence < 30) return false;
   
   return true;
}

void Predicted_CancelPending(int &ticketRef) {
   if (ticketRef > 0) {
      if (OrderSelect(ticketRef, SELECT_BY_TICKET)) {
         if (OrderCloseTime() == 0 && OrderType() >= OP_BUYLIMIT) {
            bool ok = OrderDelete(ticketRef);
            if (ok) ticketRef = -1;
         } else {
            ticketRef = -1;
         }
      } else {
         ticketRef = -1;
      }
   }
}

void Predicted_OCO_Check() {
   if (g_pred_buyLimitTicket > 0 && OrderSelect(g_pred_buyLimitTicket, SELECT_BY_TICKET)) {
      if (OrderType() == OP_BUY) {
         Predicted_CancelPending(g_pred_sellLimitTicket);
         TPSL_RegisterTrade(g_pred_buyLimitTicket, PredictedMagic, "Predicted", 
                            OP_BUY, OrderOpenPrice(), OrderStopLoss());
         g_pred_buyLimitTicket = -1;
      }
   }
   if (g_pred_sellLimitTicket > 0 && OrderSelect(g_pred_sellLimitTicket, SELECT_BY_TICKET)) {
      if (OrderType() == OP_SELL) {
         Predicted_CancelPending(g_pred_buyLimitTicket);
         TPSL_RegisterTrade(g_pred_sellLimitTicket, PredictedMagic, "Predicted",
                            OP_SELL, OrderOpenPrice(), OrderStopLoss());
         g_pred_sellLimitTicket = -1;
      }
   }
}

void Predicted_PlaceLimits() {
   if (g_pred_buyLimitTicket > 0 || g_pred_sellLimitTicket > 0) return;
   if (!g_pred_ote2Active) return;
   
   double lots = NormalizeLotToMarket(Active_ManualLot());
   double atr = iATR(Symbol(), Period(), 14, 1);
   double sl_dist = atr * 2.0;
   double tp_dist = atr * 3.5;
   
   double buyEntry = g_pred_ote2Low;
   double buySL = buyEntry - sl_dist;
   lots = Risk_ClampLotToMaxRisk(Symbol(), lots, buySL, buyEntry);
   if (lots <= 0) return;
   
   double buyTP = buyEntry + tp_dist;
   double sellEntry = g_pred_ote2High;
   double sellSL = sellEntry + sl_dist;
   double sellTP = sellEntry - tp_dist;
   
   datetime expiry = TimeCurrent() + Period() * 60 * 10;
   
   int buyTicket = SafeOrderSend(Symbol(), OP_BUYLIMIT, lots,
      NormalizeDouble(buyEntry, Digits), 3,
      NormalizeDouble(buySL, Digits), NormalizeDouble(buyTP, Digits),
      "Predicted_OTE2_BuyLimit", PredictedMagic, expiry, clrGreen);
   if (buyTicket > 0) g_pred_buyLimitTicket = buyTicket;
   
   int sellTicket = SafeOrderSend(Symbol(), OP_SELLLIMIT, lots,
      NormalizeDouble(sellEntry, Digits), 3,
      NormalizeDouble(sellSL, Digits), NormalizeDouble(sellTP, Digits),
      "Predicted_OTE2_SellLimit", PredictedMagic, expiry, clrRed);
   if (sellTicket > 0) g_pred_sellLimitTicket = sellTicket;
   
   if (buyTicket > 0 || sellTicket > 0)
      g_pred_lastSetupTime = TimeCurrent();
}

void Predicted_InvalidateStaleSetup() {
   if (!g_pred_ote2Active) return;
   
   int minutesSinceSetup = (int)((TimeCurrent() - g_pred_lastSetupTime) / 60);
   int maxMinutes = Period() * 12;
   
   if (minutesSinceSetup > maxMinutes || !Predicted_AntiLateFilter()) {
      Predicted_CancelPending(g_pred_buyLimitTicket);
      Predicted_CancelPending(g_pred_sellLimitTicket);
      g_pred_ote2Active = false;
      g_pred_impulseValid = false;
   }
}


//| 25. Strategy_Predicted_Logic

void Strategy_Predicted_Logic() {
   if (!OBL_OwnerContextOK("Predicted")) return;
   if (!AllowStrategyToTrade()) return;
   if (!Predicted) return;
   if (!NewsPolicy_CanOpen("Predicted")) return;
   
   // OCO check: if one pending filled, cancel the other
   Predicted_OCO_Check();
   
   // Invalidate stale setups
   Predicted_InvalidateStaleSetup();
   
   // If already have pending orders, just manage them
   if (g_pred_buyLimitTicket > 0 || g_pred_sellLimitTicket > 0) return;
   
   // If OTE2 already active but no pendings, try placing again
   if (g_pred_ote2Active && Predicted_AntiChaosFilter()) {
      Predicted_PlaceLimits();
      return;
   }
   
   // Try to detect new impulse from news
   if (!Predicted_DetectImpulse()) return;
   if (!Predicted_BuildOTE2()) return;
   if (!Predicted_AntiLateFilter()) return;
   if (!Predicted_AntiChaosFilter()) return;
   
   // Place limits at OTE2 extremities
   Predicted_PlaceLimits();
}

