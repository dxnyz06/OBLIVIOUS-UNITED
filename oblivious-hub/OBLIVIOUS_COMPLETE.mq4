bool ConfirmSRPercentRank(bool isBuy)
{

      int p = Auto_MA_Period();
      double c = iClose(Symbol(), PERIOD_CURRENT, 1);
      double lo = 1e10, hi = -1e10;
      for (int i = 1; i <= p; i++) {
        double v = iClose(Symbol(), PERIOD_CURRENT, i);
        if (v < lo)
          lo = v;
        if (v > hi)
          hi = v;
      }
      double rank = (hi > lo ? 100.0 * (c - lo) / (hi - lo) : 50.0);
      static double ema_rank = EMPTY_VALUE;
      ema_rank = (ema_rank == EMPTY_VALUE ? rank : 0.2 * rank + 0.8 * ema_rank);
      return isBuy ? (rank > ema_rank) : (rank < ema_rank);
}

