void DrawTriggersDispatcher()
{
      datetime t1 = iTime(Symbol(), Period(), 1);
      double c1 = iClose(Symbol(), Period(), 1);
      for (int i = 0; i < 11; i++) {
        if (!TB_ShowTrig[i])
          continue;
        int sig = GetSignalForIndex(i);
        if (sig == 0)
          continue;
        // avoid duplicates on same bar
        if (TB_LastSigTime[i] == t1)
          continue;
        TB_LastSigTime[i] = t1;
        string base =
            "TRIG_" + IntegerToString(i) + "_" + IntegerToString((int)t1);
        DrawWhiteArrow(base + "_A", t1, c1, sig > 0);
        DrawWhiteNote(base + "_T", t1, c1, TB_StrategyNames[i]);
      }
}

bool Orchestrator_IsNewBar()
{
      datetime curBar = iTime(Symbol(), Period(), 0);
      if (curBar != g_orch_lastBar) {
        g_orch_lastBar = curBar;
        g_orch_newBar = true;
        return true;
      }
      g_orch_newBar = false;
      return false;
}

// Returns the most-relevant owner strategy name for ai_query
// labelling. Used so the hub can apply per-strategy weights when
// fusing orderflow / engines / providers. The actual dispatch
// (LEVEL 1) is unaffected — every enabled owner still runs.
string Orchestrator_DominantOwner() {
   if (Predicted) return "Predicted";
   if (SMC)       return "SMC";
   if (ICT)       return "ICT";
   if (FVG)       return "FVG";
   if (Reverse)   return "Reverse";
   if (Breakout)  return "Breakout";
   if (Grid)      return "Grid";
   return "Native";
}

// Functions: 110

                                          bool Orchestrator_CanTrade() {
                                            // News filter
                                            if (NewsBridge_ShouldBlock())
                                              return false;

                                            // Account health
                                            double marginLevel = 0;
                                            if (AccountMargin() > 0)
                                              marginLevel = AccountEquity() /
   AccountMargin() *
   100.0;
                                            if (marginLevel > 0 &&
                                                marginLevel < 120.0)
                                              return false; // Margin too
                                            // low

                                            // Max drawdown
                                            double dd = (AccountBalance() -
                                                         AccountEquity());
                                            if (AccountBalance() > 0 &&
                                                dd / AccountBalance() > 0.30)
                                              return false; // >30% drawdown

                                            // Trading allowed
                                            if (!EA_IsTradeAllowed())
                                              return false;

                                            return true;
                                          }

// ============================================================
// FASE 12 - EA REATTACH SAFE RECOVERY ENGINE
//
// Quando l'EA viene caricato (OnInit) il sistema scansiona TUTTI
// gli ordini aperti del simbolo, identifica quelli appartenenti
// al sistema tramite magic number e li riprende in gestione in
// modo prudente:
//   - g_ownerRegistry rebuild
//   - g_tpsl_tracks rebuild per market positions (isRecovery=true)
//   - g_active_setups rebuild per pending LIMIT (recovered_setup)
//   - NO close, NO invalidate, NO SL squeeze
//   - warmup grace window dove TPSL/ClusterMoney non toccano nulla
//   - overlay chart si auto-ridisegna ad ogni tick via
//     TpSlOverlay_Update + Pending_Lifecycle_Tick
// ============================================================

datetime g_ea_recoveryDoneAt = 0;
int      g_ea_recoveredCount = 0;
int      g_ea_recoveredPendingCount = 0;

string EA_MagicToOwner(int magic) {
   if (magic == FVGMagic)       return "FVG";
   if (magic == SMCMagic)       return "SMC";
   if (magic == ICTMagic)       return "ICT";
   if (magic == ReverseMagic)   return "Reverse";
   if (magic == BreakoutMagic)  return "Breakout";
   if (magic == GridMagic)      return "Grid";
   if (magic == PredictedMagic) return "Predicted";
   return "";
}

void EA_ReattachRecovery() {
   int total = OrdersTotal();
   if (total <= 0) {
      g_ea_recoveryDoneAt = TimeCurrent();
      PrintFormat("[Recovery] no open orders to recover");
      return;
   }
   int recLive = 0, recPend = 0, skipped = 0;
   double atr_now = iATR(Symbol(), Period(), 14, 1);

   for (int i = 0; i < total; i++) {
      if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES)) continue;
      if (OrderSymbol() != Symbol())                   continue;
      int    magic    = OrderMagicNumber();
      string owner    = EA_MagicToOwner(magic);
      if (owner == "") { skipped++; continue; }   // non nostro

      int    ticket   = OrderTicket();
      int    otype    = OrderType();
      double openPx   = OrderOpenPrice();
      double slBroker = OrderStopLoss();
      double tpBroker = OrderTakeProfit();
      double lots     = OrderLots();

      // 1) Owner registry rebuild (idempotente: Register skippa duplicati)
      OwnerRegistry_Register(ticket, owner, owner, magic,
                             "RECOVERED_ON_ATTACH", 0.0, "standard",
                             OrderComment());

      // 2) MARKET position -> TPSL track recovery (no SL squeeze)
      if (otype == OP_BUY || otype == OP_SELL) {
         int normalizedType = (otype == OP_BUY ? OP_BUY : OP_SELL);
         double initialSL = (slBroker > 0)
            ? slBroker
            : ((otype == OP_BUY) ? openPx - 1.40 * atr_now
                                  : openPx + 1.40 * atr_now);
         TPSL_RegisterTrade(ticket, magic, owner, normalizedType,
                            openPx, initialSL, true);  // isRecovery=true
         recLive++;
         continue;
      }

      // 3) PENDING LIMIT -> setup recovery
      if (otype == OP_BUYLIMIT || otype == OP_SELLLIMIT) {
         int dir = (otype == OP_BUYLIMIT ? 1 : -1);
         double pendSL = (slBroker > 0)
            ? slBroker
            : ((dir == 1) ? openPx - 1.40 * atr_now
                          : openPx + 1.40 * atr_now);
         // Invalidation: usa l'SL come livello di invalidazione di default
         int parentId = Setup_Register(owner, dir, openPx, pendSL,
                                       1.0, 60, openPx);
         Setup_AttachPending(parentId, ticket, openPx, pendSL, tpBroker);
         recPend++;
         continue;
      }
      // STOP orders / BUYSTOP/SELLSTOP: registry only, no rebind
      skipped++;
   }

   g_ea_recoveredCount        = recLive;
   g_ea_recoveredPendingCount = recPend;
   g_ea_recoveryDoneAt        = TimeCurrent();
   PrintFormat("[Recovery] DONE live=%d pending=%d skipped=%d (warmup grace active)",
               recLive, recPend, skipped);
}

                                          void Orchestrator_OnInit() {
                                            g_orch_lastBar = 0;
                                            g_orch_newBar = false;
                                            g_orch_tickCounter = 0;

                                            // Bootstrap owner profile table
                                            // for the Dynamic Levels Engine.
                                            // Auto-active — no user input.
                                            OBL_InitOwnerProfiles();

                                            // FASE 2.2 (Patch 6): bootstrap
                                            // unico - estratte SOLO le 3
                                            // righe utili da Init() legacy
                                            // (mai chiamata). g_startEquity
                                            // e g_peakEquity erano dichiarati
                                            // ma mai inizializzati: senza
                                            // questi il RiskEngine partiva da
                                            // 0 -> DD totale sempre 100% e
                                            // peak retrace lock impossibile.
                                            if (!IsDllsAllowed()) {
                                              Alert("DLLs must be allowed "
                                                    "for bridge functionality");
                                            }
                                            g_startEquity    = AccountEquity();
                                            g_peakEquity     = AccountEquity();
                                            g_tradingBlocked = false;
                                            // PATCH C: attach grace period.
                                            // Per i primi g_ea_attach_grace_sec
                                            // secondi dopo init, NESSUN market
                                            // fallback delle 5 owner non-grid/
                                            // non-predicted. Solo LIMIT pending.
                                            // Evita il "trade casuale su attach"
                                            // quando il prezzo e' gia' dentro
                                            // una zona storica al momento del
                                            // collegamento.
                                            g_ea_attachTime = TimeCurrent();

                                            // FASE 1 - cleanup OBL_LIQ_*
                                            // residui (da EX4 precedente che
                                            // li disegnava). La logica
                                            // liquidita' resta interna ma
                                            // niente piu' overlay chart.
                                            Liq_RemovePoolObjects();

                                            // Initialize subsystems
                                            IndicatorManager_Init();
                                            NewsBridge_Init();

                                            // Initialize strategy-specific
                                            // state
                                            Strategy_Grid_Init();
                                            Strategy_Martingale_Init();

                                            // AI Bridge
                                            Bridge_Init();

                                            // SmartLog
                                            SmartLog_Create(Symbol());

                                            // Rainbow + Panels
                                            Rainbow_CleanChart();
                                            g_rainbowColor = HSVtoRGB(g_hue, 1.0, 1.0);
                                            ApplyRainbow(g_rainbowColor);
                                            DynPanel_Init();
                                            TrigPanel_Init();
                                            SmartPanel_Init();

                                            // FASE 12 - REATTACH SAFE
                                            // RECOVERY: scansiona TUTTI gli
                                            // ordini aperti del simbolo,
                                            // riprende ownership/TPSL/setup
                                            // per i ticket con magic owner
                                            // valido. NO close automatico.
                                            // Recovery grace window attiva
                                            // su TPSL Manager e ClusterMoney.
                                            EA_ReattachRecovery();

                                            // FASE 2.2 (Patch 6): UNICO
                                            // EventSetTimer ufficiale. Il
                                            // timer scatena OnTimer ->
                                            // Orchestrator_OnTimer ->
                                            // ProfitGuards_OnTimer +
                                            // ClusterMoney_CleanupOrphanGV
                                            // (vedi FASE 4.3). RGB_InitCycle
                                            // NON deve piu' chiamare
                                            // EventSetTimer (rimosso in
                                            // FASE 9) altrimenti collisione.
                                            EventSetTimer(1);

                                            SmartLog("INFO", "Orchestrator",
                                                     "All strategies "
                                                     "initialized");
                                          }

                                          void Orchestrator_OnDeinit() {
                                            // FASE 2.2 (Patch 6 + 7): kill
                                            // timer ufficiale + cleanup di
                                            // tutte le GlobalVariable PTP_PEAK_*
                                            // create da ClusterMoney_OnTick
                                            // (vedi FASE 4.3) per evitare di
                                            // lasciare stato sporco nel terminal
                                            // dopo Remove dell'EA.
                                            EventKillTimer();
                                            ClusterMoney_CleanupAllGV();
                                            // FASE 8+11: cleanup overlay TP/SL
                                            // ticket (OBL_LVL_*) e trigger OF
                                            // EXE bridge (OBL_OF_*).
                                            for (int __i = ObjectsTotal(0, -1, -1) - 1; __i >= 0; --__i) {
                                              string __nm = ObjectName(0, __i);
                                              if (StringFind(__nm, "OBL_LVL_") == 0 ||
                                                  StringFind(__nm, "OBL_OF_")  == 0 ||
                                                  StringFind(__nm, "OBL_LIQ_") == 0 ||
                                                  StringFind(__nm, "OBL_STG_") == 0) {
                                                ObjectDelete(0, __nm);
                                              }
                                            }
                                            Panels_Cleanup();
                                            Bridge_Shutdown();
                                            SmartLog_Destroy();
                                            VTPSL_Cleanup();
                                          }

void Orchestrator_OnTick() {
   // Phase 1 hooks
   SpreadFilter_Update();
   NewsPolicy_Update();
   TPSLManager_OnTick();        // FASE 1: ladder TP1/2/3/Max + trailing SL
                                // (ora con entryPrice corretto).
   TpSlOverlay_Update();        // FASE 8: overlay live HLine TP1/2/3/MAX/SL
                                // per ticket (throttled 3s).
   OBL_OrphanCleanup();         // ITER 34: rimuove OBL_LVL_* di ticket morti
                                // (throttled 10s) — fix linee residue chart.
   Liq_DrawPools();             // FASE 8 - liquidity pools BSL/SSL adaptive.
   ManageOpenPositions();       // FASE 2.1: breakeven + trailing classici
                                // (riga 17287, prima MAI chiamata - causa
                                // root del "profit -> perdita").
   ClusterMoney_OnTick();       // FASE 4: UNICA authority per safe close
                                // (peak retrace + min profit auto-class).
   Grid_AutoAverage();          // FASE 6.2: mediazione automatica Grid
                                // (no doppia chiusura con ClusterMoney).
   RiskEngine_Update();         // FASE 5.3: popola g_risk per i pre-flight
                                // della prossima entry.

   g_orch_newBar = Orchestrator_IsNewBar();
   g_orch_tickCounter++;

   // === LEVEL 2: Indicator support sub-dispatch (ATR, MACD, RSI, etc.) ===
   DispatchIndicatorStrategies();

   // === LEVEL 2: Filter Engine sub-dispatch (volatility, session, spread filters) ===
   UpdateFilterEngine();

   // === LEVEL 2: ICT/SMC Professional Triggers update ===
   if (g_orch_newBar) {
      UpdateOrderBlockDatabase();
      // FASE 4 - Setup Thinking Engine: rivaluta staging map ad
      // ogni nuova candela (decay quality vecchi + log mappa).
      Staging_OnNewBar();
      // FASE 5+8 NEW - i TP dei trade LIVE non sono numeri congelati:
      // ricalcola TP1/2/3/MAX con ATR corrente, clamp anti-back e
      // movement tolerance, cosi' la ladder si adatta al contesto
      // di mercato (volatility regime) senza chasing.
      TPSL_RebalanceTPs_OnNewBar();
   }

   // === LEVEL 2: Grid FTMO-safe state management ===
   Grid_UpdateState();

   // === LEVEL 3: Pattern Engine sub-dispatch (candlestick / structure / liquidity patterns - non-owner) ===
   DispatchPatternStrategies();

   // === LEVEL 2: AI generic support ===
   DispatchAIStrategy();

   // === LEVEL 2.5: Hybrid Engine (always-on, internal, NON-OWNER) ===
   // Reads structure primitives + Pattern/Indicator/Filter/AI context and
   // produces soft refinements consumed by the six non-Predicted owners.
   // NEVER applied to Predicted as primary engine.
   UpdateHybridEngine();

   // === LEVEL 2.6: Hub bridge — synchronous ai_query (NON-OWNER) =====
   // Sends a structured JSON ai_query to the Electron hub at most
   // once every AIQ_MIN_INTERVAL_SEC seconds. The hub fuses Bookmap
   // orderflow + news + AI providers and returns a SOFT decision
   // frame (final_bias, ai_confidence, hold_continue, cancel_signal,
   // tp1..tpmax, of_context) consumed via OF_* / AIQ_* helpers. A
   // missing or silent hub never blocks the EA: helpers fall back to
   // pure-EA Hybrid + Pattern + Indicator + Filter behaviour.
   Bridge_QueryAI(Symbol(), Orchestrator_DominantOwner());
   // Stream live `context_push` (account/equity/perf_*/positions[]) sulla
   // PUSH port 5557 ogni ~3s. La UI dell'hub (ACCOUNT MATRIX,
   // PERFORMANCE METRICS, ACTIVE POSITIONS) si nutre di questo.
   AIBridge_OnTick(Symbol());
   // Drain dei topic PUB dell'hub (oblivious.heartbeat / .command /
   // .news / .bookmap / .decision) ad ogni tick. Senza questo i comandi
   // del Hub e il fast-path orderflow arriverebbero solo via OnTimer
   // (ogni 30s), perdendo eventi e reagendo in ritardo.
   AIBridge_Poll();
   DynPanel_UpdateBridgeStatus();
   DynPanel_UpdateNewsRows();

   // === LEVEL 1: Canonical strategy dispatch ===
   // ────────────────────────────────────────────────────────────────
   // PHASE 1 (ITER 20) — Decision Engine HARD-PRIMARY dispatch.
   //
   // For every non-Predicted owner we call OBL_OwnerDecide() FIRST:
   //   • OBL_DEC_INVALIDATE → OBL_KillStagedFor(owner) + skip this tick
   //   • OBL_DEC_WAIT       → skip (no legacy fallback, no time bypass)
   //   • OBL_DEC_BUY/SELL   → proceed with anti-spam cooldown only
   //
   // The owner direction is now sourced from the Decision Engine. The
   // legacy direction-picking blocks inside Strategy_*_Logic (bullBOS,
   // bearBOS, OTE-direction, body-ratio, reclaim, fib-direction) are
   // overridden by g_owner_dec_dir_<owner> set here. Cooldowns remain
   // ONLY as anti-spam (post-decision), never as the primary engine.
   // ────────────────────────────────────────────────────────────────
   // Predicted (AI-driven news+context entries) — UNCHANGED, isolated.
   DispatchPredictedStrategy();

   // Per-owner Decision-first dispatch ----------------------------------
   // ITER 21 (F1) — TIME COOLDOWN ELIMINATED as primary engine gate.
   //   The old Mode_MinSecondsBetweenStaged()-based cooldown is GONE.
   //   We keep only a 10-second anti-burst floor so a runaway tick
   //   storm cannot fire the same owner-side twice in the same second.
   //   The PRIMARY engine is now: Decision Engine → owner mechanics.
   //   Anti-spam dedup is handled deeper by Staging_Submit (zone match
   //   + SUPERIOR_REPLACE), not by clock cooldowns.
   {
      // ITER 23 (FASE B): CD_ANTI_BURST inline replaced by Owner_AntiBurstOK().
      //   ANTI_BURST_SEC + wrapper defined at L2213.
      double qDec;
      int    dec;

      // FVG ----------------------------------------------------------
      if (FVG && NewsPolicy_CanOpen("FVG")) {
         dec = OBL_OwnerDecide("FVG", qDec);
         int dirFVG = (dec == OBL_DEC_BUY ? +1 :
                       (dec == OBL_DEC_SELL ? -1 : 0));
         OBL_DecSet("FVG", dec, qDec, dirFVG);
         if (dec == OBL_DEC_INVALIDATE) {
            OBL_KillStagedFor("FVG");
         } else if (dec == OBL_DEC_BUY || dec == OBL_DEC_SELL) {
            if (Owner_AntiBurstOK_Q("FVG", qDec))
               FVG_Logic();
         }
      }

      // SMC ----------------------------------------------------------
      if (SMC && NewsPolicy_CanOpen("SMC") &&
          CountOpenOrders(SMCMagic) < MaxOpenTradesPerStrat) {
         dec = OBL_OwnerDecide("SMC", qDec);
         int dirSMC = (dec == OBL_DEC_BUY ? +1 :
                       (dec == OBL_DEC_SELL ? -1 : 0));
         OBL_DecSet("SMC", dec, qDec, dirSMC);
         if (dec == OBL_DEC_INVALIDATE) {
            OBL_KillStagedFor("SMC");
         } else if (dec == OBL_DEC_BUY || dec == OBL_DEC_SELL) {
            if (Owner_AntiBurstOK_Q("SMC", qDec))
               Strategy_SMC_Logic();
         }
      }

      // ICT ----------------------------------------------------------
      if (ICT && NewsPolicy_CanOpen("ICT") &&
          CountOpenOrders(ICTMagic) < MaxOpenTradesPerStrat) {
         dec = OBL_OwnerDecide("ICT", qDec);
         int dirICT = (dec == OBL_DEC_BUY ? +1 :
                       (dec == OBL_DEC_SELL ? -1 : 0));
         OBL_DecSet("ICT", dec, qDec, dirICT);
         if (dec == OBL_DEC_INVALIDATE) {
            OBL_KillStagedFor("ICT");
         } else if (dec == OBL_DEC_BUY || dec == OBL_DEC_SELL) {
            if (Owner_AntiBurstOK_Q("ICT", qDec))
               Strategy_ICT_Logic();
         }
      }

      // ════════════════════════════════════════════════════════════════
      // ITER 22 (P3) — Breakout + Reverse + Grid Decision-first dispatch
      //   These 3 owners were previously dispatched via ExecuteStrategies
      //   + Check*Signal shallow probes + ExecuteStrategy market path.
      //   They now follow the SAME Decision-first pattern as FVG/SMC/ICT:
      //   OBL_OwnerDecide → OBL_DecSet → Strategy_*_Logic on BUY/SELL.
      //   Legacy CheckBreakoutSignal/CheckReverseSignal/CheckGridSignal
      //   gates and ExecuteStrategy("Grid") market path are bypassed.
      // ════════════════════════════════════════════════════════════════

      // Breakout -----------------------------------------------------
      if (Breakout && NewsPolicy_CanOpen("Breakout") &&
          CountOpenOrders(BreakoutMagic) < MaxOpenTradesPerStrat) {
         dec = OBL_OwnerDecide("Breakout", qDec);
         int dirBO = (dec == OBL_DEC_BUY ? +1 :
                      (dec == OBL_DEC_SELL ? -1 : 0));
         OBL_DecSet("Breakout", dec, qDec, dirBO);
         if (dec == OBL_DEC_INVALIDATE) {
            OBL_KillStagedFor("Breakout");
         } else if (dec == OBL_DEC_BUY || dec == OBL_DEC_SELL) {
            if (Owner_AntiBurstOK_Q("Breakout", qDec))
               Strategy_Breakout_Logic();
         }
      }

      // Reverse ------------------------------------------------------
      // Reverse is special: it fires on autonomous trigger maturity
      // (ITER 21 F7) EVEN when DEC=WAIT — exhaustion owner self-triggers
      // when 2+ structural reversal signals stack. So we always call
      // Strategy_Reverse_Logic; it internally checks DEC first then
      // falls back to autonomous synthesis if dir==0.
      if (Reverse && NewsPolicy_CanOpen("Reverse") &&
          CountOpenOrders(ReverseMagic) < MaxOpenTradesPerStrat) {
         dec = OBL_OwnerDecide("Reverse", qDec);
         int dirREV = (dec == OBL_DEC_BUY ? +1 :
                       (dec == OBL_DEC_SELL ? -1 : 0));
         OBL_DecSet("Reverse", dec, qDec, dirREV);
         if (dec == OBL_DEC_INVALIDATE) {
            OBL_KillStagedFor("Reverse");
         } else if (Owner_AntiBurstOK_Q("Reverse", qDec)) {
            Strategy_Reverse_Logic();
         }
      }

      // Grid ---------------------------------------------------------
      if (Grid && NewsPolicy_CanOpen("Grid")) {
         dec = OBL_OwnerDecide("Grid", qDec);
         int dirG = (dec == OBL_DEC_BUY ? +1 :
                     (dec == OBL_DEC_SELL ? -1 : 0));
         OBL_DecSet("Grid", dec, qDec, dirG);
         if (dec == OBL_DEC_INVALIDATE) {
            OBL_KillStagedFor("Grid");
            // Live basket preserved; just no new levels added.
         } else if (dec == OBL_DEC_BUY || dec == OBL_DEC_SELL) {
            if (Owner_AntiBurstOK_Q("Grid", qDec))
               Strategy_Grid_Logic();
         }
      }
   }

   // ITER 23 (FASE A + MISSING-2) — ExecuteStrategies() CALLSITE REMOVED.
   //   The Decision-first dispatcher above is the SINGLE authoritative
   //   owner flow. No legacy parallel path can affect Breakout/Reverse/
   //   Grid/FVG/SMC/ICT execution. The legacy ExecuteStrategies()
   //   function still exists (L18300) as no-op return for safety, but
   //   it is NO LONGER invoked from any live path.

   // Panel updates — throttled to PANELS_UPDATE_MS to keep the UI
   // fluid without flooding the chart with redraws on tick-heavy
   // symbols. PnL_CalcFromHistory walks the closed-order history so
   // it's especially expensive on long-lived accounts; tying it to
   // the same gate keeps OnTick light.
   uint nowMs = GetTickCount();
   if (nowMs - g_panelsLastUpdate >= PANELS_UPDATE_MS) {
      g_panelsLastUpdate = nowMs;
      // Re-assert chart scheme each tick so template/timeframe switches
      // don't reset candles back to RGB or drop the BMP watermark.
      OBL_ApplyChartScheme();
      PnL_CalcFromHistory();
      OBL_StateWatcher();   // emit Smart Log on bridge/market/AI/news transitions
      OBL_TS_Scan();        // Trade State Machine (UNARMED/PROTECTED/BE/TRAIL)
      OBL_Ladder_Tick();    // TP1/TP2/TP3/TP MAX ratchet — never close in loss
      OBL_DynamicLevels_Tick(); // ITER 16 — real-time TP2/TP3/TPMAX retune on VolRegime shifts
      OBL_RefreshAdaptiveInputs(); // ITER 18.1 — auto-overwrite RSI/SuperTrend/Pivot from VolRegime+TF
      Grid_RecomputeClusterTP(); // ITER 18.3 — refresh shared cluster TP for all Grid orders
      Grid_DrawLevels();         // ITER 22 (P4) — sync visual SEED/AVG/NEXT/TARGET right after recompute
      OBL_OnNewBarEvent();              // ITER 19 — event-driven candle hook (replaces time-driven re-eval)
      OBL_StalePendingCleanup();        // ITER 19 — cancel zombie limits older than freshness window
      OBL_LiquiditySweepInvalidation(); // ITER 19.2 — kill setups whose target liquidity is gone
      OBL_IntrabarTick();               // PHASE 6 (ITER 20) — wick-aware promote/invalidate per tick
      OBL_OwnerDynamicSLTP();           // PHASE 7 (ITER 20) — owner-driven dynamic SL/TP reproject per bar
      OBL_LifecycleTick();              // ITER 19 Fase 3 — setup lifecycle state machine
      DynPanel_Update();
      TrigPanel_Update();
      SmartPanel_Update();
      OBL_DrawChipLabels();
      SmartLog_Render();
   }
   // Anti-zombie pending lifecycle (self-throttled to 1Hz).
   // Runs OUTSIDE the panel throttle so cleanup happens promptly
   // even when the chart paint loop is gated.
   PendingLifecycle_OnTick();
}

                                          void Orchestrator_OnTimer() {
                                            // AI Bridge timer
                                            AIBridge_OnTimer();

                                            // News update
                                            NewsBridge_Update();

                                            // HUB/BOOKMAP/NEWS rows — live even on slow-tick symbols
                                            DynPanel_RefreshBridgeAndNews();

                                            // SmartLog timer
                                            SmartLog_OnTimer();

                                            // Profit guards timer check
                                            ProfitGuards_OnTimer();

                                            // FASE 2 - Pending Lifecycle Manager
                                            // (smart KEEP/MODIFY/CANCEL/EXPIRE
                                            // per pending FVG/SMC/ICT/Reverse/Breakout)
                                            Pending_Lifecycle_Tick();

                                            // FASE 2-5 - Staging Tick (DRAWN ->
                                            // PENDING_ELIGIBLE -> DEPLOYED) per
                                            // i setup pre-deploy delle 5 owner.
                                            Staging_Tick();

                                            // OTE system timer
                                            AIP2_TimerHandler(MagicNumberBase +
   100);

                                            // Rainbow color cycle
                                            Rainbow_UpdateColor();
                                          }

                                          void Orchestrator_OnChartEvent(
                                              int id, long lparam,
                                              double dparam, string sparam) {
                                            // Forward to UI toggle handler
                                            UIToggles_OnChartEvent(
                                                id, lparam, dparam, sparam);

                                            // Forward to dashboard (legacy
                                            // dashboard is unreachable by
                                            // default but this stays for
                                            // backward compatibility — see
                                            // Dashboard_OnChartEvent guard).
                                            Dashboard_OnChartEvent(
                                                id, lparam, dparam, sparam);

                                            // Trigger panel click handler
                                            if (id == CHARTEVENT_OBJECT_CLICK) {
                                               TrigPanel_OnClick(sparam);
                                               SmartPanel_OnClick(sparam);
                                            }

                                            // PANEL-LAYOUT-FIX: il chart e' stato
                                            // ridimensionato o spostato (l'utente
                                            // ha allargato la finestra, cambiato
                                            // timeframe, scroll laterale, ecc.).
                                            // Forziamo il ridisegno di SmartLog e
                                            // SmartPanel cosi' il loro ancoraggio
                                            // al bottom del chart (calcolato come
                                            // chartH - H - margin) viene rifatto
                                            // sulle NUOVE dimensioni. Senza questo
                                            // i pannelli restavano "appesi" alla
                                            // vecchia altezza e finivano fuori
                                            // schermo o sotto i bordi.
                                            if (id == CHARTEVENT_CHART_CHANGE) {
                                               if (SmartPanel)   SmartPanel_Update();
                                               if (DynamicPanel) DynPanel_Update();
                                               if (TriggerPanel) TrigPanel_DrawBar();
                                               SmartLog_Render();
                                               OBL_ApplyChartScheme();   // re-assert candles/grid on resize/TF
                                               ChartRedraw();
                                            }
                                          }

void DispatchIndicatorStrategies() {
   // ============================================================
   // LEVEL 2: Indicator Context Accumulation  NO TRADES OPENED
   // Each enabled indicator contributes a bull/bear signal.
   // Canonical strategies read g_ind_consensus for confidence.
   // ============================================================
   g_ind_bull_count  = 0;
   g_ind_bear_count  = 0;
   g_ind_rsi_score   = 0.0;
   g_ind_macd_score  = 0.0;
   g_ind_trend_score = 0.0;
   g_ind_osc_score   = 0.0;

   // Each Strategy_<Name>_Logic() now operates as a context contributor:
   // it computes its signal and updates g_ind_bull_count / g_ind_bear_count.
   // No trade execution occurs inside these functions.

   if (RSI)                                   Strategy_RSI_Logic();
   if (MACD)                                  Strategy_MACD_Logic();
   if (Stochastic)                            Strategy_Stochastic_Logic();
   if (ADX)                                   Strategy_ADX_Logic();
   if (CCI)                                   Strategy_CCI_Logic();
   if (Bollinger || BollingerBands || Bands)  Strategy_Bollinger_Logic();
   if (SuperTrend)                            Strategy_SuperTrend_Logic();
   if (Momentum)                              Strategy_Momentum_Logic();
   if (EMA)                                   Strategy_EMA_Logic();
   if (SMA)                                   Strategy_SMA_Logic();
   if (Ichimoku)                              Strategy_Ichimoku_Logic();
   if (OBV)                                   Strategy_OBV_Logic();
   if (SAR || ParabolicSAR)                   Strategy_SAR_Logic();
   if (ATR)                                   Strategy_ATR_Logic();
   if (MFI)                                   Strategy_MFI_Logic();
   if (Vortex)                                Strategy_Vortex_Logic();
   if (VWAP)                                  Strategy_VWAP_Logic();
   if (AVWAP)                                 Strategy_AVWAP_Logic();
   if (MultiTFTrend)                          Strategy_MultiTFTrend_Logic();
   if (DeMarker)                              Strategy_DeMarker_Logic();
   if (CMF)                                   Strategy_CMF_Logic();
   if (DMI)                                   Strategy_DMI_Logic();
   if (QQE)                                   Strategy_QQE_Logic();
   if (HMA || HullMovingAverage)              Strategy_HMA_Logic();
   if (Keltner || KeltnerChannel)             Strategy_Keltner_Logic();
   if (LaguerreRSI)                           Strategy_LaguerreRSI_Logic();
   if (ROC)                                   Strategy_ROC_Logic();
   if (TRIX)                                  Strategy_TRIX_Logic();
   if (UlcerIndex)                            Strategy_UlcerIndex_Logic();
   if (Alligator)                             Strategy_Alligator_Logic();
   if (AC)                                    Strategy_AC_Logic();
   if (AD)                                    Strategy_AD_Logic();
   if (BearsPower)                            Strategy_BearsPower_Logic();
   if (BullsPower)                            Strategy_BullsPower_Logic();
   if (Envelopes)                             Strategy_Envelopes_Logic();
   if (Gator)                                 Strategy_Gator_Logic();
   if (BWMFI)                                 Strategy_BWMFI_Logic();
   if (OsMA)                                  Strategy_OsMA_Logic();
   if (RVI)                                   Strategy_RVI_Logic();
   if (AO || Awesome)                         Strategy_AO_Logic();
   if (Williams || WPR)                       Strategy_WPR_Logic();
   if (SchaffTrendCycle || MACD)              Strategy_SchaffTrendCycle_Logic();
   if (Fibo)                                  Strategy_Fibo_Logic();
   if (Aroon)                                 Strategy_Aroon_Logic();
   if (Elder || ElderRay)                     Strategy_Elder_Logic();
   if (Force || ForceIndex)                   Strategy_Force_Logic();
   if (LinReg || LinearRegression)            Strategy_LinReg_Logic();
   if (Fractal || Fractals)                   Strategy_Fractal_Logic();
   if (Chandelier || ChandelierExit)          Strategy_Chandelier_Logic();
   if (KAMA)                                  Strategy_KAMA_Logic();
   if (TEMA)                                  Strategy_TEMA_Logic();
   if (Donchian)                              Strategy_Donchian_Logic();
   if (BBWidth)                               Strategy_BBWidth_Logic();
   if (ATRExp)                                Strategy_ATRExp_Logic();
   if (MA)                                    Strategy_MA_Logic();
   if (GannHiLo)                              Strategy_GannHiLo_Logic();
   if (HeikenAshi)                            Strategy_HeikenAshi_Logic();
   if (VIDYA)                                 Strategy_VIDYA_Logic();
   if (Pivots)                                Strategy_Pivots_Logic();
   if (SessionOHLC)                           Strategy_SessionOHLC_Logic();
   if (SRPercentRank)                         Strategy_SRPercentRank_Logic();
   if (EfficiencyRatio)                       Strategy_EfficiencyRatio_Logic();
   if (AvgVolume)                             Strategy_AvgVolume_Logic();
   if (PriceAction)                           Strategy_PriceAction_Logic();
   if (HigherHighLowerLow)                    Strategy_HigherHighLowerLow_Logic();
   if (TradeEntry)                            Strategy_TradeEntry_Logic();
   if (StdDev || StandardDeviation)          Strategy_StdDev_Logic();
   if (Reflex)                                Strategy_Reflex_Logic();

   // Compute final consensus score: -100 (all bear) to +100 (all bull)
   int total = g_ind_bull_count + g_ind_bear_count;
   g_ind_consensus = (total > 0) ? (100.0 * (g_ind_bull_count - g_ind_bear_count) / total) : 0.0;

   // Separate trend vs oscillator blends
   g_ind_trend_score = (g_ind_macd_score + g_ind_rsi_score) * 0.5;
   g_ind_osc_score   = g_ind_rsi_score;
}

// ============================================================
// PROFESSIONAL FILTER & CONTEXT MODULES — Section 13 Extension
// ============================================================

// ============================================================
// PROFESSIONAL MODULES — Filter/Context Quality (Section 13 extension)
// ============================================================

// --- ATR PERCENTILE / VOLATILITY REGIME ---
// Returns index 0=low, 1=normal, 2=expansion, 3=panic
int GetVolatilityRegime(string sym, int tf, int period, int lookback) {
   double curATR = iATR(sym, tf, period, 1);
   if (curATR <= 0 || lookback < 2) return 1;
   double vals[];
   ArrayResize(vals, lookback);
   for (int i = 0; i < lookback; i++) vals[i] = iATR(sym, tf, period, i + 1);
   ArraySort(vals);
   double p25 = vals[(int)(lookback * 0.25)];
   double p50 = vals[(int)(lookback * 0.50)];
   double p75 = vals[(int)(lookback * 0.75)];
   double p90 = vals[(int)(lookback * 0.90)];
   if (curATR >= p90) return 3;  // panic
   if (curATR >= p75) return 2;  // expansion
   if (curATR >= p25) return 1;  // normal
   return 0;                      // low / compressed
}

double GetATRPercentile(string sym, int tf, int period, int lookback) {
   double curATR = iATR(sym, tf, period, 1);
   if (curATR <= 0 || lookback < 2) return 0.5;
   double below = 0;
   for (int i = 1; i <= lookback; i++) {
      if (iATR(sym, tf, period, i) <= curATR) below++;
   }
   return below / lookback;
}

double GetVolOfVol(string sym, int tf, int period) {
   // Simple vol-of-vol: std-dev of ATR over last 20 bars
   int lb = 20;
   double atrs[];
   ArrayResize(atrs, lb);
   for (int i = 0; i < lb; i++) atrs[i] = iATR(sym, tf, period, i + 1);
   double mean = 0;
   for (int i = 0; i < lb; i++) mean += atrs[i];
   mean /= lb;
   double variance = 0;
   for (int i = 0; i < lb; i++) variance += MathPow(atrs[i] - mean, 2);
   return MathSqrt(variance / lb);
}

// --- CHOPPINESS / TREND EFFICIENCY ---
double GetChoppinessIndex(string sym, int tf, int period) {
   // CI = 100 * log10(Sum(ATR1,n) / (Highest_n - Lowest_n)) / log10(n)
   if (period < 2) return 50;
   double atrSum = 0;
   for (int i = 1; i <= period; i++) atrSum += iATR(sym, tf, 1, i);
   int hiIdx = iHighest(sym, tf, MODE_HIGH, period, 1);
   int loIdx = iLowest(sym, tf, MODE_LOW,  period, 1);
   double hi = iHigh(sym, tf, hiIdx);
   double lo = iLow(sym, tf,  loIdx);
   if (hi <= lo || atrSum <= 0) return 50;
   double ci = 100.0 * MathLog10(atrSum / (hi - lo)) / MathLog10((double)period);
   return MathMax(0, MathMin(100, ci));
}

bool IsCleanTrend(string sym, int tf) {
   return GetChoppinessIndex(sym, tf, 14) < 38.2;
}

bool IsChoppyRange(string sym, int tf) {
   return GetChoppinessIndex(sym, tf, 14) > 61.8;
}

// --- SESSION QUALITY / RELATIVE VOLUME (extends existing partial) ---
double GetSessionRVOL(string sym, int tf, int lookbackBars) {
   long curVol = iVolume(sym, tf, 1);
   if (lookbackBars < 2 || curVol <= 0) return 1.0;
   double avgVol = 0;
   for (int i = 1; i <= lookbackBars; i++) avgVol += (double)iVolume(sym, tf, i);
   avgVol /= lookbackBars;
   return (avgVol > 0) ? (double)curVol / avgVol : 1.0;
}

int GetSessionQualityScore(string sym, int tf) {
   // Returns 0-100 based on RVOL, volatility regime, and spread
   int score = 50;
   double rvol = GetSessionRVOL(sym, tf, 20);
   if (rvol >= 1.5) score += 25;
   else if (rvol >= 1.0) score += 10;
   else if (rvol < 0.5) score -= 25;
   int regime = GetVolatilityRegime(sym, tf, 14, 50);
   if (regime == 2) score += 15;
   else if (regime == 3) score -= 20;
   else if (regime == 0) score -= 10;
   double spread = (MarketInfo(sym, MODE_ASK) - MarketInfo(sym, MODE_BID)) / _Point;
   double medSpread = iATR(sym, tf, 14, 1) / _Point * 0.05;
   if (spread > medSpread * 3.0) score -= 20;
   return MathMax(0, MathMin(100, score));
}

bool IsDeadSession(string sym, int tf) {
   return GetSessionRVOL(sym, tf, 20) < 0.4 || GetVolatilityRegime(sym, tf, 14, 50) == 0;
}

double GetTrendEfficiency(string sym, int tf, int period) {
   // Trend efficiency = net move / total move
   if (period < 2) return 0.5;
   
   double netMove = MathAbs(iClose(sym, tf, 1) - iClose(sym, tf, period));
   double totalMove = 0.0;
   
   for (int i = 1; i < period; i++) {
      totalMove += MathAbs(iClose(sym, tf, i) - iClose(sym, tf, i + 1));
   }
   
   return (totalMove > 0) ? netMove / totalMove : 0.0;
}

// --- SMT DIVERGENCE ---
// sym1 = primary (e.g. EURUSD), sym2 = correlated (e.g. GBPUSD or index)
// dir: filled with 1=bullish divergence, -1=bearish
bool DetectSMTDivergence(string sym1, string sym2, int tf, int &dir) {
   dir = 0;
   int lb = 10;
   double hi1 = iHigh(sym1, tf, iHighest(sym1, tf, MODE_HIGH, lb, 1));
   double lo1 = iLow(sym1,  tf, iLowest(sym1,  tf, MODE_LOW,  lb, 1));
   double hi2 = iHigh(sym2, tf, iHighest(sym2, tf, MODE_HIGH, lb, 1));
   double lo2 = iLow(sym2,  tf, iLowest(sym2,  tf, MODE_LOW,  lb, 1));
   // Bearish SMT: sym1 makes new high, sym2 fails to confirm
   if (iHigh(sym1, tf, 1) >= hi1 * 0.999 && iHigh(sym2, tf, 1) < hi2 * 0.999) {
      dir = -1; return true;
   }
   // Bullish SMT: sym1 makes new low, sym2 fails to confirm
   if (iLow(sym1, tf, 1) <= lo1 * 1.001 && iLow(sym2, tf, 1) > lo2 * 1.001) {
      dir = 1; return true;
   }
   return false;
}

// --- BPR (BALANCED PRICE RANGE) ---
// A BPR exists when a bullish FVG and bearish FVG overlap
bool DetectBPR(string sym, int tf, double &bprH, double &bprL) {
   bprH = 0; bprL = 0;
   // Bullish FVG: Low[i] > High[i+2]
   // Bearish FVG: High[i] < Low[i+2]
   double bullFVGH = 0, bullFVGL = 0, bearFVGH = 0, bearFVGL = 0;
   for (int i = 3; i <= 20; i++) {
      if (iLow(sym, tf, i) > iHigh(sym, tf, i + 2)) {
         bullFVGL = iHigh(sym, tf, i + 2);
         bullFVGH = iLow(sym, tf, i);
      }
      if (iHigh(sym, tf, i) < iLow(sym, tf, i + 2)) {
         bearFVGH = iLow(sym, tf, i + 2);
         bearFVGL = iHigh(sym, tf, i);
      }
   }
   if (bullFVGL <= 0 || bearFVGL <= 0) return false;
   // Overlap check
   double overlapL = MathMax(bullFVGL, bearFVGL);
   double overlapH = MathMin(bullFVGH, bearFVGH);
   if (overlapH <= overlapL) return false;
   bprH = overlapH; bprL = overlapL;
   return true;
}

// --- POI INVALIDATION (after N bars) ---
bool IsPOIInvalidated(double poiH, double poiL, int startBar, int maxBars) {
   // POI is invalidated if price closes through the opposite edge
   for (int i = startBar; i <= startBar + maxBars; i++) {
      if (iClose(_Symbol, _Period, i) < poiL) return true;  // closed below zone
      if (iClose(_Symbol, _Period, i) > poiH) return true;  // closed above zone
   }
   return false;
}

// --- FIRST-TOUCH VS SECOND-TOUCH POI ---
int GetPOITouchCount(double poiH, double poiL, int lookback) {
   int count = 0;
   double mid = (poiH + poiL) * 0.5;
   double half = (poiH - poiL) * 0.5;
   for (int i = 1; i <= lookback; i++) {
      if (iLow(_Symbol, _Period, i)  <= poiH + half &&
          iHigh(_Symbol, _Period, i) >= poiL - half) count++;
   }
   return count;
}

bool IsFirstTouchPOI(double poiH, double poiL, int lookback) {
   return GetPOITouchCount(poiH, poiL, lookback) <= 1;
}

// --- OPENING RANGE / SESSION SWEEP ---
bool DetectOpeningRangeBreakout(string sym, int tf, double &orH, double &orL) {
   // Define opening range as first N bars of current session
   orH = 0; orL = 0;
   datetime sessionOpen = iTime(sym, PERIOD_D1, 0);
   int orBars = 4; // first 4 bars of session
   for (int i = 0; i < orBars; i++) {
      int idx = iBarShift(sym, tf, sessionOpen, false) - i;
      if (idx < 0) continue;
      double h = iHigh(sym, tf, idx);
      double l = iLow(sym, tf,  idx);
      if (orH == 0 || h > orH) orH = h;
      if (orL == 0 || l < orL) orL = l;
   }
   if (orH <= 0 || orL <= 0) return false;
   // Breakout: current bar closes outside OR
   double closeNow = iClose(sym, tf, 1);
   return (closeNow > orH || closeNow < orL);
}

bool DetectSessionSweep(string sym, int tf, int dir) {
   // Detect if current session has swept the prior session's high/low
   double prevH = iHigh(sym, PERIOD_D1, 1);
   double prevL = iLow(sym,  PERIOD_D1, 1);
   double atr = iATR(sym, tf, 14, 1);
   double tol = atr * 0.1;
   for (int i = 1; i <= 10; i++) {
      if (dir == 1 && iLow(sym, tf, i) < prevL - tol && iClose(sym, tf, i) > prevL) return true;
      if (dir ==-1 && iHigh(sym, tf, i) > prevH + tol && iClose(sym, tf, i) < prevH) return true;
   }
   return false;
}

// --- TURTLE SOUP PATTERN ---
// False break of N-bar high/low with quick reversal
bool DetectTurtleSoup(string sym, int tf, int lookback, int &dir, double &entry) {
   dir = 0; entry = 0;
   double prevH = iHigh(sym, tf, iHighest(sym, tf, MODE_HIGH, lookback, 2));
   double prevL = iLow(sym,  tf, iLowest(sym,  tf, MODE_LOW,  lookback, 2));
   double atr = iATR(sym, tf, 14, 1);
   double tol = atr * 0.15;
   // Bearish Turtle Soup: bar[1] briefly broke above N-bar high, closed back inside
   double h1 = iHigh(sym, tf, 1), c1 = iClose(sym, tf, 1);
   if (h1 > prevH + tol && c1 < prevH) {
      dir = -1; entry = prevH; return true;
   }
   // Bullish Turtle Soup: bar[1] briefly broke below N-bar low, closed back inside
   double l1 = iLow(sym, tf, 1);
   if (l1 < prevL - tol && c1 > prevL) {
      dir = 1; entry = prevL; return true;
   }
   return false;
}

// --- QUASIMODO / QML ---
bool DetectQuasimodo(string sym, int tf, int &dir, double &qmLevel) {
   dir = 0; qmLevel = 0;
   // QM pattern: HH ÃƒÃ‚Â¢— → LH ÃƒÃ‚Â¢— → LL (bearish) or LL ÃƒÃ‚Â¢— → HL ÃƒÃ‚Â¢— → HH (bullish)
   // Detect via 3 pivot swing points
   double h1 = iHigh(sym, tf, 2), h2 = iHigh(sym, tf, 4), h3 = iHigh(sym, tf, 6);
   double l1 = iLow(sym,  tf, 2), l2 = iLow(sym,  tf, 4), l3 = iLow(sym,  tf, 6);
   // Bearish QM: h1 > h2 (HH) then h3 < h1 (LH), l1 < l2 (LL forming)
   if (h1 > h2 && h3 < h1 && l1 < l2) {
      dir = -1; qmLevel = h3; return true;
   }
   // Bullish QM: l1 < l2 (LL) then l3 > l1 (HL), h1 > h2 (HH forming)
   if (l1 < l2 && l3 > l1 && h1 > h2) {
      dir = 1; qmLevel = l3; return true;
   }
   return false;
}

// --- LIQUIDITY VOID / VOLUME IMBALANCE ---
bool DetectLiquidityVoid(string sym, int tf, int dir, double &voidH, double &voidL) {
   voidH = 0; voidL = 0;
   // Liquidity void: three consecutive unidirectional bars with minimal wick overlap
   for (int i = 3; i <= 15; i++) {
      double o3 = iOpen(sym, tf, i+2), c3 = iClose(sym, tf, i+2);
      double o2 = iOpen(sym, tf, i+1), c2 = iClose(sym, tf, i+1);
      double o1 = iOpen(sym, tf, i),   c1 = iClose(sym, tf, i);
      if (dir == 1) {
         if (c3 > o3 && c2 > o2 && c1 > o1) {
            // Bullish void: gap between successive lows
            double gapL = iHigh(sym, tf, i+2);
            double gapH = iLow(sym,  tf, i);
            if (gapH > gapL) { voidH = gapH; voidL = gapL; return true; }
         }
      } else {
         if (c3 < o3 && c2 < o2 && c1 < o1) {
            double gapH2 = iLow(sym,  tf, i+2);
            double gapL2 = iHigh(sym, tf, i);
            if (gapH2 > gapL2) { voidH = gapH2; voidL = gapL2; return true; }
         }
      }
   }
   return false;
}

// --- CONVENIENCE SCORE HELPERS ---
// Compute a combined context quality score 0-100 for use in FVG/SMC gate
int ComputeContextQualityScore(string sym, int tf) {
   int score = 0;
   int sessQ = GetSessionQualityScore(sym, tf);
   score += (int)(sessQ * 0.4);  // session quality 40%
   int regime = GetVolatilityRegime(sym, tf, 14, 50);
   if (regime == 0) score += 5;
   else if (regime == 1) score += 20;
   else if (regime == 2) score += 30;
   else score += 0;             // panic: no bonus
   double ci = GetChoppinessIndex(sym, tf, 14);
   if (ci < 38.2) score += 25; // clean trend
   else if (ci < 50) score += 10;
   else score += 0;             // no bonus for choppy
   return MathMax(0, MathMin(100, score));
}

// SECTION 15: PATTERNS RAW / FVG / SMC / ICT / LIQUIDITY / STRUCTURE

// Functions: 150

int SMC_BiasHTF(int tf) {
      // Higher timeframe bias: EMA20 vs EMA50 on parent TF
      double ema20 = iMA(Symbol(), tf, 20, 0, MODE_EMA, PRICE_CLOSE, 0);
      double ema50 = iMA(Symbol(), tf, 50, 0, MODE_EMA, PRICE_CLOSE, 0);
      if (ema20 > ema50 * 1.001)
        return 1; // bullish
      if (ema20 < ema50 * 0.999)
        return -1; // bearish
      return 0;
}

bool SMC_MSS(int tf, int dir) {
      // Market Structure Shift: higher-high violation (bullish) or lower-low
      // (bearish)
      if (iBars(Symbol(), tf) < 15)
        return false;
      int iH = iHighest(Symbol(), tf, MODE_HIGH, 10, 1);
      int iL = iLowest(Symbol(), tf, MODE_LOW, 10, 1);
      double prevHH = iHigh(Symbol(), tf, iH);
      double prevLL = iLow(Symbol(), tf, iL);
      if (dir > 0)
        return (iClose(Symbol(), tf, 0) > prevHH); // bullish MSS
      if (dir < 0)
        return (iClose(Symbol(), tf, 0) < prevLL); // bearish MSS
      return false;
}

double POI_PipSize()
{
      return ADV_Pip();
}

double POI_AutoATR()
  {
      int atrPeriod = Auto_ATR_Period(); // funzione giÃƒÃ†ÃƒÃ‚Â  presente nel tuo EA
      return (iATR(Symbol(), PERIOD_CURRENT, atrPeriod, 0));
