// === Market Regime Utilities (auto-adaptive) ===

bool __AP_DailyDrawdownGuard(){
      if (!__AP_ChallengePassageOn())
        return true; // only active in ChallengePassage
      static double dayStartEquity = -1;
      static int dayStamp = -1;
      datetime now = TimeCurrent();
      int d = TimeDayOfYear(now);
      if (dayStamp != d) {
        dayStamp = d;
        dayStartEquity = AccountEquity();
      }
      if (dayStartEquity <= 0)
        return true;
      double dd = (dayStartEquity - AccountEquity()) / dayStartEquity;
      // FASE 5 (Patch 2): dd e' una FRAZIONE (0..1), quindi
      // confronto con MaxDailyDDPercent / 100.0.
      // Hard close = limite pieno; warn = 78% del limite.
      double __cp_hard = MaxDailyDDPercent / 100.0;
      double __cp_warn = (MaxDailyDDPercent * 0.78) / 100.0;
      if (dd >= __cp_hard) {
        PrintFormat("[CP] Daily DD >= %.2f%%: closing all open positions on %s",
                    MaxDailyDDPercent, Symbol());
        for (int i = OrdersTotal() - 1; i >= 0; --i) {
          if (!OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
            continue;
          if (OrderSymbol() != Symbol())
            continue;
          int type = OrderType();
          if (type != OP_BUY && type != OP_SELL)
            continue;
          double lots = OrderLots();
          bool ok = false;
          int slip = GetAdaptiveSlippagePoints();
#ifdef slippage
          slip = slippage;
#endif
          {
            int __ticket = OrderTicket();
            double __lots = OrderLots();
            SmartLogWrap(
                "CLOSE",
                StringFormat("PreClose | ticket=%d lots=%.2f symbol=%s",
                             __ticket, __lots, OrderSymbol()));
          }
          if (type == OP_BUY)
            ok = OrderClose(OrderTicket(), lots, Bid,
                            GetAdaptiveSlippagePoints(), clrNONE);
          else
            ok = OrderClose(OrderTicket(), lots, Ask,
                               GetAdaptiveSlippagePoints(), clrNONE);
          {
            int __err = GetLastError();
            bool __isok = (__err == 0);
            SmartLogWrap(
                "CLOSE",
                StringFormat("%s | ticket=%d price=%.5f lots=%.2f err=%d",
                             __isok ? "PostClose OK" : "PostClose FAIL",
                             OrderTicket(), OrderClosePrice(), OrderLots(),
                             __err));
          }
          if (!ok)
            Print("[CP] Close failed ticket ", OrderTicket(),
                  " err=", GetLastError());
        }
        return false;
      }
      // Soft block at 78% del DD limit (warn)
      if (dd >= __cp_warn) {
        PrintFormat("[CP] Daily DD >= %.2f%% (warn): blocking new entries (%.2f%%)",
                    MaxDailyDDPercent * 0.78, dd * 100);
        return false;
      }
      return true;
}

bool __AP_TotalDrawdownGuard(){
      if (!__AP_ChallengePassageOn())
        return true;
      double base = __AP_GetChallengeBaseEquity();
      if (base <= 0)
        return true;
      double loss = (base - AccountEquity()) /
                    base; // total max loss from challenge start
      // FASE 5 (Patch 2): loss e' FRAZIONE -> MaxTotalDDPercent / 100.0
      if (loss >= MaxTotalDDPercent / 100.0) {
        PrintFormat("[CP] Total MAX LOSS >= %.2f%% from base: blocking new entries (base=%.2f)",
                    MaxTotalDDPercent, base);
        return false;
      }
      return true;
}

// Functions: 33

bool IsDrawdownOk();

color MakeRGB(int r, int g, int b)
{
      r = MathMax(0, MathMin(255, r));
      g = MathMax(0, MathMin(255, g));
      b = MathMax(0, MathMin(255, b));
      // MQL4 color format: 0x00BBGGRR
      return (color)((b << 16) | (g << 8) | r);
}

void Toggle_CreateObjects(int idx, int x, int y)
{
      if (idx < 0 || idx >= g_toggle_count)
        return;
      g_toggles[idx].x = x;
      g_toggles[idx].y = y;

      string trk = g_toggles[idx].objTrack;
      string knb = g_toggles[idx].objKnob;
      string lbl = g_toggles[idx].objLabel;

      // --- Track (pill) ---
      if (ObjectFind(0, trk) < 0) {
        ObjectCreate(0, trk, OBJ_RECTANGLE_LABEL, 0, 0, 0);
        ObjectSetInteger(0, trk, OBJPROP_CORNER, TGL_CORNER);
        ObjectSetInteger(0, trk, OBJPROP_XSIZE, TGL_TRACK_W);
        ObjectSetInteger(0, trk, OBJPROP_YSIZE, TGL_TRACK_H);
        ObjectSetInteger(0, trk, OBJPROP_BORDER_TYPE, BORDER_FLAT);
        ObjectSetInteger(0, trk, OBJPROP_BORDER_COLOR, clrNONE);
        ObjectSetInteger(0, trk, OBJPROP_BACK, false);
        ObjectSetInteger(0, trk, OBJPROP_SELECTABLE, false);
        ObjectSetInteger(0, trk, OBJPROP_HIDDEN, true);
      }
      ObjectSetInteger(0, trk, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, trk, OBJPROP_YDISTANCE, y);

      // --- Knob (small square acting as circle) ---
      if (ObjectFind(0, knb) < 0) {
        ObjectCreate(0, knb, OBJ_RECTANGLE_LABEL, 0, 0, 0);
        ObjectSetInteger(0, knb, OBJPROP_CORNER, TGL_CORNER);
        ObjectSetInteger(0, knb, OBJPROP_XSIZE, TGL_KNOB_SZ);
        ObjectSetInteger(0, knb, OBJPROP_YSIZE, TGL_KNOB_SZ);
        ObjectSetInteger(0, knb, OBJPROP_BORDER_TYPE, BORDER_FLAT);
        ObjectSetInteger(0, knb, OBJPROP_BORDER_COLOR, clrNONE);
        ObjectSetInteger(0, knb, OBJPROP_BGCOLOR, clrWhite);
        ObjectSetInteger(0, knb, OBJPROP_BACK, false);
        ObjectSetInteger(0, knb, OBJPROP_SELECTABLE, false);
        ObjectSetInteger(0, knb, OBJPROP_HIDDEN, true);
      }

      // --- Label ---
      if (ObjectFind(0, lbl) < 0) {
        ObjectCreate(0, lbl, OBJ_LABEL, 0, 0, 0);
        ObjectSetInteger(0, lbl, OBJPROP_CORNER, TGL_CORNER);
        ObjectSetInteger(0, lbl, OBJPROP_ANCHOR, ANCHOR_LEFT_UPPER);
        ObjectSetString(0, lbl, OBJPROP_FONT, "Consolas");
        ObjectSetInteger(0, lbl, OBJPROP_FONTSIZE, 8);
        ObjectSetInteger(0, lbl, OBJPROP_BACK, false);
        ObjectSetInteger(0, lbl, OBJPROP_SELECTABLE, false);
        ObjectSetInteger(0, lbl, OBJPROP_HIDDEN, true);
      }
      ObjectSetString(0, lbl, OBJPROP_TEXT, g_toggles[idx].label);
      ObjectSetInteger(0, lbl, OBJPROP_XDISTANCE,
                       x + TGL_TRACK_W + TGL_LABEL_GAP);
      ObjectSetInteger(0, lbl, OBJPROP_YDISTANCE, y + 1);

      g_toggles[idx].created = true;

      // Apply initial colors
      Toggle_UpdateColors(idx);
}

int Toggle_FindByObject(string objName)
{
      for (int i = 0; i < g_toggle_count; i++) {
        if (g_toggles[i].objTrack == objName)
          return i;
        if (g_toggles[i].objKnob == objName)
          return i;
        if (g_toggles[i].objLabel == objName)
          return i;
      }
      return -1;
}

void Toggle_DestroyAll()
{
   for (int i = 0; i < g_toggle_count; i++) {
      ObjectDelete(0, g_toggles[i].objTrack);
      ObjectDelete(0, g_toggles[i].objKnob);
      ObjectDelete(0, g_toggles[i].objLabel);
      g_toggles[i].created = false;
   }
}

