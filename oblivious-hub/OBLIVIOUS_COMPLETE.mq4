                                              ObjectSetInteger(
                                                  0, id, OBJPROP_FONTSIZE, 7);
                                            }
                                            string t = (StringLen(vals[i]) > 0
   ? vals[i]
   : "");
                                            ObjectSetString(0, id, OBJPROP_TEXT,
   t);
                                          }
                                        }

