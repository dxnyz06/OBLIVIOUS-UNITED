bool IsStrategyAiConfirmed(double strategyConf, double aiConf) {
                    double combined = (strategyConf * aiConf) *
                                      100.0; // Percentuale combinata
                    return (combined >= AiMinConfidence);
}

bool CheckHighImpactNews() {
                          // Bridge-based high impact news
                          // check (replaces
                          // CheckNewsFile/GetCurrentNewsImpact)
                          datetime now = TimeCurrent();
                          int blockTrading = 0, severity = 0,
                              minutesToEvent = 0;

                          if (Bridge_GetNewsStatus(now, blockTrading, severity,
                                                   minutesToEvent)) {
                            // High impact = severity >= 3
                            // (HIGH)
                            return (severity >= 3);
                          }
                          // Fallback: conservative - no high
                          // impact news if EXE not available
                          return false;
}

