   void __AP_MoveSLtoBEIfEligible() {
   // Move SL to breakeven once favorable pips exceed dynamic threshold based on MTR
   double mtr =
   _MedianTrueRangeN(
   14) /
   Point;
   double beTrig = MathMax(
   10,
   mtr *
   0.6); // at least 10 pips, else 0.6*MTR
   double fav =
   __AP_OrderFavorablePips();
   if (fav >=
   beTrig) {
   double newSL =
   OrderOpenPrice();
   // Apply only if improves
   if (OrderType() == OP_BUY &&



   (OrderStopLoss() <=
   0 ||
   newSL >
   OrderStopLoss())) {
   LogGate(
   "BLOCK NEWS",
   StringFormat(
   "Symbol=%s Time=%s (file=file path)",
   Symbol(),
   TimeToStr(
   TimeCurrent(),
   TIME_SECONDS)));
   {
   int __ticket =
   OrderTicket();
   double
   __newSL =
   0,
   __newTP = Auto_TP_Points_Strategy(
   "__new"); /* prefetch desired sl/tp from args not trivial; logging current after select */
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "PreModify | ticket=%d symbol=%s",
   __ticket,
   OrderSymbol()));
   }
   bool _wOk = OrderModify(
   OrderTicket(),
   OrderOpenPrice(),
   newSL,
   OrderTakeProfit(),
   0,
   clrNONE);
   {
   int __ok =
   (GetLastError() == 0);



   double
   __exe =
   OrderOpenPrice(),
   __sl =
   OrderStopLoss(),
   __tp =
   OrderTakeProfit();
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d", __ok ? "PostModify OK" : "PostModify FAIL", OrderTicket(), __exe, __sl, __tp, GetLastError()));
   }
   }
   if (OrderType() == OP_SELL &&



   (OrderStopLoss() <=
   0 ||
   newSL <
   OrderStopLoss())) {
   LogGate(
   "BLOCK NEWS",
   StringFormat(
   "Symbol=%s Time=%s (file=file path)",
   Symbol(),
   TimeToStr(
   TimeCurrent(),
   TIME_SECONDS)));
   {
   int __ticket =
   OrderTicket();
   double
   __newSL =
   0,
   __newTP = Auto_TP_Points_Strategy(
   "__new"); /* prefetch desired sl/tp from args not trivial; logging current after select */
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "PreModify | ticket=%d symbol=%s",
   __ticket,
   OrderSymbol()));
   }
   bool _wOk = OrderModify(
   OrderTicket(),
   OrderOpenPrice(),
   newSL,
   OrderTakeProfit(),
   0,
   clrNONE);
   {
   int __ok =
   (GetLastError() == 0);



   double
   __exe =
   OrderOpenPrice(),
   __sl =
   OrderStopLoss(),
   __tp =
   OrderTakeProfit();
   SmartLogWrap(
   "MODIFY",
   StringFormat(
   "%s | ticket=%d exe=%.5f sl=%.5f tp=%.5f err=%d", __ok ? "PostModify OK" : "PostModify FAIL", OrderTicket(), __exe, __sl, __tp, GetLastError()));
   }
   }
   }
   }

   double __AP_ProfitBuffer10pcOverCosts() {
   // Ensure at least 10% over all costs (commission+swap+spread approx) to be safely positive
   double comm =
   OrderCommission();
   if (comm <
   0)
   comm =
   -comm;
   double swp =
   OrderSwap();
   if (swp <
   0)
   swp =
   -swp;
   double spr = __AP_EstimatedSpreadCost(
   OrderTicket());
   double base =
   comm +
   swp +
   spr;
   if (base <=
   0)
   base =
   0.5 *
   MarketInfo(
   OrderSymbol(),
   MODE_TICKVALUE) *
   OrderLots(); // minimal buffer
   return 0.10 *
   base; // 10% over cost baseline
   }

   double __PTP_GetDbl(
   string
   k,
   double def =
   0.0) {
   if (GlobalVariableCheck(
   k))
   return GlobalVariableGet(
   k);
   return def;
   }

   void __PTP_SetDbl(
   string
   k,
   double
   v) {
   GlobalVariableSet(
   k,
   v);
   }

   double __PTP_CostBuffer() {
   return MathAbs(
   OrderCommission()) +
   MathAbs(
   OrderSwap());
   }

//| 20. strategy helpers / orchestrator / dispatchers

int GetSignalForIndex(int idx) {
  // Returns +1 buy, -1 sell, 0 neutral for strategy index
  if (idx < 0 || idx >= 12) return 0;
  string nm = TB_StrategyNames[idx];
  if (nm == "RSI" || nm == "rsi") {
    double r = iRSI(Symbol(), Period(), 14, PRICE_CLOSE, 1);
    if (r < 30) return 1; if (r > 70) return -1; return 0;
  }
  double c1 = iClose(Symbol(), Period(), 1), c2 = iClose(Symbol(), Period(), 2);
  return (c1 > c2) ? 1 : (c1 < c2) ? -1 : 0;
}

void DrawWhiteArrow(string name, datetime t, double price, bool isBuy) {
  /* ITER42: chart arrows DISABLED — user contract: no arrows on MT4 chart. */
  return;
}

void DrawWhiteNote(string name, datetime t, double price, string label) {
  if (ObjectFind(0, name) < 0)
    ObjectCreate(0, name, OBJ_TEXT, 0, t, price + 8 * Point);
  ObjectSetString(0, name, OBJPROP_TEXT, label);
  ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite);
  ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 7);
}

double __AP_EstimatedSpreadCost(int ticket = -1) {
  double lots = (ticket > 0 && OrderSelect(ticket, SELECT_BY_TICKET)) ? OrderLots() : MarketInfo(Symbol(), MODE_MINLOT);
  double spread = (Ask - Bid);
  double tv = MarketInfo(Symbol(), MODE_TICKVALUE);
  double ts = MarketInfo(Symbol(), MODE_TICKSIZE);
  if (ts <= 0) return 0;
  return spread / ts * tv * lots;
}

int GetMagicNumber(string strategy) {
  return MagicNumberBase + (int)StringToInteger(StringSubstr(strategy, 0, 3));
}

// Maps canonical strategy names to their configured magic numbers
int GetStrategyMagic(string name) {
   if (name == "Predicted")            return PredictedMagic;
   if (name == "Breakout")             return BreakoutMagic;
   if (name == "FVG")                  return FVGMagic;
   if (name == "Grid")                 return GridMagic;
   if (name == "SMC") return SMCMagic;
   if (name == "ICT") return ICTMagic;

   if (name == "Reverse")              return ReverseMagic;
   return GetMagicNumber(name);
}

// ============================================================
// INDICATOR CONSENSUS  Level 2 Support API
// Returns -100 (full bear) to +100 (full bull).
// Called by canonical strategies to boost/reduce confidence.
// ============================================================
double GetIndicatorConsensus() { return g_ind_consensus; }

// Returns true if indicator consensus strongly opposes direction
// dir: +1 bull, -1 bear. threshold: 0-100 opposition strength
bool IndicatorOpposesTrade(int dir, double threshold = 40.0) {
   if (dir == 1  && g_ind_consensus < -threshold) return true;
   if (dir == -1 && g_ind_consensus >  threshold) return true;
   return false;
}

// Confidence bonus from indicator alignment (0 to +20)
double IndicatorAlignmentBonus(int dir) {
   double consensus = GetIndicatorConsensus();
   if ((dir == 1 && consensus > 0) || (dir == -1 && consensus < 0))
      return MathMin(MathAbs(consensus) * 0.2, 20.0);
   return 0.0;
}

// ============================================================
// PATTERN CONSENSUS  Level 3 Support API
// Returns -100 (full bear) to +100 (full bull).
// Called by canonical strategies to refine entry timing.
// ============================================================
double GetPatternConsensus()  { return g_pat_consensus; }
double GetPatternConfidence() { return g_pat_confidence; }

// Returns true if any strong pattern supports the direction
bool PatternSupportsTrade(int dir, double threshold = 30.0) {
   if (dir == 1  && g_pat_consensus >  threshold) return true;
   if (dir == -1 && g_pat_consensus < -threshold) return true;
   return false;
}


double EB_PriceFromFrac(double H, double L, double fUp) { return H - fUp * (H - L); }
