bool SimulateLicenseValidation(string account_id, string license_key) {
      // Questa funzione esegue una validazione simulata lato client, senza
      // chiamate HTTP esterne. Esegue solo controlli di base sui parametri
      // ricevuti. Basic validation checks
      if (StringLen(account_id) < 3)
        return false;
      if (StringLen(license_key) < 10)
        return false;
      // Check key format (example: should contain letters and numbers)
      bool has_letters = false;
      bool has_numbers = false;
      for (int i = 0; i < StringLen(license_key); i++) {
        int char_code = StringGetCharacter(license_key, i);
        if (char_code >= 65 && char_code <= 90)
          has_letters = true; // A-Z
        if (char_code >= 97 && char_code <= 122)
          has_letters = true; // a-z
        if (char_code >= 48 && char_code <= 57)
          has_numbers = true; // 0-9
      }
      // For demo: accept if key has both letters and numbers
      return (has_letters && has_numbers);
}


void StateManager_Init()
{
      // Restore persisted state
      if (GlobalVariableCheck(GV_SYSTEM_STATE)) {
        int savedState = (int)GlobalVariableGet(GV_SYSTEM_STATE);
        if (savedState >= STATE_TRADING_ENABLED &&
            savedState <= STATE_EMERGENCY_CLOSE)
          g_systemState = (SystemState)savedState;
      }

      if (GlobalVariableCheck(GV_STATE_TIMESTAMP))
        g_stateChangedTime = (datetime)GlobalVariableGet(GV_STATE_TIMESTAMP);
      else
        g_stateChangedTime = TimeCurrent();

      // Check if daily reset is needed
      if (GlobalVariableCheck(GV_DAILY_RESET_DAY))
        g_lastResetDay = (int)GlobalVariableGet(GV_DAILY_RESET_DAY);

      int today = TimeDay(TimeCurrent());
      if (today != g_lastResetDay) {
        // New day: if we were paused for daily DD, reset to enabled
        if (g_systemState == STATE_PAUSED_DAILY_DD) {
          g_systemState = STATE_TRADING_ENABLED;
          g_stateReason = "Daily DD reset on new day";
          PrintFormat(
              "[StateManager] Daily DD pause lifted - new trading day %d",
              today);
        }
        g_lastResetDay = today;
        GlobalVariableSet(GV_DAILY_RESET_DAY, (double)today);
      }

      StateManager_Persist();
      PrintFormat("[StateManager] Init complete. State: %s",
                  StateManager_GetStateName());
}

void StateManager_TransitionTo(SystemState newState, string reason)
{
      if (newState == g_systemState)
        return;

      SystemState oldState = g_systemState;
      g_systemState = newState;
      g_stateChangedTime = TimeCurrent();
      g_stateReason = reason;

      PrintFormat("[StateManager] TRANSITION: %s -> %s | Reason: %s",
                  StateManager_StateName(oldState),
                  StateManager_StateName(newState), reason);

      StateManager_Persist();

      // Alert on critical transitions
      if (newState == STATE_LOCKED_TOTAL_DD ||
          newState == STATE_EMERGENCY_CLOSE) {
        Alert(StringFormat("OBLIVIOUS EA: %s | %s",
                           StateManager_StateName(newState), reason));
      }
}

void StateManager_ForceState(SystemState state, string reason)
{
      StateManager_TransitionTo(state, "FORCED: " + reason);
}

bool StateManager_CanTrade()
{
      return (g_systemState == STATE_TRADING_ENABLED);
}

bool StateManager_CanManage()
{
      return (g_systemState != STATE_EMERGENCY_CLOSE);
}

string StateManager_StateName(SystemState s)
{
      switch (s) {
      case STATE_TRADING_ENABLED:
        return "TRADING_ENABLED";
      case STATE_PAUSED_DAILY_DD:
        return "PAUSED_DAILY_DD";
      case STATE_LOCKED_TOTAL_DD:
        return "LOCKED_TOTAL_DD";
      case STATE_EQUITY_LOCK:
        return "EQUITY_LOCK";
      case STATE_EMERGENCY_CLOSE:
        return "EMERGENCY_CLOSE";
      }
      return "UNKNOWN";
}

void StateManager_Persist()
{
      GlobalVariableSet(GV_SYSTEM_STATE, (double)g_systemState);
      GlobalVariableSet(GV_STATE_TIMESTAMP, (double)g_stateChangedTime);
}

void StateManager_Deinit()
{
      StateManager_Persist();
}

