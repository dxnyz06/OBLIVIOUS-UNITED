# OBLIVIOUS HUB — runtime configuration.
# Copy this to .env and edit as needed. All values are optional.

# ZMQ endpoints (must match the EA's broker configuration).
ZMQ_REQ_PORT=5555
ZMQ_PUB_PORT=5556
ZMQ_PULL_PORT=5557

# Bookmap WebSocket relay port.
BOOKMAP_WS_PORT=8081

# News refresh interval (minutes). 5 = every 5 minutes.
NEWS_REFRESH_MINUTES=5

# Override the ForexFactory CSV mirror (advanced).
# FOREXFACTORY_CSV_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.csv

# DEV mode flags. Leave commented for normal use.
# OBLIVIOUS_DEV=1                   # Force DEV mode even when packaged.
# OBLIVIOUS_PROD_VAULT=1            # Force prod vault flow even in DEV.
# OBLIVIOUS_HEADLESS=1              # Suppress all dialogs (for CI).
